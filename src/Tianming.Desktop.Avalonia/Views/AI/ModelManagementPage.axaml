<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Tianming.Desktop.Avalonia.Controls"
             xmlns:vm="using:Tianming.Desktop.Avalonia.ViewModels.AI"
             x:Class="Tianming.Desktop.Avalonia.Views.AI.ModelManagementPage"
             x:DataType="vm:ModelManagementViewModel"
             mc:Ignorable="d"
             d:DesignWidth="800" d:DesignHeight="600">
  <ScrollViewer Padding="24">
    <StackPanel Spacing="20">

      <!-- 添加模型表单 -->
      <controls:SectionCard Header="添加模型" Subtitle="配置新的 AI 模型连接">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,*">
            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
              <TextBlock Text="Provider" FontSize="12" FontWeight="SemiBold"/>
              <ComboBox ItemsSource="{Binding Providers}"
                        SelectedValue="{Binding NewProviderId, Mode=TwoWay}"
                        SelectedValueBinding="{Binding Id}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:DefaultAIProviderOption">
                    <TextBlock Text="{Binding DisplayName}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="4" Margin="8,0,0,0">
              <TextBlock Text="Model" FontSize="12" FontWeight="SemiBold"/>
              <TextBox Text="{Binding NewModelId}" Watermark="模型 ID（如 gpt-4o）"/>
            </StackPanel>
          </Grid>
          <Grid ColumnDefinitions="2*,*,*">
            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
              <TextBlock Text="自定义端点（可选）" FontSize="12" FontWeight="SemiBold"/>
              <TextBox Text="{Binding NewEndpoint}" Watermark="留空使用默认端点"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="4" Margin="8,0,8,0">
              <TextBlock Text="Temperature" FontSize="12" FontWeight="SemiBold"/>
              <NumericUpDown Value="{Binding NewTemperature}" Minimum="0" Maximum="2" Increment="0.1"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
              <TextBlock Text="Max Tokens" FontSize="12" FontWeight="SemiBold"/>
              <NumericUpDown Value="{Binding NewMaxTokens}" Minimum="1" Maximum="128000" Increment="256"/>
            </StackPanel>
          </Grid>
          <Button Content="添加模型" Command="{Binding AddModelCommand}"
                  HorizontalAlignment="Right"
                  Classes="accent"/>
        </StackPanel>
      </controls:SectionCard>

      <!-- 模型列表 -->
      <controls:SectionCard Header="已配置模型" Subtitle="管理 AI 模型配置，设置默认模型">
        <StackPanel Spacing="8">
          <!-- 表头 -->
          <Grid ColumnDefinitions="120,120,180,80,110,80,*" Margin="0,0,0,4">
            <TextBlock Grid.Column="0" Text="Provider" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Grid.Column="1" Text="Model" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Grid.Column="2" Text="端点" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Grid.Column="3" Text="Temp" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Grid.Column="4" Text="用途" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Grid.Column="5" Text="状态" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Grid.Column="6" Text="操作" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
          </Grid>

          <Separator/>

          <!-- 模型列表 -->
          <ItemsControl ItemsSource="{Binding Models}" x:Name="ModelList">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="120,120,180,80,110,80,*" Margin="0,6">
                  <TextBlock Grid.Column="0" Text="{Binding ProviderId}" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="{Binding ModelId}" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="2" Text="{Binding Endpoint}" VerticalAlignment="Center"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             TextTrimming="CharacterEllipsis"/>
                  <TextBlock Grid.Column="3" Text="{Binding Temperature, StringFormat=F1}" VerticalAlignment="Center"/>
                  <ComboBox Grid.Column="4"
                            ItemsSource="{Binding PurposeOptions}"
                            SelectedItem="{Binding Purpose, Mode=TwoWay}"
                            DropDownClosed="OnPurposeDropDownClosed"
                            MinWidth="100"/>
                  <TextBlock Grid.Column="5" Text="默认" Foreground="Green" FontWeight="SemiBold"
                             VerticalAlignment="Center" IsVisible="{Binding IsActive}"/>
                  <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Content="设为默认"
                            Click="OnSetActiveClick"
                            Tag="{Binding Id}"
                            IsVisible="{Binding !IsActive}"/>
                    <Button Content="删除"
                            Click="OnDeleteModelClick"
                            Tag="{Binding Id}"
                            Classes="danger"/>
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- 空状态 -->
          <TextBlock Text="还没有配置任何模型，点击上方「添加模型」开始配置"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     HorizontalAlignment="Center"
                     Margin="0,20"
                     IsVisible="{Binding HasNoModels}"/>
        </StackPanel>
      </controls:SectionCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
