<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Tianming.Desktop.Avalonia.Controls"
             xmlns:vm="using:Tianming.Desktop.Avalonia.ViewModels.AI"
             x:Class="Tianming.Desktop.Avalonia.Views.AI.PromptManagementPage"
             x:DataType="vm:PromptManagementViewModel"
             mc:Ignorable="d"
             d:DesignWidth="800" d:DesignHeight="600">
  <ScrollViewer Padding="24">
    <StackPanel Spacing="20">

      <!-- 提示词列表 -->
      <controls:SectionCard Header="提示词模板" Subtitle="管理系统提示词模板">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="点击列表项编辑，或点击「新建」创建提示词"/>
            <Button Grid.Column="1" Content="新建" Command="{Binding AddTemplateCommand}"
                    Classes="accent"/>
          </Grid>

          <Separator/>

          <ItemsControl ItemsSource="{Binding Templates}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Spacing="4"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="*,120,80,80" Margin="0,4"
                      Background="Transparent">
                  <Grid.Styles>
                    <Style Selector="Grid:pointerover /template/ ContentPresenter">
                      <Setter Property="Background" Value="{DynamicResource BackgroundHighlightBrush}"/>
                    </Style>
                  </Grid.Styles>
                  <TextBlock Grid.Column="0" Text="{Binding Name}"
                             FontWeight="SemiBold" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="{Binding Category}"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <TextBlock Grid.Column="2" Text="{Binding IsBuiltIn}"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource TextSecondaryBrush}">
                    <TextBlock.Text>
                      <Binding Path="IsBuiltIn">
                        <Binding.StringFormat>内置: {0}</Binding.StringFormat>
                      </Binding>
                    </TextBlock.Text>
                  </TextBlock>
                  <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4"
                              VerticalAlignment="Center">
                    <Button Content="编辑"
                            Click="OnEditClick"
                            Tag="{Binding Id}"/>
                    <Button Content="删除"
                            Click="OnDeleteClick"
                            Tag="{Binding Id}"
                            Classes="danger"
                            IsVisible="{Binding !IsBuiltIn}"/>
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </controls:SectionCard>

      <!-- 编辑区 -->
      <controls:SectionCard Header="编辑提示词"
                            Subtitle="{Binding SelectedItem.Name}"
                            IsVisible="{Binding IsEditing}">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,*">
            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
              <TextBlock Text="名称" FontSize="12" FontWeight="SemiBold"/>
              <TextBox Text="{Binding EditName}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="4" Margin="8,0,0,0">
              <TextBlock Text="类别" FontSize="12" FontWeight="SemiBold"/>
              <TextBox Text="{Binding EditCategory}"/>
            </StackPanel>
          </Grid>
          <StackPanel Spacing="4">
            <TextBlock Text="描述" FontSize="12" FontWeight="SemiBold"/>
            <TextBox Text="{Binding EditDescription}" AcceptsReturn="False"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="模板内容" FontSize="12" FontWeight="SemiBold"/>
            <TextBox Text="{Binding EditTemplate}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="180"
                     FontFamily="monospace"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="变量（逗号分隔）" FontSize="12" FontWeight="SemiBold"/>
            <TextBox Text="{Binding EditVariables}"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="取消" Command="{Binding CancelEditCommand}"/>
            <Button Content="保存" Command="{Binding SaveTemplateCommand}"
                    Classes="accent"/>
          </StackPanel>
        </StackPanel>
      </controls:SectionCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
