<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tianming.Desktop.Avalonia.ViewModels"
             xmlns:vshell="using:Tianming.Desktop.Avalonia.ViewModels.Shell"
             xmlns:vc="using:Tianming.Desktop.Avalonia.ViewModels.Conversation"
             xmlns:vmd="using:Tianming.Desktop.Avalonia.ViewModels.Design"
             xmlns:vmg="using:Tianming.Desktop.Avalonia.ViewModels.Generate"
             xmlns:vmai="using:Tianming.Desktop.Avalonia.ViewModels.AI"
             xmlns:v="using:Tianming.Desktop.Avalonia.Views"
             xmlns:vcv="using:Tianming.Desktop.Avalonia.Views.Conversation"
             xmlns:vsh="using:Tianming.Desktop.Avalonia.Views.Shell"
             xmlns:vd="using:Tianming.Desktop.Avalonia.Views.Design"
             xmlns:vg="using:Tianming.Desktop.Avalonia.Views.Generate"
             xmlns:vai="using:Tianming.Desktop.Avalonia.Views.AI"
             xmlns:vme="using:Tianming.Desktop.Avalonia.ViewModels.Editor"
             xmlns:ve="using:Tianming.Desktop.Avalonia.Views.Editor"
             x:Class="Tianming.Desktop.Avalonia.App"
             RequestedThemeVariant="Light">
  <Application.DataTemplates>
    <DataTemplate DataType="vm:WelcomeViewModel">
      <v:WelcomeView/>
    </DataTemplate>
    <DataTemplate DataType="vm:DashboardViewModel">
      <v:DashboardView/>
    </DataTemplate>
    <DataTemplate DataType="vm:PlaceholderViewModel">
      <v:PlaceholderView/>
    </DataTemplate>
    <DataTemplate DataType="vshell:LeftNavViewModel">
      <vsh:LeftNavView/>
    </DataTemplate>
    <DataTemplate DataType="vshell:RightConversationViewModel">
      <vsh:RightConversationView/>
    </DataTemplate>
    <DataTemplate DataType="vc:ConversationPanelViewModel">
      <vcv:ConversationPanelView/>
    </DataTemplate>
    <!-- M4.1 设计模块 6 VM → DesignModulePage（共用 view） -->
    <DataTemplate DataType="vmd:WorldRulesViewModel">
      <vd:DesignModulePage/>
    </DataTemplate>
    <DataTemplate DataType="vmd:CharacterRulesViewModel">
      <vd:DesignModulePage/>
    </DataTemplate>
    <DataTemplate DataType="vmd:FactionRulesViewModel">
      <vd:DesignModulePage/>
    </DataTemplate>
    <DataTemplate DataType="vmd:LocationRulesViewModel">
      <vd:DesignModulePage/>
    </DataTemplate>
    <DataTemplate DataType="vmd:PlotRulesViewModel">
      <vd:DesignModulePage/>
    </DataTemplate>
    <DataTemplate DataType="vmd:CreativeMaterialsViewModel">
      <vd:DesignModulePage/>
    </DataTemplate>
    <!-- M4.2 生成规划 4 schema VM → DesignModulePage（共用 view） -->
    <DataTemplate DataType="vmg:OutlineViewModel">
      <vd:DesignModulePage/>
    </DataTemplate>
    <DataTemplate DataType="vmg:VolumeDesignViewModel">
      <vd:DesignModulePage/>
    </DataTemplate>
    <DataTemplate DataType="vmg:ChapterPlanningViewModel">
      <vd:DesignModulePage/>
    </DataTemplate>
    <DataTemplate DataType="vmg:BlueprintViewModel">
      <vd:DesignModulePage/>
    </DataTemplate>
    <!-- ChapterPipelinePage 独立 view -->
    <DataTemplate DataType="vmg:ChapterPipelineViewModel">
      <vg:ChapterPipelinePage/>
    </DataTemplate>
    <!-- M4.6 AI 管理 -->
    <DataTemplate DataType="vmai:ModelManagementViewModel">
      <vai:ModelManagementPage/>
    </DataTemplate>
    <DataTemplate DataType="vmai:ApiKeysViewModel">
      <vai:ApiKeysPage/>
    </DataTemplate>
    <DataTemplate DataType="vmai:PromptManagementViewModel">
      <vai:PromptManagementPage/>
    </DataTemplate>
    <DataTemplate DataType="vmai:UsageStatisticsViewModel">
      <vai:UsageStatisticsPage/>
    </DataTemplate>
    <!-- M4.3 章节编辑器 -->
    <DataTemplate DataType="vme:EditorWorkspaceViewModel">
      <ve:EditorWorkspaceView/>
    </DataTemplate>
  </Application.DataTemplates>

  <!-- M5：NativeMenu 真实绑定挂到 MainWindow（DataContext = MainWindowViewModel），
       Avalonia 11 在 macOS 下会自动把 active window 的 NativeMenu 升到系统菜单栏。 -->

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- 1. Design tokens 先合 -->
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Theme/DesignTokens/Colors.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Theme/DesignTokens/Typography.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Theme/DesignTokens/Spacing.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Theme/DesignTokens/Radii.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Theme/DesignTokens/Shadows.axaml"/>
        <!-- 2. 旧 palette 兼容（PalettesLight 现在 internally MergedDictionaries 了 Colors.axaml） -->
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Theme/PalettesLight.axaml"/>
        <!-- 3. Controls (primitives ControlTheme) -->
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Controls/BadgePill.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Controls/StatusBarItem.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Controls/SectionCard.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Controls/StatsCard.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Controls/SearchBox.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Controls/SegmentedTabs.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Controls/BreadcrumbBar.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Controls/NavRail.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Controls/SidebarTreeItem.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Controls/ProjectCard.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Controls/DataGridRowCell.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Controls/ConversationBubble.axaml"/>
        <ResourceInclude Source="avares://Tianming.Desktop.Avalonia/Controls/ToolCallCard.axaml"/>
        <!-- M4.3 章节编辑器：MarkdownEditor / MarkdownPreview / ChapterTabBar 都是 UserControl
             （非 ResourceDictionary），不在此处合并；XAML 类型解析通过 controls: xmlns 即可。 -->
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Tianming.Desktop.Avalonia/Theme/CommonStyles.axaml"/>
    <StyleInclude Source="avares://Tianming.Desktop.Avalonia/Theme/ControlStyles/Button.axaml"/>
    <StyleInclude Source="avares://Tianming.Desktop.Avalonia/Theme/ControlStyles/TextBox.axaml"/>
    <StyleInclude Source="avares://Tianming.Desktop.Avalonia/Theme/ControlStyles/ComboBox.axaml"/>
    <StyleInclude Source="avares://Tianming.Desktop.Avalonia/Theme/ControlStyles/ListBox.axaml"/>
    <StyleInclude Source="avares://Tianming.Desktop.Avalonia/Theme/ControlStyles/DataGrid.axaml"/>
    <StyleInclude Source="avares://Tianming.Desktop.Avalonia/Theme/ControlStyles/ScrollBar.axaml"/>
  </Application.Styles>
</Application>
