<UserControl x:Class="TM.Framework.UI.Windows.ThreeColumnLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:workspace="clr-namespace:TM.Framework.UI.Workspace">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{DynamicResource UnifiedBackground}"
            BorderBrush="{DynamicResource WindowBorder}"
            BorderThickness="{StaticResource StandardBorder}"
            CornerRadius="{StaticResource LargeRadius}">
        <Grid x:Name="MainGrid">
            <Grid.Clip>
                <RectangleGeometry RadiusX="4" RadiusY="4" Rect="0,0,10000,10000"/>
            </Grid.Clip>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="15,0,0,0">
                <Border x:Name="AppIconBorder"
                        Width="24" Height="24"
                        CornerRadius="5"
                        ClipToBounds="True"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"/>
                <TextBlock Text="天命" 
                           Style="{StaticResource TitleTextStyle}"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,5,0">
                <Button x:Name="MultiWindowButton"
                        Style="{StaticResource SettingsButtonStyle}"
                        ToolTip="切换单/多窗口显示模式"
                        Click="OnMultiWindowToggleClick">
                    <StackPanel HorizontalAlignment="Center">
                        <emoji:TextBlock Text="🏠" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="MultiWindowButtonLabel" Text="单窗口" FontSize="13" HorizontalAlignment="Center" Margin="0"/>
                    </StackPanel>
                </Button>

                <Border Width="1" 
                        Height="20" 
                        Background="{DynamicResource BorderBrush}"
                        Margin="10,0"
                        VerticalAlignment="Center"/>

                <Button Style="{StaticResource SettingsButtonStyle}" 
                        ToolTip="工具台（AI生成与个人设置）"
                        Click="OnOpenWorkbench">
                    <StackPanel HorizontalAlignment="Center">
                        <emoji:TextBlock Text="🎯" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="工具台" FontSize="13" HorizontalAlignment="Center" Margin="0"/>
                    </StackPanel>
                </Button>

                <Border Width="1" 
                        Height="20" 
                        Background="{DynamicResource BorderBrush}"
                        Margin="10,0"
                        VerticalAlignment="Center"/>

                <Button x:Name="MainPinButton"
                        Style="{StaticResource WindowButtonStyle}"
                        ToolTip="置顶"
                        Click="OnMainPinToggleClick">
                    <StackPanel x:Name="MainPinButtonContent" HorizontalAlignment="Center" Opacity="0.4">
                        <emoji:TextBlock Text="📌" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="置顶" FontSize="13" HorizontalAlignment="Center" Margin="0"/>
                    </StackPanel>
                </Button>

                <Button x:Name="MinimizeButton"
                        Style="{StaticResource WindowButtonStyle}" 
                        ToolTip="最小化">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="—" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="最小化" FontSize="13" HorizontalAlignment="Center" Margin="0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="MaximizeButton"
                        Style="{StaticResource WindowButtonStyle}" 
                        ToolTip="最大化">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="□" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="最大化" FontSize="13" HorizontalAlignment="Center" Margin="0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="CloseButton"
                        Style="{StaticResource CloseButtonStyle}" 
                        ToolTip="关闭">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="✕" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="关闭" FontSize="13" HorizontalAlignment="Center" Margin="0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <ProgressBar Grid.Row="1" Name="GlobalProgressBar"
                     Height="3" Minimum="0" Maximum="100" Value="0"
                     Visibility="Collapsed"
                     Foreground="{DynamicResource PrimaryColor}"
                     Background="Transparent"
                     BorderThickness="0"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Top">
            </StackPanel>

            </Grid>

            <Border Grid.Column="1" 
                    Background="{DynamicResource ContentBackground}"
                    Margin="1,0"
                    CornerRadius="{StaticResource SmallRadius}"
                    ClipToBounds="True">
                <workspace:WorkspaceLayout x:Name="WorkspaceContainer" />
            </Border>

            <Grid Grid.Column="2"/>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                       x:Name="StatusText"
                       Text="就绪"
                       Style="{StaticResource StatusTextStyle}"
                       Margin="15,0,0,0"/>

            <TextBlock Grid.Column="1" 
                       x:Name="SystemInfo"
                       Style="{StaticResource StatusTextStyle}"
                       Margin="0,0,15,0"/>

            <TextBlock Grid.Column="2" 
                       x:Name="TimeDisplay"
                       Style="{StaticResource StatusTextStyle}"
                       Margin="0,0,15,0"/>
        </Grid>
        </Grid>
    </Border>
</UserControl>

