<UserControl x:Class="TM.Framework.UI.Workspace.LeftPanel.ChapterList.ChapterListPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tree="clr-namespace:TM.Framework.Common.Controls"
             xmlns:menus="clr-namespace:TM.Framework.Common.Controls.Menus"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <tree:DataTreeView x:Name="ChapterTreeView"
                               Margin="8,5,8,0"
                               ItemsSource="{Binding ChapterTree}"
                               ParentClickMode="Toggle"
                               ChildNodeClickCommand="{Binding SelectChapterCommand}"
                               DeleteCategoryCommand="{Binding DeleteCategoryCommand}"
                               DeleteAllCategoriesCommand="{Binding DeleteAllCommand}"
                               AddChapterCommand="{Binding AddChapterCommand}"
                               ShowActionButtons="False"
                               Visibility="{Binding ShowEmptyGuide, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                <tree:DataTreeView.NodeContextMenu>
                    <menus:ChapterManagementContextMenu/>
                </tree:DataTreeView.NodeContextMenu>
            </tree:DataTreeView>

            <StackPanel HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        MaxWidth="500"
                        Margin="5,220,5,0"
                        Visibility="{Binding ShowEmptyGuide, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="开始管理你的文档"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>
                <TextBlock Text="选择下方操作开始创作"
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <StackPanel>
                    <Border Background="{DynamicResource ContentBackground}"
                            BorderBrush="{DynamicResource SuccessColor}"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="15"
                            Cursor="Hand"
                            MouseLeftButtonDown="OnQuickAction_StartCreation"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <emoji:TextBlock Text="🧠" FontSize="16" 
                                                 Foreground="{DynamicResource SuccessColor}" 
                                                 VerticalAlignment="Center"/>
                                <TextBlock Text="开始创作"
                                          FontSize="16"
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextPrimary}"
                                          Margin="8,0,0,0"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="进入【智能拆书-拆书分析】，快速提取书籍结构、写作方法与关键素材。"
                                      FontSize="12"
                                      Foreground="{DynamicResource TextSecondary}"
                                      TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource ContentBackground}"
                            BorderBrush="{DynamicResource InfoColor}"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="15"
                            Cursor="Hand"
                            MouseLeftButtonDown="OnQuickAction_NewCategory"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <emoji:TextBlock Text="🗂️" FontSize="16" 
                                                 Foreground="{DynamicResource InfoColor}" 
                                                 VerticalAlignment="Center"/>
                                <TextBlock Text="创建分类"
                                          FontSize="16"
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextPrimary}"
                                          Margin="8,0,0,0"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="前往分卷设计，建立分卷结构与章节范围，便于后续自动归类。"
                                      FontSize="12"
                                      Foreground="{DynamicResource TextSecondary}"
                                      TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource ContentBackground}"
                            BorderBrush="{DynamicResource WarningColor}"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="15"
                            Cursor="Hand"
                            MouseLeftButtonDown="OnQuickAction_Refresh">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <emoji:TextBlock Text="🔄" FontSize="16" 
                                                 Foreground="{DynamicResource WarningColor}" 
                                                 VerticalAlignment="Center"/>
                                <TextBlock Text="刷新列表"
                                          FontSize="16"
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextPrimary}"
                                          Margin="8,0,0,0"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="重新加载分卷与章节数据，保持目录树与内容状态同步。"
                                      FontSize="12"
                                      Foreground="{DynamicResource TextSecondary}"
                                      TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Padding="10,6">
            <DockPanel>
                <Button x:Name="OpenFolderButton"
                        DockPanel.Dock="Right"
                        Content="导出 📂"
                        FontSize="14"
                        Padding="4,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="打开章节目录"
                        Click="OnOpenChapterFolder_Click"/>
                <TextBlock x:Name="StatsText"
                           Text="共 0 章 / 0 字"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
