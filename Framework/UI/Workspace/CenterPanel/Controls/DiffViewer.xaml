<UserControl x:Class="TM.Framework.UI.Workspace.CenterPanel.Controls.DiffViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <Border Background="{DynamicResource ContentBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <emoji:TextBlock Text="📄" FontSize="14"/>
                        <TextBlock Text="原文"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <emoji:TextBlock Text="✨" FontSize="14"/>
                        <TextBlock Text="修改后"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              Padding="12">
                    <TextBlock Text="{Binding OriginalContent}"
                               Foreground="{DynamicResource TextSecondary}"
                               TextWrapping="Wrap"
                               FontSize="13"
                               LineHeight="22"/>
                </ScrollViewer>

                <Border Grid.Column="1"
                        Background="{DynamicResource BorderBrush}"/>

                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              Padding="12">
                    <TextBlock Text="{Binding ModifiedContent}"
                               Foreground="{DynamicResource TextPrimary}"
                               TextWrapping="Wrap"
                               FontSize="13"
                               LineHeight="22"/>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Border>
</UserControl>
