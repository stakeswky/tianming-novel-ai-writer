<UserControl x:Class="TM.Framework.UI.Workspace.CenterPanel.Controls.VersionHistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <Border Background="{DynamicResource ContentBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <emoji:TextBlock Text="📜" FontSize="14"/>
                        <TextBlock Text="版本历史" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="8,0,0,0"/>
                        <TextBlock Text="{Binding VersionCount, StringFormat='({0})'}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="4,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Command="{Binding UndoCommand}"
                                ToolTip="撤销 (Ctrl+Z)"
                                Background="Transparent"
                                BorderThickness="0"
                                Width="28" Height="28"
                                Cursor="Hand"
                                IsEnabled="{Binding CanUndo}">
                            <emoji:TextBlock Text="↩️" FontSize="14"/>
                        </Button>
                        <Button Command="{Binding RedoCommand}"
                                ToolTip="重做 (Ctrl+Y)"
                                Background="Transparent"
                                BorderThickness="0"
                                Width="28" Height="28"
                                Cursor="Hand"
                                IsEnabled="{Binding CanRedo}">
                            <emoji:TextBlock Text="↪️" FontSize="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Versions}"
                     SelectedItem="{Binding SelectedVersion}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     ScrollViewer.CanContentScroll="True">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bg" 
                                            Background="Transparent"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="12,10">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SelectedBackground}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBackground}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Ellipse Grid.Column="0"
                                     Width="8" Height="8"
                                     Fill="{DynamicResource PrimaryColor}"
                                     Margin="0,0,10,0"
                                     VerticalAlignment="Center"
                                     Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Description}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:MM-dd HH:mm}'}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextTertiary}"/>
                                    <TextBlock Text="{Binding WordCount, StringFormat=' · {0}字'}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextTertiary}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" 
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                <Button Command="{Binding DataContext.RevertCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="回退到此版本"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Width="24" Height="24"
                                        Cursor="Hand">
                                    <emoji:TextBlock Text="🔄" FontSize="11"/>
                                </Button>
                                <Button Command="{Binding DataContext.CompareCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="与当前版本对比"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Width="24" Height="24"
                                        Cursor="Hand">
                                    <emoji:TextBlock Text="📊" FontSize="11"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Row="2"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,6">
                <TextBlock Text="{Binding SummaryText}"
                           FontSize="10"
                           Foreground="{DynamicResource TextTertiary}"
                           HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
