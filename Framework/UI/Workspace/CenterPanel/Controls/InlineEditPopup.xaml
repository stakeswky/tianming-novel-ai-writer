<UserControl x:Class="TM.Framework.UI.Workspace.CenterPanel.Controls.InlineEditPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <Border Background="{DynamicResource ContentBackground}" 
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16"
            MinWidth="400"
            MaxWidth="600">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="16" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource ContentHighlight}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0"
                    Margin="-16,-16,-16,0"
                    Height="34"
                    Padding="16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <emoji:TextBlock Text="✨" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="AIGC" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryColor}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1" 
                            Content="✕" 
                            Command="{Binding CloseCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{DynamicResource TextSecondary}"
                            Cursor="Hand"
                            VerticalAlignment="Center"
                            Padding="4"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="0,16,0,0">

            <Border Background="{DynamicResource Surface}" 
                    CornerRadius="6" 
                    Padding="12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="选中内容" 
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding SelectedText}" 
                               TextWrapping="Wrap"
                               MaxHeight="100"
                               Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="润色要求" 
                       Foreground="{DynamicResource TextSecondary}"
                       FontSize="12"
                       Margin="0,0,0,6"/>
            <TextBox Text="{Binding EditRequest, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60"
                     MaxHeight="120"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,12">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Modifiers="Ctrl" Command="{Binding GenerateCommand}"/>
                </TextBox.InputBindings>
            </TextBox>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="润色模板"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="13"
                           FontWeight="Medium"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>

                <ComboBox Grid.Column="1"
                          Width="160"
                          ItemsSource="{Binding PolishTemplateNames}"
                          SelectedItem="{Binding SelectedPolishTemplateName}"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="12,0,0,0">
                    <Button Content="内置-1" 
                            Command="{Binding BuiltIn1Command}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            ToolTip="风格拟态"
                            Padding="10,4"
                            Margin="0,0,4,0"/>
                    <Button Content="内置-2" 
                            Command="{Binding BuiltIn2Command}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            ToolTip="深度润色"
                            Padding="10,4"
                            Margin="0,0,4,0"/>
                    <Button Content="内置-3" 
                            Command="{Binding BuiltIn3Command}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            ToolTip="头条风格"
                            Padding="10,4"/>
                </StackPanel>

                <Button Grid.Column="3"
                        Content="开始润色"
                        Command="{Binding GenerateCommand}"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        IsEnabled="{Binding CanStartPolish}"
                        Padding="16,6"/>
            </Grid>

            <Border Background="{DynamicResource Surface}" 
                    CornerRadius="6" 
                    Padding="12"
                    Margin="0,0,0,12"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="修改结果" 
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding ResultText}" 
                               TextWrapping="Wrap"
                               MaxHeight="150"
                               Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        Margin="0,0,0,12"
                        Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Width="16" Height="16" VerticalAlignment="Center">
                    <Border.RenderTransform>
                        <RotateTransform x:Name="SpinTransform" Angle="0" CenterX="8" CenterY="8"/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="SpinTransform"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360"
                                                     Duration="0:0:1"
                                                     RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <TextBlock Text="↻" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryColor}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="正在生成修改..." 
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button Content="拒绝" 
                        Command="{Binding RejectCommand}"
                        Style="{DynamicResource DangerButtonStyle}"
                        MinWidth="72"
                        Padding="16,6"
                        Margin="0,0,8,0"/>
                <Button Content="对比" 
                        Command="{Binding ShowDiffCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        MinWidth="72"
                        Padding="16,6"
                        Margin="0,0,8,0"/>
                <Button Content="接受" 
                        Command="{Binding AcceptCommand}"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        MinWidth="72"
                        Padding="16,6"/>
            </StackPanel>
        </StackPanel>
        </Grid>
    </Border>
</UserControl>
