<UserControl x:Class="TM.Framework.UI.Workspace.CenterPanel.ChapterEditor.HomepageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="5,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <Grid Width="64" Height="64" Margin="0,0,20,0" VerticalAlignment="Center">
                    <Border x:Name="AppIconBorder"
                            CornerRadius="12"
                            ClipToBounds="True"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" />
                    <emoji:TextBlock x:Name="FallbackIconTextBlock" Text="🎯" FontSize="40"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Visibility="Collapsed"/>
                </Grid>
                <Grid VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="欢迎使用天命" 
                               FontSize="32" 
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Grid.Row="1" Text="智能小说创作辅助系统" 
                               FontSize="16" 
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,6,150,0"
                               HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>

            <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderBrush}" 
                    Margin="0,10" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="2" 
                       Text="选择下方模块开始你的创作之旅" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center"/>

            <Grid Grid.Row="5" HorizontalAlignment="Stretch" Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="1" Margin="0,0,0,4" 
                        Background="{DynamicResource ContentBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Padding="12,3"
                        CornerRadius="12"
                        Tag="Design"
                        MouseEnter="ModuleCard_MouseEnter"
                        MouseLeave="ModuleCard_MouseLeave"
                        MouseLeftButtonUp="ModuleCard_Click">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.15"/>
                    </Border.Effect>
                    <Grid Grid.IsSharedSizeScope="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="QuickArea"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.RowSpan="2" Grid.Column="0" Background="{DynamicResource PrimaryColor}"
                                    CornerRadius="10"
                                    Width="44" Height="44"
                                    Margin="0,0,20,0"
                                    VerticalAlignment="Center">
                                <emoji:TextBlock Text="✏️" FontSize="30" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Grid.Row="0" Grid.Column="1" Text="设计" FontSize="26" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Bottom"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="智能拆书/创作模板/全局设定/设计元素四大板块，沉淀可复用的创作资料库" 
                                       FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,1,0,0"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="常用功能" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="10,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="QuickArea"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="64,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="智能拆书：参考书籍分析、写作技巧提取与灵感沉淀" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,3"/>
                                <TextBlock Text="创作模板：素材模板管理，快速复用创作经验" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,3"/>
                                <TextBlock Text="全局设定：世界观规则体系、时间线与设定边界" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,3"/>
                                <TextBlock Text="设计元素：角色/势力/位置/剧情规则，多维度创作素材" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,0"/>
                            </StackPanel>

                            <UniformGrid Grid.Column="1" x:Name="DesignQuickGrid" Columns="2" Rows="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <Button Content="拆书分析" Tag="Design/智能拆书/拆书分析" 
                                            Click="SubModule_Click" Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                                    <Button Content="模板管理" Tag="Design/创作模板/模板管理" 
                                            Click="SubModule_Click"
                                            Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                                    <Button Content="世界观规则" Tag="Design/全局设定/世界观规则" 
                                            Click="SubModule_Click" Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                                    <Button Content="角色规则" Tag="Design/设计元素/角色规则" 
                                            Click="SubModule_Click"
                                            Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                            </UniformGrid>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Margin="0,0,0,4" 
                        Background="{DynamicResource ContentBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Padding="12,3"
                        CornerRadius="12"
                        Tag="Generate"
                        MouseEnter="ModuleCard_MouseEnter"
                        MouseLeave="ModuleCard_MouseLeave"
                        MouseLeftButtonUp="ModuleCard_Click">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.15"/>
                    </Border.Effect>
                    <Grid Grid.IsSharedSizeScope="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,1,0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="QuickArea"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.RowSpan="2" Grid.Column="0" Background="{DynamicResource SuccessColor}"
                                    CornerRadius="10"
                                    Width="44" Height="44"
                                    Margin="0,0,20,0"
                                    VerticalAlignment="Center">
                                <emoji:TextBlock Text="✍️" FontSize="30" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Grid.Row="0" Grid.Column="1" Text="创作" FontSize="26" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Bottom"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="围绕全书设定/创作元素/正文配置三大板块，形成写作流水线快速产出" 
                                       FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,1,0,0"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="常用功能" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="10,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="QuickArea"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="64,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="全书设定：大纲设计，主题/主线/终局设计，明确全局目标与边界" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,3"/>
                                <TextBlock Text="创作元素：章节设计与蓝图设计，单章目标/冲突/场景/约束" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,3"/>
                                <TextBlock Text="正文配置：数据中心与章节预览，打包/生成/输出统一管理" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,0"/>
                            </StackPanel>

                            <UniformGrid Grid.Column="1" x:Name="GenerateQuickGrid" Columns="2" Rows="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <Button Content="大纲设计" Tag="Generate/全书设定/大纲设计" 
                                            Click="SubModule_Click" Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                                    <Button Content="章节设计" Tag="Generate/创作元素/章节设计" 
                                            Click="SubModule_Click"
                                            Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                                    <Button Content="数据中心" Tag="Generate/正文配置/数据中心" 
                                            Click="SubModule_Click" Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                                    <Button Content="蓝图设计" Tag="Generate/创作元素/蓝图设计" 
                                            Click="SubModule_Click"
                                            Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                            </UniformGrid>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Margin="0,0,0,0" 
                        Background="{DynamicResource ContentBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Padding="12,3"
                        CornerRadius="12"
                        Tag="Validate"
                        MouseEnter="ModuleCard_MouseEnter"
                        MouseLeave="ModuleCard_MouseLeave"
                        MouseLeftButtonUp="ModuleCard_Click">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.15"/>
                    </Border.Effect>
                    <Grid Grid.IsSharedSizeScope="True" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,1,0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="QuickArea"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.RowSpan="2" Grid.Column="0" Background="{DynamicResource WarningColor}"
                                    CornerRadius="10"
                                    Width="44" Height="44"
                                    Margin="0,0,20,0"
                                    VerticalAlignment="Center">
                                <emoji:TextBlock Text="🔍" FontSize="30" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Grid.Row="0" Grid.Column="1" Text="校验" FontSize="26" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Bottom"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="从世界观/逻辑/结构/数据/输出等维度发现矛盾与缺陷，提前降低返工成本" 
                                       FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,1,0,0"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="常用功能" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="10,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="QuickArea"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="64,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="校验汇总：校验结果统一查看，问题追踪与修复建议" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,3"/>
                                <TextBlock Text="世界观校验：设定一致性、规则边界、禁忌项与自洽检查" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,3"/>
                                <TextBlock Text="角色校验：人物动机、成长弧、关系网一致性检查" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,3"/>
                                <TextBlock Text="剧情校验：冲突链、因果链、伏笔回收与节奏把控" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,0"/>
                            </StackPanel>

                            <UniformGrid Grid.Column="1" x:Name="ValidateQuickGrid" Columns="2" Rows="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <Button Content="校验结果" Tag="Validate/校验汇总/校验结果" 
                                            Click="SubModule_Click" Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                                    <Button Content="世界观校验" Tag="Validate/校验介绍/世界观校验" 
                                            Click="SubModule_Click"
                                            Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                                    <Button Content="角色校验" Tag="Validate/校验介绍/角色校验" 
                                            Click="SubModule_Click" Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                                    <Button Content="剧情校验" Tag="Validate/校验介绍/剧情校验" 
                                            Click="SubModule_Click"
                                            Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                            </UniformGrid>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="0" Margin="0,0,0,4" 
                        Background="{DynamicResource ContentBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Padding="12,3"
                        CornerRadius="12"
                        Tag="SmartAssistant"
                        MouseEnter="ModuleCard_MouseEnter"
                        MouseLeave="ModuleCard_MouseLeave"
                        MouseLeftButtonUp="ModuleCard_Click">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.15"/>
                    </Border.Effect>
                    <Grid Grid.IsSharedSizeScope="True" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="QuickArea"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.RowSpan="2" Grid.Column="0" Background="{DynamicResource InfoColor}"
                                    CornerRadius="10"
                                    Width="44" Height="44"
                                    Margin="0,0,20,0"
                                    VerticalAlignment="Center">
                                <emoji:TextBlock Text="🤖" FontSize="30" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Grid.Row="0" Grid.Column="1" Text="智助" FontSize="26" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Bottom"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Ask/Agent/Plan 三种模式，提供问答、智能代理与任务规划执行，贯穿整个工作流" 
                                       FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,1,0,0"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="常用功能" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="10,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="QuickArea"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="64,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="Ask：快速问答与写作建议，随问随用降低决策成本" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,3"/>
                                <TextBlock Text="Agent：多步骤智能代理执行，自动推进复杂任务" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,3"/>
                                <TextBlock Text="Plan：任务规划与拆解执行，过程可跟踪可迭代" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,3"/>
                                <TextBlock Text="模型集成：模型配置管理、密钥管理与API用量统计" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,3"/>
                                <TextBlock Text="提示词工具：提示词模板、变量管理、版本测试与沉淀复用" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,0"/>
                            </StackPanel>

                            <UniformGrid Grid.Column="1" x:Name="SmartAssistantQuickGrid" Columns="2" Rows="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <Button Content="模型管理" Tag="SmartAssistant/模型集成/模型管理" 
                                            Click="SubModule_Click" Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                                    <Button Content="API统计" Tag="SmartAssistant/模型集成/API统计" 
                                            Click="SubModule_Click"
                                            Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                                    <Button Content="提示词管理" Tag="SmartAssistant/提示词工具/提示词管理" 
                                            Click="SubModule_Click" Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                                    <Button Content="版本测试" Tag="SmartAssistant/提示词工具/版本测试" 
                                            Click="SubModule_Click"
                                            Margin="0,0,2,2"
                                            Padding="12,6" FontSize="12" Width="96" HorizontalContentAlignment="Left"/>
                            </UniformGrid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

    </Grid>
</UserControl>
