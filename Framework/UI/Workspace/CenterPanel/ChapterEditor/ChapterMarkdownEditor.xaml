<UserControl x:Class="TM.Framework.UI.Workspace.CenterPanel.ChapterEditor.ChapterMarkdownEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:controls="clr-namespace:TM.Framework.UI.Workspace.CenterPanel.Controls"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls">

    <Border CornerRadius="0,0,6,6" ClipToBounds="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{DynamicResource Surface}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,2"
                Visibility="{Binding ShowSearchBar, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="搜索:" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"
                           Foreground="{DynamicResource TextSecondary}"/>
                <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Padding="4,2" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Column="2" Text="替换:" FontSize="11" VerticalAlignment="Center" Margin="8,0,4,0"
                           Foreground="{DynamicResource TextSecondary}"/>
                <TextBox Grid.Column="3" Text="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Padding="4,2" VerticalContentAlignment="Center"/>

                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button Content="上一个" Command="{Binding FindPreviousCommand}" 
                            FontSize="10" Padding="6,2" Margin="0,0,3,0"/>
                    <Button Content="下一个" Command="{Binding FindNextCommand}" 
                            FontSize="10" Padding="6,2" Margin="0,0,3,0"/>
                    <Button Content="替换" Command="{Binding ReplaceOneCommand}" 
                            FontSize="10" Padding="6,2" Margin="0,0,3,0"/>
                    <Button Content="全部替换" Command="{Binding ReplaceAllCommand}" 
                            FontSize="10" Padding="6,2"/>
                </StackPanel>

                <TextBlock Grid.Column="5" Text="{Binding MatchInfo}" FontSize="10" 
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           Foreground="{DynamicResource TextSecondary}"/>

                <Button Grid.Column="6" Content="✕" Command="{Binding CloseSearchCommand}"
                        Width="18" Height="18" FontSize="9"
                        Background="Transparent" BorderThickness="0"/>
            </Grid>
        </Border>

        <Border Grid.Row="0" 
                Padding="10,6"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding ShowSearchBar, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton Content="编辑" IsChecked="{Binding IsEditMode}" GroupName="ViewMode" 
                                 FontSize="11" Margin="0,0,4,0" VerticalContentAlignment="Center"/>
                    <RadioButton Content="预览" IsChecked="{Binding IsPreviewMode}" GroupName="ViewMode" 
                                 FontSize="11" Margin="0,0,4,0" VerticalContentAlignment="Center"/>
                    <RadioButton Content="分屏" IsChecked="{Binding IsSplitMode}" GroupName="ViewMode" 
                                 FontSize="11" Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                    <Button Content="☰ 大纲" Command="{Binding ToggleOutlineCommand}"
                            Height="18" Padding="8,0" FontSize="11"
                            Background="Transparent" BorderThickness="1"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Fill="{DynamicResource BorderBrush}" Margin="10,4"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="行 " Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                    <TextBlock Text="{Binding CurrentLine}" Foreground="{DynamicResource TextPrimary}" FontSize="11"/>
                    <TextBlock Text=", 列 " Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                    <TextBlock Text="{Binding CurrentColumn}" Foreground="{DynamicResource TextPrimary}" FontSize="11" Margin="0,0,12,0"/>
                    <TextBlock Text="段落: " Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                    <TextBlock Text="{Binding ParagraphCount}" Foreground="{DynamicResource TextPrimary}" FontSize="11" Margin="0,0,10,0"/>
                    <TextBlock Text="字数: " Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                    <TextBlock Text="{Binding WordCount}" Foreground="{DynamicResource TextPrimary}" FontSize="11"/>
                </StackPanel>

                <common:BreathingLight Grid.Column="3" 
                                        IsActive="{Binding IsPolishSplitMode}"
                                        Visibility="{Binding IsPolishSplitMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border x:Name="PolishButtonBorder"
                            Height="28" Margin="10,0,0,0"
                            CornerRadius="4"
                            Background="#EF4444">
                        <Button Content="润色中" 
                                Click="OnPolishButtonClick"
                                Height="28" Padding="16,0" FontSize="11"
                                Background="Transparent" Foreground="White"
                                BorderThickness="0" Cursor="Hand"/>
                    </Border>
                </common:BreathingLight>

                <common:BreathingLight Grid.Column="4" IsActive="{Binding IsDirty}">
                    <Border x:Name="SaveButtonBorder"
                            Height="28" Margin="10,0,0,0"
                            CornerRadius="4"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource ContentBackground}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                        <Setter Property="Background" Value="#EF4444"/>
                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Content="保存" Command="{Binding SaveCommand}"
                                Height="28" Padding="16,0" FontSize="11"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Border>
                </common:BreathingLight>
            </Grid>
        </Border>

        <Border Grid.Row="1" 
                Background="{DynamicResource ContentBackground}"
                CornerRadius="0,0,6,6">
        <Grid>
            <Grid Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="{DynamicResource Surface}" 
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0"
                        CornerRadius="0,0,0,6"
                        MinWidth="40">
                    <ScrollViewer x:Name="LineNumberScroller"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Hidden"
                                  IsHitTestVisible="False">
                        <ItemsControl x:Name="LineNumbers" 
                                      ItemsSource="{Binding LineNumberList}"
                                      Padding="0,4,0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" 
                                               FontFamily="Consolas, Microsoft YaHei UI"
                                               FontSize="14"
                                               Height="21"
                                               Foreground="{DynamicResource TextTertiary}"
                                               TextAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border x:Name="EditorBorder" Grid.Column="1" Background="{DynamicResource ContentBackground}" CornerRadius="0,0,6,0">
                    <Border.OpacityMask>
                        <VisualBrush>
                            <VisualBrush.Visual>
                                <Border Background="Black" CornerRadius="0,0,6,0"
                                        Width="{Binding ActualWidth, ElementName=EditorBorder}"
                                        Height="{Binding ActualHeight, ElementName=EditorBorder}"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.OpacityMask>
                <RichTextBox x:Name="EditorTextBox"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas, Microsoft YaHei UI"
                             FontSize="14"
                             Padding="8,4"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderThickness="0"
                             ScrollViewer.ScrollChanged="OnEditorScrollChanged"
                             SelectionChanged="OnEditorSelectionChanged"
                             TextChanged="OnRichTextBoxTextChanged">
                    <RichTextBox.Resources>
                        <Style TargetType="Paragraph">
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="LineHeight" Value="21"/>
                        </Style>
                    </RichTextBox.Resources>
                    <RichTextBox.InputBindings>
                        <KeyBinding Key="B" Modifiers="Ctrl" Command="{Binding BoldCommand}"/>
                        <KeyBinding Key="I" Modifiers="Ctrl" Command="{Binding ItalicCommand}"/>
                        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
                        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding SearchCommand}"/>
                        <KeyBinding Key="H" Modifiers="Ctrl" Command="{Binding ReplaceCommand}"/>
                        <KeyBinding Key="D1" Modifiers="Ctrl" Command="{Binding Heading1Command}"/>
                        <KeyBinding Key="D2" Modifiers="Ctrl" Command="{Binding Heading2Command}"/>
                    </RichTextBox.InputBindings>
                    <RichTextBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="全选" Command="ApplicationCommands.SelectAll"/>
                            <MenuItem Header="复制" Command="ApplicationCommands.Copy"/>
                            <MenuItem Header="粘贴" Command="ApplicationCommands.Paste"/>
                            <MenuItem Header="剪切" Command="ApplicationCommands.Cut"/>
                            <Separator/>
                            <MenuItem Header="撤销" Command="ApplicationCommands.Undo"/>
                            <MenuItem Header="重做" Command="ApplicationCommands.Redo"/>
                            <Separator/>
                            <MenuItem Header="AIGC" Click="OnInlineEditClick">
                                <MenuItem.Icon>
                                    <emoji:TextBlock Text="✏️" FontSize="14"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </RichTextBox.ContextMenu>
                </RichTextBox>
                </Border>
            </Grid>

            <Border Background="{DynamicResource ContentBackground}"
                    CornerRadius="0,0,6,6"
                    Visibility="{Binding IsPreviewMode, Converter={StaticResource BoolToVisibilityConverter}}">
                <FlowDocumentScrollViewer x:Name="PreviewViewer"
                                          VerticalScrollBarVisibility="Auto"
                                          Document="{Binding PreviewDocument}"
                                          Padding="16"/>
            </Border>

            <Grid Visibility="{Binding IsSplitMode, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource ContentBackground}" CornerRadius="0,0,0,6">
                    <FlowDocumentScrollViewer VerticalScrollBarVisibility="Auto"
                                              Document="{Binding SplitPreviewDocument}"
                                              Padding="16"/>
                </Border>

                <GridSplitter Grid.Column="1" 
                              Width="4" 
                              HorizontalAlignment="Stretch"
                              Background="{DynamicResource BorderBrush}"/>

                <Border x:Name="SplitEditorBorder" Grid.Column="2" Background="{DynamicResource ContentBackground}" CornerRadius="0,0,6,0">
                    <Border.OpacityMask>
                        <VisualBrush>
                            <VisualBrush.Visual>
                                <Border Background="Black" CornerRadius="0,0,6,0"
                                        Width="{Binding ActualWidth, ElementName=SplitEditorBorder}"
                                        Height="{Binding ActualHeight, ElementName=SplitEditorBorder}"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.OpacityMask>
                <RichTextBox x:Name="SplitEditorTextBox"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas, Microsoft YaHei UI"
                             FontSize="14"
                             Padding="16"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderThickness="0"
                             TextChanged="OnSplitEditorTextChanged">
                    <RichTextBox.Resources>
                        <Style TargetType="Paragraph">
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="LineHeight" Value="21"/>
                        </Style>
                    </RichTextBox.Resources>
                    <RichTextBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="全选" Command="ApplicationCommands.SelectAll"/>
                            <MenuItem Header="复制" Command="ApplicationCommands.Copy"/>
                            <MenuItem Header="粘贴" Command="ApplicationCommands.Paste"/>
                            <MenuItem Header="剪切" Command="ApplicationCommands.Cut"/>
                            <Separator/>
                            <MenuItem Header="撤销" Command="ApplicationCommands.Undo"/>
                            <MenuItem Header="重做" Command="ApplicationCommands.Redo"/>
                            <Separator/>
                            <MenuItem Header="AIGC" Click="OnSplitInlineEditClick">
                                <MenuItem.Icon>
                                    <emoji:TextBlock Text="✏️" FontSize="14"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </RichTextBox.ContextMenu>
                </RichTextBox>
                </Border>
            </Grid>
        </Grid>
        </Border>

        <controls:InlineEditPopup x:Name="InlineEditPopup"
                                  Grid.Row="1"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed"/>

        <Border Grid.Row="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Width="200"
                Background="{DynamicResource Surface}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1,0,0,0"
                Visibility="{Binding ShowOutline, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="{DynamicResource Surface}" Padding="10,8">
                    <Grid>
                        <TextBlock Text="文档大纲" FontWeight="SemiBold" FontSize="12"/>
                        <Button Content="✕" HorizontalAlignment="Right"
                                Command="{Binding ToggleOutlineCommand}"
                                Width="18" Height="18" FontSize="10"
                                Background="Transparent" BorderThickness="0"/>
                    </Grid>
                </Border>

                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding OutlineItems}"
                         SelectedItem="{Binding SelectedOutlineItem}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}" 
                                       FontSize="12"
                                       Padding="{Binding Indent}"
                                       Foreground="{DynamicResource TextPrimary}"
                                       TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
    </Border>
</UserControl>
