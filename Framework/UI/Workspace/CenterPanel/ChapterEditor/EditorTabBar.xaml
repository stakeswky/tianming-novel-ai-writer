<UserControl x:Class="TM.Framework.UI.Workspace.CenterPanel.ChapterEditor.EditorTabBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <ItemsControl x:Name="TabList"
                      Grid.Column="0"
                      ItemsSource="{Binding Tabs}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="TabBorder"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,1,1,0"
                            CornerRadius="6,6,0,0"
                            Padding="8,0"
                            Margin="2,0,0,0"
                            Cursor="Hand"
                            MouseLeftButtonDown="OnTabClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <emoji:TextBlock x:Name="TabIcon"
                                             Grid.Column="0"
                                             Text="📄"
                                             FontSize="11"
                                             VerticalAlignment="Center"
                                             Margin="0,0,4,0"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding DisplayTitle}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"
                                       MaxWidth="120"
                                       TextTrimming="CharacterEllipsis"/>

                            <Button x:Name="CloseButton"
                                    Grid.Column="2"
                                    Width="16" Height="16"
                                    Margin="6,0,0,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="OnCloseTab"
                                    Tag="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="Transparent"
                                                CornerRadius="2">
                                            <TextBlock Text="×"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextTertiary}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DangerColor}"/>
                                                <Setter TargetName="Bd" Property="TextBlock.Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ContentBackground}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsHomepage}" Value="True">
                            <Setter TargetName="TabIcon" Property="Text" Value="🏠"/>
                            <Setter TargetName="CloseButton" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button x:Name="CloseAllButton"
                Grid.Column="1"
                Height="30"
                Padding="12,4"
                Margin="4,0,1,0"
                Background="Transparent"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1,1,1,0"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"
                Cursor="Hand"
                Click="OnCloseAll">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6,6,0,0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DangerColor}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource DangerColor}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <TextBlock Text="关闭全部"
                       FontSize="12"
                       Foreground="{DynamicResource TextPrimary}"/>
        </Button>
    </Grid>
</UserControl>
