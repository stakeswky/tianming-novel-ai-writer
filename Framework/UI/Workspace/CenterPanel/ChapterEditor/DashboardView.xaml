<UserControl x:Class="TM.Framework.UI.Workspace.CenterPanel.ChapterEditor.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <Grid Margin="10,0" MaxWidth="1000" HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,40,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="-50,0,0,0">
                <Grid Width="56" Height="56" Margin="0,0,18,0">
                    <Border x:Name="AppIconBorder"
                            CornerRadius="12"
                            ClipToBounds="True"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" />
                    <emoji:TextBlock x:Name="FallbackIconTextBlock" Text="🎯" FontSize="36"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Visibility="Collapsed"/>
                </Grid>
                <TextBlock Text="天命" 
                           FontSize="32" 
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,-50,0">
                <TextBlock x:Name="DateText" 
                           FontSize="15" 
                           Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Right"/>
                <TextBlock x:Name="TimeText" 
                           FontSize="24" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           HorizontalAlignment="Right"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderBrush}" Margin="-50,24,-50,0" Visibility="Collapsed"/>

        <StackPanel Grid.Row="3" Margin="0,-200,0,0">
            <TextBlock Text="欢迎"
                       FontSize="30"
                       FontWeight="Light"
                       Foreground="{DynamicResource TextPrimary}"
                       HorizontalAlignment="Center"
                       Margin="-230,50,0,8"/>

            <TextBlock x:Name="WelcomeText"
                       Text="欢迎回来" 
                       FontSize="40" 
                       FontWeight="Light"
                       Foreground="{DynamicResource TextPrimary}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,36"/>

            <UniformGrid Columns="3" Margin="0,0,0,24">
                <Border Background="{DynamicResource ContentBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24,20"
                        Margin="0,0,12,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="CurrentVolumeText" 
                                   Text="--" 
                                   FontSize="42" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource InfoColor}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="当前卷" 
                                   FontSize="15" 
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource ContentBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24,20"
                        Margin="6,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="ChapterCountText" 
                                   Text="0" 
                                   FontSize="42" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryColor}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="章节数" 
                                   FontSize="15" 
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource ContentBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24,20"
                        Margin="12,0,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="WordCountText" 
                                   Text="0" 
                                   FontSize="42" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessColor}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="总字数" 
                                   FontSize="15" 
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Background="{DynamicResource ContentBackground}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20,14"
                    Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="最近编辑：" 
                               FontSize="15" 
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="RecentEditText" 
                               Text="暂无编辑记录" 
                               FontSize="15" 
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <UniformGrid Columns="4">
                <Button Content="AI助手" 
                        Tag="SmartAssistant"
                        Click="QuickAction_Click"
                        Height="44"
                        Margin="0,0,8,0"
                        Padding="16,8"
                        FontSize="15"/>
                <Button Content="打开设计" 
                        Tag="Design"
                        Click="QuickAction_Click"
                        Height="44"
                        Margin="4,0"
                        Padding="16,8"
                        FontSize="15"/>
                <Button Content="新建章节" 
                        Tag="NewChapter"
                        Click="QuickAction_Click"
                        Height="44"
                        Margin="4,0"
                        Padding="16,8"
                        FontSize="15"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Content="继续写作" 
                        Tag="ContinueWriting"
                        Click="QuickAction_Click"
                        Height="44"
                        Margin="8,0,0,0"
                        Padding="16,8"
                        FontSize="15"/>
            </UniformGrid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,100,-100,0">
                <TextBlock Text="让灵感自由流淌"
                           FontSize="30"
                           FontWeight="Light"
                           Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text=" — "
                           FontSize="15"
                           FontWeight="Light"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,4"/>
                <TextBlock Text="子夜"
                           FontSize="15"
                           FontWeight="Light"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,4"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
