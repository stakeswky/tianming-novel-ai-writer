<UserControl x:Class="TM.Framework.UI.Workspace.CenterPanel.ValidationReport.ValidationReportPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource UnifiedBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="📋" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="校验报告"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Button Grid.Column="1"
                        x:Name="RefreshButton"
                        Padding="8,4"
                        Background="{DynamicResource PrimaryColor}"
                        Foreground="White"
                        BorderThickness="0"
                        Click="OnRefresh">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="🔄" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBlock Text="重新校验" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource ContentBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock x:Name="StatusIcon" Text="⏳" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <StackPanel>
                        <TextBlock x:Name="StatusText"
                                   Text="等待校验"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock x:Name="SummaryText"
                                   Text="选择章节后点击校验"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0">
                    <Border Background="{DynamicResource SuccessColor}" CornerRadius="10" Padding="8,2" MinWidth="40">
                        <TextBlock x:Name="PassCountText" Text="0" FontSize="12" Foreground="White" HorizontalAlignment="Center" />
                    </Border>
                    <TextBlock Text="通过" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="4,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0">
                    <Border Background="{DynamicResource WarningColor}" CornerRadius="10" Padding="8,2" MinWidth="40">
                        <TextBlock x:Name="WarningCountText" Text="0" FontSize="12" Foreground="White" HorizontalAlignment="Center" />
                    </Border>
                    <TextBlock Text="警告" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="4,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="10,0">
                    <Border Background="{DynamicResource DangerColor}" CornerRadius="10" Padding="8,2" MinWidth="40">
                        <TextBlock x:Name="ErrorCountText" Text="0" FontSize="12" Foreground="White" HorizontalAlignment="Center" />
                    </Border>
                    <TextBlock Text="错误" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="4,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <ListBox Grid.Row="2"
                 x:Name="ItemsListBox"
                 Background="Transparent"
                 BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12,10"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" 
                                    Width="28" Height="28"
                                    CornerRadius="14"
                                    Background="{Binding ResultBackground}"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{Binding ResultIcon}"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ValidationType}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextTertiary}"
                                               Padding="4,1"
                                               Background="{DynamicResource Surface}" />
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               Margin="8,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="{Binding Details}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                                <TextBlock Text="{Binding Suggestion}"
                                           FontSize="11"
                                           Foreground="{DynamicResource WarningColor}"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0"
                                           Visibility="{Binding HasSuggestion, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
