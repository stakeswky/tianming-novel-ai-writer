<Window x:Class="TM.Framework.UI.Workspace.RightPanel.Dialogs.SessionHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Width="500"
        Height="600">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44"
                      CornerRadius="12"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <Border Style="{DynamicResource StandardDialogBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource StandardDialogTitleBarStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <emoji:TextBlock Text="📜" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="历史会话" Style="{DynamicResource StandardDialogTitleTextStyle}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Click="OnCancel"
                            Style="{DynamicResource StandardDialogCloseButtonStyle}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20,12,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             x:Name="SearchBox"
                             Height="36"
                             Style="{DynamicResource StandardTextBoxStyle}"
                             Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"/>

                    <Button Grid.Column="1"
                            Content="全选删除"
                            Style="{DynamicResource DangerButtonStyle}"
                            Padding="16,8"
                            Margin="8,0,0,0"
                            Click="OnDeleteAll"/>
                </Grid>

                <ListBox Grid.Row="1"
                         x:Name="SessionsListBox"
                         ItemsSource="{Binding FilteredSessions}"
                         SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                         Background="{DynamicResource ContentBackground}"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         ScrollViewer.CanContentScroll="True">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource Surface}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{Binding Title}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding MessageCount, StringFormat={}{0} 条消息}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondary}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="{Binding UpdatedAt, StringFormat=更新时间：{0:yyyy-MM-dd HH:mm:ss}}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextTertiary}"
                                               Margin="0,4,0,0"/>

                                    <Button Grid.Row="2" Grid.Column="0"
                                            Content="删除"
                                            Style="{DynamicResource DangerButtonStyle}"
                                            Padding="12,4"
                                            FontSize="11"
                                            HorizontalAlignment="Left"
                                            Margin="0,8,0,0"
                                            Click="OnDeleteSession"
                                            Tag="{Binding Id}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Style="{DynamicResource StandardDialogFooterStyle}">
                    <Button Content="切换到选中会话"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Padding="24,8"
                            MinWidth="120"
                            IsEnabled="{Binding HasSelectedSession}"
                            Click="OnConfirm"
                            Margin="0,0,10,0"/>
                    <Button Content="取消"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="24,8"
                            MinWidth="80"
                            Click="OnCancel"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
