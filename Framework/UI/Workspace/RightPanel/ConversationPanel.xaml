<UserControl x:Class="TM.Framework.UI.Workspace.RightPanel.ConversationPanel"
             x:Name="ConversationPanelRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:modes="clr-namespace:TM.Framework.UI.Workspace.RightPanel.Modes"
             xmlns:uihelpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:chatcontrols="clr-namespace:TM.Framework.UI.Workspace.RightPanel.Controls"
             xmlns:controls="clr-namespace:TM.Framework.Common.Controls"
             xmlns:diffplex="clr-namespace:DiffPlex.Wpf.Controls;assembly=DiffPlex.Wpf">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Windows/Theme.xaml"/>
                <ResourceDictionary Source="../Common/Resources/ChatStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate x:Key="CollapsiblePanelTemplate">
                <StackPanel>
                    <controls:BreathingLight IsActive="{Binding IsProcessing}"
                                             MinOpacity="0.3" MaxOpacity="1.0"
                                             HorizontalAlignment="Left">
                        <TextBlock Text="{Binding Summary, TargetNullValue=Thinking...}"
                                   FontSize="9"
                                   Foreground="{DynamicResource TextTertiary}"
                                   Cursor="Hand">
                            <TextBlock.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding ToggleCommand}"/>
                            </TextBlock.InputBindings>
                        </TextBlock>
                    </controls:BreathingLight>
                    <Border Margin="0,2,0,0"
                            Background="{DynamicResource UnifiedBackground}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="6,6,6,1"
                            Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150">
                            <ItemsControl ItemsSource="{Binding Blocks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Body}"
                                                   FontSize="10"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   Margin="0,0,0,3"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

        <Border 

                Background="{DynamicResource ContentHighlight}"
                BorderBrush="{DynamicResource WindowBorder}"
                BorderThickness="{StaticResource StandardBorder}"
                CornerRadius="{StaticResource SmallRadius}"
                Margin="1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource UnifiedBackground}"
                        BorderBrush="{DynamicResource WindowBorder}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="6,6,6,6"
                        Height="30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="SessionDropdownButton"
                                Grid.Column="0"
                                Height="30"
                                Padding="8,4"
                                Margin="4,0,0,0"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1,1,1,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Cursor="Hand"
                                ToolTip="点击查看最近对话"
                                Click="OnSessionDropdownClick">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6,6,0,0"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackground}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                            <emoji:TextBlock Text="📋" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <Grid>
                                                <TextBlock x:Name="SessionTitleDisplay"
                                                           Text="{Binding SessionTitle, FallbackValue='新对话'}" 
                                                           FontSize="11" 
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           VerticalAlignment="Center"
                                                           MaxWidth="120"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="双击编辑标题"
                                                           MouseLeftButtonDown="OnSessionTitleMouseDown"/>
                                                <TextBox x:Name="SessionTitleEditor"
                                                         Text="{Binding SessionTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11"
                                                         MinWidth="80"
                                                         MaxWidth="120"
                                                         VerticalAlignment="Center"
                                                         Visibility="Collapsed"
                                                         LostFocus="OnSessionTitleEditorLostFocus"
                                                         KeyDown="OnSessionTitleEditorKeyDown">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="TextBox">
                                                                        <Border Background="{DynamicResource ContentBackground}"
                                                                                BorderBrush="{DynamicResource PrimaryColor}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="4"
                                                                                Padding="4,2">
                                                                            <ScrollViewer x:Name="PART_ContentHost"
                                                                                          VerticalAlignment="Center"
                                                                                          Margin="0"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                            </Grid>
                                <Path Data="M7,10L12,15L17,10H7Z"
                                      Fill="{DynamicResource TextSecondary}"
                                      Width="10" Height="10"
                                      Stretch="Uniform"
                                      Margin="4,0,0,0"
                                      VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.ContextMenu>
                                <ContextMenu x:Name="SessionHistoryMenu" HasDropShadow="True" Placement="Bottom">
                                    <ContextMenu.Resources>
                                        <Style TargetType="ContextMenu">
                                            <Setter Property="Background" Value="{DynamicResource ContentBackground}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="MinWidth" Value="180"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ContextMenu">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6"
                                                                Padding="4">
                                                            <StackPanel IsItemsHost="True"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ContextMenu.Resources>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>

                        <Button Grid.Column="2" x:Name="MonitorButton"
                                Height="30"
                                Padding="8,4"
                                Margin="0,0,4,0"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1,1,1,0"
                                VerticalAlignment="Center"
                                Click="MonitorButton_OnClick"
                                ToolTip="点击查看最近一次运行详情"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6,6,0,0"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding MonitorTitle, FallbackValue='ASK'}" 
                                           FontSize="12" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding MonitorSubTitle, FallbackValue='监控'}" 
                                           FontSize="12" 
                                           Foreground="{DynamicResource TextSecondary}"
                                           VerticalAlignment="Center"
                                           Margin="2,0,0,0"
                                           MaxWidth="80"
                                           TextTrimming="CharacterEllipsis"/>
                                <Ellipse Width="6" Height="6"
                                         Margin="6,0,0,0"
                                         Fill="{Binding CurrentModeActiveColor, FallbackValue='#22C55E'}"
                                         VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="3" 
                                Width="28" Height="28"
                                Margin="0,0,4,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="OnSettingsButtonClick">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4">
                                        <Path Data="M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8M12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12A2,2 0 0,0 12,10M10,22C9.75,22 9.54,21.82 9.5,21.58L9.13,18.93C8.5,18.68 7.96,18.34 7.44,17.94L4.95,18.95C4.73,19.03 4.46,18.95 4.34,18.73L2.34,15.27C2.21,15.05 2.27,14.78 2.46,14.63L4.57,12.97L4.5,12L4.57,11L2.46,9.37C2.27,9.22 2.21,8.95 2.34,8.73L4.34,5.27C4.46,5.05 4.73,4.96 4.95,5.05L7.44,6.05C7.96,5.66 8.5,5.32 9.13,5.07L9.5,2.42C9.54,2.18 9.75,2 10,2H14C14.25,2 14.46,2.18 14.5,2.42L14.87,5.07C15.5,5.32 16.04,5.66 16.56,6.05L19.05,5.05C19.27,4.96 19.54,5.05 19.66,5.27L21.66,8.73C21.79,8.95 21.73,9.22 21.54,9.37L19.43,11L19.5,12L19.43,13L21.54,14.63C21.73,14.78 21.79,15.05 21.66,15.27L19.66,18.73C19.54,18.95 19.27,19.04 19.05,18.95L16.56,17.95C16.04,18.34 15.5,18.68 14.87,18.93L14.5,21.58C14.46,21.82 14.25,22 14,22H10M11.25,4L10.88,6.61C9.68,6.86 8.62,7.5 7.85,8.39L5.44,7.35L4.69,8.65L6.8,10.2C6.4,11.37 6.4,12.64 6.8,13.8L4.68,15.36L5.43,16.66L7.86,15.62C8.63,16.5 9.68,17.14 10.87,17.38L11.24,20H12.76L13.13,17.39C14.32,17.14 15.37,16.5 16.14,15.62L18.57,16.66L19.32,15.36L17.2,13.81C17.6,12.64 17.6,11.37 17.2,10.2L19.31,8.65L18.56,7.35L16.15,8.39C15.38,7.5 14.32,6.86 13.12,6.62L12.75,4H11.25Z"
                                              Fill="{DynamicResource TextSecondary}"
                                              Stretch="Uniform"
                                              Width="16" Height="16"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>

                            <Button.ContextMenu>
                                <ContextMenu HasDropShadow="True">
                                    <ContextMenu.Resources>
                                        <Style TargetType="ContextMenu">
                                            <Setter Property="Background" Value="{DynamicResource ContentBackground}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ContextMenu">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6"
                                                                Padding="4">
                                                            <StackPanel IsItemsHost="True"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ContextMenu.Resources>
                                    <MenuItem Header="Spec规则" Click="OnShowProjectSpecClick">
                                        <MenuItem.Icon>
                                            <emoji:TextBlock Text="📝" FontSize="14"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem Header="生成参数" Click="OnShowGenerationParamsClick">
                                        <MenuItem.Icon>
                                            <emoji:TextBlock Text="⚙" FontSize="14"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <Separator/>

                                    <MenuItem Header="星标消息" Command="{Binding ShowStarredMessagesCommand}">
                                        <MenuItem.Icon>
                                            <Path Data="M12,2 L14.5,8.5 L21,8.5 L16,13 L18.5,19.5 L12,15 L5.5,19.5 L8,13 L3,8.5 L9.5,8.5 Z"
                                                  Fill="#FFD700"
                                                  Stroke="{DynamicResource TextPrimary}"
                                                  StrokeThickness="0.5"
                                                  Width="16" Height="16"
                                                  Stretch="Uniform"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem Header="清空对话" Command="{Binding ClearSessionCommand}">
                                        <MenuItem.Icon>
                                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                  Fill="{DynamicResource TextPrimary}"
                                                  Width="16" Height="16"
                                                  Stretch="Uniform"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource ContentBackground}"
                        CornerRadius="0,0,6,6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="1">
                            <StackPanel x:Name="EmptyStateGuide" 
                                       HorizontalAlignment="Stretch" 
                                       VerticalAlignment="Top"
                                       Margin="5,220,5,0"
                                       Visibility="Collapsed">
                                <TextBlock Text="欢迎使用天命 AI 助手" 
                                          FontSize="24" 
                                          FontWeight="Bold"
                                          Foreground="{DynamicResource TextPrimary}"
                                          HorizontalAlignment="Center"
                                          Margin="0,0,0,15"/>
                                <TextBlock Text="选择下方对话模式开始创作" 
                                          FontSize="14" 
                                          Foreground="{DynamicResource TextSecondary}"
                                          HorizontalAlignment="Center"
                                          Margin="0,0,0,25"/>

                                <StackPanel>
                                    <Border Background="{DynamicResource ContentBackground}"
                                           BorderBrush="{DynamicResource SuccessColor}"
                                           BorderThickness="2"
                                           CornerRadius="8"
                                           Padding="15"
                                           Margin="0,0,0,12"
                                           Cursor="Hand"
                                           MouseLeftButtonDown="OnModeCardClick"
                                           Tag="0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="◉" FontSize="16" FontWeight="Bold" 
                                                          Foreground="{DynamicResource SuccessColor}" 
                                                          VerticalAlignment="Center"/>
                                                <TextBlock Text="Ask 模式" 
                                                          FontSize="16" 
                                                          FontWeight="SemiBold"
                                                          Foreground="{DynamicResource TextPrimary}"
                                                          Margin="8,0,0,0"
                                                          VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="快速问答模式，适合简单咨询、灵感激发、快速获取建议。单次对话，响应迅速。" 
                                                      FontSize="12" 
                                                      Foreground="{DynamicResource TextSecondary}"
                                                      TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{DynamicResource ContentBackground}"
                                           BorderBrush="{DynamicResource InfoColor}"
                                           BorderThickness="2"
                                           CornerRadius="8"
                                           Padding="15"
                                           Margin="0,0,0,12"
                                           Cursor="Hand"
                                           MouseLeftButtonDown="OnModeCardClick"
                                           Tag="1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="∞" FontSize="16" FontWeight="Bold" 
                                                          Foreground="{DynamicResource InfoColor}" 
                                                          VerticalAlignment="Center"/>
                                                <TextBlock Text="Agent 模式" 
                                                          FontSize="16" 
                                                          FontWeight="SemiBold"
                                                          Foreground="{DynamicResource TextPrimary}"
                                                          Margin="8,0,0,0"
                                                          VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="智能代理模式，具备自主思考和多步推理能力。适合复杂任务、深度分析、创意构思。" 
                                                      FontSize="12" 
                                                      Foreground="{DynamicResource TextSecondary}"
                                                      TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{DynamicResource ContentBackground}"
                                           BorderBrush="{DynamicResource WarningColor}"
                                           BorderThickness="2"
                                           CornerRadius="8"
                                           Padding="15"
                                           Cursor="Hand"
                                           MouseLeftButtonDown="OnModeCardClick"
                                           Tag="2">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="☰" FontSize="16" FontWeight="Bold" 
                                                          Foreground="{DynamicResource WarningColor}" 
                                                          VerticalAlignment="Center"/>
                                                <TextBlock Text="Plan 模式" 
                                                          FontSize="16" 
                                                          FontWeight="SemiBold"
                                                          Foreground="{DynamicResource TextPrimary}"
                                                          Margin="8,0,0,0"
                                                          VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="任务规划模式，自动拆分任务、分步执行、实时反馈。适合多步骤流程、系统化创作。" 
                                                      FontSize="12" 
                                                      Foreground="{DynamicResource TextSecondary}"
                                                      TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <ListBox x:Name="MessagesListBox"
                                     ItemsSource="{Binding Messages}"
                                     SelectedItem="{Binding SelectedMessage, Mode=TwoWay}"
                                     SelectionChanged="OnMessagesSelectionChanged"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     VirtualizingPanel.ScrollUnit="Pixel"
                                     ScrollViewer.CanContentScroll="True">
                            <ListBox.ContextMenu>
                                <ContextMenu x:Name="MessagesContextMenu" Opened="OnMessagesContextMenuOpened">
                                    <ContextMenu.Template>
                                        <ControlTemplate TargetType="ContextMenu">
                                            <Border Background="{DynamicResource ContentBackground}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="4">
                                                <StackPanel IsItemsHost="True"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ContextMenu.Template>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="SelectionMode" Value="Single"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMultiSelectMode}" Value="True">
                                            <Setter Property="SelectionMode" Value="Extended"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="8,4"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <EventSetter Event="MouseRightButtonDown" Handler="OnMessageBubbleRightClick"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <StackPanel>
                                                    <ContentControl x:Name="AnalysisPanel"
                                                                    Visibility="Collapsed"
                                                                    Margin="10,0,0,4"
                                                                    Content="{Binding ThinkingPanelBindings}"
                                                                    ContentTemplate="{StaticResource CollapsiblePanelTemplate}"/>

                                                    <Border x:Name="Bubble"
                                                            Background="{DynamicResource ContentBackground}"
                                                            BorderBrush="{DynamicResource WindowBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Padding="10,6"
                                                            SnapsToDevicePixels="True">
                                                        <ContentPresenter x:Name="contentPresenter"
                                                                          HorizontalAlignment="Left"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>

                                                    <ContentControl x:Name="ChangesPanel"
                                                                    Visibility="Collapsed"
                                                                    Margin="10,4,0,0"
                                                                    Content="{Binding ChangesPanelBindings}"
                                                                    ContentTemplate="{StaticResource CollapsiblePanelTemplate}"/>

                                                    <Border x:Name="ChapterDiffPanel"
                                                            Visibility="Collapsed"
                                                            Margin="10,4,0,0"
                                                            Background="{DynamicResource Surface}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="8,6">
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                <emoji:TextBlock Text="📝" FontSize="11" VerticalAlignment="Center"/>
                                                                <TextBlock Text=" 改写对比"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource TextSecondary}"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                            <diffplex:DiffViewer
                                                                OldText="{Binding OldChapterContent}"
                                                                NewText="{Binding NewChapterContent}"
                                                                IsSideBySide="False"
                                                                MaxHeight="400"
                                                                FontSize="12"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border x:Name="ReferencesPanel"
                                                            Visibility="Collapsed"
                                                            Margin="10,4,0,0"
                                                            Background="{DynamicResource Surface}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="8,6">
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                <emoji:TextBlock Text="📎" FontSize="11" VerticalAlignment="Center"/>
                                                                <TextBlock Text=" 参考来源"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource TextSecondary}"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                            <ItemsControl ItemsSource="{Binding References}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock FontSize="11"
                                                                                   Foreground="{DynamicResource TextTertiary}"
                                                                                   TextWrapping="NoWrap"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   Margin="0,1">
                                                                            <Run Text="第"/><Run Text="{Binding ChapterId}"/><Run Text=" 章"/>
                                                                            <Run Text="（相关度 "/><Run Text="{Binding Score, StringFormat=F2}"/><Run Text="）"/>
                                                                        </TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right"/>
                                                        <Setter TargetName="Bubble" Property="Background" Value="{DynamicResource UnifiedBackground}"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding IsUser}" Value="False">
                                                        <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Left"/>
                                                        <Setter TargetName="Bubble" Property="Background" Value="{DynamicResource ContentBackground}"/>
                                                    </DataTrigger>

                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bubble" Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                                                    </Trigger>

                                                    <DataTrigger Binding="{Binding IsTypingPlaceholder}" Value="True">
                                                        <Setter TargetName="Bubble" Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding HasThinking}" Value="True">
                                                        <Setter TargetName="AnalysisPanel" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding HasAnalysisSummary}" Value="True">
                                                        <Setter TargetName="AnalysisPanel" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding IsTypingPlaceholder}" Value="True">
                                                        <Setter TargetName="AnalysisPanel" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding HasChanges}" Value="True">
                                                        <Setter TargetName="ChangesPanel" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding HasChangesSummary}" Value="True">
                                                        <Setter TargetName="ChangesPanel" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding HasChapterDiff}" Value="True">
                                                        <Setter TargetName="ChapterDiffPanel" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding IsChangesProcessing}" Value="True">
                                                        <Setter TargetName="ChangesPanel" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding HasReferences}" Value="True">
                                                        <Setter TargetName="ReferencesPanel" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding IsError}" Value="True">
                                                        <Setter TargetName="Bubble" Property="BorderBrush" Value="{DynamicResource DangerColor}"/>
                                                        <Setter TargetName="Bubble" Property="BorderThickness" Value="2"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                        <StackPanel x:Name="NormalMessagePanel">
                                            <TextBlock x:Name="Header"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       TextAlignment="Left">
                                                <Run x:Name="HeaderName" Text="天命"/>
                                                <Run Text=" "/>
                                                <Run x:Name="HeaderTime" Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" FontSize="13" FontWeight="Normal"/>
                                            </TextBlock>

                                            <emoji:TextBlock x:Name="ContentTextBlock"
                                                             Text="{Binding Content}"
                                                             Margin="0,8,0,0"
                                                             FontSize="13"
                                                             TextWrapping="Wrap"
                                                             Foreground="{DynamicResource TextPrimary}"/>

                                            <StackPanel x:Name="ErrorIndicator" 
                                                        Orientation="Horizontal" 
                                                        Margin="0,6,0,0"
                                                        Visibility="Collapsed">
                                                <emoji:TextBlock Text="⚠️" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="发送失败" 
                                                           Foreground="{DynamicResource DangerColor}" 
                                                           FontSize="12" 
                                                           Margin="4,0,0,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ErrorMessage}" 
                                                           Foreground="{DynamicResource TextSecondary}" 
                                                           FontSize="11" 
                                                           Margin="8,0,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="200"
                                                           VerticalAlignment="Center"
                                                           ToolTip="{Binding ErrorMessage}"/>
                                            </StackPanel>

                                            <Grid x:Name="ActionBarGrid" Margin="0,4,0,0">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>

                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Opacity="0.85">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAssistant}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>

                                                <Button Command="{Binding DataContext.CopyMessageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        Style="{StaticResource ChatActionIconButtonStyle}"
                                                        Margin="4,0,0,0"
                                                        ToolTip="复制">
                                                    <Path Stroke="{DynamicResource TextSecondary}"
                                                          StrokeThickness="1.2"
                                                          Data="M3,5 L3,15 L11,15 L11,5 Z M7,3 L15,3 L15,13"/>
                                                </Button>

                                                <Button Command="{Binding DataContext.RegenerateAssistantMessageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        Style="{StaticResource ChatActionIconButtonStyle}"
                                                        Margin="4,0,0,0"
                                                        ToolTip="重新生成">
                                                    <Path Stroke="{DynamicResource TextSecondary}"
                                                          StrokeThickness="1.2"
                                                          Data="M10,4 A6,6 0 1 1 5.2,6.2 L6.5,4.5 M5.2,6.2 L7.3,6.3"/>
                                                </Button>

                                                <Button Command="{Binding DataContext.SwitchModelAnswerCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        Style="{StaticResource ChatActionIconButtonStyle}"
                                                        Margin="4,0,0,0"
                                                        ToolTip="切换模型回答">
                                                    <TextBlock Text="@"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Margin="0,2,0,0"/>
                                                </Button>

                                                <Button Command="{Binding DataContext.TranslateMessageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        Style="{StaticResource ChatActionIconButtonStyle}"
                                                        Margin="4,0,0,0"
                                                        ToolTip="翻译">
                                                    <TextBlock Text="文"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Margin="0,2,0,0"/>
                                                </Button>

                                                <Button Command="{Binding DataContext.DeleteMessageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        Style="{StaticResource ChatActionIconButtonStyle}"
                                                        Margin="4,0,0,0"
                                                        ToolTip="删除">
                                                    <Path Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.2" Data="M6,5 L14,5 L13,15 L7,15 Z M8,5 L8,4 L12,4 L12,5"/>
                                                </Button>

                                                <Button Command="{Binding DataContext.ExportMessageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        Style="{StaticResource ChatActionIconButtonStyle}"
                                                        Margin="4,0,0,0"
                                                        ToolTip="导出">
                                                    <Path Stroke="{DynamicResource TextSecondary}"
                                                          StrokeThickness="1.2"
                                                          Data="M10,4 L10,11 L7.5,8.5 M10,11 L12.5,8.5 M7,13 L13,13 L13,17 L7,17 Z"/>
                                                </Button>

                                                <Button Command="{Binding DataContext.ToggleStarCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        Style="{StaticResource ChatActionIconButtonStyle}"
                                                        Margin="4,0,0,0"
                                                        ToolTip="星标">
                                                    <Path Stroke="{DynamicResource TextSecondary}"
                                                          StrokeThickness="1.2"
                                                          Data="M10,3 L11.5,7.5 L16,7.5 L12.5,10.5 L14,15 L10,12 L6,15 L7.5,10.5 L4,7.5 L8.5,7.5 Z">
                                                        <Path.Style>
                                                            <Style TargetType="Path">
                                                                <Setter Property="Fill" Value="White"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsStarred}" Value="True">
                                                                        <Setter Property="Fill" Value="#FFC107"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Path.Style>
                                                    </Path>
                                                </Button>

                                                <Button Command="{Binding DataContext.ToggleMultiSelectCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        Style="{StaticResource ChatActionIconButtonStyle}"
                                                        Margin="6,0,0,0"
                                                        ToolTip="多选">
                                                    <Path Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.2" Data="M3,6 L5,8 L9,4 M3,11 L5,13 L9,9"/>
                                                </Button>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Opacity="0.85">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>

                                                <Button Command="{Binding DataContext.RegenerateFromUserMessageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        Style="{StaticResource ChatActionIconButtonStyle}"
                                                        Margin="4,0,0,0"
                                                        ToolTip="重新生成">
                                                    <Path Stroke="{DynamicResource TextSecondary}"
                                                          StrokeThickness="1.2"
                                                          Data="M10,4 A6,6 0 1 1 5.2,6.2 L6.5,4.5 M5.2,6.2 L7.3,6.3"/>
                                                </Button>

                                                <Button Command="{Binding DataContext.EditUserMessageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        Style="{StaticResource ChatActionIconButtonStyle}"
                                                        Margin="4,0,0,0"
                                                        ToolTip="编辑">
                                                    <Path Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.2" Data="M4,14 L4,16 L8,16 L14,10 L10,6 Z"/>
                                                </Button>

                                                <Button Command="{Binding DataContext.CopyMessageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        Style="{StaticResource ChatActionIconButtonStyle}"
                                                        Margin="2,0,0,0"
                                                        ToolTip="复制">
                                                    <Path Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.2" Data="M3,5 L3,15 L11,15 L11,5 Z M7,3 L15,3 L15,13"/>
                                                </Button>

                                                <Button Command="{Binding DataContext.DeleteUserWithAssistantCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        Style="{StaticResource ChatActionIconButtonStyle}"
                                                        Margin="4,0,0,0"
                                                        ToolTip="删除">
                                                    <Path Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.2" Data="M6,5 L14,5 L13,15 L7,15 Z M8,5 L8,4 L12,4 L12,5"/>
                                                </Button>

                                                <Button Command="{Binding DataContext.RecallToInputCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        Style="{StaticResource ChatActionIconButtonStyle}"
                                                        Margin="4,0,0,0"
                                                        ToolTip="撤回到输入框">
                                                    <Path Stroke="{DynamicResource TextSecondary}"
                                                          StrokeThickness="1.2"
                                                          Data="M8,6 L5,9 L8,12 M5,9 L11,9 C13,9 14,10 14,12"/>
                                                </Button>

                                                <Button Command="{Binding DataContext.ToggleStarCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        Style="{StaticResource ChatActionIconButtonStyle}"
                                                        Margin="4,0,0,0"
                                                        ToolTip="星标">
                                                    <Path Stroke="{DynamicResource TextSecondary}"
                                                          StrokeThickness="1.2"
                                                          Data="M10,3 L11.5,7.5 L16,7.5 L12.5,10.5 L14,15 L10,12 L6,15 L7.5,10.5 L4,7.5 L8.5,7.5 Z">
                                                        <Path.Style>
                                                            <Style TargetType="Path">
                                                                <Setter Property="Fill" Value="White"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsStarred}" Value="True">
                                                                        <Setter Property="Fill" Value="#FFC107"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Path.Style>
                                                    </Path>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                            <Setter TargetName="HeaderName" Property="Text" Value="我"/>
                                            <Setter TargetName="Header" Property="TextAlignment" Value="Right"/>
                                            <Setter TargetName="HeaderName" Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                            <Setter TargetName="HeaderTime" Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding IsUser}" Value="False">
                                            <Setter TargetName="HeaderName" Property="Text" Value="天命"/>
                                            <Setter TargetName="Header" Property="TextAlignment" Value="Left"/>
                                            <Setter TargetName="HeaderName" Property="Foreground" Value="{DynamicResource PrimaryColor}"/>
                                            <Setter TargetName="HeaderTime" Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding IsTypingPlaceholder}" Value="True">
                                            <Setter TargetName="NormalMessagePanel" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                            <Setter TargetName="ErrorIndicator" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        </Grid>

                        <chatcontrols:TodoOverlay x:Name="TodoOverlayPanel"
                                                  Grid.Row="1"
                                                  Panel.ZIndex="10"
                                                  DataContext="{Binding TodoPanelViewModel}"
                                                  VerticalAlignment="Top"
                                                  Margin="8,8,8,0"
                                                  Visibility="{Binding DataContext.ShowTodoOverlay, ElementName=ConversationPanelRoot, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <Border Grid.Row="2"
                                Padding="8,5,8,5"
                                Background="{DynamicResource Surface}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Visibility="{Binding HasSuggestedActions, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Vertical">

                                <DockPanel LastChildFill="False"
                                           Visibility="{Binding HasPlanContinueAction, Converter={StaticResource BoolToVisibilityConverter}}">

                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                DockPanel.Dock="Left">
                                        <TextBlock Text="▶ 继续  "
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding PlanContinueDisplayPrefix}"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding PlanContinueStartNum}"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text=" - "
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBox Text="{Binding PlanContinueEndText, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="52"
                                                 Height="24"
                                                 FontSize="11"
                                                 VerticalContentAlignment="Center"
                                                 HorizontalContentAlignment="Center"
                                                 BorderThickness="1"
                                                 BorderBrush="{DynamicResource BorderBrush}"
                                                 Background="{DynamicResource ContentBackground}"
                                                 Foreground="{DynamicResource TextPrimary}"
                                                 Padding="4,0"
                                                 VerticalAlignment="Center">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Return"
                                                            Command="{Binding DataContext.SendPlanContinueCommand, ElementName=ConversationPanelRoot}"/>
                                            </TextBox.InputBindings>
                                        </TextBox>
                                        <TextBlock Text=" 章"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>

                                    <Button Command="{Binding SendPlanContinueCommand}"
                                            DockPanel.Dock="Right"
                                            Padding="10,0"
                                            Height="24"
                                            Cursor="Hand"
                                            BorderThickness="0"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource PrimaryColor}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        BorderThickness="0"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryHover}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryActive}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="▶ 发送" FontSize="11" Foreground="White"/>
                                    </Button>

                                </DockPanel>

                                <DockPanel LastChildFill="False"
                                           Visibility="{Binding HasAgentActions, Converter={StaticResource BoolToVisibilityConverter}}">

                                    <Button Command="{Binding AgentRewriteCommand}"
                                            DockPanel.Dock="Left"
                                            Padding="10,0"
                                            Height="24"
                                            Cursor="Hand"
                                            BorderThickness="1"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource ContentBackground}"
                                            BorderBrush="{DynamicResource BorderBrush}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ActiveBackground}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="{Binding AgentRewriteLabel}" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                    </Button>

                                    <Button Command="{Binding AgentContinueCommand}"
                                            DockPanel.Dock="Right"
                                            Visibility="{Binding HasAgentContinue, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Padding="10,0"
                                            Height="24"
                                            Cursor="Hand"
                                            BorderThickness="0"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource PrimaryColor}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        BorderThickness="0"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryHover}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryActive}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="{Binding AgentContinueLabel}" FontSize="11" Foreground="White"/>
                                    </Button>

                                </DockPanel>

                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4"
                                Background="{DynamicResource Surface}"
                                CornerRadius="0,0,6,6"
                                Padding="4">
                            <Border Background="{DynamicResource ContentBackground}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <DockPanel>
                                    <Border Background="{DynamicResource SelectedBackground}"
                                            BorderThickness="0,0,0,1"
                                            Height="32"
                                            DockPanel.Dock="Top">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSending}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DataContext.CurrentMode, ElementName=ConversationPanelRoot}" Value="{x:Static modes:ChatMode.Ask}">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessColor}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DataContext.CurrentMode, ElementName=ConversationPanelRoot}" Value="{x:Static modes:ChatMode.Agent}">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource InfoColor}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DataContext.CurrentMode, ElementName=ConversationPanelRoot}" Value="{x:Static modes:ChatMode.Plan}">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource WarningColor}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel Orientation="Horizontal" 
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <controls:BreathingLight IsActive="True" 
                                                                      MinOpacity="1.0" MaxOpacity="1.0"
                                                                      EnableScale="True" MinScale="1.0" MaxScale="1.3">
                                                <TextBlock Text="●" FontSize="14">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.CurrentMode, ElementName=ConversationPanelRoot}" Value="{x:Static modes:ChatMode.Ask}">
                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.CurrentMode, ElementName=ConversationPanelRoot}" Value="{x:Static modes:ChatMode.Agent}">
                                                                    <Setter Property="Foreground" Value="{DynamicResource InfoColor}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.CurrentMode, ElementName=ConversationPanelRoot}" Value="{x:Static modes:ChatMode.Plan}">
                                                                    <Setter Property="Foreground" Value="{DynamicResource WarningColor}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </controls:BreathingLight>
                                            <controls:BreathingLight IsActive="True" MinOpacity="0.3" MaxOpacity="1.0">
                                                <TextBlock Text="天命正在思考..." Margin="8,0,0,0" 
                                                           Foreground="{DynamicResource TextSecondary}"/>
                                            </controls:BreathingLight>
                                        </StackPanel>
                                    </Border>

                                    <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Padding="12,12,12,4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <RichTextBox x:Name="InputBox"
                                                       Grid.Row="0"
                                                       MinHeight="60"
                                                       MaxHeight="200"
                                                       Background="Transparent"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       BorderThickness="0"
                                                       FontSize="13"
                                                       Padding="0"
                                                       AcceptsReturn="True"
                                                       VerticalScrollBarVisibility="Auto"
                                                       IsDocumentEnabled="True"
                                                       PreviewKeyDown="InputBox_OnPreviewKeyDown"
                                                       TextChanged="InputBox_OnTextChanged">
                                                <RichTextBox.Resources>
                                                    <Style TargetType="Paragraph">
                                                        <Setter Property="Margin" Value="0"/>
                                                    </Style>
                                                </RichTextBox.Resources>
                                                <FlowDocument>
                                                    <Paragraph/>
                                                </FlowDocument>
                                            </RichTextBox>

                                            <TextBlock x:Name="InputPlaceholder"
                                                       Grid.Row="0"
                                                       Text="输入消息... (输入 @ 可引用章节)"
                                                       Foreground="{DynamicResource TextTertiary}"
                                                       FontSize="13"
                                                       IsHitTestVisible="False"
                                                       VerticalAlignment="Top"
                                                       Margin="2,0,0,0"/>

                                            <chatcontrols:ReferenceDropdown x:Name="ReferenceDropdownControl" Grid.Row="0"/>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Background="Transparent"
                                            Padding="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal" 
                                                       HorizontalAlignment="Left">
                                                <ComboBox Width="75"
                                                          Style="{StaticResource ChatModeComboBoxStyle}"
                                                          SelectedValue="{Binding CurrentMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValuePath="Tag">
                                                    <ComboBoxItem Tag="{x:Static modes:ChatMode.Ask}">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <controls:BreathingLight IsActive="{Binding DataContext.IsGenerating, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                                      MinOpacity="0.3" MaxOpacity="1.0">
                                                                <TextBlock Text="◉" FontSize="12" FontWeight="Bold" 
                                                                           VerticalAlignment="Center" Foreground="{DynamicResource SuccessColor}"/>
                                                            </controls:BreathingLight>
                                                            <TextBlock Text="Ask" Margin="4,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ComboBoxItem>

                                                    <ComboBoxItem Tag="{x:Static modes:ChatMode.Agent}">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <controls:BreathingLight IsActive="{Binding DataContext.IsGenerating, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                                      MinOpacity="0.3" MaxOpacity="1.0">
                                                                <TextBlock Text="∞" FontSize="12" FontWeight="Bold" 
                                                                           VerticalAlignment="Center" Foreground="{DynamicResource InfoColor}"/>
                                                            </controls:BreathingLight>
                                                            <TextBlock Text="Agent" Margin="4,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ComboBoxItem>

                                                    <ComboBoxItem Tag="{x:Static modes:ChatMode.Plan}">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <controls:BreathingLight IsActive="{Binding DataContext.IsGenerating, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                                      MinOpacity="0.3" MaxOpacity="1.0">
                                                                <TextBlock Text="☰" FontSize="12" FontWeight="Bold" 
                                                                           VerticalAlignment="Center" Foreground="{DynamicResource WarningColor}"/>
                                                            </controls:BreathingLight>
                                                            <TextBlock Text="Plan" Margin="4,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ComboBoxItem>
                                                </ComboBox>

                                                <ComboBox x:Name="ModelComboBox"
                                                          Width="120"
                                                          HorizontalAlignment="Left"
                                                          Margin="2,0,0,0"
                                                          Style="{StaticResource CompactComboBoxStyle}"
                                                          ItemsSource="{Binding ModelConfigurations}"
                                                          SelectedItem="{Binding ActiveConfiguration, Mode=TwoWay}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="11"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>

                                                <Border x:Name="ContextUsageButton"
                                                        Margin="2,0,0,0"
                                                        Width="22" Height="22"
                                                        Background="{DynamicResource ContentBackground}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="11"
                                                        VerticalAlignment="Center"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="OnContextUsageClick"
                                                        MouseEnter="OnContextUsageMouseEnter"
                                                        MouseLeave="OnContextUsageMouseLeave">
                                                    <Grid>
                                                        <uihelpers:CircleProgress 
                                                            Width="18" Height="18"
                                                            Progress="{Binding ContextUsagePercent}"
                                                            StrokeColor="{Binding ContextUsageColor}"
                                                            StrokeThickness="2"/>
                                                        <TextBlock Text="{Binding ContextUsagePercentText, FallbackValue='0'}"
                                                                   FontSize="6"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <Popup x:Name="ContextUsagePopup"
                                                       PlacementTarget="{Binding ElementName=ContextUsageButton}"
                                                       Placement="Top"
                                                       StaysOpen="False"
                                                       AllowsTransparency="True">
                                                    <Border Background="{DynamicResource ContentBackground}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="12,10"
                                                            Margin="0,0,0,4">
                                                        <Border.Effect>
                                                            <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
                                                        </Border.Effect>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding ContextUsageDetailLine1}" FontSize="12" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                                            <TextBlock Text="压缩上限: 90%" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                                                            <TextBlock Text="{Binding ContextUsageStatusText}" FontSize="10" Foreground="{DynamicResource PrimaryColor}" Margin="0,4,0,0"
                                                                       Visibility="{Binding IsSessionCompressed, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding InputCharacterCount}"
                                                          FontSize="9"
                                                          Foreground="{DynamicResource TextTertiary}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,4,0"/>

                                                <controls:BreathingLight IsActive="{Binding IsGenerating}" 
                                                                          MinOpacity="0.3" MaxOpacity="1.0">
                                                    <Button Width="20" Height="20"
                                                            Background="Transparent"
                                                            BorderThickness="1.5"
                                                            Padding="0"
                                                            Cursor="Hand"
                                                            ToolTip="发送 (Enter)，换行 (Shift+Enter)">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Command" Value="{Binding SendCommand}"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="border"
                                                                                    Background="{TemplateBinding Background}"
                                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                                    CornerRadius="10"
                                                                                    Width="20"
                                                                                    Height="20">
                                                                                <Viewbox Width="10" Height="10">
                                                                                    <Canvas Width="24" Height="24">
                                                                                        <Rectangle x:Name="SquareIcon" Width="10" Height="10" StrokeThickness="2" Visibility="Collapsed" Canvas.Left="7" Canvas.Top="7"/>
                                                                                        <Path x:Name="ArrowIcon" Data="M12,6 L12,18 M8,10 L12,6 L16,10" StrokeThickness="2" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                                                    </Canvas>
                                                                                </Viewbox>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <DataTrigger Binding="{Binding DataContext.CurrentMode, ElementName=ConversationPanelRoot}" Value="{x:Static modes:ChatMode.Ask}">
                                                                                    <Setter TargetName="SquareIcon" Property="Stroke" Value="{DynamicResource SuccessColor}"/>
                                                                                    <Setter TargetName="ArrowIcon" Property="Stroke" Value="{DynamicResource SuccessColor}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding DataContext.CurrentMode, ElementName=ConversationPanelRoot}" Value="{x:Static modes:ChatMode.Agent}">
                                                                                    <Setter TargetName="SquareIcon" Property="Stroke" Value="{DynamicResource InfoColor}"/>
                                                                                    <Setter TargetName="ArrowIcon" Property="Stroke" Value="{DynamicResource InfoColor}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding DataContext.CurrentMode, ElementName=ConversationPanelRoot}" Value="{x:Static modes:ChatMode.Plan}">
                                                                                    <Setter TargetName="SquareIcon" Property="Stroke" Value="{DynamicResource WarningColor}"/>
                                                                                    <Setter TargetName="ArrowIcon" Property="Stroke" Value="{DynamicResource WarningColor}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsGenerating}" Value="True">
                                                                                    <Setter TargetName="SquareIcon" Property="Visibility" Value="Visible"/>
                                                                                    <Setter TargetName="ArrowIcon" Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DataContext.CurrentMode, ElementName=ConversationPanelRoot}" Value="{x:Static modes:ChatMode.Ask}">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessColor}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding DataContext.CurrentMode, ElementName=ConversationPanelRoot}" Value="{x:Static modes:ChatMode.Agent}">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource InfoColor}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding DataContext.CurrentMode, ElementName=ConversationPanelRoot}" Value="{x:Static modes:ChatMode.Plan}">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource WarningColor}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsGenerating}" Value="True">
                                                                        <Setter Property="Command" Value="{Binding CancelCommand}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </controls:BreathingLight>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    </Grid>
                                </DockPanel>
                            </Border>
                        </Border>
                    </Grid>
                </Border>
            </DockPanel>
        </Border>
</UserControl>
