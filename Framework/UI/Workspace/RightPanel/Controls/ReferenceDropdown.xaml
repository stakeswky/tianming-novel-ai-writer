<UserControl x:Class="TM.Framework.UI.Workspace.RightPanel.Controls.ReferenceDropdown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <Popup x:Name="DropdownPopup"
           PlacementTarget="{Binding PlacementTarget}"
           Placement="Top"
           StaysOpen="False"
           AllowsTransparency="True"
           IsOpen="{Binding IsOpen, Mode=TwoWay}">

        <Grid Margin="12">
            <Border MinWidth="240"
                    MaxWidth="320"
                    MaxHeight="160"
                    CornerRadius="12"
                    Background="{DynamicResource ContentBackground}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.25" Color="#000"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" 
                            Background="{DynamicResource Surface}"
                            CornerRadius="11,11,0,0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Height="28"
                            Padding="6,0">
                        <TextBox x:Name="SearchBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="12"
                                 Foreground="{DynamicResource TextPrimary}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <TextBlock Text="搜索引用..."
                                                               Foreground="{DynamicResource TextTertiary}"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding Text.Length, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource InverseCountToVisibilityConverter}}"/>
                                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>

                    <Border Grid.Row="1" CornerRadius="0,0,11,11" Background="Transparent">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="3,2">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding ReferenceTypes}"
                                              Visibility="{Binding ShowTypes, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectTypeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    HorizontalContentAlignment="Stretch"
                                                    Cursor="Hand"
                                                    Margin="3,1"
                                                    Height="30">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bg" Background="Transparent" 
                                                                CornerRadius="4" 
                                                                Padding="6,0">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <emoji:TextBlock Text="{Binding Icon}"
                                                                     FontSize="11"
                                                                     VerticalAlignment="Center"/>
                                                    <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12">
                                                        <Run Text="{Binding Type}" FontWeight="Medium" Foreground="{DynamicResource TextPrimary}"/>
                                                        <Run Text="：" Foreground="{DynamicResource TextSecondary}"/>
                                                        <Run Text="{Binding Description}" Foreground="{DynamicResource TextSecondary}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{Binding FilteredItems}"
                                              Visibility="{Binding ShowItems, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    HorizontalContentAlignment="Stretch"
                                                    Cursor="Hand"
                                                    Margin="3,1"
                                                    Height="30">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bg" Background="Transparent" 
                                                                CornerRadius="4" 
                                                                Padding="6,0">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="未找到匹配项"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextTertiary}"
                                           HorizontalAlignment="Center"
                                           Margin="0,20"
                                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Popup>
</UserControl>
