<UserControl x:Class="TM.Framework.UI.Workspace.RightPanel.Controls.ThinkingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:controls="clr-namespace:TM.Framework.Common.Controls">

    <Border Background="{DynamicResource ContentBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <emoji:TextBlock Text="💭" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="思考过程" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <controls:BreathingLight Grid.Column="1" 
                                          IsActive="{Binding IsThinking}" 
                                          MinOpacity="0.3" MaxOpacity="1.0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusIndicator" 
                                 Width="8" Height="8" 
                                 Fill="{DynamicResource WarningColor}"/>
                        <TextBlock Text="{Binding StatusText, FallbackValue='分析中...'}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </controls:BreathingLight>

                <Button Grid.Column="2"
                        Command="{Binding ToggleExpandCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Width="24" Height="24"
                        ToolTip="折叠/展开">
                    <Path x:Name="ExpandIcon"
                          Data="M4,6 L10,12 L16,6"
                          Stroke="{DynamicResource TextSecondary}"
                          StrokeThickness="1.5"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center">
                        <Path.RenderTransform>
                            <RotateTransform Angle="0" CenterX="10" CenterY="9"/>
                        </Path.RenderTransform>
                        <Path.Style>
                            <Style TargetType="Path">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <RotateTransform Angle="180" CenterX="10" CenterY="9"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          MaxHeight="200">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <ItemsControl ItemsSource="{Binding ThinkingSteps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,4" Padding="8,6"
                                    Background="{DynamicResource Surface}"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <emoji:TextBlock Grid.Column="0"
                                                     Text="{Binding Icon}"
                                                     FontSize="12"
                                                     VerticalAlignment="Top"
                                                     Margin="0,2,8,0"/>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="12"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{Binding Detail}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"
                                                   Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="2"
                       Text="{Binding ElapsedTimeText, FallbackValue='耗时: 0.0s'}"
                       FontSize="10"
                       Foreground="{DynamicResource TextTertiary}"
                       HorizontalAlignment="Right"
                       Margin="0,8,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Border>
</UserControl>
