<UserControl x:Class="TM.Framework.UI.Workspace.Common.Controls.GenerationParamsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="{DynamicResource ContentBackground}" 
            CornerRadius="0,0,12,12" 
            Padding="12,8,12,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="调整长卷一致性引擎的注入参数，影响 AI 生成时可见的上下文范围。默认值已针对万章小说优化。"
                       Foreground="{DynamicResource TextSecondary}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <Border Background="{DynamicResource Surface}" 
                            CornerRadius="6" 
                            Padding="16,10,16,10" 
                            Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="活跃窗口" 
                                       FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="实体活跃窗口（章）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="距当前章N章内的实体视为活跃，注入快照" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding ActiveEntityWindowChapters, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="活跃实体上限（条）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="每次注入最多N条活跃实体，防止token膨胀" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding ActiveEntityWindowMaxCount, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="近期摘要窗口（章）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="注入最近N章摘要作为前情回顾" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding SummaryRecentWindowCount, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="前情摘要加载上限（章）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="从摘要库加载的前史章节数上限（A/B模式共用）" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding PreviousSummaryCount, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource Surface}" 
                            CornerRadius="6" 
                            Padding="16,10,16,10" 
                            Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="里程碑" 
                                       FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="锚点间隔（章）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="每隔N章取一个内部里程碑锚点" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding MilestoneAnchorInterval, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="卷里程碑字数上限" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="每卷里程碑摘要最大字符数" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding VolumeMilestoneMaxChars, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="卷尾近期章数" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="卷末里程碑保留最近N章的详细记录" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding VolumeMilestoneTailRecentCount, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource Surface}" 
                            CornerRadius="6" 
                            Padding="16,10,16,10" 
                            Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="跨卷注入" 
                                       FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="里程碑前卷数" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="注入最近N卷的里程碑摘要" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding MilestoneMaxPreviousVolumes, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="存档前卷数" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="注入最近N卷的结构化事实存档" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding ArchiveMaxPreviousVolumes, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource Surface}" 
                            CornerRadius="6" 
                            Padding="16,10,16,10" 
                            Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="快照注入上限" 
                                       FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="势力注入上限（条）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="快照中注入的势力状态最大条数" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding SnapshotMaxFactionInject, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="物品注入上限（条）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="快照中注入的物品状态最大条数" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding SnapshotMaxItemInject, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="时间线注入上限（条）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="快照中注入的近期时间线条数（与存档时间线上限独立控制）" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding SnapshotMaxTimelineInject, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="存档物品上限（条）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="跨卷存档注入的物品状态最大条数（独立于快照物品上限）" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding ArchiveInjectMaxItemStates, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="存档角色上限（条）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="跨卷存档注入的角色状态最大条数" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding ArchiveInjectMaxCharacterStates, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="存档冲突上限（条）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="跨卷存档注入的冲突进度最大条数" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding ArchiveInjectMaxConflictProgress, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="字段字符上限" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="存档注入时每个字段的最大字符数" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding ArchiveInjectMaxFieldChars, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="存档伏笔上限（条）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="跨卷存档注入的未解伏笔最大条数（逾期/已埋设优先）" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding ArchiveInjectMaxForeshadowingStatus, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="存档时间线上限（条）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="跨卷存档注入的时间线条目最大数" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding ArchiveInjectMaxTimelineEntries, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="存档角色位置上限（条）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="跨卷存档注入的角色位置记录最大条数" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding ArchiveInjectMaxCharacterLocations, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="存档势力状态上限（条）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="跨卷存档注入的势力状态最大条数" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding ArchiveInjectMaxFactionStates, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>

                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="存档地点状态上限（条）" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <TextBlock Text="跨卷存档注入的地点状态最大条数" Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding ArchiveInjectMaxLocationStates, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{DynamicResource StandardTextBoxStyle}" Height="30" VerticalContentAlignment="Center" HorizontalAlignment="Right" Width="70"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" 
                    Background="{DynamicResource Surface}" 
                    CornerRadius="6" 
                    Padding="12,8" 
                    Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="128K" 
                                Command="{Binding Preset128KCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                MinWidth="52" Padding="8,5" FontSize="12"
                                Margin="0,0,6,0"
                                ToolTip="标准模型（GPT-4 / Claude 3.5 等）"/>
                        <Button Content="256K" 
                                Command="{Binding Preset256KCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                MinWidth="52" Padding="8,5" FontSize="12"
                                Margin="0,0,6,0"
                                ToolTip="大上下文模型（Claude Sonnet / Gemini Pro 等）"/>
                        <Button Content="1M+" 
                                Command="{Binding Preset1MCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                MinWidth="52" Padding="8,5" FontSize="12"
                                Margin="0,0,0,0"
                                ToolTip="超大上下文模型（Gemini 1.5/2.0 / GPT-5 等）"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource SuccessColor}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Button Grid.Column="2" 
                            Content="恢复默认" 
                            Command="{Binding ResetCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            MinWidth="80" Padding="14,6"
                            Margin="0,0,10,0"/>
                    <Button Grid.Column="3" 
                            Content="保存" 
                            Command="{Binding SaveCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            MinWidth="80" Padding="14,6"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
