<UserControl x:Class="TM.Framework.UI.Workspace.Common.Controls.ProjectSpecPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <Border Background="{DynamicResource ContentBackground}" 
            CornerRadius="0,0,12,12" 
            Padding="12,8,12,8">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="{DynamicResource Surface}" 
                        CornerRadius="6" 
                        Padding="12" 
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="📋 使用模板" 
                                   VerticalAlignment="Center" 
                                    Margin="0,0,12,0"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding TemplateNames}"
                                  SelectedItem="{Binding SelectedTemplateName}"
                                  VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="2"
                                    Orientation="Vertical"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Margin="12,0,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="重置默认" 
                                        Command="{Binding ResetCommand}"
                                        Style="{DynamicResource SecondaryButtonStyle}"
                                        Margin="0,0,12,0"/>
                                <Button Content="保存设置" 
                                        Command="{Binding SaveCommand}"
                                        Style="{DynamicResource PrimaryButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Grid.ColumnSpan="3"
                                   Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource SuccessColor}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,0,-18"
                                   Panel.ZIndex="10"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Border>

                <TextBlock Text="配置项目级别的写作风格和约束，所有章节生成时都会遵循这些规格。"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>

                <Border Background="{DynamicResource Surface}" 
                        CornerRadius="6" 
                        Padding="16,10,16,10" 
                        Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock Text="写作风格" 
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="100"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*" MinWidth="120"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*" MinWidth="100"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="风格偏好" 
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="12"
                                           Margin="0,0,0,6"/>
                                <ComboBox SelectedValue="{Binding WritingStyle}"
                                          SelectedValuePath="Content">
                                    <ComboBoxItem Content="流畅自然"/>
                                    <ComboBoxItem Content="热血激昂"/>
                                    <ComboBoxItem Content="飘逸洒脱"/>
                                    <ComboBoxItem Content="沉稳内敛"/>
                                    <ComboBoxItem Content="爽快明快"/>
                                    <ComboBoxItem Content="细腻温柔"/>
                                    <ComboBoxItem Content="典雅古韵"/>
                                    <ComboBoxItem Content="瑰丽奇幻"/>
                                    <ComboBoxItem Content="豪迈洒脱"/>
                                    <ComboBoxItem Content="理性冷峻"/>
                                    <ComboBoxItem Content="严谨缜密"/>
                                    <ComboBoxItem Content="厚重深沉"/>
                                    <ComboBoxItem Content="铁血硬朗"/>
                                    <ComboBoxItem Content="诡异惊悚"/>
                                    <ComboBoxItem Content="轻松幽默"/>
                                    <ComboBoxItem Content="朴实真挚"/>
                                    <ComboBoxItem Content="精炼紧凑"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="叙事视角" 
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="12"
                                           Margin="0,0,0,6"/>
                                <ComboBox SelectedValue="{Binding Pov}"
                                          SelectedValuePath="Content">
                                    <ComboBoxItem Content="第一人称"/>
                                    <ComboBoxItem Content="第三人称限知"/>
                                    <ComboBoxItem Content="第三人称全知"/>
                                    <ComboBoxItem Content="多视角"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="语气基调" 
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="12"
                                           Margin="0,0,0,6"/>
                                <ComboBox SelectedValue="{Binding Tone}"
                                          SelectedValuePath="Content">
                                    <ComboBoxItem Content="平衡"/>
                                    <ComboBoxItem Content="紧张悬疑"/>
                                    <ComboBoxItem Content="温馨治愈"/>
                                    <ComboBoxItem Content="冷峻客观"/>
                                    <ComboBoxItem Content="轻松诙谐"/>
                                    <ComboBoxItem Content="平和深沉"/>
                                    <ComboBoxItem Content="热血激昂"/>
                                    <ComboBoxItem Content="侠义豪情"/>
                                    <ComboBoxItem Content="史诗宏大"/>
                                    <ComboBoxItem Content="缠绵悱恻"/>
                                    <ComboBoxItem Content="严肃深沉"/>
                                    <ComboBoxItem Content="豪迈悲壮"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface}" 
                        CornerRadius="6" 
                        Padding="16,10,16,10" 
                        Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock Text="格式约束" 
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="目标字数" 
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="12"
                                           Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding TargetWordCount, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalContentAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="字" 
                                               VerticalAlignment="Center"
                                               Margin="6,0,0,0"
                                               Foreground="{DynamicResource TextSecondary}"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="段落长度" 
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="12"
                                           Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding ParagraphLength, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalContentAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="字/段" 
                                               VerticalAlignment="Center"
                                               Margin="6,0,0,0"
                                               Foreground="{DynamicResource TextSecondary}"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="对话比例" 
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="12"
                                           Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid VerticalAlignment="Center">
                                        <Slider Minimum="0" Maximum="100" 
                                                Value="{Binding DialogueRatioPercent}"/>
                                        <TextBlock Text="{Binding DialogueRatioPercent, StringFormat={}{0:F0}%}" 
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="11"
                                                   IsHitTestVisible="False"/>
                                    </Grid>
                                    <TextBox Grid.Column="1" 
                                             Text="{Binding DialogueRatioPercent, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F0}}"
                                             VerticalContentAlignment="Center"
                                             HorizontalContentAlignment="Center"
                                             Margin="6,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface}" 
                        CornerRadius="6" 
                        Padding="16,10,16,10" 
                        Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock Text="内容约束" 
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="必须包含的元素（用逗号分隔）" 
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="12"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding MustIncludeText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="40"
                                 MaxHeight="80"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="必须避免的内容（用逗号分隔）" 
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="12"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding MustAvoidText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="40"
                                 MaxHeight="80"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface}" 
                        CornerRadius="6" 
                        Padding="16,10,16,10" 
                        Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="润色模式" 
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="关闭：直接落盘，速度最快&#x0a;一次润色：语言级兜底，推荐&#x0a;二次润色：时间约增加一倍，更接近人工写作" 
                                       Foreground="{DynamicResource TextTertiary}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>

                            <ComboBox Grid.Column="1"
                                      SelectedIndex="{Binding PolishMode, Mode=TwoWay}"
                                      Width="120"
                                      VerticalAlignment="Center">
                                <ComboBoxItem Content="关闭润色"/>
                                <ComboBoxItem Content="一次润色"/>
                                <ComboBoxItem Content="二次润色"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
