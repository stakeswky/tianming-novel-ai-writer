<UserControl x:Class="TM.Framework.UI.Workspace.Common.Controls.ProjectSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <Grid>
        <Button x:Name="ProjectButton"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Click="OnProjectButtonClick"
                Padding="8,4">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <emoji:TextBlock Grid.Column="0" 
                                             Text="📁" 
                                             FontSize="14"
                                             VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding CurrentProjectName, FallbackValue='选择项目'}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"
                                       Margin="6,0"
                                       MaxWidth="120"
                                       TextTrimming="CharacterEllipsis"/>

                            <Path Grid.Column="2"
                                  Data="M0,0 L4,4 L8,0"
                                  Stroke="{DynamicResource TextSecondary}"
                                  StrokeThickness="1.5"
                                  VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBackground}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Popup x:Name="ProjectPopup"
               PlacementTarget="{Binding ElementName=ProjectButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Background="{DynamicResource ContentBackground}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    MinWidth="200"
                    MaxWidth="300"
                    MaxHeight="400"
                    Margin="0,4,0,0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox Grid.Row="0"
                             ItemsSource="{Binding Projects}"
                             SelectedItem="{Binding SelectedProject}"
                             Background="Transparent"
                             BorderThickness="0"
                             MaxHeight="300">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bg" 
                                                    Background="Transparent"
                                                    Cursor="Hand"
                                                    Padding="12,10">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SelectedBackground}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="12"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    </StackPanel>

                                    <emoji:TextBlock Grid.Column="1"
                                                     Text="✓"
                                                     FontSize="12"
                                                     Foreground="{DynamicResource SuccessColor}"
                                                     VerticalAlignment="Center"
                                                     Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="1"
                            Background="{DynamicResource Surface}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="8,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Command="{Binding ManageProjectsCommand}"
                                    ToolTip="项目信息"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Width="28" Height="28"
                                    Cursor="Hand">
                                <emoji:TextBlock Text="⚙️" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
