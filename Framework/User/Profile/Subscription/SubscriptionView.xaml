<UserControl x:Class="TM.Framework.User.Profile.Subscription.SubscriptionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:visibility="clr-namespace:TM.Framework.Common.Converters.Visibility"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:local="clr-namespace:TM.Framework.User.Profile.Subscription">

    <UserControl.Resources>
        <ResourceDictionary>

            <visibility:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <visibility:BoolToVisibilityConverter x:Key="InverseBoolConverter" IsInverted="True"/>
            <local:BoolToActivatingTextConverter x:Key="BoolToActivatingTextConverter"/>
            <local:ZeroToVisibleConverter x:Key="ZeroToVisibleConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <layout:IconHeaderGroupBox Grid.Row="0" Icon="👤" Title="会员状态" Margin="0,0,0,5">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{Binding PlanTypeDisplay}" 
                                   FontSize="22" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <Border Background="{Binding StatusColor}" 
                                CornerRadius="4" 
                                Padding="8,4" 
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusText}" 
                                       Foreground="White" 
                                       FontSize="12"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="到期时间：" 
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding EndTimeText}" 
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="13"
                                   FontWeight="Medium"/>
                        <TextBlock Text=" | " 
                                   Foreground="{DynamicResource TextTertiary}"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding RemainingDaysText}" 
                                   Foreground="{DynamicResource PrimaryColor}"
                                   FontSize="13"
                                   FontWeight="Medium"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" 
                        Content="刷新" 
                        Command="{Binding RefreshCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Width="80"
                        Height="36"
                        VerticalAlignment="Center"/>
            </Grid>
        </layout:IconHeaderGroupBox>

        <layout:IconHeaderGroupBox Grid.Row="1" Icon="🎁" Title="套餐权益" Margin="0,0,0,5">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="16"
                        Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="免费版" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="¥0" 
                                   FontSize="24" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="• 基础功能" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,4"/>
                        <TextBlock Text="• 本地存储" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,4"/>
                        <TextBlock Text="• 社区支持" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,4"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" 
                        BorderBrush="{DynamicResource PrimaryColor}" 
                        BorderThickness="2" 
                        CornerRadius="8" 
                        Padding="16"
                        Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="基础版" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryColor}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="¥0" 
                                   FontSize="24" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryColor}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="• 全部基础功能" Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,4"/>
                        <TextBlock Text="• 云端同步" Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,4"/>
                        <TextBlock Text="• AI 辅助写作" Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,4"/>
                        <TextBlock Text="• 邮件支持" Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,4"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" 
                        BorderBrush="{DynamicResource WarningColor}" 
                        BorderThickness="2" 
                        CornerRadius="8" 
                        Padding="16"
                        Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="专业版" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningColor}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="¥0" 
                                   FontSize="24" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource WarningColor}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="• 全部基础版功能" Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,4"/>
                        <TextBlock Text="• 多项目管理" Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,4"/>
                        <TextBlock Text="• 高级模板库" Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,4"/>
                        <TextBlock Text="• 优先客服支持" Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,4"/>
                    </StackPanel>
                </Border>
            </Grid>
        </layout:IconHeaderGroupBox>

        <layout:IconHeaderGroupBox Grid.Row="2" Icon="🔑" Title="续费卡密" Margin="0,0,0,5">
            <StackPanel Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding CardKey, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource StandardTextBoxStyle}"
                             FontSize="14"
                             Height="40"
                             Padding="12,0"
                             VerticalContentAlignment="Center"
                             Margin="0,0,12,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding ActivateCardKeyCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="1"
                            Content="{Binding IsActivating, Converter={StaticResource BoolToActivatingTextConverter}, FallbackValue=续费}"
                            Command="{Binding ActivateCardKeyCommand}"
                            IsEnabled="{Binding IsActivating, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Width="100"
                            Height="40"/>
                </Grid>

                <TextBlock Text="请输入16-32位卡密，续费后立即生效" 
                           FontSize="12" 
                           Foreground="{DynamicResource TextTertiary}"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </layout:IconHeaderGroupBox>

        <layout:IconHeaderGroupBox Grid.Row="3" Icon="📋" Title="续费记录" ShowCount="True" Count="{Binding ActivationHistory.Count}" VerticalAlignment="Stretch">
            <Grid Margin="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ActivationHistory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}" 
                                        BorderThickness="0,0,0,1" 
                                        Padding="0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" 
                                                   Text="{Binding CardKey}" 
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontFamily="Consolas"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding DurationDays, StringFormat=+{0}天}" 
                                                   Foreground="{DynamicResource SuccessColor}"
                                                   FontWeight="Medium"
                                                   Margin="0,0,16,0"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding ActivatedTime, StringFormat=yyyy-MM-dd HH:mm}" 
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Text="暂无激活记录" 
                           Foreground="{DynamicResource TextTertiary}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding ActivationHistory.Count, Converter={StaticResource ZeroToVisibleConverter}, FallbackValue=Visible}"/>
            </Grid>
        </layout:IconHeaderGroupBox>
    </Grid>
</UserControl>
