<UserControl x:Class="TM.Framework.User.Profile.BasicInfo.BasicInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="5">
            <common:IconHeaderGroupBox Icon="📝" Title="基本信息" Style="{StaticResource StandardGroupBoxStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.RowSpan="5" VerticalAlignment="Center">
                        <Border Width="60" Height="60" 
                                Background="{DynamicResource ContentHighlight}"
                                CornerRadius="30"
                                Margin="0,0,0,10">
                            <Border.Clip>
                                <EllipseGeometry Center="30,30" RadiusX="30" RadiusY="30"/>
                            </Border.Clip>
                            <Image x:Name="AvatarImage" 
                                   Source="{Binding AvatarPath}" 
                                   Stretch="UniformToFill"/>
                        </Border>
                        <Button Command="{Binding UploadAvatarCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="80"
                                FontSize="12"
                                Padding="5,3">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <emoji:TextBlock Text="📷" FontSize="12" Margin="0,0,3,0"/>
                                    <TextBlock Text="换头像" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button.Content>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <emoji:TextBlock Text="🆔" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="用户名" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Grid.Row="0" Grid.Column="4" 
                             Text="{Binding Username}" 
                             IsReadOnly="True"
                             Background="{DynamicResource ContentHighlight}"
                             Style="{StaticResource StandardTextBoxStyle}"/>

                    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <emoji:TextBlock Text="👤" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="真实姓名" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Grid.Row="2" Grid.Column="4" 
                             Text="{Binding RealName, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource StandardTextBoxStyle}"/>

                    <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <emoji:TextBlock Text="⚧️" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="性别" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ComboBox Grid.Row="4" Grid.Column="4" 
                              ItemsSource="{Binding GenderOptions}"
                              SelectedItem="{Binding Gender}"
                              Style="{StaticResource StandardComboBoxStyle}"/>
                </Grid>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📞" Title="联系方式" Style="{StaticResource StandardGroupBoxStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <emoji:TextBlock Text="📧" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="邮箱" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Grid.Row="0" Grid.Column="2" 
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource StandardTextBoxStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" 
                               Text="{Binding EmailError}" 
                               Foreground="{DynamicResource DangerColor}"
                               FontSize="12"
                               Margin="0,2,0,0"
                               Visibility="{Binding HasEmailError, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <emoji:TextBlock Text="📱" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="手机号" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Grid.Row="3" Grid.Column="2" 
                             Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource StandardTextBoxStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" 
                               Text="{Binding PhoneError}" 
                               Foreground="{DynamicResource DangerColor}"
                               FontSize="12"
                               Margin="0,2,0,0"
                               Visibility="{Binding HasPhoneError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🌏" Title="地区信息" Style="{StaticResource StandardGroupBoxStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <emoji:TextBlock Text="🌏" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="国家" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ComboBox Grid.Row="0" Grid.Column="2" 
                              ItemsSource="{Binding CountryList}"
                              SelectedItem="{Binding Country}"
                              Style="{StaticResource StandardComboBoxStyle}"/>

                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <emoji:TextBlock Text="📍" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="省份" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ComboBox Grid.Row="2" Grid.Column="2" 
                              ItemsSource="{Binding ProvinceList}"
                              SelectedItem="{Binding Province}"
                              Style="{StaticResource StandardComboBoxStyle}"/>

                    <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <emoji:TextBlock Text="🏙️" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="城市" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Grid.Row="4" Grid.Column="2" 
                             Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource StandardTextBoxStyle}"/>
                </Grid>
            </common:IconHeaderGroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Command="{Binding ImportDataCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="120" Margin="0,0,10,0">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="📥" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="导入资料" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
                <Button Command="{Binding ExportDataCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="120" Margin="0,0,10,0">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="📤" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="导出资料" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
                <Button Command="{Binding ResetCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="100" Margin="0,0,10,0"
                        helpers:ButtonHelper.ConfirmMessage="确定要重置吗？未保存的修改将丢失！"
                        helpers:ButtonHelper.ConfirmTitle="确认重置">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="🔄" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="重置" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
                <Button Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="120">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="💾" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="保存更改" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
