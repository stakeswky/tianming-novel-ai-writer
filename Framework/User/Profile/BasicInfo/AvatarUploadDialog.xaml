<Window x:Class="TM.Framework.User.Profile.BasicInfo.AvatarUploadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Width="650"
        Height="580">

    <Border Style="{DynamicResource StandardDialogBorderStyle}" Margin="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource StandardDialogTitleBarStyle}" 
                    MouseLeftButtonDown="TitleBar_MouseDown" Padding="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <emoji:TextBlock Text="📷" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock Text="上传头像" Style="{DynamicResource StandardDialogTitleTextStyle}"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" 
                         VerticalScrollBarVisibility="Auto" 
                         Margin="20,20,20,0">
                <StackPanel>
                    <layout:IconHeaderGroupBox Icon="👁️" Title="预览" Margin="0,0,0,15">
                        <Border Width="150" Height="150" 
                                Background="{DynamicResource Surface}"
                                CornerRadius="75"
                                HorizontalAlignment="Center">
                            <Border.Clip>
                                <EllipseGeometry Center="75,75" RadiusX="75" RadiusY="75"/>
                            </Border.Clip>
                            <Image x:Name="PreviewImage" Stretch="UniformToFill"/>
                        </Border>
                    </layout:IconHeaderGroupBox>

                    <layout:IconHeaderGroupBox Icon="📁" Title="本地上传" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="支持格式：JPG、PNG、BMP" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource TextSecondary}" 
                                       Margin="0,0,0,10"/>
                            <Button Content="📁 选择图片" 
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Click="SelectImage_Click"
                                    HorizontalAlignment="Left"
                                    Width="120"/>
                        </StackPanel>
                    </layout:IconHeaderGroupBox>

                    <layout:IconHeaderGroupBox Icon="🎨" Title="预设头像">
                        <UniformGrid Columns="5" Rows="2">
                            <Button x:Name="PresetAvatar1" Click="PresetAvatar_Click" Style="{DynamicResource SecondaryButtonStyle}" Margin="5">
                                <emoji:TextBlock Text="📷" FontSize="32"/>
                            </Button>
                            <Button x:Name="PresetAvatar2" Click="PresetAvatar_Click" Style="{DynamicResource SecondaryButtonStyle}" Margin="5">
                                <emoji:TextBlock Text="👤" FontSize="32"/>
                            </Button>
                            <Button x:Name="PresetAvatar3" Click="PresetAvatar_Click" Style="{DynamicResource SecondaryButtonStyle}" Margin="5">
                                <emoji:TextBlock Text="🎨" FontSize="32"/>
                            </Button>
                            <Button x:Name="PresetAvatar4" Click="PresetAvatar_Click" Style="{DynamicResource SecondaryButtonStyle}" Margin="5">
                                <emoji:TextBlock Text="🌟" FontSize="32"/>
                            </Button>
                            <Button x:Name="PresetAvatar5" Click="PresetAvatar_Click" Style="{DynamicResource SecondaryButtonStyle}" Margin="5">
                                <emoji:TextBlock Text="💼" FontSize="32"/>
                            </Button>
                            <Button x:Name="PresetAvatar6" Click="PresetAvatar_Click" Style="{DynamicResource SecondaryButtonStyle}" Margin="5">
                                <emoji:TextBlock Text="🎯" FontSize="32"/>
                            </Button>
                            <Button x:Name="PresetAvatar7" Click="PresetAvatar_Click" Style="{DynamicResource SecondaryButtonStyle}" Margin="5">
                                <emoji:TextBlock Text="🚀" FontSize="32"/>
                            </Button>
                            <Button x:Name="PresetAvatar8" Click="PresetAvatar_Click" Style="{DynamicResource SecondaryButtonStyle}" Margin="5">
                                <emoji:TextBlock Text="💎" FontSize="32"/>
                            </Button>
                            <Button x:Name="PresetAvatar9" Click="PresetAvatar_Click" Style="{DynamicResource SecondaryButtonStyle}" Margin="5">
                                <emoji:TextBlock Text="🔥" FontSize="32"/>
                            </Button>
                            <Button x:Name="PresetAvatar10" Click="PresetAvatar_Click" Style="{DynamicResource SecondaryButtonStyle}" Margin="5">
                                <emoji:TextBlock Text="⚡" FontSize="32"/>
                            </Button>
                        </UniformGrid>
                    </layout:IconHeaderGroupBox>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" 
                       Orientation="Horizontal" 
                       HorizontalAlignment="Right" 
                       Margin="20,15,20,20">
                <Button Content="取消" 
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Click="Cancel_Click" 
                        Width="100" 
                        Margin="0,0,10,0"/>
                <Button Content="确定" 
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Click="Confirm_Click" 
                        Width="100"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
