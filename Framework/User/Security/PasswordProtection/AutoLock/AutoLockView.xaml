<UserControl x:Class="TM.Framework.User.Security.PasswordProtection.AutoLock.AutoLockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <TextBlock Text="自动锁定" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

            <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource PrimaryColor}" 
                    BorderThickness="2" CornerRadius="8" Padding="5" Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock Text="距离自动锁定" FontSize="14" Foreground="{DynamicResource TextSecondary}" 
                                   HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding RemainingTime}" FontSize="48" FontWeight="Bold" 
                                   Foreground="{Binding CountdownColor, Converter={StaticResource ResourceKeyToDynamicResourceConverter}}" 
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderBrush}" Margin="0,10"/>

                    <Grid Grid.Row="2" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="上次活动时间：" Foreground="{DynamicResource TextSecondary}" 
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding LastActivityTime}" Foreground="{DynamicResource TextPrimary}" 
                                   FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="⏱️" Title="自动锁定设置" TitleFontWeight="SemiBold">
                <StackPanel>
                    <CheckBox Content="启用自动锁定" 
                              IsChecked="{Binding EnableAutoLock, Mode=TwoWay}"
                              Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,15"/>

                    <TextBlock Text="启用后，应用将在无操作一段时间后自动锁定" 
                               Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,0"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="⏲️" Title="锁定时间" TitleFontWeight="SemiBold" IsEnabled="{Binding AutoLockOptionsEnabled}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="无操作" VerticalAlignment="Center" 
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,10,0"/>
                        <ComboBox Grid.Column="1" Style="{DynamicResource StandardComboBoxStyle}"
                                  ItemsSource="{Binding AvailableMinutes}"
                                  SelectedItem="{Binding AutoLockMinutes, Mode=TwoWay}"/>
                        <TextBlock Grid.Column="2" Text="分钟后自动锁定" VerticalAlignment="Center" 
                                   Foreground="{DynamicResource TextPrimary}" Margin="10,0,0,0"/>
                    </Grid>
                    <TextBlock Text="建议设置为5-15分钟，平衡安全性和便利性" 
                               Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,10,0,0"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="🚀" Title="快捷操作" TitleFontWeight="SemiBold">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="🔒 立即锁定" 
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Command="{Binding LockNowCommand}"/>

                        <Button Grid.Column="2" Content="🔄 重置计时" 
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Command="{Binding ResetTimerCommand}"
                                IsEnabled="{Binding AutoLockOptionsEnabled}"/>
                    </Grid>
                    <TextBlock Text="立即锁定：马上触发锁定屏幕 | 重置计时：从当前时间重新开始计时" 
                               Foreground="{DynamicResource TextTertiary}" FontSize="12" Margin="0,10,0,0"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="📊" Title="锁定统计" TitleFontWeight="SemiBold" Visibility="{Binding EnableAutoLock, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <emoji:TextBlock Text="🔒" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="{Binding RecentLockCount}" FontSize="32" FontWeight="Bold" 
                                       Foreground="{DynamicResource PrimaryColor}" HorizontalAlignment="Center"/>
                            <TextBlock Text="本周自动锁定次数" FontSize="13" Foreground="{DynamicResource TextSecondary}" 
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="💾 保存设置" Style="{DynamicResource PrimaryButtonStyle}" 
                        Command="{Binding SaveSettingsCommand}" MinWidth="120"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>

