<UserControl x:Class="TM.Framework.User.Security.PasswordProtection.PasswordLock.PasswordLockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <common:IconHeaderGroupBox Icon="🔐" Title="密码状态" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding PasswordStatusText}" 
                                       Foreground="{Binding PasswordStatusColor, Converter={StaticResource ResourceKeyToDynamicResourceConverter}}"
                                       VerticalAlignment="Center" FontSize="14"/>
                            <TextBlock Text="  |  强度：" 
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center" FontSize="14"
                                       Visibility="{Binding HasPassword, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding PasswordStrength}" 
                                       Foreground="{Binding PasswordStrengthColor, Converter={StaticResource ResourceKeyToDynamicResourceConverter}}"
                                       VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                                       Visibility="{Binding HasPassword, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                        <TextBlock Text="提示：启用密码锁定前需要先设置应用密码" 
                                   Foreground="{DynamicResource TextTertiary}" FontSize="12" Margin="0,10,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="⚙️ 设置密码" 
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Command="{Binding SetPasswordCommand}" 
                            MinWidth="120" VerticalAlignment="Top"/>
                </Grid>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📊" Title="本周统计" Margin="0,0,0,20"
                    Visibility="{Binding HasPassword, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                        <emoji:TextBlock Text="🔒" FontSize="20" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <StackPanel>
                            <TextBlock Text="{Binding WeekLockCount}" FontSize="24" FontWeight="Bold" 
                                       Foreground="{DynamicResource PrimaryColor}" HorizontalAlignment="Center"/>
                            <TextBlock Text="锁定次数" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <emoji:TextBlock Text="❌" FontSize="20" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <StackPanel>
                            <TextBlock Text="{Binding WeekFailureCount}" FontSize="24" FontWeight="Bold" 
                                       Foreground="{DynamicResource DangerColor}" HorizontalAlignment="Center"/>
                            <TextBlock Text="失败次数" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="⚡" Title="快捷设置" TitleFontWeight="SemiBold" Visibility="{Binding HasPassword, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="一键应用推荐配置：" 
                               Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,15"/>

                    <UniformGrid Columns="3" Rows="1">
                        <Button Content="🛡️ 高安全" 
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Command="{Binding QuickSetupCommand}"
                                CommandParameter="high_security"
                                Margin="0,0,5,0"
                                ToolTip="启动锁定 + 切换锁定 + 5分钟自动锁定"/>

                        <Button Content="⚖️ 平衡" 
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Command="{Binding QuickSetupCommand}"
                                CommandParameter="balanced"
                                Margin="5,0,5,0"
                                ToolTip="启动锁定 + 15分钟自动锁定"/>

                        <Button Content="🚀 便利" 
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Command="{Binding QuickSetupCommand}"
                                CommandParameter="convenient"
                                Margin="5,0,0,0"
                                ToolTip="仅启动锁定"/>
                    </UniformGrid>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="🔒" Title="密码锁定设置" TitleFontWeight="SemiBold">
                <StackPanel>
                    <CheckBox Content="启用密码锁定" 
                              IsChecked="{Binding EnablePasswordLock, Mode=TwoWay}"
                              Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,15"/>

                    <TextBlock Text="启用后，应用将在以下情况下要求输入密码：" 
                               Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,10"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="⏱️" Title="锁定时机" TitleFontWeight="SemiBold" IsEnabled="{Binding LockOptionsEnabled}">
                <StackPanel>
                    <CheckBox Content="应用启动时锁定" 
                              IsChecked="{Binding LockOnStartup, Mode=TwoWay}"
                              Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>
                    <TextBlock Text="每次启动应用时都需要输入密码才能使用" 
                               Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="20,0,0,15"/>

                    <CheckBox Content="窗口切换时锁定" 
                              IsChecked="{Binding LockOnSwitch, Mode=TwoWay}"
                              Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>
                    <TextBlock Text="当应用失去焦点后再次获得焦点时需要输入密码" 
                               Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="20,0,0,0"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="🔑" Title="紧急解锁码" TitleFontWeight="SemiBold" Visibility="{Binding HasPassword, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="紧急解锁码可在忘记密码时使用，使用后自动失效" 
                               Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,15"/>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding HasEmergencyCode, Converter={StaticResource BoolToVisibilityConverter}}" 
                                   Foreground="{DynamicResource SuccessColor}" 
                                   VerticalAlignment="Center" FontSize="14" Margin="0,0,10,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="❌ 未设置"/>
                                    <Setter Property="Foreground" Value="{DynamicResource DangerColor}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasEmergencyCode}" Value="True">
                                            <Setter Property="Text" Value="✅ 已设置"/>
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Button Content="🔑 设置紧急解锁码" 
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Command="{Binding SetEmergencyCodeCommand}" 
                                MinWidth="140"/>
                    </StackPanel>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="🧪" Title="测试功能" TitleFontWeight="SemiBold">
                <StackPanel>
                    <TextBlock Text="点击下方按钮可以立即触发锁定屏幕，测试密码验证功能" 
                               Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,15"/>
                    <Button Content="🔒 测试锁定" 
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Command="{Binding TestLockCommand}" 
                            MinWidth="120" HorizontalAlignment="Left"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="💾 保存设置" Style="{DynamicResource PrimaryButtonStyle}" 
                        Command="{Binding SaveSettingsCommand}" MinWidth="120"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>

