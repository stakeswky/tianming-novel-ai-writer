<UserControl x:Class="TM.Framework.User.Preferences.Display.DisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:behaviors="clr-namespace:TM.Framework.Common.Behaviors"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:local="clr-namespace:TM.Framework.User.Preferences.Display">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      behaviors:SmoothScrollBehavior.EnableSmoothScroll="True"
                      behaviors:SmoothScrollBehavior.ScrollIncrement="48"
                      behaviors:SmoothScrollBehavior.AnimationDuration="200">
            <StackPanel Margin="5">

                <common:IconHeaderGroupBox Icon="🔍" Title="界面缩放" Margin="0,0,0,20">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="80%" FontSize="12" 
                                       Foreground="{DynamicResource TextSecondary}" 
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>

                            <Slider Grid.Column="1" 
                                    Minimum="0.8" Maximum="2.0" 
                                    Value="{Binding UiScale}"
                                    TickFrequency="0.1" 
                                    IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="2" Text="200%" FontSize="12" 
                                       Foreground="{DynamicResource TextSecondary}" 
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>

                        <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="14" FontWeight="SemiBold">
                            <Run Text="当前缩放:"/>
                            <Run Text="{Binding UiScalePercent, Mode=OneWay}" Foreground="{DynamicResource PrimaryColor}"/>
                        </TextBlock>

                        <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="10" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="ℹ️" FontSize="12" Margin="0,0,8,0"/>
                                <TextBlock Text="缩放立即生效，并自动保存" 
                                           FontSize="11" Foreground="{DynamicResource TextSecondary}" 
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Icon="⚙️" Title="显示选项" Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox Content="显示左侧功能栏" 
                                  IsChecked="{Binding ShowFunctionBar}"
                                  Margin="0,0,0,15" FontSize="13"/>

                        <TextBlock Text="列表密度" FontSize="13" Margin="0,0,0,10"/>
                        <StackPanel>
                            <RadioButton Content="紧凑" 
                                         IsChecked="{Binding SelectedDensity, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=0}"
                                         Margin="0,0,0,8" FontSize="13"/>
                            <RadioButton Content="标准（推荐）" 
                                         IsChecked="{Binding SelectedDensity, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=1}"
                                         Margin="0,0,0,8" FontSize="13"/>
                            <RadioButton Content="宽松" 
                                         IsChecked="{Binding SelectedDensity, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=2}"
                                         Margin="0,0,0,8" FontSize="13"/>
                        </StackPanel>

                        <TextBlock Text="{Binding DensityDescription, Mode=OneWay}" 
                                   FontSize="11" Foreground="{DynamicResource TextSecondary}" 
                                   Margin="20,5,0,0"/>
                    </StackPanel>
                </common:IconHeaderGroupBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="重置为默认" Command="{Binding ResetCommand}"
                            Style="{DynamicResource DangerButtonStyle}" Padding="20,8"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
