<UserControl x:Class="TM.Framework.User.Preferences.Locale.LocaleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:behaviors="clr-namespace:TM.Framework.Common.Behaviors"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      behaviors:SmoothScrollBehavior.EnableSmoothScroll="True"
                      behaviors:SmoothScrollBehavior.ScrollIncrement="48"
                      behaviors:SmoothScrollBehavior.AnimationDuration="200">
            <StackPanel Margin="5">

                <common:IconHeaderGroupBox Icon="🌍" Title="语言设置" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="显示语言" FontSize="13" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0" 
                                      ItemsSource="{Binding AvailableLanguages}"
                                      SelectedValue="{Binding SelectedLanguage}"
                                      SelectedValuePath="Code"
                                      DisplayMemberPath="Display"
                                      Height="36" Margin="0,0,10,0"/>

                            <Button Grid.Column="1" Content="应用并重启" 
                                    Command="{Binding ApplyLanguageCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    Padding="15,6"/>
                        </Grid>

                        <Border Background="{DynamicResource HoverBackground}" BorderBrush="{DynamicResource WarningColor}" 
                                BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="⚠️" FontSize="12" Margin="0,0,8,0"/>
                                <TextBlock Text="更改语言需要重启应用程序才能生效" 
                                           FontSize="11" Foreground="{DynamicResource TextSecondary}" 
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Icon="🕐" Title="时区设置" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="选择时区" FontSize="13" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding AvailableTimeZones}"
                                  SelectedValue="{Binding SelectedTimeZone}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="DisplayName"
                                  Height="36" Margin="0,0,0,10"/>

                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondary}">
                            <Run Text="当前时区偏移:"/>
                            <Run Text="{Binding TimeZoneDisplay, Mode=OneWay}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </StackPanel>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Icon="📅" Title="日期时间格式" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="日期格式" FontSize="13" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding AvailableDateFormats}"
                                  SelectedItem="{Binding SelectedDateFormat}"
                                  Height="36" Margin="0,0,0,10"/>

                        <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="📋" FontSize="12" Margin="0,0,8,0"/>
                                <TextBlock FontSize="12">
                                    <Run Text="预览:" Foreground="{DynamicResource TextSecondary}"/>
                                    <Run Text="{Binding DateFormatPreview, Mode=OneWay}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="时间显示" FontSize="13" Margin="0,0,0,5"/>
                        <CheckBox Content="使用24小时制" IsChecked="True" Margin="0,0,0,5" FontSize="12"/>
                    </StackPanel>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Icon="🔢" Title="数字格式" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="数字显示格式" FontSize="13" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding AvailableNumberFormats}"
                                  SelectedItem="{Binding SelectedNumberFormat}"
                                  Height="36" Margin="0,0,0,10"/>

                        <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="10">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="📋" FontSize="12" Margin="0,0,8,0"/>
                                <TextBlock FontSize="12">
                                    <Run Text="预览:" Foreground="{DynamicResource TextSecondary}"/>
                                    <Run Text="{Binding NumberFormatPreview, Mode=OneWay}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </common:IconHeaderGroupBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="重置为默认" Command="{Binding ResetCommand}"
                            Style="{DynamicResource DangerButtonStyle}" Padding="20,8"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
