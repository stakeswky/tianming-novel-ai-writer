<UserControl x:Class="TM.Framework.User.Account.AccountBinding.AccountBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:converters="clr-namespace:TM.Framework.Common.Converters"
             xmlns:visibility="clr-namespace:TM.Framework.Common.Converters.Visibility"
             xmlns:local="clr-namespace:TM.Framework.User.Account.AccountBinding"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <UserControl.Resources>
        <ResourceDictionary>

            <visibility:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" IsInverted="True"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <common:IconHeaderGroupBox Icon="🔗" Title="第三方账号绑定" Style="{DynamicResource StandardGroupBoxStyle}">
                <StackPanel>

                    <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="ℹ️" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap">
                                <Run Text="绑定第三方账号后，可使用快速登录、数据同步等功能。您可以随时解除绑定。"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding AvailablePlatforms}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" CornerRadius="8" 
                                        Padding="15" Margin="0,0,0,12" BorderThickness="1" 
                                        BorderBrush="{DynamicResource BorderBrush}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Image Source="{Binding LogoImage}" 
                                                       Width="40" Height="40" 
                                                       Margin="0,0,12,0" 
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding LogoImage}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <emoji:TextBlock Text="{Binding PlatformIcon}" FontSize="28" Margin="0,0,12,0">
                                                    <emoji:TextBlock.Style>
                                                        <Style TargetType="emoji:TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding LogoImage}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </emoji:TextBlock.Style>
                                                </emoji:TextBlock>

                                                <StackPanel>
                                                    <TextBlock Text="{Binding PlatformName}" FontSize="15" FontWeight="SemiBold"/>

                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <Border CornerRadius="3" Padding="6,2" Margin="0,0,6,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#FFF8E1"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsBound}" Value="True">
                                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>

                                                            <TextBlock FontSize="11" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="未绑定"/>
                                                                        <Setter Property="Foreground" Value="#F57C00"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsBound}" Value="True">
                                                                                <Setter Property="Text" Value="已绑定"/>
                                                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>

                                                        <TextBlock Text="{Binding SyncStatusDisplay, Mode=OneWay}" FontSize="12" 
                                                                   Margin="0,0,4,0" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsBound}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding SyncStatus}" Value="Syncing">
                                                                            <Setter Property="Foreground" Value="#F57C00"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding SyncStatus}" Value="Failed">
                                                                            <Setter Property="Foreground" Value="{DynamicResource DangerColor}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondary}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsBound}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Setter Property="Text" Value="{Binding LastSyncDisplay, Mode=OneWay}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBound}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>

                                                <TextBlock Text="{Binding Nickname}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Email}" FontSize="11" 
                                                           Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Email}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Email}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal">

                                                <Button Height="36" Padding="16,0" MinWidth="80" Margin="0,0,8,0"
                                                        Command="{Binding DataContext.BindAccountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Platform}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                            <Setter Property="Content" Value="绑定"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsBound}" Value="True">
                                                                    <Setter Property="Content" Value="查看详情"/>
                                                                    <Setter Property="Background" Value="{DynamicResource Surface}"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button Height="36" Padding="12,0" MinWidth="70" Margin="0,0,8,0"
                                                        Command="{Binding DataContext.SyncAccountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Platform}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsBound}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <Button.Content>
                                                        <StackPanel Orientation="Horizontal">
                                                            <emoji:TextBlock Text="🔄" FontSize="14" Margin="0,0,5,0"/>
                                                            <TextBlock Text="同步" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button.Content>
                                                </Button>

                                                <Button Height="36" Padding="12,0" MinWidth="70"
                                                        Content="解绑"
                                                        Command="{Binding DataContext.UnbindAccountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Platform}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsBound}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="1" Margin="52,8,0,0">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBound}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>

                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondary}">
                                                    <Run Text="账号ID: "/>
                                                    <Run Text="{Binding AccountId, Mode=OneWay}"/>
                                                </TextBlock>

                                                <TextBlock Text="•" FontSize="11" Margin="10,0" 
                                                           Foreground="{DynamicResource TextSecondary}"/>

                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondary}" Text="{Binding BindTimeDisplay, StringFormat='绑定于 {0}', Mode=OneWay}"/>
                                            </StackPanel>
                                        </Grid>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Background="{DynamicResource SelectedBackground}" CornerRadius="6" Padding="12" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="🔒" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock FontSize="11" Foreground="{DynamicResource InfoColor}" TextWrapping="Wrap">
                                <Run Text="隐私保护："/>
                                <Run Text="所有绑定信息仅存储在本地，不会上传到云端。解绑后将立即删除相关数据。"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </common:IconHeaderGroupBox>

        </StackPanel>
    </ScrollViewer>

</UserControl>
