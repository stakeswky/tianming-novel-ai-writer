<Window x:Class="TM.Framework.User.Account.AccountBinding.BindingDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="600"
        Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Style="{DynamicResource StandardDialogBorderStyle}" Margin="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource StandardDialogTitleBarStyle}" 
                    MouseDown="TitleBar_MouseDown" Padding="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <emoji:TextBlock x:Name="PlatformIconText" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock x:Name="PlatformNameText" Style="{DynamicResource StandardDialogTitleTextStyle}"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,0">
                <StackPanel>

                    <layout:IconHeaderGroupBox Icon="👤" Title="账号信息" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="账号ID：" FontSize="13" 
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AccountIdText" FontSize="13" 
                                       FontWeight="SemiBold" Margin="10,5,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="昵称：" FontSize="13" 
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="NicknameText" FontSize="13" 
                                       FontWeight="SemiBold" Margin="10,5,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="邮箱：" FontSize="13" 
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="EmailText" FontSize="13" 
                                       Margin="10,5,0,5"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="同步状态：" FontSize="13" 
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,5"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="10,5,0,5">
                                <Border x:Name="SyncStatusBorder" CornerRadius="4" Padding="8,4">
                                    <TextBlock x:Name="SyncStatusText" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </layout:IconHeaderGroupBox>

                    <layout:IconHeaderGroupBox Icon="🕐" Title="时间信息" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="绑定时间：" FontSize="13" 
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="BindTimeText" FontSize="13" Margin="10,5,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="最后同步：" FontSize="13" 
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="LastSyncTimeText" FontSize="13" Margin="10,5,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="最后使用：" FontSize="13" 
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="LastUseTimeText" FontSize="13" Margin="10,5,0,5"/>
                        </Grid>
                    </layout:IconHeaderGroupBox>

                    <layout:IconHeaderGroupBox Icon="🔐" Title="已授权权限" Margin="0,0,0,15">
                        <ItemsControl x:Name="PermissionsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Surface}" CornerRadius="4" Padding="10,8" Margin="0,4">
                                        <StackPanel Orientation="Horizontal">
                                            <emoji:TextBlock Text="✓" FontSize="14" Foreground="{DynamicResource SuccessColor}" 
                                                             Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding}" FontSize="13"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </layout:IconHeaderGroupBox>

                    <layout:IconHeaderGroupBox Icon="📋" Title="最近操作历史">
                        <ListBox x:Name="HistoryList" MaxHeight="200" BorderThickness="0" Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <emoji:TextBlock Grid.Column="0" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Top">
                                            <emoji:TextBlock.Style>
                                                <Style TargetType="emoji:TextBlock">
                                                    <Setter Property="Text" Value="🔗"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Action}" Value="Unbind">
                                                            <Setter Property="Text" Value="🔓"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Action}" Value="Update">
                                                            <Setter Property="Text" Value="🔄"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Action}" Value="PermissionChange">
                                                            <Setter Property="Text" Value="🔐"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </emoji:TextBlock.Style>
                                        </emoji:TextBlock>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontSize="13" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="绑定账号"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Action}" Value="Unbind">
                                                                <Setter Property="Text" Value="解绑账号"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Action}" Value="Update">
                                                                <Setter Property="Text" Value="更新信息"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Action}" Value="PermissionChange">
                                                                <Setter Property="Text" Value="权限变更"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Details}" FontSize="11" 
                                                       Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" Text="{Binding Timestamp, StringFormat='{}{0:MM-dd HH:mm}'}" 
                                                   FontSize="11" Foreground="{DynamicResource TextSecondary}" 
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </layout:IconHeaderGroupBox>

                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource Surface}" CornerRadius="0,0,16,16" 
                    Padding="20,15" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="🔄 立即同步" Click="Sync_Click" 
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="15,8"/>

                    <Button Grid.Column="2" Content="关闭" Click="Close_Click" 
                            Style="{DynamicResource PrimaryButtonStyle}" Padding="20,8" MinWidth="80"/>
                </Grid>
            </Border>

        </Grid>
    </Border>

</Window>

