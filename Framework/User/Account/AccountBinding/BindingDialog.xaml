<Window x:Class="TM.Framework.User.Account.AccountBinding.BindingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="400"
        Height="250"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Border Style="{DynamicResource StandardDialogBorderStyle}" Margin="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource StandardDialogTitleBarStyle}" 
                    MouseDown="TitleBar_MouseDown" Padding="16,0">
                <TextBlock Text="绑定第三方账号" Style="{DynamicResource StandardDialogTitleTextStyle}"/>
            </Border>

            <StackPanel Grid.Row="1" Margin="20,10,20,10">

                <TextBlock x:Name="PlatformNameText" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>

                <TextBlock Text="账号ID" FontSize="13" Margin="0,0,0,5"/>
                <TextBox x:Name="AccountIdTextBox" Height="36" Margin="0,0,0,10"/>

                <TextBlock Text="昵称" FontSize="13" Margin="0,0,0,5"/>
                <TextBox x:Name="NicknameTextBox" Height="36"/>

            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0,20,20">
                <Button Content="取消" Click="Cancel_Click" Style="{DynamicResource SecondaryButtonStyle}" 
                        Padding="20,6" Margin="0,0,10,0" MinWidth="80"/>
                <Button Content="确定" Click="Confirm_Click" Style="{DynamicResource PrimaryButtonStyle}" 
                        Padding="20,6" MinWidth="80"/>
            </StackPanel>

        </Grid>
    </Border>

</Window>

