<UserControl x:Class="TM.Framework.User.Account.AccountDeletion.AccountDeletionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:behaviors="clr-namespace:TM.Framework.Common.Behaviors">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  behaviors:SmoothScrollBehavior.EnableSmoothScroll="True">
        <StackPanel Margin="5">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <emoji:TextBlock Text="🗑️" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="账号注销" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <Border Background="{DynamicResource Surface}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <TextBlock Text="注销账号将永久删除您的所有数据，包括个人信息、订阅记录、登录历史等。此操作不可撤销，请谨慎操作。" 
                           FontSize="13" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
            </Border>

            <common:IconHeaderGroupBox Icon="⚠️" Title="重要提醒" Style="{DynamicResource StandardGroupBoxStyle}" Margin="0,0,0,15">
                <Border Background="#FFEBEE" CornerRadius="6" Padding="15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <emoji:TextBlock Text="❌" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="您的账号将被永久停用" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <emoji:TextBlock Text="❌" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="所有数据将被标记为待删除" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <emoji:TextBlock Text="❌" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="您将无法使用此账号登录" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="⚠️" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="此操作不可撤销" FontSize="13" FontWeight="Bold" 
                                       Foreground="{DynamicResource DangerColor}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="💡" Title="注销前建议" Style="{DynamicResource StandardGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <emoji:TextBlock Text="📦" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="备份您的重要数据" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <emoji:TextBlock Text="🔗" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="解除第三方账号绑定" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="💳" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="确认没有未使用的订阅权益" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🔐" Title="确认注销" Style="{DynamicResource StandardGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="为确保您是本人操作，请在下方输入框中输入「确认注销」" 
                               FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10"/>
                    <TextBox Text="{Binding ConfirmText, UpdateSourceTrigger=PropertyChanged}" 
                             Height="40" FontSize="14"
                             Style="{DynamicResource StandardTextBoxStyle}"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,20">
                <Button Content="取消" Command="{Binding CancelCommand}" 
                        Style="{DynamicResource SecondaryButtonStyle}" 
                        Width="120" Height="40" Margin="0,0,15,0"/>

                <Button Command="{Binding ConfirmDeletionCommand}" 
                        Width="140" Height="40"
                        IsEnabled="{Binding CanConfirm}"
                        Background="{DynamicResource DangerColor}"
                        Foreground="White"
                        BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="6" Padding="12,8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource DangerHover}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="🗑️" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="确认注销" VerticalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </Button>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>
