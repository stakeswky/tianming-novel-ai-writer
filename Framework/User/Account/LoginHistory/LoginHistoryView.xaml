<UserControl x:Class="TM.Framework.User.Account.LoginHistory.LoginHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:tree="clr-namespace:TM.Framework.Common.Controls"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <layout:IconHeaderGroupBox Icon="📊" Title="统计信息" Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{DynamicResource Surface}" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="总登录次数" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="{Binding TotalRecords}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{DynamicResource Surface}" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="异常登录次数" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="{Binding AbnormalRecords}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource DangerColor}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{DynamicResource Surface}" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="高风险登录" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="{Binding HighRiskCount}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource WarningColor}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Background="{DynamicResource Surface}" CornerRadius="8" Padding="15">
                            <StackPanel>
                                <TextBlock Text="活动会话" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="{Binding ActiveSessionsCount}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource SuccessColor}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{DynamicResource Surface}" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="安全评分" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding SecurityScore}" FontSize="32" FontWeight="Bold" Margin="0,0,10,0">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="{Binding SecurityScoreColor, Mode=OneWay}"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="/100" FontSize="14" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding SecurityScoreText, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding SecurityScoreColor, Mode=OneWay}"/>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{DynamicResource Surface}" CornerRadius="8" Padding="15">
                            <StackPanel>
                                <TextBlock Text="最后登录时间" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="{Binding LastLoginTime, Mode=OneWay}" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="🔍" Title="筛选与分析" Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="开始日期" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding FilterStartDate}" Height="36" Margin="0,0,10,0"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="结束日期" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker Grid.Row="0" Grid.Column="3" SelectedDate="{Binding FilterEndDate}" Height="36" Margin="0,0,10,0"/>

                    <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal">
                        <Button Content="筛选" Command="{Binding FilterCommand}" Style="{DynamicResource PrimaryButtonStyle}" Padding="20,6" Margin="0,0,10,0"/>
                        <Button Content="刷新" Command="{Binding RefreshCommand}" Style="{DynamicResource SecondaryButtonStyle}" Padding="20,6"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" Orientation="Horizontal">
                        <CheckBox Content="只显示异常登录" IsChecked="{Binding ShowOnlyAbnormal}" Margin="0,0,20,0" 
                                  VerticalAlignment="Center" FontSize="13"/>

                        <Button Content="📈 统计分析" Command="{Binding ShowAnalyticsCommand}" 
                                Style="{DynamicResource SecondaryButtonStyle}" Padding="15,6"/>
                    </StackPanel>
                </Grid>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="📝" Title="登录记录">
                <StackPanel>

                    <tree:DataTreeView ItemsSource="{Binding LoginTree}" 
                                       ParentClickMode="Select" 
                                       ParentNodeClickCommand="{Binding SelectLoginCommand}"
                                       MaxHeight="500"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="导出历史" Command="{Binding ExportCommand}" Style="{DynamicResource SecondaryButtonStyle}" Padding="20,6" Margin="0,0,10,0"/>
                        <Button Content="清空历史" Command="{Binding ClearHistoryCommand}" Style="{DynamicResource DangerButtonStyle}" Padding="20,6"/>
                    </StackPanel>

                </StackPanel>
            </layout:IconHeaderGroupBox>

        </StackPanel>
    </ScrollViewer>

</UserControl>
