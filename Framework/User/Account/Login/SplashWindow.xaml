<Window x:Class="TM.Framework.User.Account.Login.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        Title="天命 - 启动中" 
        SizeToContent="Height"
        Width="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Loaded="Window_Loaded">

    <Border Background="{DynamicResource Surface}" 
            CornerRadius="12" 
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="1"
            Margin="12"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.25" Color="Black" RenderingBias="Quality"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <Border x:Name="AppIconBorder"
                        Width="30" Height="30"
                        CornerRadius="7"
                        ClipToBounds="True"
                        Margin="0,0,12,0" />
                <emoji:TextBlock x:Name="FallbackIconTextBlock" Text="🚀" FontSize="28" Margin="0,0,12,0" Visibility="Collapsed"/>
                <TextBlock Text="天命正在启动..." 
                           FontSize="20" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,8">
                <ProgressBar x:Name="ProgressBar"
                             Height="10"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Background="{DynamicResource ContentBackground}"
                             Foreground="{DynamicResource PrimaryColor}"
                             BorderThickness="0">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ProgressBar">
                                        <Grid>
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="5"/>
                                            <Border x:Name="PART_Track" CornerRadius="5">
                                                <Border x:Name="PART_Indicator"
                                                        Background="{TemplateBinding Foreground}"
                                                        HorizontalAlignment="Left"
                                                        CornerRadius="5"/>
                                            </Border>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>

                <TextBlock x:Name="PercentageTextBlock"
                           Text="0%"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>

            <TextBlock x:Name="TaskDescriptionTextBlock"
                       Grid.Row="2"
                       Text="正在初始化..."
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>
    </Border>
</Window>
