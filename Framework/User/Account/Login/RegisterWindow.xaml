<Window x:Class="TM.Framework.User.Account.Login.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        Title="天命 - 注册"
        SizeToContent="Height"
        Width="460"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Background="{DynamicResource Surface}"
            CornerRadius="12"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Margin="12"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.25" Color="Black" RenderingBias="Quality"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource ContentBackground}"
                    CornerRadius="12,12,0,0"
                    Padding="18,10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="📝" FontSize="22" Margin="0,0,10,0"/>
                        <TextBlock Text="注册账号"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="CloseButton"
                            Content="✕"
                            HorizontalAlignment="Right"
                            Width="32" Height="32"
                            FontSize="16"
                            Foreground="{DynamicResource TextSecondary}"
                            Cursor="Hand"
                            Style="{DynamicResource CloseButtonStyle}"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20,9,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="账号"
                               FontSize="13"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="UsernameTextBox"
                             Style="{DynamicResource StandardTextBoxStyle}"
                             FontSize="14"
                             Height="40"
                             Padding="12,0"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,14">
                    <TextBlock Text="密码"
                               FontSize="13"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{DynamicResource StandardPasswordBoxStyle}"
                                 FontSize="14"
                                 Height="40"
                                 Padding="12,0"
                                 VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,14">
                    <TextBlock Text="确认密码"
                               FontSize="13"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Style="{DynamicResource StandardPasswordBoxStyle}"
                                 FontSize="14"
                                 Height="40"
                                 Padding="12,0"
                                 VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,0,0,14">
                    <TextBlock Text="卡密"
                               FontSize="13"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="LicenseKeyTextBox"
                             Style="{DynamicResource StandardTextBoxStyle}"
                             FontSize="14"
                             Height="40"
                             Padding="12,0"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Margin="0">
                    <TextBlock Text="邀请码（可选）"
                               FontSize="13"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="InviteCodeTextBox"
                             Style="{DynamicResource StandardTextBoxStyle}"
                             FontSize="14"
                             Height="40"
                             Padding="12,0"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <TextBlock x:Name="ErrorTextBlock"
                           Grid.Row="5"
                           Foreground="{DynamicResource DangerColor}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,2,0,0"
                           Visibility="Collapsed"/>
            </Grid>

            <Grid Grid.Row="2" Margin="20,14,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="取消"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Height="40"
                        Click="CancelButton_Click"/>

                <Button Grid.Column="2"
                        x:Name="RegisterButton"
                        Content="注册"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Height="40"
                        Click="RegisterButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
