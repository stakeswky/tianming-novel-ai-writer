<Window x:Class="TM.Framework.User.Account.Login.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        Title="天命 - 登录" 
        SizeToContent="Height"
        Width="640"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Border Background="{DynamicResource Surface}" 
            CornerRadius="12" 
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="1"
            Margin="12"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.25" Color="Black" RenderingBias="Quality"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" 
                    Background="{DynamicResource PrimaryColor}" 
                    CornerRadius="12,0,0,12"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                        <Border x:Name="AppIconBorder"
                                Width="64" Height="64"
                                CornerRadius="14"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,12"
                                ClipToBounds="True">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.3" Color="Black"/>
                            </Border.Effect>
                        </Border>
                        <emoji:TextBlock x:Name="FallbackIconTextBlock" Text="🔐" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12" Visibility="Collapsed"/>

                        <TextBlock Text="欢迎使用天命" 
                                   FontSize="22" 
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="智能创作助手" 
                                   FontSize="13" 
                                   Foreground="#CCFFFFFF"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>

                        <TextBlock Text="让写作更高效" 
                                   FontSize="12" 
                                   Foreground="#99FFFFFF"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" 
                    Background="{DynamicResource Surface}" 
                    CornerRadius="0,12,12,0">
                <Grid>

                    <Button x:Name="CloseButton"
                            Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Width="32" Height="32"
                            FontSize="16"
                            Margin="0,12,12,0"
                            Foreground="{DynamicResource TextSecondary}"
                            Cursor="Hand"
                            Style="{DynamicResource CloseButtonStyle}"
                            Click="CloseButton_Click"
                            Panel.ZIndex="10"/>

                    <Grid Margin="24" VerticalAlignment="Stretch">
                <Grid.Resources>
                    <Style x:Key="LoginAccountComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource StandardComboBoxStyle}">
                        <Setter Property="IsTextSearchEnabled" Value="True"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBox">
                                    <Grid>
                                        <ToggleButton x:Name="toggleButton"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="2"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                    Focusable="False"
                                                    Height="{TemplateBinding Height}"
                                                    VerticalAlignment="Center"
                                                    ClickMode="Press">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border x:Name="templateRoot"
                                                           Background="{TemplateBinding Background}"
                                                           BorderBrush="{TemplateBinding BorderBrush}"
                                                           BorderThickness="{TemplateBinding BorderThickness}"
                                                           CornerRadius="6"
                                                           Height="{TemplateBinding Height}"
                                                           VerticalAlignment="Center"
                                                           SnapsToDevicePixels="True">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="36"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Path x:Name="arrow"
                                                                 Grid.Column="1"
                                                                 Data="M 0 0 L 4 4 L 8 0 Z"
                                                                 Fill="{DynamicResource TextSecondary}"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,8,0"/>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="templateRoot" Property="BorderBrush" Value="{DynamicResource PrimaryHover}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="templateRoot" Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                                                            <Setter TargetName="arrow" Property="Data" Value="M 0 4 L 4 0 L 8 4 Z"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>

                                        <ContentPresenter x:Name="contentPresenter"
                                                        Content="{TemplateBinding SelectionBoxItem}"
                                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                        ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                        VerticalAlignment="Center"
                                                        Margin="{TemplateBinding Padding}"
                                                        IsHitTestVisible="False"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>

                                        <TextBox x:Name="PART_EditableTextBox"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="{TemplateBinding Foreground}"
                                                Margin="12,0,36,0"
                                                Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                VerticalContentAlignment="Center"
                                                VerticalAlignment="Center"
                                                Height="{TemplateBinding Height}"
                                                Visibility="Hidden"/>

                                        <Popup x:Name="PART_Popup"
                                              AllowsTransparency="True"
                                              Placement="Bottom"
                                              IsOpen="{TemplateBinding IsDropDownOpen}"
                                              Focusable="False"
                                              PopupAnimation="Slide">
                                            <Border Background="Transparent"
                                                   Margin="10"
                                                   MinWidth="{TemplateBinding ActualWidth}">
                                                <Border.Effect>
                                                    <DropShadowEffect ShadowDepth="0" 
                                                                     BlurRadius="12" 
                                                                     Opacity="0.2" 
                                                                     Color="#000000"
                                                                     RenderingBias="Quality"/>
                                                </Border.Effect>
                                                <Border x:Name="dropDownBorder"
                                                       Background="{DynamicResource ContentBackground}"
                                                       BorderBrush="{DynamicResource BorderBrush}"
                                                       BorderThickness="1"
                                                       CornerRadius="8"
                                                       MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                       Padding="6"
                                                       SnapsToDevicePixels="True">
                                                    <ScrollViewer x:Name="DropDownScrollViewer"
                                                                Background="Transparent"
                                                                VerticalScrollBarVisibility="Auto"
                                                                HorizontalScrollBarVisibility="Disabled">
                                                        <ItemsPresenter x:Name="ItemsPresenter"
                                                                      KeyboardNavigation.DirectionalNavigation="Contained"
                                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                                      Margin="0"/>
                                                    </ScrollViewer>
                                                </Border>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEditable" Value="True">
                                            <Setter TargetName="contentPresenter" Property="Visibility" Value="Hidden"/>
                                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="账号" 
                               FontSize="13" 
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="UsernameComboBox"
                              Style="{StaticResource LoginAccountComboBoxStyle}"
                              IsEditable="True"
                              FontSize="14"
                              Height="38"
                              Padding="12,0,36,0"
                              VerticalContentAlignment="Center"
                              Margin="0,0,0,12"
                              KeyDown="Input_KeyDown"
                              SelectionChanged="UsernameComboBox_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="密码" 
                               FontSize="13" 
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,10">
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{DynamicResource StandardPasswordBoxStyle}"
                                     FontSize="14"
                                     Height="40"
                                     Padding="12,0,42,0"
                                     KeyDown="Input_KeyDown"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>
                        <TextBox x:Name="VisiblePasswordTextBox"
                                 Style="{DynamicResource StandardTextBoxStyle}"
                                 FontSize="14"
                                 Height="40"
                                 Padding="12,0,42,0"
                                 KeyDown="Input_KeyDown"
                                 TextChanged="VisiblePasswordTextBox_TextChanged"
                                 Visibility="Collapsed"/>
                        <Button x:Name="TogglePasswordVisibilityButton"
                                Width="36" Height="36"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Margin="0,0,2,0"
                                Cursor="Hand"
                                Click="TogglePasswordVisibilityButton_Click">
                            <emoji:TextBlock x:Name="TogglePasswordVisibilityIcon" Text="👁" FontSize="16"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <Grid Grid.Row="2" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="MoreOptionsButton"
                            Grid.Column="0"
                            Content="更多选项 ▼"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            HorizontalAlignment="Left"
                            Foreground="{DynamicResource PrimaryColor}"
                            Cursor="Hand"
                            Click="MoreOptionsButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="RegisterMenuItem" Header="注册账号" Click="RegisterMenuItem_Click"/>
                                <MenuItem x:Name="RenewAccountMenuItem" Header="账号续费" Click="RenewAccountMenuItem_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <TextBlock x:Name="ErrorTextBlock"
                               Grid.Column="1"
                               Foreground="{DynamicResource DangerColor}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="8,0"
                               Visibility="Collapsed"/>

                    <Button x:Name="RememberOptionsButton"
                            Grid.Column="2"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            HorizontalAlignment="Right"
                            Foreground="{DynamicResource TextSecondary}"
                            Cursor="Hand"
                            Click="RememberOptionsButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="RememberAccountMenuItem" Header="记住账号" IsCheckable="False" StaysOpenOnClick="True" Click="RememberOptionMenuItem_Click"/>
                                <MenuItem x:Name="RememberPasswordMenuItem" Header="记住密码" IsCheckable="False" StaysOpenOnClick="True" Click="RememberOptionMenuItem_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>

                <TextBlock x:Name="FirstTimeHintTextBlock"
                           Grid.Row="4"
                           Text="首次使用？请点击「更多选项 → 注册账号」"
                           FontSize="11"
                           Foreground="{DynamicResource TextTertiary}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"
                           Visibility="Collapsed"/>

                <Grid Grid.Row="5"/>

                <Grid Grid.Row="6" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="取消"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Height="40"
                            Click="CancelButton_Click"/>

                    <Button Grid.Column="2"
                            x:Name="LoginButton"
                            Content="登录"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Height="40"
                            Click="LoginButton_Click"/>
                </Grid>

                <StackPanel Grid.Row="7" Margin="0,12,0,0">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Height="1" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="其他登录方式" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="12,0"/>
                        <Border Grid.Column="2" Height="1" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>
                    </Grid>

                    <UniformGrid Rows="1" HorizontalAlignment="Center">
                        <Button x:Name="WeChatLoginButton" 
                                Width="48" Height="48" 
                                Margin="6,0" 
                                Background="Transparent" 
                                BorderThickness="1" 
                                BorderBrush="{DynamicResource BorderBrush}"
                                ToolTip="微信登录"
                                Click="ThirdPartyLogin_Click" Tag="wechat">
                            <Image x:Name="WeChatIcon" Width="28" Height="28" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Button>
                        <Button x:Name="QQLoginButton" 
                                Width="48" Height="48" 
                                Margin="6,0" 
                                Background="Transparent" 
                                BorderThickness="1" 
                                BorderBrush="{DynamicResource BorderBrush}"
                                ToolTip="QQ登录"
                                Click="ThirdPartyLogin_Click" Tag="qq">
                            <Image x:Name="QQIcon" Width="28" Height="28" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Button>
                        <Button x:Name="GitHubLoginButton" 
                                Width="48" Height="48" 
                                Margin="6,0" 
                                Background="Transparent" 
                                BorderThickness="1" 
                                BorderBrush="{DynamicResource BorderBrush}"
                                ToolTip="GitHub登录"
                                Click="ThirdPartyLogin_Click" Tag="github">
                            <Image x:Name="GitHubIcon" Width="28" Height="28" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Button>
                        <Button x:Name="GoogleLoginButton" 
                                Width="48" Height="48" 
                                Margin="6,0" 
                                Background="Transparent" 
                                BorderThickness="1" 
                                BorderBrush="{DynamicResource BorderBrush}"
                                ToolTip="Google登录"
                                Click="ThirdPartyLogin_Click" Tag="google">
                            <Image x:Name="GoogleIcon" Width="28" Height="28" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Button>
                        <Button x:Name="MicrosoftLoginButton" 
                                Width="48" Height="48" 
                                Margin="6,0" 
                                Background="Transparent" 
                                BorderThickness="1" 
                                BorderBrush="{DynamicResource BorderBrush}"
                                ToolTip="Microsoft登录"
                                Click="ThirdPartyLogin_Click" Tag="microsoft">
                            <Image x:Name="MicrosoftIcon" Width="28" Height="28" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Button>
                        <Button x:Name="BaiduLoginButton" 
                                Width="48" Height="48" 
                                Margin="6,0" 
                                Background="Transparent" 
                                BorderThickness="1" 
                                BorderBrush="{DynamicResource BorderBrush}"
                                ToolTip="百度登录"
                                Click="ThirdPartyLogin_Click" Tag="baidu">
                            <Image x:Name="BaiduIcon" Width="28" Height="28" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Button>
                    </UniformGrid>
                    </StackPanel>

                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
