<UserControl x:Class="TM.Framework.User.Account.PasswordSecurity.PasswordSecurityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <common:IconHeaderGroupBox Icon="🔒" Title="账户安全状态" Style="{DynamicResource StandardGroupBoxStyle}" Margin="0,0,0,20">
                <StackPanel>

                    <Border Visibility="{Binding IsAccountLocked, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="{DynamicResource DangerColor}" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <emoji:TextBlock Text="⚠️" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="账户已锁定" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                            <TextBlock FontSize="12" Foreground="White">
                                <Run Text="剩余锁定时间: "/>
                                <Run Text="{Binding LockoutTimeRemaining}" FontWeight="SemiBold"/>
                            </TextBlock>
                            <Button Content="手动解锁" Command="{Binding UnlockAccountCommand}" 
                                    Style="{DynamicResource SecondaryButtonStyle}" 
                                    HorizontalAlignment="Left" Margin="0,10,0,0"
                                    xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
                                    helpers:ButtonHelper.ConfirmMessage="确定要手动解锁账户吗？这将重置所有失败计数。"
                                    helpers:ButtonHelper.ConfirmTitle="确认解锁"/>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <emoji:TextBlock Grid.Column="0" Text="🔐" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="登录失败次数" FontSize="13" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="当前失败次数: " FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="{Binding FailedLoginAttempts}" FontSize="12" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FailedLoginAttempts}" Value="0">
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FailedLoginAttempts}" Value="1">
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FailedLoginAttempts}" Value="2">
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FailedLoginAttempts}" Value="3">
                                                    <Setter Property="Foreground" Value="{DynamicResource WarningColor}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FailedLoginAttempts}" Value="4">
                                                    <Setter Property="Foreground" Value="{DynamicResource WarningColor}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text=" / 5次锁定15分钟，10次锁定1小时，15次永久锁定" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="5,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🔐" Title="修改密码" Style="{DynamicResource StandardGroupBoxStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MaxWidth="500"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="旧密码" FontSize="14" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="OldPasswordBox" Height="36" Margin="0,0,0,15" 
                                     PasswordChanged="OldPasswordBox_PasswordChanged"/>

                        <TextBlock Text="新密码" FontSize="14" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="NewPasswordBox" Height="36" Margin="0,0,0,8" 
                                     PasswordChanged="NewPasswordBox_PasswordChanged"/>

                        <Grid Height="24" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ProgressBar Grid.Column="0" Height="6" Value="{Binding PasswordStrength}" Maximum="100" 
                                         Foreground="{Binding PasswordStrengthColor}" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="强度: " FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="{Binding PasswordStrengthText}" FontSize="11" FontWeight="SemiBold" 
                                           Foreground="{Binding PasswordStrengthColor}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="确认密码" FontSize="14" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="ConfirmPasswordBox" Height="36" Margin="0,0,0,20" 
                                     PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                        <Button Content="修改密码" Command="{Binding ChangePasswordCommand}" 
                                Style="{DynamicResource PrimaryButtonStyle}" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <Border Grid.Column="2" Background="{DynamicResource Surface}" CornerRadius="6" 
                            Padding="15" VerticalAlignment="Top">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <emoji:TextBlock Text="ℹ️" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="密码要求" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <emoji:TextBlock Text="✓" FontSize="11" Margin="0,0,6,0" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="最少8个字符" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <emoji:TextBlock Text="✓" FontSize="11" Margin="0,0,6,0" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="包含字母" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <emoji:TextBlock Text="✓" FontSize="11" Margin="0,0,6,0" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="包含数字" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🔒" Title="双因素认证" Style="{DynamicResource StandardGroupBoxStyle}">
                <StackPanel>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="启用双因素认证" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="使用Google Authenticator等应用进行二次验证" FontSize="12" 
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                        </StackPanel>

                        <CheckBox Grid.Column="1" IsChecked="{Binding IsTwoFactorEnabled}" 
                                  VerticalAlignment="Center" Style="{DynamicResource ToggleCheckBoxStyle}"/>
                    </Grid>

                    <Border Visibility="{Binding IsTwoFactorEnabled, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="{DynamicResource Surface}" CornerRadius="6" Padding="15">
                        <StackPanel>

                            <TextBlock Text="扫描二维码" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Border Width="200" Height="200" Background="White" CornerRadius="8" 
                                    HorizontalAlignment="Left" Margin="0,0,0,15">
                                <Image Source="{Binding QRCodeImage}" Stretch="Uniform"/>
                            </Border>

                            <TextBlock Text="或手动输入密钥" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource ContentBackground}" CornerRadius="6" Padding="12,8" 
                                    Margin="0,0,0,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding FormattedSecret, Mode=OneWay}" FontFamily="Consolas" 
                                               FontSize="14" VerticalAlignment="Center"/>

                                    <Button Grid.Column="1" Command="{Binding CopySecretCommand}"
                                            Style="{DynamicResource SecondaryButtonStyle}" Padding="10,4">
                                        <Button.Content>
                                            <StackPanel Orientation="Horizontal">
                                                <emoji:TextBlock Text="📋" FontSize="14" Margin="0,0,5,0"/>
                                                <TextBlock Text="复制" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button.Content>
                                    </Button>
                                </Grid>
                            </Border>

                            <TextBlock Text="测试验证码" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" Text="{Binding VerificationCode, UpdateSourceTrigger=PropertyChanged}" 
                                         Height="36" MaxLength="6"/>

                                <Button Grid.Column="2" Content="验证" Command="{Binding VerifyCodeCommand}"
                                        Style="{DynamicResource PrimaryButtonStyle}" Padding="20,6"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </common:IconHeaderGroupBox>

        </StackPanel>
    </ScrollViewer>

</UserControl>
