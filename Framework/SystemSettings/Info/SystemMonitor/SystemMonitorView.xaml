<UserControl x:Class="TM.Framework.SystemSettings.Info.SystemMonitor.SystemMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:local="clr-namespace:TM.Framework.SystemSettings.Info.SystemMonitor"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">
    <UserControl.DataContext>
        <local:SystemMonitorViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="20,20,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <emoji:TextBlock Text="📊" FontSize="24" Margin="0,0,10,0"/>
                <TextBlock Text="系统监控" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <Button Grid.Column="1" Content="刷新数据" Command="{Binding RefreshCommand}" 
                    Style="{DynamicResource PrimaryButtonStyle}" Width="120" Height="36"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,0,20,20">
            <StackPanel>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource Surface}" CornerRadius="8" Padding="5" Margin="0,0,10,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <emoji:TextBlock Text="💻" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="CPU" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="当前频率: " FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CPUCurrentFrequency}" FontSize="12" Margin="5,5,0,5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="温度: " FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,5"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CPUTemperature}" FontSize="12" Margin="5,5,0,5"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="使用率: " FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,5"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CPUUsagePercent, StringFormat={}{0}%}" FontSize="12" Margin="5,5,0,5" FontWeight="SemiBold"/>
                            </Grid>

                            <ProgressBar Value="{Binding CPUUsagePercent}" Maximum="100" Height="12"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{DynamicResource Surface}" CornerRadius="8" Padding="5" Margin="10,0,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <emoji:TextBlock Text="💾" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="内存" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="可用内存: " FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AvailableMemory}" FontSize="12" Margin="5,5,0,5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="使用率: " FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,5"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MemoryUsagePercent, StringFormat={}{0}%}" FontSize="12" Margin="5,5,0,5" FontWeight="SemiBold"/>
                            </Grid>

                            <ProgressBar Value="{Binding MemoryUsagePercent}" Maximum="100" Height="12"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="💿" Title="磁盘使用率">
                    <ListBox ItemsSource="{Binding DiskUsages}" Margin="10" MaxHeight="300" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding DriveName}" FontWeight="Bold" FontSize="14" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding DriveType}" Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding TotalSize, StringFormat={}总: {0}}" FontSize="11"/>
                                            <TextBlock Grid.Column="1" Text="{Binding FreeSize, StringFormat={}剩余: {0}}" FontSize="11" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding UsagePercent, StringFormat={}使用: {0}%}" FontSize="11" TextAlignment="Right"/>
                                        </Grid>
                                        <ProgressBar Value="{Binding UsagePercent}" Maximum="100" Height="8"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="🌐" Title="网络流量统计">
                    <ListBox ItemsSource="{Binding NetworkTraffics}" Margin="10" MaxHeight="300" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="连接速度: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentSpeed}" FontSize="11" Margin="5,2,0,2" FontWeight="SemiBold"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="已发送: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BytesSent}" FontSize="11" Margin="5,2,0,2"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="已接收: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding BytesReceived}" FontSize="11" Margin="5,2,0,2"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Style="{DynamicResource StandardGroupBoxStyle}" Icon="📊" Title="传感器监控">
                    <ListBox ItemsSource="{Binding Sensors}" Margin="10" MaxHeight="300" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <emoji:TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Type}" FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" Text="{Binding Value}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>

                                        <TextBlock Grid.Column="3" Text="{Binding Status}" FontSize="11" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </common:IconHeaderGroupBox>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

