<UserControl x:Class="TM.Framework.SystemSettings.Info.DiagnosticInfo.DiagnosticInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:local="clr-namespace:TM.Framework.SystemSettings.Info.DiagnosticInfo"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <UserControl.DataContext>
        <local:DiagnosticInfoViewModel/>
    </UserControl.DataContext>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="刷新" Command="{Binding RefreshCommand}" 
                   Style="{DynamicResource PrimaryButtonStyle}" Width="100" Height="36" Margin="0,0,10,0"/>
            <Button Content="健康检查" Command="{Binding RunHealthCheckCommand}" 
                   Style="{DynamicResource SecondaryButtonStyle}" Width="100" Height="36" Margin="0,0,10,0"/>
            <Button Content="导出报告" Command="{Binding ExportReportCommand}" 
                   Style="{DynamicResource SecondaryButtonStyle}" Width="100" Height="36"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="0,0,0,20">
            <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,10,0">
                <StackPanel>
                    <emoji:TextBlock Text="⚡" FontSize="20" HorizontalAlignment="Center"/>
                    <TextBlock Text="CPU使用率" FontSize="12" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <TextBlock Text="{Binding CPUUsage, StringFormat={}{0:F1}%}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="5,0">
                <StackPanel>
                    <emoji:TextBlock Text="💾" FontSize="20" HorizontalAlignment="Center"/>
                    <TextBlock Text="内存使用" FontSize="12" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <TextBlock Text="{Binding MemoryUsageMB, StringFormat={}{0} MB}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="5,0">
                <StackPanel>
                    <emoji:TextBlock Text="🔀" FontSize="20" HorizontalAlignment="Center"/>
                    <TextBlock Text="线程数" FontSize="12" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <TextBlock Text="{Binding ThreadCount}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="10,0,0,0">
                <StackPanel>
                    <emoji:TextBlock Text="🔧" FontSize="20" HorizontalAlignment="Center"/>
                    <TextBlock Text="句柄数" FontSize="12" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <TextBlock Text="{Binding HandleCount}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="❤️" Title="健康状态">
                    <StackPanel Margin="10">
                        <TextBlock Text="系统状态" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                        <TextBlock Text="{Binding HealthStatus}" FontSize="20" FontWeight="Bold" Margin="0,5,0,0">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="{Binding HealthStatusColor}"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </StackPanel>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Style="{DynamicResource StandardGroupBoxStyle}" Icon="🗑️" Title="GC统计">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="0代回收" Margin="0,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Gen0Collections}" FontWeight="Bold" Margin="10,5,0,5"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="1代回收" Margin="0,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Gen1Collections}" FontWeight="Bold" Margin="10,5,0,5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="2代回收" Margin="0,5"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Gen2Collections}" FontWeight="Bold" Margin="10,5,0,5"/>
                    </Grid>
                </common:IconHeaderGroupBox>
            </StackPanel>

            <common:IconHeaderGroupBox Grid.Column="1" Margin="10,0,0,0" Style="{DynamicResource StandardGroupBoxStyle}"
                                        Icon="💡" Title="系统建议">
                <ListBox ItemsSource="{Binding Suggestions}" Margin="10" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,5"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </common:IconHeaderGroupBox>
        </Grid>
    </Grid>
</UserControl>
