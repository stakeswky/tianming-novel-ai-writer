<UserControl x:Class="TM.Framework.SystemSettings.Info.SystemInfo.SystemInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:local="clr-namespace:TM.Framework.SystemSettings.Info.SystemInfo"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="刷新" Command="{Binding RefreshCommand}" 
                   Style="{DynamicResource PrimaryButtonStyle}" Width="100" Height="36" Margin="0,0,10,0"/>
            <Button Content="导出" Command="{Binding ExportCommand}" 
                   Style="{DynamicResource SecondaryButtonStyle}" Width="100" Height="36"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="💻" Title="操作系统信息">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                            <TextBlock Text="操作系统" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding OSName}" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,10">
                            <TextBlock Text="版本" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding OSVersion}" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                            <TextBlock Text="架构" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding OSArchitecture}" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,10">
                            <TextBlock Text="计算机名" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding ComputerName}" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="用户名" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding UserName}" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="⚡" Title="处理器信息">
                    <StackPanel Margin="10">
                        <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="处理器名称" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding CPUName}" FontSize="13" FontWeight="Bold" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,5,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="架构: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CPUArchitecture}" FontSize="11" Margin="5,3,0,3"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="物理核心: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CPUCores, StringFormat={}{0} 核}" FontSize="11" Margin="5,3,0,3"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="逻辑处理器: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CPULogicalProcessors, StringFormat={}{0} 个}" FontSize="11" Margin="5,3,0,3"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="虚拟化: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CPUVirtualization}" FontSize="11" Margin="5,3,0,3"/>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="5,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="基础频率: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CPUBaseFrequency}" FontSize="11" Margin="5,3,0,3"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="L1缓存: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CPUL1Cache}" FontSize="11" Margin="5,3,0,3"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="L2缓存: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CPUL2Cache}" FontSize="11" Margin="5,3,0,3"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="L3缓存: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CPUL3Cache}" FontSize="11" Margin="5,3,0,3"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="💾" Title="内存信息">
                    <StackPanel Margin="10">
                        <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="总内存" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                <TextBlock Text="{Binding TotalMemory}" FontSize="13" FontWeight="Bold" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="总虚拟内存" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                    <TextBlock Text="{Binding TotalVirtualMemory}" FontSize="12" Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                    <TextBlock Text="可用虚拟内存" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                    <TextBlock Text="{Binding AvailableVirtualMemory}" FontSize="12" Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock Text="页面文件大小" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                    <TextBlock Text="{Binding PageFileSize}" FontSize="12" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                            <emoji:TextBlock Text="🔧" FontSize="12" Margin="0,0,5,0"/>
                            <TextBlock Text="内存模块" FontWeight="SemiBold" FontSize="12"/>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding MemoryModules}" MaxHeight="300" BorderThickness="0" Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="插槽: " FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding BankLabel}" FontSize="11" FontWeight="Bold" Margin="5,0,15,0"/>

                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="容量: " FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding Capacity}" FontSize="11" FontWeight="Bold" Margin="5,0,0,0"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="类型: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MemoryType}" FontSize="11" Margin="5,3,15,0"/>

                                            <TextBlock Grid.Row="1" Grid.Column="2" Text="频率: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Speed}" FontSize="11" Margin="5,3,0,0"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="制造商: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Manufacturer}" FontSize="11" Margin="5,3,15,0"/>

                                            <TextBlock Grid.Row="2" Grid.Column="2" Text="型号: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding PartNumber}" FontSize="11" Margin="5,3,0,0" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="🎮" Title="显卡信息">
                    <ListBox ItemsSource="{Binding GpuInfos}" Margin="10" MaxHeight="300" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="制造商: " FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Manufacturer}" FontSize="12" Margin="5,3,0,3"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="显存: " FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding VideoMemorySize}" FontSize="12" Margin="5,3,0,3"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="驱动版本: " FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DriverVersion}" FontSize="12" Margin="5,3,0,3"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="状态: " FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Status}" FontSize="12" Margin="5,3,0,3"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="🔧" Title="主板和BIOS">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,10,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <emoji:TextBlock Text="🔲" FontSize="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="主板" FontWeight="SemiBold" FontSize="14"/>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="制造商: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MotherboardManufacturer}" FontSize="11" Margin="5,3,0,3" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="型号: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MotherboardProduct}" FontSize="11" Margin="5,3,0,3" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="版本: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MotherboardVersion}" FontSize="11" Margin="5,3,0,3"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="序列号: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MotherboardSerialNumber}" FontSize="11" Margin="5,3,0,3" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="10,0,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <emoji:TextBlock Text="💾" FontSize="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="BIOS" FontWeight="SemiBold" FontSize="14"/>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="制造商: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding BiosManufacturer}" FontSize="11" Margin="5,3,0,3" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="版本: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BiosVersion}" FontSize="11" Margin="5,3,0,3" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="发布日期: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding BiosReleaseDate}" FontSize="11" Margin="5,3,0,3"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="SMBIOS版本: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding BiosSmbiosVersion}" FontSize="11" Margin="5,3,0,3"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="💿" Title="磁盘信息">
                    <ListBox ItemsSource="{Binding DriveInfos}" Margin="10" MaxHeight="400" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding DriveName}" FontWeight="Bold" FontSize="14" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding MediaType}" Foreground="{DynamicResource PrimaryColor}" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding HealthStatus}" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="型号: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Model}" FontSize="11" Margin="5,2,0,2" TextWrapping="Wrap"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="接口: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding InterfaceType}" FontSize="11" Margin="5,2,0,2"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="文件系统: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FileSystem}" FontSize="11" Margin="5,2,0,2"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="序列号: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SerialNumber}" FontSize="11" Margin="5,2,0,2"/>
                                        </Grid>

                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding TotalSize, StringFormat={}总: {0}}" FontSize="11"/>
                                            <TextBlock Grid.Column="1" Text="{Binding FreeSize, StringFormat={}剩余: {0}}" FontSize="11" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding UsagePercent, StringFormat={}使用: {0}%}" FontSize="11" TextAlignment="Right"/>
                                        </Grid>
                                        <ProgressBar Value="{Binding UsagePercent}" Maximum="100" Height="8"/>
        </StackPanel>
    </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="🖥️" Title="显示器信息">
                    <ListBox ItemsSource="{Binding Displays}" Margin="10" MaxHeight="400" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <emoji:TextBlock Text="🖥️" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                <Grid Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="分辨率: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Resolution}" FontSize="11" Margin="5,3,0,3" FontWeight="SemiBold"/>

                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="工作区域: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WorkingArea}" FontSize="11" Margin="5,3,0,3"/>

                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="刷新率: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RefreshRate}" FontSize="11" Margin="5,3,0,3"/>

                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="宽高比: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding AspectRatio}" FontSize="11" Margin="5,3,0,3"/>

                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="色深: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding BitsPerPixel}" FontSize="11" Margin="5,3,0,3"/>

                                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="DPI: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DPI}" FontSize="11" Margin="5,3,0,3"/>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="制造商: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Manufacturer}" FontSize="11" Margin="5,3,0,3"/>

                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="产品代码: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProductCode}" FontSize="11" Margin="5,3,0,3"/>

                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="序列号: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SerialNumber}" FontSize="11" Margin="5,3,0,3"/>

                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="生产年份: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,3"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ManufactureYear}" FontSize="11" Margin="5,3,0,3"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Margin="0,0,0,0" Style="{DynamicResource StandardGroupBoxStyle}" Icon="🌐" Title="网络适配器">
                    <ListBox ItemsSource="{Binding NetworkAdapters}" Margin="10" MaxHeight="400" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <emoji:TextBlock Text="{Binding ConnectionIcon}" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IPv4地址: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding IPAddress}" FontSize="11" Margin="5,2,0,2"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="IPv6地址: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding IPv6Address}" FontSize="11" Margin="5,2,0,2" TextWrapping="Wrap"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="MAC地址: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MACAddress}" FontSize="11" Margin="5,2,0,2"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="连接速度: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Speed}" FontSize="11" Margin="5,2,0,2" FontWeight="SemiBold"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="网关: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Gateway}" FontSize="11" Margin="5,2,0,2"/>

                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="DNS服务器: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DNS}" FontSize="11" Margin="5,2,0,2"/>

                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="已发送: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2"/>
                                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding BytesSent}" FontSize="11" Margin="5,2,0,2"/>

                                            <TextBlock Grid.Row="7" Grid.Column="0" Text="已接收: " FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2"/>
                                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding BytesReceived}" FontSize="11" Margin="5,2,0,2"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </common:IconHeaderGroupBox>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
