<UserControl x:Class="TM.Framework.SystemSettings.Info.RuntimeEnv.RuntimeEnvView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:local="clr-namespace:TM.Framework.SystemSettings.Info.RuntimeEnv"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <UserControl.DataContext>
        <local:RuntimeEnvViewModel/>
    </UserControl.DataContext>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="刷新" Command="{Binding RefreshCommand}" 
                   Style="{DynamicResource PrimaryButtonStyle}" Width="100" Height="36" Margin="0,0,10,0"/>
            <Button Content="导出" Command="{Binding ExportCommand}" 
                   Style="{DynamicResource SecondaryButtonStyle}" Width="100" Height="36"/>
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="运行时信息">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="5">
                        <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}"
                                                    Icon="⚙️" Title=".NET 运行时信息">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="运行时版本: " Margin="0,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RuntimeVersion}" FontWeight="Bold" Margin="10,5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="CLR版本: " Margin="0,5"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CLRVersion}" FontWeight="Bold" Margin="10,5"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="GC模式: " Margin="0,5"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GCMode}" FontWeight="Bold" Margin="10,5"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="运行时标识符: " Margin="0,5"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FrameworkDescription}" FontWeight="Bold" Margin="10,5"/>
                            </Grid>
                        </common:IconHeaderGroupBox>

                        <common:IconHeaderGroupBox Style="{DynamicResource StandardGroupBoxStyle}"
                                                    Icon="🌍" Title="区域和语言设置">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="当前区域: " Margin="0,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentCulture}" FontWeight="Bold" Margin="10,5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="时区: " Margin="0,5"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TimeZone}" FontWeight="Bold" Margin="10,5"/>
                            </Grid>
                        </common:IconHeaderGroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="程序集">
                <ListBox ItemsSource="{Binding AssemblyList}" Margin="10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="{Binding Version, StringFormat={}版本: {0}}" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>

            <TabItem Header="环境变量">
                <ListBox ItemsSource="{Binding EnvironmentVariables}" Margin="10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="{Binding Value}" FontSize="11" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
