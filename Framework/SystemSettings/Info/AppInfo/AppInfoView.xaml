<UserControl x:Class="TM.Framework.SystemSettings.Info.AppInfo.AppInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:local="clr-namespace:TM.Framework.SystemSettings.Info.AppInfo"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <UserControl.DataContext>
        <local:AppInfoViewModel/>
    </UserControl.DataContext>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="刷新" Command="{Binding RefreshCommand}" 
                   Style="{DynamicResource PrimaryButtonStyle}" Width="100" Height="36" Margin="0,0,10,0"/>
            <Button Content="检查更新" Command="{Binding CheckUpdateCommand}" 
                   Style="{DynamicResource SecondaryButtonStyle}" Width="100" Height="36" Margin="0,0,10,0"/>
            <Button Content="导出" Command="{Binding ExportCommand}" 
                   Style="{DynamicResource SecondaryButtonStyle}" Width="100" Height="36"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="📱" Title="应用基本信息">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                            <TextBlock Text="应用名称" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding AppName}" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,10">
                            <TextBlock Text="版本号" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding AppVersion}" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                            <TextBlock Text="目标框架" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding TargetFramework}" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,10">
                            <TextBlock Text="进程ID" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding ProcessId}" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,10">
                            <TextBlock Text="安装路径" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding InstallPath}" FontSize="14" FontWeight="Bold" Margin="0,5,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,0" Grid.ColumnSpan="2">
                            <TextBlock Text="开发者" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding Developer}" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                            <TextBlock Text="{Binding DeveloperDescription}" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="⏱️" Title="运行信息">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="启动时间" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding StartupTime}" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="运行时长" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding RunningTime}" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="📋" Title="版本历史">
                    <ListBox ItemsSource="{Binding VersionHistory}" Margin="10" MaxHeight="300" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Version, StringFormat={}版本 {0}}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ReleaseDate, StringFormat={}{0:yyyy-MM-dd}}" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="10,0"/>
                                            <Border Grid.Column="2" Background="{DynamicResource PrimaryColor}" CornerRadius="4" Padding="6,2" Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="当前版本" FontSize="10" Foreground="White"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding ChangeLog}" FontSize="11" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="📊" Title="应用资源统计">
                    <ItemsControl ItemsSource="{Binding ResourceStats}" Margin="10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <emoji:TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Category}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Count, StringFormat={}{0} 个}" FontSize="12" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="15,0"/>
                                        <TextBlock Grid.Column="3" Text="{Binding TotalSize}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="🎯" Title="功能模块统计">
                    <ItemsControl ItemsSource="{Binding FeatureModules}" Margin="10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <emoji:TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CategoryName}" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding SubfunctionCount, StringFormat={}{0} 个子功能}" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="10,0"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Status}" FontSize="11" Foreground="{DynamicResource SuccessColor}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="📜" Title="许可证信息">
                    <ItemsControl ItemsSource="{Binding Licenses}" Margin="10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding LicenseType}" FontSize="11" Foreground="{DynamicResource InfoColor}"/>
                                        </Grid>
                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="�" Title="依赖项分析">
                    <ListBox ItemsSource="{Binding Dependencies}" Margin="10" MaxHeight="300" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"/>
                                            <TextBlock Text="{Binding Type}" FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Version, StringFormat={}v{0}}" FontSize="11" VerticalAlignment="Center" Margin="10,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Margin="0,0,0,20" Style="{DynamicResource StandardGroupBoxStyle}" Icon="⚡" Title="性能指标">
                    <ItemsControl ItemsSource="{Binding PerformanceMetrics}" Margin="10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <emoji:TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Value}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Status}" FontSize="11" Foreground="{DynamicResource SuccessColor}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Style="{DynamicResource StandardGroupBoxStyle}" Icon="📚" Title="已加载程序集">
                    <ListBox ItemsSource="{Binding AssemblyList}" Margin="10" MaxHeight="400">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="{Binding Version, StringFormat={}版本: {0}}" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </common:IconHeaderGroupBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
