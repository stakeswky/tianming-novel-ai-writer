<UserControl x:Class="TM.Framework.SystemSettings.DataCleanup.DataCleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TM.Framework.SystemSettings.DataCleanup"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="500">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ItemCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SelectAllButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="50"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="选择要清除的业务数据："
                   FontSize="14"
                   Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      Padding="0,0,10,0">
            <ItemsControl ItemsSource="{Binding Modules}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <layout:IconHeaderGroupBox Icon="{Binding Icon}" 
                                                   Title="{Binding Name}"
                                                   ShowCount="True"
                                                   Count="{Binding Items.Count}"
                                                   Margin="0,0,0,10"
                                                   Padding="10">
                            <layout:IconHeaderGroupBox.Style>
                                <Style TargetType="layout:IconHeaderGroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDangerous}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource WarningColor}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </layout:IconHeaderGroupBox.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ItemsControl Grid.Column="0" ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected}"
                                                      ToolTip="{Binding WarningMessage}"
                                                      Margin="0,4,15,4"
                                                      Cursor="Hand">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}"/>
                                                    <TextBlock Text=" ⚠️" Foreground="{DynamicResource WarningColor}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding RiskLevel}" Value="High">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Grid.Column="1" 
                                        Content="全选"
                                        Command="{Binding DataContext.SelectModuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SelectAllButtonStyle}"
                                        VerticalAlignment="Top"
                                        Margin="10,0,0,0"/>
                            </Grid>
                        </layout:IconHeaderGroupBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" 
                BorderThickness="0,1,0,0" 
                BorderBrush="{DynamicResource BorderBrush}"
                Margin="0,15,0,0"
                Padding="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="全选" 
                        Command="{Binding SelectAllCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Margin="0,0,10,0"
                        Padding="20,8"/>
                <Button Content="全不选" 
                        Command="{Binding SelectNoneCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Margin="0,0,10,0"
                        Padding="20,8"/>
                <Button Content="开始清理" 
                        Command="{Binding CleanupCommand}"
                        Style="{DynamicResource DangerButtonStyle}"
                        Padding="20,8"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource TextTertiary}"
                   FontSize="12"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Center"/>
    </Grid>
</UserControl>
