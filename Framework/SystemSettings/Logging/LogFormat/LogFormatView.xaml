<UserControl x:Class="TM.Framework.SystemSettings.Logging.LogFormat.LogFormatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:local="clr-namespace:TM.Framework.SystemSettings.Logging.LogFormat"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <common:IconHeaderGroupBox Icon="🎨" Title="格式模板编辑" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <TextBlock Text="使用占位符自定义日志格式：{timestamp}, {level}, {message}, {caller}, {threadid}, {processid}" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <TextBox Text="{Binding FormatTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{DynamicResource StandardTextBoxStyle}"
                            Height="80"
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            VerticalScrollBarVisibility="Auto"
                            Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="预设模板：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox ItemsSource="{Binding PresetTemplates}" Width="150" Height="36" Margin="0,0,10,0"/>
                        <Button Content="应用" 
                               Command="{Binding ApplyPresetCommand}"
                               CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="80" Height="36"/>
                    </StackPanel>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="⚙️" Title="格式配置" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="输出格式" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <ComboBox Grid.Column="1" Height="36"
                                 ItemsSource="{Binding OutputFormatTypes}"
                                 SelectedItem="{Binding OutputFormat, Mode=TwoWay}"
                                 Margin="10,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="时间戳格式" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <TextBox Grid.Column="1" Height="36" 
                                Text="{Binding TimestampFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{DynamicResource StandardTextBoxStyle}" Margin="10,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="字段分隔符" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <TextBox Grid.Column="1" Height="36" 
                                Text="{Binding FieldSeparator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{DynamicResource StandardTextBoxStyle}" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📐" Title="对齐和缩进" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <CheckBox Content="启用字段宽度对齐" IsChecked="{Binding EnableFieldAlignment, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="时间戳宽度" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <Slider Grid.Column="1" Minimum="10" Maximum="50" Value="{Binding TimestampWidth, Mode=TwoWay}" 
                               TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="10,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding TimestampWidth, StringFormat={}{0} 字符}" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="级别宽度" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <Slider Grid.Column="1" Minimum="5" Maximum="20" Value="{Binding LevelWidth, Mode=TwoWay}" 
                               TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="10,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding LevelWidth, StringFormat={}{0} 字符}" VerticalAlignment="Center"/>
                    </Grid>

                    <CheckBox Content="启用多行消息缩进" IsChecked="{Binding EnableMultilineIndent, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="缩进字符" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <TextBox Grid.Column="1" Height="36" 
                                Text="{Binding MultilineIndent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{DynamicResource StandardTextBoxStyle}" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="✅" Title="格式验证" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="验证模板" 
                               Command="{Binding ValidateCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding ValidationMessage}" 
                                  VerticalAlignment="Center" 
                                  FontWeight="Bold"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding ValidationResults}" Height="120">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Width="60">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="错误"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerColor}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                            <Setter Property="Text" Value="警告"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource WarningColor}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Info">
                                                            <Setter Property="Text" Value="信息"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource InfoColor}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Message}" FontWeight="Bold"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Suggestion}" 
                                              Foreground="{DynamicResource TextSecondary}" 
                                              FontSize="12"
                                              Margin="60,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🔧" Title="自定义字段" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <TextBlock Text="添加自定义字段以扩展日志格式（使用 {fieldname} 在模板中引用）" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="添加字段" 
                               Command="{Binding AddCustomFieldCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36" Margin="0,0,10,0"/>
                        <Button Content="删除字段" 
                               Command="{Binding RemoveCustomFieldCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding CustomFields}" Height="120">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Placeholder, StringFormat={}占位符: \{{0}\}}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DataType}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Description}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📚" Title="模板库管理" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="保存模板" 
                               Command="{Binding SaveAsTemplateCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36" Margin="0,0,10,0"/>
                        <Button Content="加载模板" 
                               Command="{Binding LoadTemplateCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36" Margin="0,0,10,0"/>
                        <Button Content="删除模板" 
                               Command="{Binding DeleteTemplateCommand}"
                               Style="{DynamicResource DangerButtonStyle}"
                               Width="100" Height="36" Margin="0,0,10,0"/>
                        <Button Content="导出" 
                               Command="{Binding ExportTemplateCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="80" Height="36" Margin="0,0,10,0"/>
                        <Button Content="导入" 
                               Command="{Binding ImportTemplateCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="80" Height="36"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding SavedTemplates}" Height="150">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Width="200"/>
                                        <TextBlock Text="{Binding UsageCount, StringFormat={}使用 {0} 次}" Width="100" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding LastUsedTime, StringFormat={}最后使用: {0:MM-dd HH:mm}}" Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Template}" 
                                              FontFamily="Consolas" 
                                              FontSize="11"
                                              Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Text="{Binding Description}" 
                                              FontSize="11"
                                              Foreground="{DynamicResource TextTertiary}"
                                              Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="👁️" Title="实时预览" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <TextBlock Text="预览效果（基于示例数据）：" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <Border Background="{DynamicResource Surface}" 
                           BorderBrush="{DynamicResource BorderBrush}" 
                           BorderThickness="1" 
                           CornerRadius="6" 
                           Padding="10">
                        <TextBlock Text="{Binding PreviewText}" 
                                  FontFamily="Consolas" 
                                  FontSize="12"
                                  TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="重置" 
                       Command="{Binding ResetCommand}"
                       Style="{DynamicResource SecondaryButtonStyle}"
                       Width="100" Height="36" Margin="0,0,10,0"/>
                <Button Content="保存" 
                       Command="{Binding SaveCommand}"
                       Style="{DynamicResource PrimaryButtonStyle}"
                       Width="100" Height="36"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
