<UserControl x:Class="TM.Framework.SystemSettings.Logging.LogRotation.LogRotationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:local="clr-namespace:TM.Framework.SystemSettings.Logging.LogRotation"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <UserControl.DataContext>
        <local:LogRotationViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <common:IconHeaderGroupBox Icon="🔄" Title="轮转规则" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="轮转类型" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <ComboBox Grid.Column="1" Height="36"
                                 ItemsSource="{Binding RotationTypes}"
                                 SelectedItem="{Binding RotationType, Mode=TwoWay}"
                                 Margin="10,0,0,0"/>
                    </Grid>

                    <CheckBox Content="启用按大小轮转" IsChecked="{Binding EnableSizeRotation, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="最大文件大小" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <Slider Grid.Column="1" Minimum="1" Maximum="1000" Value="{Binding MaxFileSizeMB, Mode=TwoWay}" 
                               TickFrequency="10" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="10,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding MaxFileSizeMB, StringFormat={}{0} MB}" VerticalAlignment="Center"/>
                    </Grid>

                    <CheckBox Content="启用按时间轮转" IsChecked="{Binding EnableTimeRotation, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="时间间隔" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <ComboBox Grid.Column="1" Height="36"
                                 ItemsSource="{Binding TimeIntervals}"
                                 SelectedItem="{Binding TimeInterval, Mode=TwoWay}"
                                 Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="💾" Title="保留策略" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="最大保留数量" Grid.Column="0" VerticalAlignment="Center" Width="120"/>
                        <Slider Grid.Column="1" Minimum="1" Maximum="100" Value="{Binding MaxRetainCount, Mode=TwoWay}" 
                               TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="10,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding MaxRetainCount, StringFormat={}{0} 个文件}" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="最大保留天数" Grid.Column="0" VerticalAlignment="Center" Width="120"/>
                        <Slider Grid.Column="1" Minimum="1" Maximum="365" Value="{Binding MaxRetainDays, Mode=TwoWay}" 
                               TickFrequency="30" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="10,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding MaxRetainDays, StringFormat={}{0} 天}" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="最大保留大小" Grid.Column="0" VerticalAlignment="Center" Width="120"/>
                        <Slider Grid.Column="1" Minimum="100" Maximum="10240" Value="{Binding MaxRetainSizeMB, Mode=TwoWay}" 
                               TickFrequency="100" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="10,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding MaxRetainSizeMB, StringFormat={}{0} MB}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📦" Title="压缩配置" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <CheckBox Content="启用自动压缩" IsChecked="{Binding EnableCompression, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="压缩格式" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <ComboBox Grid.Column="1" Height="36"
                                 ItemsSource="{Binding CompressionTypes}"
                                 SelectedItem="{Binding CompressionType, Mode=TwoWay}"
                                 Margin="10,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="压缩延迟天数" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <Slider Grid.Column="1" Minimum="1" Maximum="30" Value="{Binding CompressAfterDays, Mode=TwoWay}" 
                               TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="10,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding CompressAfterDays, StringFormat={}{0} 天后压缩}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🧹" Title="清理规则" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <CheckBox Content="启用自动清理" IsChecked="{Binding EnableAutoCleanup, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="清理策略" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <ComboBox Grid.Column="1" Height="36"
                                 ItemsSource="{Binding CleanupStrategies}"
                                 SelectedItem="{Binding CleanupStrategy, Mode=TwoWay}"
                                 Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📁" Title="归档配置" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="归档路径" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <TextBox Grid.Column="1" Height="36" 
                                Text="{Binding ArchivePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{DynamicResource StandardTextBoxStyle}" Margin="10,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="文件命名模式" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <ComboBox Grid.Column="1" Height="36"
                                 ItemsSource="{Binding FileNamingPatterns}"
                                 SelectedItem="{Binding FileNamingPattern, Mode=TwoWay}"
                                 Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📊" Title="当前日志统计" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="日志文件数量" Grid.Column="0" VerticalAlignment="Center" Width="120"/>
                        <TextBlock Grid.Column="1" Text="{Binding CurrentLogFilesCount, StringFormat={}{0} 个文件}" 
                                  FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="日志总大小" Grid.Column="0" VerticalAlignment="Center" Width="120"/>
                        <TextBlock Grid.Column="1" Text="{Binding CurrentLogsTotalSizeMB, StringFormat={}{0} MB}" 
                                  FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>

                    <Button Content="刷新统计" 
                           Command="{Binding RefreshStatsCommand}"
                           Style="{DynamicResource SecondaryButtonStyle}"
                           Width="120" Height="36" HorizontalAlignment="Left"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="💽" Title="存储空间监控" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <CheckBox Content="启用存储空间监控" IsChecked="{Binding EnableStorageMonitoring, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="警告阈值" Grid.Column="0" VerticalAlignment="Center" Width="120"/>
                        <Slider Grid.Column="1" Minimum="50" Maximum="95" Value="{Binding WarningThresholdPercentage, Mode=TwoWay}" 
                               TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="10,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding WarningThresholdPercentage, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="严重阈值" Grid.Column="0" VerticalAlignment="Center" Width="120"/>
                        <Slider Grid.Column="1" Minimum="60" Maximum="99" Value="{Binding CriticalThresholdPercentage, Mode=TwoWay}" 
                               TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="10,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding CriticalThresholdPercentage, StringFormat={}{0}%}" VerticalAlignment="Center"/>
                    </Grid>

                    <Border Background="{DynamicResource Surface}" 
                           BorderBrush="{DynamicResource BorderBrush}" 
                           BorderThickness="1" 
                           CornerRadius="6" 
                           Padding="10"
                           Margin="0,0,0,10">
                        <StackPanel>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="磁盘路径：" Width="100"/>
                                <TextBlock Grid.Column="1" Text="{Binding StorageInfo.DrivePath}" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="总空间：" Width="100"/>
                                <TextBlock Grid.Column="1" Text="{Binding StorageInfo.TotalSpaceGB, StringFormat={}{0} GB}"/>
                            </Grid>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="已用空间：" Width="100"/>
                                <TextBlock Grid.Column="1" Text="{Binding StorageInfo.UsedSpaceGB, StringFormat={}{0} GB ({1:F1}%)}" />
                            </Grid>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="可用空间：" Width="100"/>
                                <TextBlock Grid.Column="1" Text="{Binding StorageInfo.FreeSpaceGB, StringFormat={}{0} GB}"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="状态：" Width="100"/>
                                <TextBlock Grid.Column="1" Text="{Binding StorageInfo.StatusMessage}" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Button Content="检查存储空间" 
                           Command="{Binding CheckStorageCommand}"
                           Style="{DynamicResource SecondaryButtonStyle}"
                           Width="120" Height="36" HorizontalAlignment="Left"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🔮" Title="轮转预测分析" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <Border Background="{DynamicResource Surface}" 
                           BorderBrush="{DynamicResource BorderBrush}" 
                           BorderThickness="1" 
                           CornerRadius="6" 
                           Padding="10">
                        <StackPanel>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="预测下次轮转：" Width="120"/>
                                <TextBlock Grid.Column="1" Text="{Binding Prediction.PredictedNextRotation, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="距离轮转：" Width="120"/>
                                <TextBlock Grid.Column="1" Text="{Binding Prediction.TimeUntilNextRotation}"/>
                            </Grid>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="日均增长：" Width="120"/>
                                <TextBlock Grid.Column="1" Text="{Binding Prediction.AverageDailyGrowthMB, StringFormat={}{0:F2} MB/天}"/>
                            </Grid>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="预测存储使用：" Width="120"/>
                                <TextBlock Grid.Column="1" Text="{Binding Prediction.PredictedStorageUsageMB, StringFormat={}{0} MB}"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="建议：" Width="120"/>
                                <TextBlock Grid.Column="1" Text="{Binding Prediction.RecommendedAction}" Foreground="{DynamicResource InfoColor}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📜" Title="轮转历史记录" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="打开日志目录" 
                               Command="{Binding ViewHistoryCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36" Margin="0,0,10,0"/>
                        <Button Content="清空历史" 
                               Command="{Binding ClearHistoryCommand}"
                               Style="{DynamicResource DangerButtonStyle}"
                               Width="100" Height="36" Margin="0,0,10,0"/>
                        <Button Content="导出日志" 
                               Command="{Binding ExportHistoryCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding RotationHistories}" Height="150">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="{Binding RotationTime, StringFormat={}时间: {0:MM-dd HH:mm:ss}}" Width="180" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Trigger, StringFormat={}触发: {0}}" Width="100" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding DurationMs, StringFormat={}耗时: {0}ms}" Width="100" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding FileSizeBytes, StringFormat={}大小: {0:N0} 字节}" Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding OriginalFileName, StringFormat={}原始: {0}}" Margin="0,0,10,0" Foreground="{DynamicResource TextTertiary}"/>
                                        <TextBlock Text="→" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding RotatedFileName, StringFormat={}轮转: {0}}" Foreground="{DynamicResource TextTertiary}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="💡" Title="清理建议" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <Button Content="生成清理建议" 
                           Command="{Binding GenerateCleanupRecommendationsCommand}"
                           Style="{DynamicResource SecondaryButtonStyle}"
                           Width="120" Height="36" HorizontalAlignment="Left"
                           Margin="0,0,0,10"/>

                    <ListBox ItemsSource="{Binding CleanupRecommendations}" Height="150">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="{Binding Priority, StringFormat={}[{0}]}" Width="60" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Action}" FontWeight="Bold" Width="150"/>
                                        <TextBlock Text="{Binding FilesToDelete, StringFormat={}文件: {0}}" Width="100" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding EstimatedSpaceToFree, StringFormat={}可释放: {0} MB}" Foreground="{DynamicResource SuccessColor}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Reason}" Foreground="{DynamicResource TextTertiary}" FontSize="12"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="手动轮转" 
                       Command="{Binding ManualRotateCommand}"
                       Style="{DynamicResource SecondaryButtonStyle}"
                       Width="100" Height="36" Margin="0,0,10,0"/>
                <Button Content="立即清理" 
                       Command="{Binding CleanupCommand}"
                       Style="{DynamicResource SecondaryButtonStyle}"
                       Width="100" Height="36" Margin="0,0,10,0"/>
                <Button Content="保存" 
                       Command="{Binding SaveCommand}"
                       Style="{DynamicResource PrimaryButtonStyle}"
                       Width="100" Height="36"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
