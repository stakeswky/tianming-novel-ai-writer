<UserControl x:Class="TM.Framework.SystemSettings.Logging.LogLevel.LogLevelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:local="clr-namespace:TM.Framework.SystemSettings.Logging.LogLevel"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <common:IconHeaderGroupBox Icon="📊" Title="全局日志级别" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <TextBlock Text="设置全局默认日志级别，影响所有未单独配置的模块" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="全局级别" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <ComboBox Grid.Column="1" Height="36"
                                 ItemsSource="{Binding LogLevels}"
                                 SelectedItem="{Binding GlobalLevel, Mode=TwoWay}"
                                 Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🔒" Title="最低级别限制" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <TextBlock Text="设置允许输出的最低日志级别，低于此级别的日志将被过滤" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="最低级别" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <ComboBox Grid.Column="1" Height="36"
                                 ItemsSource="{Binding LogLevels}"
                                 SelectedItem="{Binding MinimumLevel, Mode=TwoWay}"
                                 Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📖" Title="级别优先级说明" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <TextBlock Text="日志级别从低到高排列如下：" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <StackPanel Margin="0,0,0,5">
                        <TextBlock Margin="5">
                            <Run Text="• Trace" FontWeight="Bold" Foreground="{DynamicResource TextTertiary}"/> - 最详细的跟踪信息
                        </TextBlock>
                        <TextBlock Margin="5">
                            <Run Text="• Debug" FontWeight="Bold" Foreground="{DynamicResource InfoColor}"/> - 调试信息
                        </TextBlock>
                        <TextBlock Margin="5">
                            <Run Text="• Info" FontWeight="Bold" Foreground="{DynamicResource SuccessColor}"/> - 一般信息
                        </TextBlock>
                        <TextBlock Margin="5">
                            <Run Text="• Warning" FontWeight="Bold" Foreground="{DynamicResource WarningColor}"/> - 警告信息
                        </TextBlock>
                        <TextBlock Margin="5">
                            <Run Text="• Error" FontWeight="Bold" Foreground="{DynamicResource DangerColor}"/> - 错误信息
                        </TextBlock>
                        <TextBlock Margin="5">
                            <Run Text="• Fatal" FontWeight="Bold" Foreground="{DynamicResource DangerHover}"/> - 致命错误
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📦" Title="模块级别配置" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <TextBlock Text="为特定模块单独配置日志级别，优先级高于全局设置" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="添加模块" 
                               Command="{Binding AddModuleCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36" Margin="0,0,10,0"/>
                        <Button Content="删除模块" 
                               Command="{Binding RemoveModuleCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding ModuleLevels}" Height="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ModuleName}" 
                                              FontWeight="Bold" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" Height="36"
                                             ItemsSource="{Binding DataContext.LogLevels, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             SelectedItem="{Binding Level, Mode=TwoWay}"
                                             Margin="10,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📊" Title="级别统计分析" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <TextBlock Text="实时统计各级别日志数量和分布（自动模拟）" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,15"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="刷新统计" 
                               Command="{Binding RefreshStatsCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36" Margin="0,0,10,0"/>
                        <Button Content="重置统计" 
                               Command="{Binding ResetStatsCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding LevelStatisticsItems}" Height="250">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" 
                                       CornerRadius="6" Padding="15" Margin="0,5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Level}" 
                                                  FontWeight="Bold" FontSize="14" 
                                                  Foreground="{Binding Color}" 
                                                  VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1" Text="{Binding Count, StringFormat={}{0} 条}" 
                                                  VerticalAlignment="Center" Margin="10,0"/>

                                        <ProgressBar Grid.Column="2" Value="{Binding Percentage}" 
                                                    Maximum="100" Height="20" 
                                                    VerticalAlignment="Center" Margin="10,0"/>

                                        <TextBlock Grid.Column="3" Text="{Binding Percentage, StringFormat={}{0:F1}%}" 
                                                  VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🎯" Title="预设方案" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <TextBlock Text="快速应用不同环境的级别配置" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{DynamicResource Surface}" 
                               CornerRadius="6" Padding="15" Margin="0,0,10,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <emoji:TextBlock Text="💻" FontSize="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="开发环境" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Trace级别，全部详细日志" FontSize="11" 
                                          Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                <Button Content="应用预设" Command="{Binding ApplyPresetCommand}" CommandParameter="Development"
                                       Style="{DynamicResource PrimaryButtonStyle}" Width="100" Height="36"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{DynamicResource Surface}" 
                               CornerRadius="6" Padding="15" Margin="5,0,5,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <emoji:TextBlock Text="🧪" FontSize="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="测试环境" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Debug级别，适度调试" FontSize="11" 
                                          Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                <Button Content="应用预设" Command="{Binding ApplyPresetCommand}" CommandParameter="Testing"
                                       Style="{DynamicResource SecondaryButtonStyle}" Width="100" Height="36"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{DynamicResource Surface}" 
                               CornerRadius="6" Padding="15" Margin="10,0,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <emoji:TextBlock Text="🚀" FontSize="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="生产环境" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Info级别，最小日志" FontSize="11" 
                                          Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                <Button Content="应用预设" Command="{Binding ApplyPresetCommand}" CommandParameter="Production"
                                       Style="{DynamicResource SecondaryButtonStyle}" Width="100" Height="36"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📜" Title="级别变更历史" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <TextBlock Text="记录所有级别调整操作，支持审计追溯" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,15"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="查看历史" 
                               Command="{Binding ViewHistoryCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36" Margin="0,0,10,0"/>
                        <Button Content="清空历史" 
                               Command="{Binding ClearHistoryCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding ChangeHistory}" Height="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Timestamp, StringFormat={}{0:MM-dd HH:mm:ss}}" 
                                                  FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Target}" FontWeight="Bold" Margin="0,0,10,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <TextBlock Text="{Binding OldLevel}" Margin="0,0,5,0"/>
                                        <TextBlock Text="→" Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding NewLevel}" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Reason}" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="重置" 
                       Command="{Binding ResetCommand}"
                       Style="{DynamicResource SecondaryButtonStyle}"
                       Width="100" Height="36" Margin="0,0,10,0"/>
                <Button Content="保存" 
                       Command="{Binding SaveCommand}"
                       Style="{DynamicResource PrimaryButtonStyle}"
                       Width="100" Height="36"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
