<UserControl x:Class="TM.Framework.SystemSettings.Logging.LogOutput.LogOutputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:local="clr-namespace:TM.Framework.SystemSettings.Logging.LogOutput"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <common:IconHeaderGroupBox Icon="📁" Title="文件输出配置" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <CheckBox Content="启用文件输出" IsChecked="{Binding EnableFileOutput, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="输出路径" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <TextBox Grid.Column="1" Height="36" 
                                Text="{Binding FileOutputPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{DynamicResource StandardTextBoxStyle}" Margin="10,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="命名模式" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <TextBox Grid.Column="1" Height="36" 
                                Text="{Binding FileNamingPattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{DynamicResource StandardTextBoxStyle}" Margin="10,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="文件编码" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <ComboBox Grid.Column="1" Height="36"
                                 ItemsSource="{Binding FileEncodings}"
                                 SelectedItem="{Binding FileEncoding, Mode=TwoWay}"
                                 Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="💻" Title="控制台输出配置" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <CheckBox Content="启用控制台输出" IsChecked="{Binding EnableConsoleOutput, Mode=TwoWay}" Margin="0,0,0,10"/>
                    <CheckBox Content="启用颜色编码" IsChecked="{Binding ConsoleColorCoding, Mode=TwoWay}" Margin="0,0,0,0"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📋" Title="系统事件日志配置" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <CheckBox Content="启用系统事件日志" IsChecked="{Binding EnableEventLog, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="事件源名称" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <TextBox Grid.Column="1" Height="36" 
                                Text="{Binding EventLogSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{DynamicResource StandardTextBoxStyle}" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🌐" Title="远程输出配置" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <CheckBox Content="启用远程输出" IsChecked="{Binding EnableRemoteOutput, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="传输协议" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <ComboBox Grid.Column="1" Height="36"
                                 ItemsSource="{Binding RemoteProtocols}"
                                 SelectedItem="{Binding RemoteProtocol, Mode=TwoWay}"
                                 Margin="10,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="远程地址" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <TextBox Grid.Column="1" Height="36" 
                                Text="{Binding RemoteAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{DynamicResource StandardTextBoxStyle}" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="⚙️" Title="通用配置" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="缓冲区大小" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <Slider Grid.Column="1" Minimum="512" Maximum="8192" Value="{Binding BufferSize, Mode=TwoWay}" 
                               TickFrequency="512" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="10,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding BufferSize, StringFormat={}{0} KB}" VerticalAlignment="Center"/>
                    </Grid>

                    <CheckBox Content="启用异步输出" IsChecked="{Binding EnableAsyncOutput, Mode=TwoWay}" Margin="0,0,0,0"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🎯" Title="输出目标管理" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="添加目标" 
                               Command="{Binding AddTargetCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36" Margin="0,0,10,0"/>
                        <Button Content="删除目标" 
                               Command="{Binding RemoveTargetCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding OutputTargets}" Height="150">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Type}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    <CheckBox Grid.Column="2" Content="启用" IsChecked="{Binding IsEnabled, Mode=TwoWay}" Margin="10,0,0,0"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Priority, StringFormat={}优先级: {0}}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🧪" Title="输出目标测试" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="测试全部" 
                               Command="{Binding TestOutputCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36" Margin="0,0,10,0"/>
                        <Button Content="测试文件输出" 
                               Command="{Binding TestFileOutputCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="120" Height="36" Margin="0,0,10,0"/>
                        <Button Content="测试远程输出" 
                               Command="{Binding TestRemoteOutputCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="120" Height="36"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding TestResults}" Height="150">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="{Binding TargetName}" FontWeight="Bold" Width="150"/>
                                        <TextBlock Text="{Binding Status}" Width="80"/>
                                        <TextBlock Text="{Binding ResponseTime, StringFormat={}耗时: {0}ms}" Margin="10,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Message}" Foreground="{DynamicResource TextSecondary}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📊" Title="输出统计信息" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="刷新统计" 
                               Command="{Binding RefreshStatsCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36" Margin="0,0,10,0"/>
                        <Button Content="重置统计" 
                               Command="{Binding ResetStatsCommand}"
                               Style="{DynamicResource DangerButtonStyle}"
                               Width="100" Height="36"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Statistics}" Height="150">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding StatusIcon}" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TargetName}" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding SuccessRate, StringFormat={}成功率: {0:F1}%}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding TotalAttempts, StringFormat={}总计: {0}}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Grid.Column="4" Text="{Binding AverageResponseTime, StringFormat={}平均: {0}ms}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🔄" Title="失败重试配置" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <CheckBox Content="启用自动重试" IsChecked="{Binding EnableRetry, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="最大重试次数" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <Slider Grid.Column="1" Minimum="1" Maximum="10" Value="{Binding MaxRetryAttempts, Mode=TwoWay}" 
                               TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="10,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding MaxRetryAttempts, StringFormat={}{0} 次}" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="重试间隔" Grid.Column="0" VerticalAlignment="Center" Width="100"/>
                        <Slider Grid.Column="1" Minimum="500" Maximum="10000" Value="{Binding RetryIntervalMs, Mode=TwoWay}" 
                               TickFrequency="500" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="10,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding RetryIntervalMs, StringFormat={}{0} ms}" VerticalAlignment="Center"/>
                    </Grid>

                    <CheckBox Content="启用指数退避策略" IsChecked="{Binding EnableExponentialBackoff, Mode=TwoWay}" Margin="0,0,0,0"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="⚠️" Title="失败记录" Margin="0,0,0,20" TitleFontWeight="Bold">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="重试失败项" 
                               Command="{Binding RetryFailedCommand}"
                               Style="{DynamicResource SecondaryButtonStyle}"
                               Width="100" Height="36" Margin="0,0,10,0"/>
                        <Button Content="清空记录" 
                               Command="{Binding ClearFailuresCommand}"
                               Style="{DynamicResource DangerButtonStyle}"
                               Width="100" Height="36"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding FailureRecords}" Height="150">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="{Binding TargetName}" FontWeight="Bold" Width="150"/>
                                        <TextBlock Text="{Binding FailureTime, StringFormat={}时间: {0:MM-dd HH:mm:ss}}" Width="180" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding RetryAttempts, StringFormat={}重试: {0}次}" Width="80"/>
                                        <TextBlock Width="60">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="未解决"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerColor}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsResolved}" Value="True">
                                                            <Setter Property="Text" Value="已解决"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerColor}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="测试输出" 
                       Command="{Binding TestOutputCommand}"
                       Style="{DynamicResource SecondaryButtonStyle}"
                       Width="100" Height="36" Margin="0,0,10,0"/>
                <Button Content="保存" 
                       Command="{Binding SaveCommand}"
                       Style="{DynamicResource PrimaryButtonStyle}"
                       Width="100" Height="36"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
