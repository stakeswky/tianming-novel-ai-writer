<UserControl x:Class="TM.Framework.SystemSettings.Proxy.ProxyTest.ProxyTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout">

    <ScrollViewer Style="{DynamicResource StandardScrollViewerStyle}">
        <StackPanel Margin="5">
            <layout:IconHeaderGroupBox Icon="✅" Title="测试项" Margin="0,0,0,15">
                <StackPanel>
                    <CheckBox Content="连通性测试" IsChecked="{Binding TestConnectivity}" Margin="0,0,0,5"/>
                    <CheckBox Content="延迟测试" IsChecked="{Binding TestLatency}" Margin="0,0,0,5"/>
                    <CheckBox Content="速度测试" IsChecked="{Binding TestSpeed}" Margin="0,0,0,5"/>
                    <CheckBox Content="IP检测" IsChecked="{Binding TestIP}" Margin="0,0,0,5"/>
                    <CheckBox Content="DNS泄漏检测" IsChecked="{Binding TestDNS}"/>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <Button Content="开始测试" Command="{Binding StartTestCommand}" 
                    Style="{DynamicResource PrimaryButtonStyle}" IsEnabled="{Binding IsTesting, Converter={StaticResource InverseBoolConverter}}" Margin="0,0,0,15"/>

            <Button Content="一键验证（应用内是否走代理）" Command="{Binding OneClickVerifyCommand}"
                    Style="{DynamicResource SecondaryButtonStyle}" IsEnabled="{Binding IsTesting, Converter={StaticResource InverseBoolConverter}}" Margin="0,0,0,15"/>

            <layout:IconHeaderGroupBox Icon="📊" Title="测试结果" Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="15">
                            <StackPanel>
                                <emoji:TextBlock Text="✅" FontSize="32" HorizontalAlignment="Center"/>
                                <TextBlock Text="连通性" TextAlignment="Center" Margin="0,10,0,5"/>
                                <TextBlock Text="{Binding LastResult.IsConnected, StringFormat={}{0}}" 
                                           FontSize="18" FontWeight="Bold" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="15">
                            <StackPanel>
                                <emoji:TextBlock Text="⏱️" FontSize="32" HorizontalAlignment="Center"/>
                                <TextBlock Text="延迟" TextAlignment="Center" Margin="0,10,0,5"/>
                                <TextBlock Text="{Binding LastResult.Latency, StringFormat={}{0}ms}" 
                                           FontSize="18" FontWeight="Bold" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="15">
                            <StackPanel>
                                <emoji:TextBlock Text="⚡" FontSize="32" HorizontalAlignment="Center"/>
                                <TextBlock Text="速度" TextAlignment="Center" Margin="0,10,0,5"/>
                                <TextBlock Text="{Binding LastResult.DownloadSpeed, StringFormat={}{0:F2} MB/s}" 
                                           FontSize="18" FontWeight="Bold" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="15">
                            <StackPanel>
                                <emoji:TextBlock Text="🌍" FontSize="32" HorizontalAlignment="Center"/>
                                <TextBlock Text="匿名性评分" TextAlignment="Center" Margin="0,10,0,5"/>
                                <TextBlock Text="{Binding LastResult.AnonymityScore, StringFormat={}{0}分}" 
                                           FontSize="18" FontWeight="Bold" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="出口IP:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding LastResult.ExitIP}" Margin="0,5,0,10"/>

                        <TextBlock Text="位置:" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding LastResult.Location}" Margin="0,5,0,10"/>
                    </StackPanel>
                </StackPanel>
            </layout:IconHeaderGroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
