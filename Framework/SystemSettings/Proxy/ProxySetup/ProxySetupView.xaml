<UserControl x:Class="TM.Framework.SystemSettings.Proxy.ProxySetup.ProxySetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <ScrollViewer Style="{DynamicResource StandardScrollViewerStyle}">
        <StackPanel Margin="5">
            <TextBlock Text="代理设置" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20"/>

            <common:IconHeaderGroupBox Icon="🌐" Title="基本配置" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="代理类型:" VerticalAlignment="Center" Width="120"/>
                        <ComboBox ItemsSource="{Binding ProxyTypes}" SelectedItem="{Binding SelectedProxyType}" Width="200"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="服务器地址:" VerticalAlignment="Center" Width="120"/>
                        <TextBox Text="{Binding Server}" Width="300"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="端口:" VerticalAlignment="Center" Width="120"/>
                        <TextBox Text="{Binding Port}" Width="100"/>
                    </StackPanel>

                    <CheckBox Content="启用系统代理" IsChecked="{Binding EnableSystemProxy}" Margin="0,10,0,0"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🔒" Title="认证设置" Margin="0,0,0,20">
                <StackPanel>
                    <CheckBox Content="需要身份验证" IsChecked="{Binding RequiresAuth}" Margin="0,0,0,10"/>

                    <StackPanel Visibility="{Binding RequiresAuth, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="用户名:" VerticalAlignment="Center" Width="120"/>
                            <TextBox Text="{Binding Username}" Width="300"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="密码:" VerticalAlignment="Center" Width="120"/>
                            <PasswordBox x:Name="PasswordBox" Width="300" PasswordChanged="PasswordBox_PasswordChanged"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📋" Title="绕过列表" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox Text="{Binding NewBypass}" Width="300" Margin="0,0,10,0"/>
                        <Button Content="添加" Command="{Binding AddBypassCommand}" Style="{DynamicResource SecondaryButtonStyle}"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding BypassList}" Height="150">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="删除" 
                                            Command="{Binding DataContext.RemoveBypassCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Style="{DynamicResource DangerButtonStyle}" Padding="5,2" Margin="5,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📝" Title="PAC脚本" Margin="0,0,0,20">
                <StackPanel>
                    <CheckBox Content="启用PAC脚本" IsChecked="{Binding PACEnabled}" Margin="0,0,0,10"/>

                    <StackPanel Visibility="{Binding PACEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button Content="加载默认模板" Command="{Binding LoadDefaultPACCommand}" 
                                Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,0,10" HorizontalAlignment="Left"/>

                        <TextBox Text="{Binding PACScript}" Height="200" AcceptsReturn="True" 
                                 VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📜" Title="配置历史" Margin="0,0,0,20">
                <StackPanel>
                    <Button Content="查看配置历史" Command="{Binding ViewHistoryCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,0,10" HorizontalAlignment="Left"/>

                    <ListBox ItemsSource="{Binding History}" Height="150" Visibility="{Binding History.Count, Converter={StaticResource CountToVisibilityConverter}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='{}{0:MM-dd HH:mm:ss}'}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ModifiedFields}" VerticalAlignment="Center" Margin="10,0"/>
                                    <Button Grid.Column="2" Content="恢复" 
                                            Command="{Binding DataContext.RestoreConfigCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Style="{DynamicResource SecondaryButtonStyle}" Padding="5,2"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📊" Title="使用统计" Margin="0,0,0,20">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="总启用次数" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Text="{Binding Statistics.TotalEnableCount}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="成功率" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Text="{Binding Statistics.SuccessRate, StringFormat='{}{0:F1}%'}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="平均延迟" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Text="{Binding Statistics.AverageLatency, StringFormat='{}{0:F0}ms'}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="总流量" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Text="{Binding Statistics.TotalTrafficFormatted}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                    <Button Content="查看详细统计" Command="{Binding ViewStatisticsCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Margin="0,10,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="⚡" Title="预设方案" Margin="0,0,0,20">
                <StackPanel>
                    <Button Content="保存当前为预设" Command="{Binding SavePresetCommand}" 
                            Style="{DynamicResource PrimaryButtonStyle}" Margin="0,0,0,10" HorizontalAlignment="Left"/>

                    <ListBox ItemsSource="{Binding Presets}" Height="150" Visibility="{Binding Presets.Count, Converter={StaticResource CountToVisibilityConverter}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <emoji:TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="24" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="应用" 
                                            Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Style="{DynamicResource PrimaryButtonStyle}" Padding="5,2" Margin="5,0"/>
                                    <Button Grid.Column="3" Content="删除" 
                                            Command="{Binding DataContext.DeletePresetCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Style="{DynamicResource DangerButtonStyle}" Padding="5,2"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="💡" Title="智能推荐" Margin="0,0,0,20">
                <StackPanel>
                    <Button Content="生成优化建议" Command="{Binding GenerateRecommendationCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,0,10" HorizontalAlignment="Left"/>

                    <ItemsControl ItemsSource="{Binding Recommendations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}" 
                                        BorderBrush="{DynamicResource BorderBrush}" 
                                        BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding Reason}" FontSize="11" Foreground="{DynamicResource TextTertiary}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button Content="保存配置" Command="{Binding SaveCommand}" 
                        Style="{DynamicResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
                <Button Content="测试连接" Command="{Binding TestCommand}" 
                        Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                <Button Content="对比配置" Command="{Binding CompareConfigsCommand}" 
                        Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                <Button Content="导出报告" Command="{Binding ExportReportCommand}" 
                        Style="{DynamicResource SecondaryButtonStyle}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
