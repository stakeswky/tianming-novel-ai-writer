<UserControl x:Class="TM.Framework.SystemSettings.Proxy.ProxyRules.ProxyRulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout">

    <ScrollViewer Style="{DynamicResource StandardScrollViewerStyle}">
        <StackPanel Margin="5">
            <layout:IconHeaderGroupBox Icon="🛠️" Title="快捷操作" Margin="0,0,0,15">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="添加规则" Command="{Binding AddRuleCommand}" Style="{DynamicResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
                        <Button Content="导入" Command="{Binding ImportCommand}" Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                        <Button Content="导出" Command="{Binding ExportCommand}" Style="{DynamicResource SecondaryButtonStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="广告屏蔽" Command="{Binding LoadTemplateCommand}" CommandParameter="ad_block" 
                                Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,5,0"/>
                        <Button Content="国内直连" Command="{Binding LoadTemplateCommand}" CommandParameter="china_direct" 
                                Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,5,0"/>
                        <Button Content="国外代理" Command="{Binding LoadTemplateCommand}" CommandParameter="foreign_proxy" 
                                Style="{DynamicResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" 
                     Width="300" HorizontalAlignment="Left" Margin="0,0,0,15"/>

            <layout:IconHeaderGroupBox Icon="📋" Title="规则列表">
                <ListBox ItemsSource="{Binding Rules}" SelectedItem="{Binding SelectedRule}" Height="500">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" 
                                              Command="{Binding DataContext.ToggleRuleCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                              CommandParameter="{Binding}" Margin="0,0,10,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1" Text="{Binding Type}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Pattern}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Action}" VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="5,0">
                                        <Button Content="↑" Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}" Style="{DynamicResource SecondaryButtonStyle}" Padding="5,2" Margin="0,0,2,0"/>
                                        <Button Content="↓" Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}" Style="{DynamicResource SecondaryButtonStyle}" Padding="5,2"/>
                                    </StackPanel>

                                    <Button Grid.Column="5" Content="删除" 
                                            Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Style="{DynamicResource DangerButtonStyle}" Padding="5,2"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </layout:IconHeaderGroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
