<UserControl x:Class="TM.Framework.SystemSettings.Proxy.ProxyChain.ProxyChainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderBrush}" 
                BorderThickness="0,0,1,0" Padding="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="🔗 代理链" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

                <Button Grid.Row="1" Content="创建代理链" Command="{Binding CreateChainCommand}" Style="{DynamicResource PrimaryButtonStyle}" 
                        HorizontalAlignment="Stretch" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="2" Style="{DynamicResource StandardScrollViewerStyle}">
                    <ListBox ItemsSource="{Binding Chains}" SelectedItem="{Binding SelectedChain}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="0,0,0,5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="{Binding Nodes.Count, StringFormat=节点数: {0}}" 
                                                   FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding Strategy}" 
                                                   FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="测试" Command="{Binding TestChainCommand}" CommandParameter="{Binding SelectedChain}"
                            Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                    <Button Content="删除" Command="{Binding DeleteChainCommand}" CommandParameter="{Binding SelectedChain}"
                            Style="{DynamicResource DangerButtonStyle}" Margin="0,0,10,0"/>
                    <Button Content="设为生效" Command="{Binding SetActiveChainCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" Style="{DynamicResource StandardScrollViewerStyle}">
            <StackPanel Margin="5" Visibility="{Binding HasSelectedChain, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding SelectedChain.Name}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"/>

                <layout:IconHeaderGroupBox Icon="⚖️" Title="负载均衡策略" Margin="0,0,0,15">
                    <StackPanel>
                        <RadioButton Content="轮询 (RoundRobin)" GroupName="Strategy" Margin="0,0,0,5"/>
                        <RadioButton Content="随机 (Random)" GroupName="Strategy" Margin="0,0,0,5"/>
                        <RadioButton Content="延迟优先 (LatencyBased)" GroupName="Strategy" IsChecked="True"/>
                    </StackPanel>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Icon="💊" Title="健康检查" Margin="0,0,0,15">
                    <StackPanel>
                        <CheckBox Content="启用自动故障切换" IsChecked="{Binding SelectedChain.AutoFailover}" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="检查间隔:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox Text="{Binding SelectedChain.HealthCheckInterval}" Width="80" Margin="0,0,5,0"/>
                            <TextBlock Text="秒" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Icon="🔗" Title="代理节点">
                    <StackPanel>
                        <Button Content="添加节点" Style="{DynamicResource SecondaryButtonStyle}" 
                                HorizontalAlignment="Left" Margin="0,0,0,10"/>

                        <ListBox ItemsSource="{Binding SelectedChain.Nodes}" Height="300">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <emoji:TextBlock Grid.Column="0" Text="🔘" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Config.Server, StringFormat={}{0}}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Config.Port, StringFormat=端口: {0}}" 
                                                           FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Margin="10,0">
                                                <TextBlock Text="{Binding Latency, StringFormat={}{0}ms}" FontSize="12" TextAlignment="Center"/>
                                                <TextBlock Text="延迟" FontSize="10" Foreground="{DynamicResource TextSecondary}" TextAlignment="Center"/>
                                            </StackPanel>

                                            <Border Grid.Column="3" Background="{DynamicResource SuccessColor}" 
                                                    CornerRadius="4" Padding="5,2" Margin="5,0"
                                                    Visibility="{Binding IsAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="可用" Foreground="White" FontSize="12"/>
                                            </Border>

                                            <Border Grid.Column="3" Background="{DynamicResource DangerColor}" 
                                                    CornerRadius="4" Padding="5,2" Margin="5,0"
                                                    Visibility="{Binding IsAvailable, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                <TextBlock Text="不可用" Foreground="White" FontSize="12"/>
                                            </Border>

                                            <Button Grid.Column="4" Content="删除" Style="{DynamicResource DangerButtonStyle}" 
                                                    Padding="5,2" Margin="5,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </layout:IconHeaderGroupBox>

                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <Button Content="保存配置" Style="{DynamicResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
                    <Button Content="测试链路" Command="{Binding TestChainCommand}" CommandParameter="{Binding SelectedChain}"
                            Style="{DynamicResource SecondaryButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasSelectedChain, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <emoji:TextBlock Text="🔗" FontSize="48" HorizontalAlignment="Center" Opacity="0.5"/>
            <TextBlock Text="选择或创建代理链" FontSize="16" Foreground="{DynamicResource TextSecondary}" 
                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
