<UserControl x:Class="TM.Framework.Notifications.SystemNotifications.SystemIntegration.SystemIntegrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">

                <layout:IconHeaderGroupBox Icon="🪟" Title="Windows系统通知" Margin="0,0,0,15">
                    <StackPanel>
                        <CheckBox x:Name="EnableWindowsNotificationCheck"
                                  Content="启用Windows系统通知中心集成"
                                  IsChecked="{Binding EnableWindowsNotification, Mode=TwoWay}"
                                  Margin="0,0,0,15"/>

                        <Grid x:Name="WindowsNotificationOptions">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="通知优先级" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                            <ComboBox Grid.Column="1" x:Name="NotificationPriorityCombo"
                                      SelectedValue="{Binding NotificationPriority, Mode=TwoWay}"
                                      SelectedValuePath="Tag"
                                      Height="36" Margin="10,0,0,0">
                                <ComboBoxItem Content="正常" Tag="Normal"/>
                                <ComboBoxItem Content="高" Tag="High"/>
                                <ComboBoxItem Content="低" Tag="Low"/>
                            </ComboBox>

                            <CheckBox Grid.Row="2" Grid.ColumnSpan="2" x:Name="NotificationSoundCheck"
                                      Content="播放通知声音"
                                      IsChecked="{Binding NotificationSound, Mode=TwoWay}"/>
                        </Grid>
                    </StackPanel>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Icon="📌" Title="系统托盘图标" Margin="0,0,0,15">
                    <StackPanel>
                        <CheckBox x:Name="ShowTrayIconCheck"
                                  Content="在任务栏系统托盘显示图标"
                                  IsChecked="{Binding ShowTrayIcon, Mode=TwoWay}"
                                  Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="单击行为" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                            <ComboBox Grid.Column="1" x:Name="SingleClickBehaviorCombo"
                                      SelectedValue="{Binding SingleClickBehavior, Mode=TwoWay}"
                                      SelectedValuePath="Tag"
                                      Height="36" Margin="10,0,0,0">
                                <ComboBoxItem Content="显示窗口" Tag="ShowWindow"/>
                                <ComboBoxItem Content="隐藏窗口" Tag="HideWindow"/>
                                <ComboBoxItem Content="切换显示/隐藏" Tag="Toggle"/>
                                <ComboBoxItem Content="无操作" Tag="DoNothing"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="双击行为" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                            <ComboBox Grid.Column="1" x:Name="DoubleClickBehaviorCombo"
                                      SelectedValue="{Binding DoubleClickBehavior, Mode=TwoWay}"
                                      SelectedValuePath="Tag"
                                      Height="36" Margin="10,0,0,0">
                                <ComboBoxItem Content="显示窗口" Tag="ShowWindow"/>
                                <ComboBoxItem Content="隐藏窗口" Tag="HideWindow"/>
                                <ComboBoxItem Content="切换显示/隐藏" Tag="Toggle"/>
                                <ComboBoxItem Content="无操作" Tag="DoNothing"/>
                            </ComboBox>
                        </Grid>

                        <CheckBox x:Name="CloseToTrayCheck" Content="关闭到托盘（而不是退出程序）" 
                                  IsChecked="{Binding CloseToTray, Mode=TwoWay}"/>
                    </StackPanel>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Icon="🚀" Title="开机自启动" Margin="0,0,0,15">
                    <StackPanel>
                        <CheckBox x:Name="AutoStartupCheck"
                                  Content="Windows启动时自动运行程序"
                                  IsChecked="{Binding AutoStartup, Mode=TwoWay}"
                                  Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="启动模式" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                            <ComboBox Grid.Column="1" x:Name="StartupModeCombo"
                                      SelectedValue="{Binding StartupMode, Mode=TwoWay}"
                                      SelectedValuePath="Tag"
                                      Height="36" Margin="10,0,0,0">
                                <ComboBoxItem Content="正常启动" Tag="Normal"/>
                                <ComboBoxItem Content="最小化到托盘" Tag="Minimized"/>
                            </ComboBox>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="启动延迟" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                            <Slider Grid.Column="1" x:Name="StartupDelaySlider"
                                    Minimum="0" Maximum="60"
                                    Value="{Binding StartupDelay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    Margin="10,0"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding StartupDelay, StringFormat={}{0}秒, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36"/>
                        </Grid>
                    </StackPanel>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Icon="⚙️" Title="高级系统集成">
                    <StackPanel>
                        <CheckBox x:Name="RegisterUrlProtocolCheck" 
                                  Content="注册URL协议 (TM://)" 
                                  IsChecked="{Binding RegisterUrlProtocol, Mode=TwoWay}"
                                  Margin="0,0,0,10"/>
                        <CheckBox x:Name="AssociateFileTypeCheck" 
                                  Content="关联文件类型 (.tm)" 
                                  IsChecked="{Binding AssociateFileType, Mode=TwoWay}"
                                  Margin="0,0,0,10"/>
                        <CheckBox x:Name="AddToContextMenuCheck" 
                                  Content="添加到右键菜单" 
                                  IsChecked="{Binding AddToContextMenu, Mode=TwoWay}"
                                  Margin="0,0,0,10"/>
                        <CheckBox x:Name="AddToSendToMenuCheck" 
                                  Content="添加到「发送到」菜单"
                                  IsChecked="{Binding AddToSendToMenu, Mode=TwoWay}"/>
                    </StackPanel>
                </layout:IconHeaderGroupBox>

            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Click="OnResetClick"
                        Style="{StaticResource DangerButtonStyle}"
                        Margin="0,0,10,0"
                        Padding="15,8"
                        helpers:ButtonHelper.ConfirmMessage="确定要重置为默认设置吗？"
                        helpers:ButtonHelper.ConfirmTitle="确认重置">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="🔄" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="恢复默认"/>
                    </StackPanel>
                </Button>

                <Button Click="OnSaveClick"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="20,8">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="💾" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="保存配置"/>
                    </StackPanel>
                </Button>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</UserControl>

