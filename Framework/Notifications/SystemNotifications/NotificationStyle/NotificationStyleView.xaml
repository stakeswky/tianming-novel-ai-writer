<UserControl x:Class="TM.Framework.Notifications.SystemNotifications.NotificationStyle.NotificationStyleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">

                <common:IconHeaderGroupBox Icon="🎨" Title="外观样式" Margin="0,0,0,20">
                    <StackPanel Margin="10">

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="圆角半径" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" x:Name="CornerRadiusSlider" 
                                    Minimum="0" Maximum="20" 
                                    Value="{Binding CornerRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Margin="10,0"/>
                            <TextBox Grid.Column="2" 
                                     Text="{Binding CornerRadius, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36"/>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="阴影强度" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" x:Name="ShadowIntensitySlider"
                                    Minimum="0" Maximum="30"
                                    Value="{Binding ShadowIntensity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Margin="10,0"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding ShadowIntensity, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36"/>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="边框粗细" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" x:Name="BorderThicknessSlider"
                                    Minimum="0" Maximum="3"
                                    Value="{Binding BorderThickness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    Margin="10,0"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding BorderThickness, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="背景透明度" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" x:Name="BackgroundOpacitySlider"
                                    Minimum="0" Maximum="100"
                                    Value="{Binding BackgroundOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    Margin="10,0"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding BackgroundOpacity, StringFormat={}{0}%, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36"/>
                        </Grid>
                    </StackPanel>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Icon="🎬" Title="动画效果" Margin="0,0,0,20">
                    <StackPanel Margin="10">

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="动画类型" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="AnimationTypeCombo"
                                      SelectedValue="{Binding AnimationType, Mode=TwoWay}"
                                      SelectedValuePath="Tag"
                                      Height="36"
                                      Margin="10,0,0,0">
                                <ComboBoxItem Content="淡入淡出" Tag="FadeInOut"/>
                                <ComboBoxItem Content="滑动" Tag="SlideIn"/>
                                <ComboBoxItem Content="弹跳" Tag="Bounce"/>
                                <ComboBoxItem Content="缩放" Tag="Scale"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="动画时长" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" x:Name="AnimationDurationSlider"
                                    Minimum="200" Maximum="2000"
                                    Value="{Binding AnimationDuration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="100" IsSnapToTickEnabled="True"
                                    Margin="10,0"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding AnimationDuration, StringFormat={}{0}ms, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="缓动函数" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="EasingFunctionCombo"
                                      SelectedValue="{Binding EasingFunction, Mode=TwoWay}"
                                      SelectedValuePath="Tag"
                                      Height="36"
                                      Margin="10,0,0,0">
                                <ComboBoxItem Content="线性" Tag="Linear"/>
                                <ComboBoxItem Content="缓入" Tag="EaseIn"/>
                                <ComboBoxItem Content="缓出" Tag="EaseOut"/>
                                <ComboBoxItem Content="缓入缓出" Tag="EaseInOut"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Icon="📐" Title="布局设置" Margin="0,0,0,20">
                    <StackPanel Margin="10">

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="屏幕位置" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="ScreenPositionCombo"
                                      SelectedValue="{Binding ScreenPosition, Mode=TwoWay}"
                                      SelectedValuePath="Tag"
                                      Height="36"
                                      Margin="10,0,0,0">
                                <ComboBoxItem Content="右上角" Tag="TopRight"/>
                                <ComboBoxItem Content="左上角" Tag="TopLeft"/>
                                <ComboBoxItem Content="右下角" Tag="BottomRight"/>
                                <ComboBoxItem Content="左下角" Tag="BottomLeft"/>
                                <ComboBoxItem Content="屏幕中心" Tag="Center"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="通知宽度" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" x:Name="NotificationWidthSlider"
                                    Minimum="200" Maximum="500"
                                    Value="{Binding NotificationWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="10" IsSnapToTickEnabled="True"
                                    Margin="10,0"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding NotificationWidth, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36"/>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="通知高度" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" x:Name="NotificationHeightSlider"
                                    Minimum="60" Maximum="200"
                                    Value="{Binding NotificationHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="10" IsSnapToTickEnabled="True"
                                    Margin="10,0"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding NotificationHeight, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36"/>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="通知间距" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" x:Name="NotificationSpacingSlider"
                                    Minimum="5" Maximum="30"
                                    Value="{Binding NotificationSpacing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    Margin="10,0"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding NotificationSpacing, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="堆叠方向" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="StackDirectionCombo"
                                      SelectedValue="{Binding StackDirection, Mode=TwoWay}"
                                      SelectedValuePath="Tag"
                                      Height="36"
                                      Margin="10,0,0,0">
                                <ComboBoxItem Content="向上堆叠" Tag="Up"/>
                                <ComboBoxItem Content="向下堆叠" Tag="Down"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Icon="👁️" Title="实时预览" Margin="0,0,0,20">
                    <StackPanel Margin="10">
                        <Grid Height="150" Background="{DynamicResource Surface}" Margin="0,0,0,10">
                            <Border x:Name="PreviewCard"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource ContentBackground}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    Padding="15">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="PreviewShadow"
                                                      ShadowDepth="0"
                                                      Color="Black"
                                                      Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <emoji:TextBlock Text="ℹ️" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="通知标题" FontSize="14" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Text="这是通知内容的预览文本" 
                                               FontSize="12" 
                                               Foreground="{DynamicResource TextSecondary}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Button x:Name="PreviewButton" Click="OnPreviewClick"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Center"
                                Padding="20,8">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="🎬" FontSize="14" Margin="0,0,5,0"/>
                                <TextBlock Text="测试通知效果"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </common:IconHeaderGroupBox>

                <common:IconHeaderGroupBox Icon="⚡" Title="快捷预设">
                    <WrapPanel Margin="10">
                        <Button Click="OnApplyPreset" Tag="simple"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,10"
                                Padding="15,8">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="🎯" FontSize="14" Margin="0,0,5,0"/>
                                <TextBlock Text="简约风格"/>
                            </StackPanel>
                        </Button>

                        <Button Click="OnApplyPreset" Tag="standard"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,10"
                                Padding="15,8">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="📋" FontSize="14" Margin="0,0,5,0"/>
                                <TextBlock Text="标准风格"/>
                            </StackPanel>
                        </Button>

                        <Button Click="OnApplyMinimalStyleClick"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,10"
                                Padding="15,8">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="✨" FontSize="14" Margin="0,0,5,0"/>
                                <TextBlock Text="华丽风格"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </common:IconHeaderGroupBox>

            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Click="OnResetClick"
                        Style="{StaticResource DangerButtonStyle}"
                        Margin="0,0,10,0"
                        Padding="15,8"
                        helpers:ButtonHelper.ConfirmMessage="确定要重置为默认设置吗？"
                        helpers:ButtonHelper.ConfirmTitle="确认重置">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="🔄" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="重置默认"/>
                    </StackPanel>
                </Button>

                <Button Click="OnSaveClick"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="20,8">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="💾" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="应用设置"/>
                    </StackPanel>
                </Button>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</UserControl>

