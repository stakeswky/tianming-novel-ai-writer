<UserControl x:Class="TM.Framework.Notifications.SystemNotifications.NotificationTypes.NotificationTypesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:systemNotifications="clr-namespace:TM.Framework.Notifications.SystemNotifications.NotificationTypes">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <common:IconHeaderGroupBox Grid.Row="0" Icon="📊" Title="配置统计">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="总类型数：" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalCount}" FontWeight="SemiBold" 
                               Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="已启用：" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding EnabledCount}" FontWeight="SemiBold" 
                               Foreground="{DynamicResource SuccessColor}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="分组数：" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding GroupCount}" FontWeight="SemiBold" 
                               Foreground="{DynamicResource InfoColor}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>
            </Grid>
        </common:IconHeaderGroupBox>

        <common:IconHeaderGroupBox Grid.Row="1" Icon="📋" Title="通知类型配置" Margin="0,10,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Types}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10" 
                                    Padding="15"
                                    Tag="{Binding Id}"
                                    MouseLeftButtonDown="OnTypeCardClick"
                                    Cursor="Hand"
                                    Focusable="False">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <emoji:TextBlock Text="{Binding Icon}" FontSize="20" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Border Background="{Binding Color}" 
                                                    CornerRadius="3" 
                                                    Padding="8,2" 
                                                    Margin="10,0,0,0">
                                                <TextBlock Text="●" Foreground="White" FontSize="10"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" 
                                                   Foreground="{DynamicResource TextSecondary}" 
                                                   TextWrapping="Wrap"
                                                   Margin="30,0,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0">
                                        <StackPanel Margin="0,0,15,0">
                                            <TextBlock Text="启用" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,5"/>
                                            <CheckBox IsChecked="{Binding IsEnabled}" 
                                                      VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,15,0" Width="100">
                                            <TextBlock Text="优先级" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,5"/>
                                            <ComboBox SelectedValue="{Binding Priority, Mode=TwoWay}"
                                                      SelectedValuePath="Tag">
                                                <ComboBox.ItemContainerStyle>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                    </Style>
                                                </ComboBox.ItemContainerStyle>
                                                <ComboBox.Items>
                                                    <ComboBoxItem Content="低" Tag="{x:Static systemNotifications:NotificationPriority.Low}"/>
                                                    <ComboBoxItem Content="中" Tag="{x:Static systemNotifications:NotificationPriority.Medium}"/>
                                                    <ComboBoxItem Content="高" Tag="{x:Static systemNotifications:NotificationPriority.High}"/>
                                                </ComboBox.Items>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,15,0" Width="120">
                                            <TextBlock Text="颜色" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,5"/>
                                            <ComboBox SelectedValue="{Binding Color, Mode=TwoWay}"
                                                      SelectedValuePath="Tag">
                                                <ComboBox.ItemContainerStyle>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                    </Style>
                                                </ComboBox.ItemContainerStyle>
                                                <ComboBoxItem Tag="#2196F3">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#2196F3" Width="16" Height="16" CornerRadius="3" Margin="0,0,8,0"/>
                                                        <TextBlock Text="蓝色" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </ComboBoxItem>
                                                <ComboBoxItem Tag="#16A34A">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#16A34A" Width="16" Height="16" CornerRadius="3" Margin="0,0,8,0"/>
                                                        <TextBlock Text="绿色" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </ComboBoxItem>
                                                <ComboBoxItem Tag="#FF9800">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#FF9800" Width="16" Height="16" CornerRadius="3" Margin="0,0,8,0"/>
                                                        <TextBlock Text="橙色" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </ComboBoxItem>
                                                <ComboBoxItem Tag="#F44336">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#F44336" Width="16" Height="16" CornerRadius="3" Margin="0,0,8,0"/>
                                                        <TextBlock Text="红色" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </ComboBoxItem>
                                                <ComboBoxItem Tag="#9C27B0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#9C27B0" Width="16" Height="16" CornerRadius="3" Margin="0,0,8,0"/>
                                                        <TextBlock Text="紫色" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </ComboBoxItem>
                                                <ComboBoxItem Tag="#00BCD4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#00BCD4" Width="16" Height="16" CornerRadius="3" Margin="0,0,8,0"/>
                                                        <TextBlock Text="青色" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </ComboBoxItem>
                                                <ComboBoxItem Tag="#E91E63">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#E91E63" Width="16" Height="16" CornerRadius="3" Margin="0,0,8,0"/>
                                                        <TextBlock Text="粉色" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </ComboBoxItem>
                                                <ComboBoxItem Tag="#607D8B">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#607D8B" Width="16" Height="16" CornerRadius="3" Margin="0,0,8,0"/>
                                                        <TextBlock Text="灰色" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </ComboBoxItem>
                                                <ComboBoxItem Tag="#FFFFFF">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#FFFFFF" Width="16" Height="16" CornerRadius="3" Margin="0,0,8,0"
                                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                                        <TextBlock Text="白色" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </ComboBoxItem>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Width="100">
                                            <TextBlock Text="分组" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding GroupName, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource StandardTextBoxStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </common:IconHeaderGroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding AddTypeCommand}"
                    Padding="12,6"
                    Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="➕" FontSize="14" Margin="0,0,5,0"/>
                    <TextBlock Text="添加类型"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource DangerButtonStyle}"
                    Command="{Binding DeleteTypeCommand}"
                    Padding="12,6"
                    Margin="0,0,10,0"
                    helpers:ButtonHelper.ConfirmMessage="确定要删除选中的通知类型吗？"
                    helpers:ButtonHelper.ConfirmTitle="确认删除">
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="🗑️" FontSize="14" Margin="0,0,5,0"/>
                    <TextBlock Text="删除类型"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding ResetDefaultsCommand}"
                    Padding="12,6"
                    Margin="0,0,10,0"
                    helpers:ButtonHelper.ConfirmMessage="确定要重置为默认配置吗？当前配置将丢失！"
                    helpers:ButtonHelper.ConfirmTitle="确认重置">
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="🔄" FontSize="14" Margin="0,0,5,0"/>
                    <TextBlock Text="重置默认"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SaveSettingsCommand}"
                    Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="💾" FontSize="14" Margin="0,0,5,0"/>
                    <TextBlock Text="保存配置"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>

