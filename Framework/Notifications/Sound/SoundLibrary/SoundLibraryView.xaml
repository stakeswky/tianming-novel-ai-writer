<UserControl x:Class="TM.Framework.Notifications.Sound.SoundLibrary.SoundLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource Surface}" 
                CornerRadius="8" Padding="15" Margin="0,0,0,15"
                BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <emoji:TextBlock Text="🎵" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="音效库管理" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="导入、管理和预览自定义音效文件" FontSize="11" 
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding ImportSoundCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="36" Padding="15,0" Margin="0,0,10,0">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="📥" FontSize="14" Margin="0,0,5,0"/>
                                <TextBlock Text="导入音效" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Content="打开文件夹" Command="{Binding OpenLibraryFolderCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="36" Padding="15,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <layout:IconHeaderGroupBox Grid.Row="1" Icon="📊" Title="音效统计" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="总音效：" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SoundFiles.Count}" FontWeight="SemiBold" 
                               Foreground="{DynamicResource PrimaryColor}" Margin="5,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="库路径：" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LibraryPath}" FontSize="11" 
                               Foreground="{DynamicResource TextSecondary}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </layout:IconHeaderGroupBox>

        <ListBox Grid.Row="2" 
                 ItemsSource="{Binding SoundFiles}"
                 SelectedItem="{Binding SelectedSound, Mode=TwoWay}"
                 Background="Transparent"
                 BorderThickness="0"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 ScrollViewer.CanContentScroll="True">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource Surface}" 
                            CornerRadius="8" 
                            Padding="15" 
                            Margin="0,0,0,10"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource BorderBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <emoji:TextBlock Grid.Column="0" Text="🎵" FontSize="32" 
                                           VerticalAlignment="Center" Margin="0,0,15,0"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Border Background="{DynamicResource InfoColor}" 
                                            CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Category}" FontSize="10" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="{Binding Size}" FontSize="11" 
                                               Foreground="{DynamicResource TextSecondary}" 
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Duration}" FontSize="11" 
                                               Foreground="{DynamicResource TextSecondary}" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Command="{Binding DataContext.PlaySoundCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Height="32" Padding="12,0" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <emoji:TextBlock Text="▶️" FontSize="12" Margin="0,0,5,0"/>
                                        <TextBlock Text="播放" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteSoundCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Height="32" Width="32" Padding="0">
                                    <emoji:TextBlock Text="🗑️" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
