<UserControl x:Class="TM.Framework.Notifications.Sound.SoundScheme.SoundSchemeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             Background="{DynamicResource ContentBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <common:IconHeaderGroupBox Icon="🎭" Title="方案选择" Margin="0,0,0,20">
                <ItemsControl ItemsSource="{Binding Schemes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="200" Height="120" Margin="0,0,15,15" 
                                    Background="{DynamicResource Surface}"
                                    CornerRadius="8"
                                    Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                                        <Setter Property="Padding" Value="12"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" 
                                                  Command="{Binding DataContext.SelectSchemeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SchemeName}" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}" 
                                               TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Description}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}" 
                                               TextWrapping="Wrap" Margin="0,0,0,8"/>

                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <emoji:TextBlock Text="✓" FontSize="14" 
                                                         Foreground="{DynamicResource SuccessColor}"
                                                         VerticalAlignment="Center"/>
                                        <TextBlock Text="当前方案" FontSize="12" 
                                                   Foreground="{DynamicResource SuccessColor}"
                                                   Margin="5,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🔔" Title="事件音效配置" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="为不同的系统事件配置对应的音效" 
                               Foreground="{DynamicResource TextSecondary}" 
                               Margin="0,0,0,15"/>

                    <ItemsControl ItemsSource="{Binding EventConfigs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding EventName}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimary}"/>

                                    <ComboBox Grid.Column="1" Style="{DynamicResource StandardComboBoxStyle}"
                                              ItemsSource="{Binding DataContext.AvailableSounds, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              SelectedValue="{Binding SelectedSound, Mode=TwoWay}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="DisplayName"
                                              Margin="10,0"/>

                                    <Button Grid.Column="2" Content="▶️ 播放" 
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Command="{Binding DataContext.PlaySoundCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding SelectedSound}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📁" Title="自定义音效管理" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="上传音效文件" Style="{DynamicResource PrimaryButtonStyle}"
                                Command="{Binding UploadSoundCommand}" 
                                Width="150"/>
                        <TextBlock Text="支持 .wav 格式" 
                                   Foreground="{DynamicResource TextSecondary}" 
                                   VerticalAlignment="Center" Margin="15,0,0,0"/>
                    </StackPanel>

                    <Border BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="1" CornerRadius="6"
                            Background="{DynamicResource Surface}"
                            MinHeight="150" MaxHeight="250">
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CustomSounds}" Margin="10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderBrush}" 
                                                    BorderThickness="0,0,0,1" Padding="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding FileName}" 
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding FileSizeText}" 
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   FontSize="11" Margin="0,2,0,0"/>
                                                    </StackPanel>

                                                    <Button Grid.Column="1" Content="▶️ 播放" 
                                                            Style="{DynamicResource SecondaryButtonStyle}"
                                                            Command="{Binding DataContext.PlaySoundCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding DisplayName}"
                                                            Height="28" Margin="0,0,5,0"/>

                                                    <Button Grid.Column="2" Content="删除" 
                                                            Style="{DynamicResource DangerButtonStyle}"
                                                            Command="{Binding DataContext.DeleteCustomSoundCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Height="28"
                                                            helpers:ButtonHelper.ConfirmMessage="确定要删除此音效文件吗？"
                                                            helpers:ButtonHelper.ConfirmTitle="确认删除"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock Text="暂无自定义音效，点击上方按钮上传" 
                                       Foreground="{DynamicResource TextTertiary}"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CustomSounds.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="恢复默认" Style="{DynamicResource DangerButtonStyle}"
                        Command="{Binding ResetToDefaultCommand}"
                        Width="100" Margin="0,0,10,0"
                        helpers:ButtonHelper.ConfirmMessage="确定要重置声音方案设置吗？这将恢复到默认方案。"
                        helpers:ButtonHelper.ConfirmTitle="确认重置"/>
                <Button Content="保存设置" Style="{DynamicResource PrimaryButtonStyle}"
                        Command="{Binding SaveSettingsCommand}"
                        Width="100"
                        helpers:ButtonHelper.ConfirmMessage="确定要保存当前的声音方案设置吗？"
                        helpers:ButtonHelper.ConfirmTitle="确认保存"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>

