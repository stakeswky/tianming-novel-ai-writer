<UserControl x:Class="TM.Framework.Notifications.Sound.VoiceBroadcast.VoiceBroadcastView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             Background="{DynamicResource ContentBackground}">

    <UserControl.Resources>
        <ResourceDictionary>

            <BooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <Border Background="{DynamicResource InfoColor}" 
                    CornerRadius="6" Padding="12" Margin="0,0,0,15">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTtsAvailable}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="ℹ️" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="系统未安装中文语音包，语音播报将使用系统提示音代替。" 
                               Foreground="White" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <common:IconHeaderGroupBox Icon="⚙️" Title="基础设置" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="引擎状态" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Grid.Column="1" Text="{Binding TtsStatusText}" 
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTtsAvailable}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource WarningColor}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="语音播报" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}" 
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding StatusText}" 
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="播报速度" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <Slider Grid.Column="1" Minimum="-10" Maximum="10" 
                                Value="{Binding Speed, Mode=TwoWay}"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="10,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding SpeedText}" 
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="播报音量" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="100" 
                                Value="{Binding Volume, Mode=TwoWay}"
                                TickFrequency="10" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="10,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding VolumeText}" 
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="音调" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <Slider Grid.Column="1" Minimum="-10" Maximum="10" 
                                Value="{Binding Pitch, Mode=TwoWay}"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="10,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding PitchText}" 
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </Grid>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🎯" Title="播报场景" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="选择需要语音播报的场景" 
                               Foreground="{DynamicResource TextSecondary}" 
                               Margin="0,0,0,15"/>

                    <CheckBox Content="通知到达时播报" 
                              IsChecked="{Binding BroadcastOnNotification, Mode=TwoWay}"
                              Margin="0,0,0,10"/>
                    <CheckBox Content="错误发生时播报" 
                              IsChecked="{Binding BroadcastOnError, Mode=TwoWay}"
                              Margin="0,0,0,10"/>
                    <CheckBox Content="成功操作时播报" 
                              IsChecked="{Binding BroadcastOnSuccess, Mode=TwoWay}"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🧪" Title="测试播报" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="输入测试文本" 
                               Foreground="{DynamicResource TextPrimary}" 
                               Margin="0,0,0,8"/>
                    <TextBox Text="{Binding TestText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource StandardTextBoxStyle}"
                             Height="36" Margin="0,0,0,15"/>

                    <Button Content="播放测试语音" 
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Command="{Binding TestBroadcastCommand}"
                            Width="150" HorizontalAlignment="Left"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="恢复默认" Style="{DynamicResource DangerButtonStyle}"
                        Command="{Binding ResetToDefaultCommand}"
                        Width="100" Margin="0,0,10,0"
                        helpers:ButtonHelper.ConfirmMessage="确定要重置语音播报设置吗？这将恢复到默认状态。"
                        helpers:ButtonHelper.ConfirmTitle="确认重置"/>
                <Button Content="保存设置" Style="{DynamicResource PrimaryButtonStyle}"
                        Command="{Binding SaveSettingsCommand}"
                        Width="100"
                        helpers:ButtonHelper.ConfirmMessage="确定要保存当前的语音播报设置吗？"
                        helpers:ButtonHelper.ConfirmTitle="确认保存"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>

