<UserControl x:Class="TM.Framework.Common.Controls.Animations.AnimatedGradientStripe"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="StripeBorder"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            CornerRadius="{Binding StripeCornerRadius, RelativeSource={RelativeSource AncestorType=UserControl}}"
            SnapsToDevicePixels="True"/>
</UserControl>

