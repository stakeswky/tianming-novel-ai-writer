<UserControl x:Class="TM.Framework.Common.Controls.Forms.CategoryManagementForm"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
            xmlns:controls="clr-namespace:TM.Framework.Common.Controls"
            xmlns:forms="clr-namespace:TM.Framework.Common.Controls.Forms">

    <StackPanel>
        <Grid Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="分类名称" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox Text="{Binding EditCategoryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource StandardTextBoxStyle}" Height="36"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="图标 (Emoji)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <controls:EmojiPicker SelectedEmoji="{Binding EditCategoryIcon, Mode=TwoWay}" Height="36" Width="Auto"/>
            </StackPanel>

            <StackPanel Grid.Column="4">
                <TextBlock Text="当前层级" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox Text="{Binding CurrentLevel, Mode=OneWay}"
                        Style="{StaticResource StandardTextBoxStyle}"
                        Height="36" IsReadOnly="True"
                        Background="{DynamicResource Surface}"/>
            </StackPanel>
        </Grid>

        <TextBlock Text="父分类" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ComboBox ItemsSource="{Binding ParentCategoryTree}"
                 Style="{StaticResource TreeComboBoxStyle}" 
                 Height="36"
                 Margin="0,0,0,15"
                 IsDropDownOpen="{Binding IsTreeComboBoxOpen, Mode=TwoWay}"
                 helpers:ComboBoxHelper.SelectedPath="{Binding SelectedParentPath, Mode=TwoWay}"
                 helpers:ComboBoxHelper.DisplayIcon="{Binding SelectedParentIcon, Mode=TwoWay}"
                 helpers:ComboBoxHelper.MaxLevel="{Binding MaxLevel, RelativeSource={RelativeSource AncestorType=forms:CategoryManagementForm}}"
                 helpers:ComboBoxHelper.NodeDoubleClickCommand="{Binding SelectParentCategoryCommand}"/>

        <StackPanel>
            <TextBlock Text="描述" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Border Background="{DynamicResource ContentBackground}" 
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6" Height="120" Padding="12">
                <TextBox Text="{Binding EditCategoryDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource StandardTextBoxStyle}"
                        TextWrapping="Wrap" AcceptsReturn="True" 
                        BorderThickness="0" Background="Transparent"
                        VerticalScrollBarVisibility="Auto"/>
            </Border>
        </StackPanel>
    </StackPanel>
</UserControl>

