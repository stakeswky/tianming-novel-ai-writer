<UserControl x:Class="TM.Framework.Common.Controls.Forms.StandardTabForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             x:Name="Root">

    <StackPanel Margin="5">

        <Grid Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowNameField, ElementName=Root}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="{Binding NameFieldLabel, ElementName=Root}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding NameValue, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource StandardTextBoxStyle}" Height="36"/>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowCategoryField, ElementName=Root}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="{Binding CategoryFieldLabel, ElementName=Root}" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding CategoryTree, ElementName=Root}"
                         Style="{StaticResource TreeComboBoxStyle}"
                         Height="36"
                         IsDropDownOpen="{Binding IsTreeComboBoxOpen, ElementName=Root, Mode=TwoWay}"
                         helpers:ComboBoxHelper.SelectedPath="{Binding CategoryPath, ElementName=Root, Mode=TwoWay}"
                         helpers:ComboBoxHelper.DisplayIcon="{Binding CategoryIcon, ElementName=Root, Mode=TwoWay}"
                         helpers:ComboBoxHelper.MaxLevel="{Binding CategoryMaxLevel, ElementName=Root}"
                         helpers:ComboBoxHelper.NodeDoubleClickCommand="{Binding CategorySelectCommand, ElementName=Root}"/>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowScopeField, ElementName=Root}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="{Binding ScopeFieldLabel, ElementName=Root}" Margin="0,0,0,5"/>
                <ComboBox SelectedItem="{Binding ScopeValue, ElementName=Root, Mode=TwoWay}"
                         ItemsSource="{Binding ScopeOptions, ElementName=Root}"
                         Style="{DynamicResource StandardComboBoxStyle}" Height="36"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,5,0,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowCategoryField, ElementName=Root}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <emoji:TextBlock Text="💡" FontSize="11" Foreground="{DynamicResource TextTertiary}"/>
                <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="5,0,0,0">
                    <Run Text="当前层级："/>
                    <Run Text="{Binding CurrentLevel, ElementName=Root}" FontWeight="SemiBold"/>
                    <Run Text=" | 路径："/>
                    <Run Text="{Binding CurrentPath, ElementName=Root}"/>
                </TextBlock>
            </StackPanel>
        </Grid>

        <StackPanel Margin="0,0,0,15">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowPriorityField, ElementName=Root}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="{Binding PriorityFieldLabel, ElementName=Root}" Margin="0,0,0,5"/>
            <ComboBox SelectedItem="{Binding PriorityValue, ElementName=Root, Mode=TwoWay}"
                     ItemsSource="{Binding PriorityOptions, ElementName=Root}"
                     Style="{DynamicResource StandardComboBoxStyle}"/>
        </StackPanel>

        <StackPanel Margin="0,0,0,15">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowAIWeightField, ElementName=Root}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="{Binding AIWeightFieldLabel, ElementName=Root}" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" 
                       Value="{Binding AIWeightValue, ElementName=Root, Mode=TwoWay}"
                       Minimum="0" Maximum="100"
                       TickFrequency="10"
                       IsSnapToTickEnabled="True"
                       Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1" 
                          Text="{Binding AIWeightValue, ElementName=Root, StringFormat={}{0}%}"
                          FontWeight="SemiBold"
                          Foreground="{DynamicResource PrimaryColor}"
                          VerticalAlignment="Center"
                          MinWidth="40"/>
            </Grid>
        </StackPanel>

        <StackPanel Margin="0,0,0,15">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowGenresField, ElementName=Root}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="{Binding GenresFieldLabel, ElementName=Root}" Margin="0,0,0,5"/>
            <ItemsControl ItemsSource="{Binding NovelGenreOptions, ElementName=Root}"
                         x:Name="GenreItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding}" 
                                 Tag="{Binding}"
                                 Margin="0,0,15,10"
                                 Checked="GenreCheckBox_Checked"
                                 Unchecked="GenreCheckBox_Unchecked"
                                 Loaded="GenreCheckBox_Loaded"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <StackPanel Margin="0,0,0,15">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowDescriptionField, ElementName=Root}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="{Binding DescriptionFieldLabel, ElementName=Root}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding DescriptionValue, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{DynamicResource StandardTextBoxStyle}"
                     Height="80"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

    </StackPanel>
</UserControl>

