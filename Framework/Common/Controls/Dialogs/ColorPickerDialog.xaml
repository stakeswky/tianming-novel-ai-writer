<Window x:Class="TM.Framework.Common.Controls.Dialogs.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Width="580"
        Height="420">

    <Border Background="{DynamicResource ContentBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="{StaticResource StandardBorder}"
            CornerRadius="16"
            Padding="0"
            Margin="15">

        <Border.Effect>
            <DropShadowEffect Color="Black" 
                            Opacity="0.2" 
                            BlurRadius="20" 
                            ShadowDepth="4" 
                            Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="16,16,0,0"
                    Padding="16,6"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="🎨"
                                     FontSize="16"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0"/>
                    <TextBlock x:Name="TitleText"
                               Text="选择颜色"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryColor}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" 
                       BorderBrush="{DynamicResource BorderBrush}" 
                       BorderThickness="1" 
                       CornerRadius="8"
                       ClipToBounds="True">
                    <Canvas x:Name="ColorCanvas" 
                           Background="White"
                           MouseLeftButtonDown="ColorCanvas_MouseDown"
                           MouseMove="ColorCanvas_MouseMove"
                           MouseLeftButtonUp="ColorCanvas_MouseUp"
                           Cursor="Cross">
                    </Canvas>
                </Border>

                <Border Grid.Column="2" 
                       BorderBrush="{DynamicResource BorderBrush}" 
                       BorderThickness="1" 
                       CornerRadius="8"
                       ClipToBounds="True">
                    <Canvas x:Name="HueCanvas"
                           MouseLeftButtonDown="HueCanvas_MouseDown"
                           MouseMove="HueCanvas_MouseMove"
                           MouseLeftButtonUp="HueCanvas_MouseUp"
                           Cursor="Hand">
                    </Canvas>
                </Border>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="预览" FontSize="12" 
                              Foreground="{DynamicResource TextSecondary}"
                              Margin="0,0,0,5"/>
                    <Border x:Name="PreviewBorder"
                           Height="60" 
                           BorderBrush="{DynamicResource BorderBrush}" 
                           BorderThickness="1" 
                           CornerRadius="8"
                           Margin="0,0,0,15"/>

                    <TextBlock Text="RGB" FontSize="12" FontWeight="SemiBold"
                              Foreground="{DynamicResource TextSecondary}"
                              Margin="0,0,0,5"/>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="R:" Width="20" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock x:Name="RValue" Text="255" FontSize="11" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="G:" Width="20" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock x:Name="GValue" Text="255" FontSize="11" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="B:" Width="20" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock x:Name="BValue" Text="255" FontSize="11" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="24,0,24,20">
                <Button Content="取消" 
                       Click="Cancel_Click"
                       MinWidth="80"
                       Margin="0,0,10,0"/>
                <Button Content="确定" 
                       Click="OK_Click"
                       Style="{StaticResource PrimaryButtonStyle}"
                       MinWidth="80"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

