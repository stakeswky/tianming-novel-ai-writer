<Window x:Class="TM.Framework.Common.Controls.Dialogs.BatchGenerationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Width="400">

    <Border Background="{DynamicResource ContentBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="0"
            Margin="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    Height="34"
                    Padding="16,7"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="🤖"
                                     FontSize="14"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"/>
                    <TextBlock x:Name="TitleText"
                               Text="批量生成"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryColor}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,20,24,4">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <emoji:TextBlock Text="📁" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="目标分类：" FontSize="14" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock x:Name="CategoryNameText" Text="未选择" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>

                <Border x:Name="SingleModeHintBorder" Visibility="Collapsed"
                        Background="{DynamicResource Surface}" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        BorderThickness="1"
                        CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="💡" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="SingleModeHintText" 
                                   Text="将基于当前分类的上下文，AI生成1条新数据" 
                                   FontSize="13" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Grid x:Name="TotalCountRow" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="生成数量（总产出数）：" FontSize="14" VerticalAlignment="Center"
                               Margin="0,0,12,0" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBox x:Name="TotalCountTextBox" Grid.Column="1" Text="10" FontSize="14"
                             Padding="10,8" VerticalAlignment="Center"
                             TextChanged="TotalCountTextBox_TextChanged"/>
                    <TextBlock Grid.Column="2" Text="个" FontSize="14" VerticalAlignment="Center"
                               Margin="8,0,0,0" Foreground="{DynamicResource TextSecondary}"/>
                </Grid>

                <Grid x:Name="BatchSizeRow" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="单批数量（单次上限）：" FontSize="14" VerticalAlignment="Center"
                               Margin="0,0,12,0" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBox x:Name="BatchSizeTextBox" Grid.Column="1" Text="10" FontSize="14"
                             Padding="10,8" VerticalAlignment="Center"
                             TextChanged="BatchSizeTextBox_TextChanged"/>
                    <TextBlock Grid.Column="2" Text="个/批" FontSize="14" VerticalAlignment="Center"
                               Margin="8,0,0,0" Foreground="{DynamicResource TextSecondary}"/>
                </Grid>

                <TextBlock x:Name="FormulaHintRow"
                           Text="生成数量 ÷ 单批数量 = 预计批次"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextTertiary}"
                           Margin="0,8,0,0"/>

                <Border x:Name="WarningBorder" Visibility="Collapsed"
                        Background="#FFF3CD" BorderBrush="#FFECB5" BorderThickness="1"
                        CornerRadius="6" Padding="12,8" Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="⚠️" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="WarningText" Text="" FontSize="13" TextWrapping="Wrap"
                                   Foreground="#856404" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Row="2" Margin="24,12,24,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="EstimatedBatchesRow" Grid.Column="0"
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="预计批次：" FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock x:Name="EstimatedBatchesText" Text="1" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}"/>
                    <TextBlock Text=" 批" FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="CancelButton" Content="取消" MinWidth="80"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="CancelButton_Click"/>
                <Button x:Name="ConfirmButton" Content="开始生成" MinWidth="100" Margin="12,0,0,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="ConfirmButton_Click"/>
            </StackPanel>
        </Grid>
        </Grid>
    </Border>
</Window>
