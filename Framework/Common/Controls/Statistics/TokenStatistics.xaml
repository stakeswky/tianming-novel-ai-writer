<UserControl x:Class="TM.Framework.Common.Controls.Statistics.TokenStatistics"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="400">
    <Border Background="{DynamicResource Surface}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8,4"
            Margin="0,5">
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="PromptTokensLabel"
                       FontSize="9"
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="0,0,8,0">
                <Run Text="输入Token: "/>
                <Run x:Name="PromptTokensValue" Text="0" FontWeight="SemiBold"/>
            </TextBlock>

            <TextBlock x:Name="CompletionTokensLabel"
                       FontSize="9"
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="0,0,8,0">
                <Run Text="输出Token: "/>
                <Run x:Name="CompletionTokensValue" Text="0" FontWeight="SemiBold"/>
            </TextBlock>

            <TextBlock x:Name="TotalTokensLabel"
                       FontSize="9"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,0,8,0">
                <Run Text="总Token: "/>
                <Run x:Name="TotalTokensValue" Text="0" FontWeight="Bold"/>
            </TextBlock>

            <TextBlock x:Name="CostLabel"
                       FontSize="9"
                       Foreground="{DynamicResource InfoColor}"
                       Margin="0,0,0,0">
                <Run Text="（¥"/>
                <Run x:Name="CostValue" Text="0.0000" FontWeight="SemiBold"/>
                <Run Text="）"/>
            </TextBlock>
        </StackPanel>
    </Border>
</UserControl>

