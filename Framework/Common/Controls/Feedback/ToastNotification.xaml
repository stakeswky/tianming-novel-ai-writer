<Window x:Class="TM.Framework.Common.Controls.Feedback.ToastNotification"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        SizeToContent="Height"
        ResizeMode="NoResize">

    <Border x:Name="ToastBorder"
            Background="{DynamicResource ContentBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            Padding="0"
            MinHeight="80"
            MaxHeight="200"
            Margin="8,2">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="12" Color="Black" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid x:Name="ContentGrid" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="16,12,32,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <emoji:TextBlock x:Name="IconText" 
                                 Grid.Column="0"
                                 FontSize="20" 
                                 Margin="0,0,12,0"
                                 VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <TextBlock x:Name="TitleText" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               TextAlignment="Left"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="MessageText" 
                               FontSize="12" 
                               TextAlignment="Left"
                               TextWrapping="Wrap"
                               Margin="0"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </Grid>

            <Button x:Name="CloseButton"
                    Click="OnCloseClick"
                    Width="24"
                    Height="24"
                    Margin="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <emoji:TextBlock Text="✖" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#20000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>

