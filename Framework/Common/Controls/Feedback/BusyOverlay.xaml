<UserControl x:Class="TM.Framework.Common.Controls.Feedback.BusyOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:visibilityConverters="clr-namespace:TM.Framework.Common.Converters.Visibility"
             xmlns:feedback="clr-namespace:TM.Framework.Common.Controls.Feedback"
             x:Name="Root">
    <UserControl.Resources>
        <visibilityConverters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <StackPanel x:Key="DefaultOverlayContent"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <feedback:LoadingIndicator Width="56" Height="56"/>
        </StackPanel>
    </UserControl.Resources>

    <Border x:Name="OverlayLayer"
            Background="{Binding OverlayBackground, ElementName=Root}"
            CornerRadius="{Binding OverlayCornerRadius, ElementName=Root}"
            Visibility="{Binding IsBusy, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}"
            IsHitTestVisible="{Binding IsBusy, ElementName=Root}">
        <Grid>
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Content="{Binding OverlayContent, ElementName=Root, TargetNullValue={StaticResource DefaultOverlayContent}}"
                              ContentTemplate="{Binding OverlayContentTemplate, ElementName=Root}"/>
        </Grid>
    </Border>
</UserControl>

