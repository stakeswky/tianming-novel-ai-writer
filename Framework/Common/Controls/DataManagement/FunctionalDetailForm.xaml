<UserControl x:Class="TM.Framework.Common.Controls.DataManagement.FunctionalDetailForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
             x:Name="Root">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <layout:IconHeaderGroupBox Grid.Row="0"
                                   Icon="{Binding HeaderIcon, ElementName=Root}"
                                   Title="{Binding HeaderTitle, ElementName=Root}"
                                   Margin="0,0,0,15">
            <layout:IconHeaderGroupBox.Style>
                <Style TargetType="layout:IconHeaderGroupBox">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowBasicFields, ElementName=Root}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </layout:IconHeaderGroupBox.Style>
            <StackPanel x:Name="FieldRowsPanel" />
        </layout:IconHeaderGroupBox>

        <Grid Grid.Row="1" Margin="0">

            <ContentPresenter Grid.Row="0"
                              Content="{Binding AdditionalContent, ElementName=Root}">
                <ContentPresenter.Style>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCreateMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentPresenter.Style>
            </ContentPresenter>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="📝" Title="新建模式">
                <layout:IconHeaderGroupBox.Style>
                    <Style TargetType="layout:IconHeaderGroupBox">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCreateMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </layout:IconHeaderGroupBox.Style>

                <StackPanel>
                    <TextBlock Text="填写上方表单，选择【类型】并按需选择【所属分类】，然后点击保存。"
                               FontSize="17"
                               LineHeight="24"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextTertiary}"/>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"
                                   Text="1. 类型与所属分类"/>
                        <StackPanel Margin="12,4,0,0">
                            <TextBlock FontSize="16" TextWrapping="Wrap" Foreground="{DynamicResource TextTertiary}" LineHeight="23" Margin="0,0,0,2"
                                       Text="• 类型=【分类】：保存将创建分类；可不选所属分类（创建顶级分类），也可选择父分类（创建子分类）"/>
                            <TextBlock FontSize="16" TextWrapping="Wrap" Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,2" LineHeight="23"
                                       Text="• 类型=【数据】：必须选择所属分类；保存将创建该分类下的数据条目"/>
                            <TextBlock FontSize="16" TextWrapping="Wrap" Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,2" LineHeight="23"
                                       Text="• 所属分类：用于确定新建内容的归属（数据必须选；分类可选）"/>
                            <TextBlock FontSize="16" TextWrapping="Wrap" Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,2" LineHeight="23"
                                       Text="• 左侧树：单击选中；双击或右键【编辑】可修改当前条目"/>
                        </StackPanel>

                        <TextBlock FontSize="17" TextWrapping="Wrap" Foreground="{DynamicResource TextTertiary}" Margin="0,10,0,0" LineHeight="24"
                                   Text="2. 新建：清空表单，重新进入新建模式"/>
                        <TextBlock FontSize="17" TextWrapping="Wrap" Foreground="{DynamicResource TextTertiary}" Margin="0,6,0,0" LineHeight="24"
                                   Text="3. 保存：创建或更新分类/数据"/>
                        <TextBlock FontSize="17" TextWrapping="Wrap" Foreground="{DynamicResource TextTertiary}" Margin="0,6,0,0" LineHeight="24"
                                   Text="4. 删除/全部删除：删除选中项或分类下全部数据"/>
                        <TextBlock FontSize="17" TextWrapping="Wrap" Foreground="{DynamicResource TextTertiary}" Margin="0,6,0,0" LineHeight="24"
                                   Text="5. AI智能生成：自动补全业务字段（需选中数据）"/>
                        <TextBlock FontSize="17" TextWrapping="Wrap" Foreground="{DynamicResource TextTertiary}" Margin="0,6,0,0" LineHeight="24"
                                   Text="6. 左侧树：单击选中，双击编辑"/>
                    </StackPanel>
                </StackPanel>
            </layout:IconHeaderGroupBox>
        </Grid>
    </Grid>

</UserControl>
