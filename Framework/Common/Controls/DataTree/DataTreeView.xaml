<UserControl x:Class="TM.Framework.Common.Controls.DataTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:local="clr-namespace:TM.Framework.Common.Controls"
             xmlns:animations="clr-namespace:TM.Framework.Common.Controls.Animations">

    <UserControl.Resources>
        <ResourceDictionary>

            <local:TreeNodeCountVisibilityConverter x:Key="TreeNodeCountVisibilityConverter"/>

            <local:TagIsDeletableVisibilityConverter x:Key="TagIsDeletableVisibilityConverter"/>

            <SolidColorBrush x:Key="TreeHighlightBluePulse" Color="#FF7CB4FF"/>
            <SolidColorBrush x:Key="TreeHighlightGreenPulse" Color="#FF8CF8BC"/>

            <Style x:Key="NodeNameTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{DynamicResource GlobalFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSiblingBranch}" Value="True">
                        <Setter Property="Foreground" Value="{Binding NameBrush}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Foreground" Value="{Binding NameBrush}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsSelectionFocus}" Value="True">
                        <Setter Property="Foreground" Value="{Binding NameBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="LevelBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="Visibility" Value="Visible"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="3,0,6,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Level}" Value="0">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="NodeButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="3,6,12,6"/>
                <Setter Property="Margin" Value="0,3"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid x:Name="LeftContainer"
                                          Grid.Column="0"
                                          Width="0"
                                          Margin="0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Stretch"
                                          ClipToBounds="True">
                                        <animations:AnimatedGradientStripe x:Name="LeftStatic"
                                                                           Orientation="Vertical"
                                                                           Thickness="5"
                                                                           BaseBrush="{DynamicResource PrimaryColor}"
                                                                           PulseBrush="{StaticResource TreeHighlightBluePulse}"
                                                                           StripeCornerRadius="6,0,0,6"
                                                                           Visibility="Collapsed"
                                                                           IsActive="False"
                                                                           AnimationDuration="0:0:2.0"/>
                                        <animations:AnimatedGradientStripe x:Name="LeftAnimated"
                                                                           Orientation="Vertical"
                                                                           Thickness="5"
                                                                           BaseBrush="{DynamicResource SuccessColor}"
                                                                           PulseBrush="{StaticResource TreeHighlightGreenPulse}"
                                                                           StripeCornerRadius="6,0,0,6"
                                                                           Visibility="Collapsed"
                                                                           IsActive="False"
                                                                           AnimationDuration="0:0:1.4"/>
                                        <animations:AnimatedGradientStripe x:Name="LeftSibling"
                                                                           Orientation="Vertical"
                                                                           Thickness="5"
                                                                           BaseBrush="{DynamicResource TextTertiary}"
                                                                           PulseBrush="{DynamicResource TextSecondary}"
                                                                           StripeCornerRadius="6,0,0,6"
                                                                           Visibility="Collapsed"
                                                                           IsActive="False"
                                                                           AnimationDuration="0:0:1.8"/>
                                    </Grid>

                                    <ContentPresenter Grid.Column="1"
                                                      Margin="{TemplateBinding Padding}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                                    <Polygon x:Name="UserDeletableCorner"
                                             Points="0,0 0,5 5,0"
                                             Fill="{DynamicResource WarningColor}"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Top"
                                             Margin="0"
                                             IsHitTestVisible="False"
                                             Panel.ZIndex="10"
                                             Visibility="{Binding Converter={StaticResource TagIsDeletableVisibilityConverter}}">
                                        <Polygon.ToolTip>
                                            <ToolTip Content="用户自建" />
                                        </Polygon.ToolTip>
                                    </Polygon>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource HoverBackground}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource BorderBrush}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ButtonHelper.IsSelected)}" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                                    <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                    <Setter TargetName="LeftContainer" Property="Width" Value="5"/>
                                    <Setter TargetName="LeftStatic" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="LeftStatic" Property="IsActive" Value="True"/>
                                    <Setter TargetName="UserDeletableCorner" Property="Margin" Value="5,0,0,0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSelectionFocus}" Value="True">
                                    <Setter TargetName="LeftContainer" Property="Width" Value="5"/>
                                    <Setter TargetName="LeftStatic" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="LeftStatic" Property="IsActive" Value="False"/>
                                    <Setter TargetName="LeftSibling" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="LeftSibling" Property="IsActive" Value="False"/>
                                    <Setter TargetName="LeftAnimated" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="LeftAnimated" Property="IsActive" Value="True"/>
                                    <Setter TargetName="Border" Property="BorderBrush" Value="#FF39B86D"/>
                                    <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                    <Setter TargetName="UserDeletableCorner" Property="Margin" Value="5,0,0,0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSiblingBranch}" Value="True">
                                    <Setter TargetName="LeftContainer" Property="Width" Value="5"/>
                                    <Setter TargetName="LeftStatic" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="LeftStatic" Property="IsActive" Value="False"/>
                                    <Setter TargetName="LeftAnimated" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="LeftAnimated" Property="IsActive" Value="False"/>
                                    <Setter TargetName="LeftSibling" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="LeftSibling" Property="IsActive" Value="True"/>
                                    <Setter TargetName="UserDeletableCorner" Property="Margin" Value="5,0,0,0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="#FFFFA500"/>
                                    <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                    <Setter TargetName="Border" Property="Opacity" Value="0.7"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="#FF39B86D"/>
                                    <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                    <Setter TargetName="Border" Property="Background" Value="#1039B86D"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="Level1NodeButtonStyle" TargetType="Button" BasedOn="{StaticResource NodeButtonStyle}">
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Margin" Value="0,5,0,2"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox Grid.Row="0" 
                 x:Name="RootItemsControl"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="True"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 BorderThickness="0"
                 Background="Transparent"
                 IsHitTestVisible="True"
                 Focusable="False"
                 ContextMenu="{Binding NodeContextMenu, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                 PreviewMouseRightButtonDown="OnRootItemsRightButtonDown">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <Button Style="{StaticResource Level1NodeButtonStyle}"
                                Command="{Binding InternalParentNodeClickCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                                CommandParameter="{Binding}"
                                helpers:ButtonHelper.IsSelected="{Binding IsSelected}"
                                MouseDoubleClick="OnNodeDoubleClick"
                                AllowDrop="True"
                                PreviewMouseLeftButtonDown="OnNodePreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="OnNodePreviewMouseLeftButtonUp"
                                PreviewMouseMove="OnNodePreviewMouseMove"
                                DragEnter="OnNodeDragEnter"
                                DragLeave="OnNodeDragLeave"
                                Drop="OnNodeDrop">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Level, StringFormat='Lv{0}'}"
                                           Foreground="{Binding LevelBrush}"
                                           Style="{StaticResource LevelBadgeTextStyle}"
                                           Visibility="{Binding ShowLevelIndicator, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <Image Source="{Binding LogoImage}" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"
                                       Visibility="{Binding HasLogoImage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <emoji:TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"
                                                 Visibility="{Binding ShowIcon, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Style="{StaticResource NodeNameTextStyle}"/>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextTertiary}"
                                           FontSize="12"
                                           Margin="10,0,0,0"
                                           Text="{Binding Children.Count, StringFormat=' ({0})'}">
                                    <TextBlock.Visibility>
                                        <MultiBinding Converter="{StaticResource TreeNodeCountVisibilityConverter}">
                                            <Binding Path="ShowChildCount"/>
                                            <Binding Path="IsFileSystemNode"/>
                                            <Binding Path="Children.Count"/>
                                        </MultiBinding>
                                    </TextBlock.Visibility>
                                </TextBlock>
                            </StackPanel>
                        </Button>

                        <ListBox ItemsSource="{Binding Children}" 
                                 Margin="10,0,0,0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Focusable="False"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 VirtualizingPanel.ScrollUnit="Pixel">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter HorizontalAlignment="Stretch"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Button Grid.Row="0"
                                                Command="{Binding InternalParentNodeClickCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                                                CommandParameter="{Binding}"
                                                helpers:ButtonHelper.IsSelected="{Binding IsSelected}"
                                                MouseDoubleClick="OnNodeDoubleClick"
                                                AllowDrop="True"
                                                PreviewMouseLeftButtonDown="OnNodePreviewMouseLeftButtonDown"
                                                PreviewMouseLeftButtonUp="OnNodePreviewMouseLeftButtonUp"
                                                PreviewMouseMove="OnNodePreviewMouseMove"
                                                DragEnter="OnNodeDragEnter"
                                                DragLeave="OnNodeDragLeave"
                                                Drop="OnNodeDrop"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource NodeButtonStyle}">
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Setter Property="FontWeight" Value="Normal"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                    <Setter Property="Padding" Value="3,6"/>
                                                </Style>
                                            </Button.Style>
                                            <DockPanel>
                                                <Border DockPanel.Dock="Right" 
                                                        Background="#E8F5E9" 
                                                        BorderBrush="#4CAF50" 
                                                        BorderThickness="1" 
                                                        CornerRadius="3" 
                                                        Padding="4,1" 
                                                        Margin="0,0,0,-3"
                                                        VerticalAlignment="Bottom"
                                                        HorizontalAlignment="Right"
                                                        Visibility="{Binding HasStatusBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="✓" Foreground="#4CAF50" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,2,0"/>
                                                        <TextBlock Text="{Binding StatusBadge}" Foreground="#2E7D32" FontSize="10" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Level, StringFormat='Lv{0}'}"
                                                               Foreground="{Binding LevelBrush}"
                                                               Style="{StaticResource LevelBadgeTextStyle}"
                                                               Visibility="{Binding ShowLevelIndicator, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <Image Source="{Binding LogoImage}" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                                           Visibility="{Binding HasLogoImage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <emoji:TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                     Visibility="{Binding ShowIcon, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Style="{StaticResource NodeNameTextStyle}"/>
                                                    <TextBlock VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextTertiary}"
                                                               FontSize="12"
                                                               Margin="10,0,0,0"
                                                               Text="{Binding Children.Count, StringFormat=' ({0})'}">
                                                        <TextBlock.Visibility>
                                                            <MultiBinding Converter="{StaticResource TreeNodeCountVisibilityConverter}">
                                                                <Binding Path="ShowChildCount"/>
                                                                <Binding Path="IsFileSystemNode"/>
                                                                <Binding Path="Children.Count"/>
                                                            </MultiBinding>
                                                        </TextBlock.Visibility>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DockPanel>
                                        </Button>

                                        <ListBox Grid.Row="1"
                                                 ItemsSource="{Binding Children}" 
                                                 Margin="10,0,0,0"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Focusable="False"
                                                 ScrollViewer.CanContentScroll="True"
                                                 VirtualizingStackPanel.IsVirtualizing="True"
                                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                                 VirtualizingPanel.ScrollUnit="Pixel">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <VirtualizingStackPanel/>
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <ContentPresenter/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.Style>
                                                <Style TargetType="ListBox">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.Style>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <Button Command="{Binding InternalParentNodeClickCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                                                                CommandParameter="{Binding}"
                                                                helpers:ButtonHelper.IsSelected="{Binding IsSelected}"
                                                                MouseDoubleClick="OnNodeDoubleClick"
                                                                AllowDrop="True"
                                                                PreviewMouseLeftButtonDown="OnNodePreviewMouseLeftButtonDown"
                                                                PreviewMouseLeftButtonUp="OnNodePreviewMouseLeftButtonUp"
                                                                PreviewMouseMove="OnNodePreviewMouseMove"
                                                                DragEnter="OnNodeDragEnter"
                                                                DragLeave="OnNodeDragLeave"
                                                                Drop="OnNodeDrop">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource NodeButtonStyle}">
                                                                    <Setter Property="FontSize" Value="12"/>
                                                                    <Setter Property="FontWeight" Value="Normal"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                                    <Setter Property="Padding" Value="3,6"/>
                                                                </Style>
                                                            </Button.Style>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Level, StringFormat='Lv{0}'}"
                                                                           Foreground="{Binding LevelBrush}"
                                                                           Style="{StaticResource LevelBadgeTextStyle}"
                                                                           Visibility="{Binding ShowLevelIndicator, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                <Image Source="{Binding LogoImage}" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                       Visibility="{Binding HasLogoImage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                <emoji:TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                                 Visibility="{Binding ShowIcon, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Style="{StaticResource NodeNameTextStyle}"/>
                                                                <TextBlock VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource TextTertiary}"
                                                                           FontSize="12"
                                                                           Margin="10,0,0,0"
                                                                           Text="{Binding Children.Count, StringFormat=' ({0})'}">
                                                                    <TextBlock.Visibility>
                                                                        <MultiBinding Converter="{StaticResource TreeNodeCountVisibilityConverter}">
                                                                            <Binding Path="ShowChildCount"/>
                                                                            <Binding Path="IsFileSystemNode"/>
                                                                            <Binding Path="Children.Count"/>
                                                                        </MultiBinding>
                                                                    </TextBlock.Visibility>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Button>

                                                        <ListBox ItemsSource="{Binding Children}" 
                                                                 Margin="10,0,0,0"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 Focusable="False"
                                                                 ScrollViewer.CanContentScroll="True"
                                                                 VirtualizingStackPanel.IsVirtualizing="True"
                                                                 VirtualizingStackPanel.VirtualizationMode="Recycling">
                                                            <ListBox.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <VirtualizingStackPanel/>
                                                                </ItemsPanelTemplate>
                                                            </ListBox.ItemsPanel>
                                                            <ListBox.ItemContainerStyle>
                                                                <Style TargetType="ListBoxItem">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                                <ContentPresenter/>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </ListBox.ItemContainerStyle>
                                                            <ListBox.Style>
                                                                <Style TargetType="ListBox">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ListBox.Style>
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel>
                                                                        <Button Command="{Binding InternalParentNodeClickCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                                                                                CommandParameter="{Binding}"
                                                                                helpers:ButtonHelper.IsSelected="{Binding IsSelected}"
                                                                                MouseDoubleClick="OnNodeDoubleClick"
                                                                                AllowDrop="True"
                                                                                PreviewMouseLeftButtonDown="OnNodePreviewMouseLeftButtonDown"
                                                                                PreviewMouseLeftButtonUp="OnNodePreviewMouseLeftButtonUp"
                                                                                PreviewMouseMove="OnNodePreviewMouseMove"
                                                                                DragEnter="OnNodeDragEnter"
                                                                                DragLeave="OnNodeDragLeave"
                                                                                Drop="OnNodeDrop">
                                                                            <Button.Style>
                                                                                <Style TargetType="Button" BasedOn="{StaticResource NodeButtonStyle}">
                                                                                    <Setter Property="FontSize" Value="12"/>
                                                                                    <Setter Property="FontWeight" Value="Normal"/>
                                                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                                                    <Setter Property="Padding" Value="3,6"/>
                                                                                </Style>
                                                                            </Button.Style>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Text="{Binding Level, StringFormat='Lv{0}'}"
                                                                                           Foreground="{Binding LevelBrush}"
                                                                                           Style="{StaticResource LevelBadgeTextStyle}"
                                                                                           Visibility="{Binding ShowLevelIndicator, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                                <Image Source="{Binding LogoImage}" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                                       Visibility="{Binding HasLogoImage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                                <emoji:TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                                                 Visibility="{Binding ShowIcon, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Style="{StaticResource NodeNameTextStyle}"/>
                                                                                <TextBlock VerticalAlignment="Center"
                                                                                           Foreground="{DynamicResource TextTertiary}"
                                                                                           FontSize="12"
                                                                                           Margin="10,0,0,0"
                                                                                           Text="{Binding Children.Count, StringFormat=' ({0})'}">
                                                                                    <TextBlock.Visibility>
                                                                                        <MultiBinding Converter="{StaticResource TreeNodeCountVisibilityConverter}">
                                                                                            <Binding Path="ShowChildCount"/>
                                                                                            <Binding Path="IsFileSystemNode"/>
                                                                                            <Binding Path="Children.Count"/>
                                                                                        </MultiBinding>
                                                                                    </TextBlock.Visibility>
                                                                                </TextBlock>
                                                                            </StackPanel>
                                                                        </Button>

                                                                        <ListBox ItemsSource="{Binding Children}" 
                                                                                 Margin="10,0,0,0"
                                                                                 BorderThickness="0"
                                                                                 Background="Transparent"
                                                                                 Focusable="False"
                                                                                 ScrollViewer.CanContentScroll="True"
                                                                                 VirtualizingStackPanel.IsVirtualizing="True"
                                                                                 VirtualizingStackPanel.VirtualizationMode="Recycling">
                                                                            <ListBox.ItemsPanel>
                                                                                <ItemsPanelTemplate>
                                                                                    <VirtualizingStackPanel/>
                                                                                </ItemsPanelTemplate>
                                                                            </ListBox.ItemsPanel>
                                                                            <ListBox.ItemContainerStyle>
                                                                                <Style TargetType="ListBoxItem">
                                                                                    <Setter Property="Template">
                                                                                        <Setter.Value>
                                                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                                                <ContentPresenter/>
                                                                                            </ControlTemplate>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </Style>
                                                                            </ListBox.ItemContainerStyle>
                                                                            <ListBox.Style>
                                                                                <Style TargetType="ListBox">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </ListBox.Style>
                                                                            <ListBox.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <Button Command="{Binding ChildNodeClickCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                                                                                            CommandParameter="{Binding}"
                                                                                            helpers:ButtonHelper.IsSelected="{Binding IsSelected}"
                                                                                            MouseDoubleClick="OnNodeDoubleClick"
                                                                                            AllowDrop="True"
                                                                                            PreviewMouseLeftButtonDown="OnNodePreviewMouseLeftButtonDown"
                                                                                            PreviewMouseLeftButtonUp="OnNodePreviewMouseLeftButtonUp"
                                                                                            PreviewMouseMove="OnNodePreviewMouseMove"
                                                                                            DragEnter="OnNodeDragEnter"
                                                                                            DragLeave="OnNodeDragLeave"
                                                                                            Drop="OnNodeDrop">
                                                                                        <Button.Style>
                                                                                            <Style TargetType="Button" BasedOn="{StaticResource NodeButtonStyle}">
                                                                                                <Setter Property="FontSize" Value="12"/>
                                                                                                <Setter Property="FontWeight" Value="Normal"/>
                                                                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                                                                <Setter Property="Padding" Value="3,6"/>
                                                                                            </Style>
                                                                                        </Button.Style>
                                                                                        <StackPanel Orientation="Horizontal">
                                                                                            <TextBlock Text="› " Foreground="{DynamicResource PrimaryColor}" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                                                            <Image Source="{Binding LogoImage}" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                                                   Visibility="{Binding HasLogoImage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                                            <emoji:TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                                                             Visibility="{Binding ShowIcon, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Style="{StaticResource NodeNameTextStyle}"/>
                                                                                            <TextBlock VerticalAlignment="Center"
                                                                                                       Foreground="{Binding LevelBrush}"
                                                                                                       FontSize="12"
                                                                                                       Margin="10,0,0,0">
                                                                                                <TextBlock.Style>
                                                                                                    <Style TargetType="TextBlock">
                                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                        <Style.Triggers>
                                                                                                            <DataTrigger Binding="{Binding ShowChildCount}" Value="True">
                                                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                                                <Setter Property="Text" Value="{Binding Children.Count, StringFormat=' ({0})'}"/>
                                                                                                            </DataTrigger>
                                                                                                        </Style.Triggers>
                                                                                                    </Style>
                                                                                                </TextBlock.Style>
                                                                                            </TextBlock>
                                                                                        </StackPanel>
                                                                                    </Button>
                                                                                </DataTemplate>
                                                                            </ListBox.ItemTemplate>
                                                                        </ListBox>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="1"
              Margin="0,10,0,0"
              HorizontalAlignment="Stretch"
              x:Name="ActionButtonPanel">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="DeleteAllButton"
                    Grid.Row="0" Grid.Column="0"
                    Margin="0,0,3,5"
                    Style="{StaticResource DangerButtonStyle}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Command="{Binding InternalDeleteAllCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                    ToolTipService.ShowOnDisabled="True">
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="🧹" FontSize="11" Margin="0,0,2,0" VerticalAlignment="Center"/>
                    <TextBlock Text="全部删除" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="DeleteButton"
                    Grid.Row="0" Grid.Column="1"
                    Margin="3,0,3,5"
                    Style="{StaticResource DangerButtonStyle}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Command="{Binding InternalDeleteCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                    ToolTipService.ShowOnDisabled="True">
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="🗑️" FontSize="11" Margin="0,0,2,0" VerticalAlignment="Center"/>
                    <TextBlock Text="删除" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="AIGenerateButton"
                    Grid.Row="0" Grid.Column="2"
                    Margin="3,0,0,5"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Visibility="Collapsed"
                    Command="{Binding AIGenerateCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                    ToolTipService.ShowOnDisabled="True">
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="🤖" FontSize="11" Margin="0,0,2,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding AIGenerateButtonText, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="1" Grid.Column="0"
                    Margin="0,0,3,0"
                    IsEnabled="{Binding IsBulkToggleEnabled, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                    Command="{Binding InternalBulkToggleCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                    ToolTip="{Binding BulkToggleToolTip, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                    ToolTipService.ShowOnDisabled="True"
                    Style="{StaticResource PrimaryButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="⚡" FontSize="11" Margin="0,0,2,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding BulkToggleButtonText, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                               FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="AddButton"
                    Grid.Row="1" Grid.Column="1"
                    Margin="3,0,3,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Command="{Binding InternalAddCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}"
                    ToolTipService.ShowOnDisabled="True">
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock x:Name="AddButtonIcon" Text="➕" FontSize="11" Margin="0,0,2,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="AddButtonText" Text="新建" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="SaveButton"
                    Grid.Row="1" Grid.Column="2"
                    Margin="3,0,0,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Command="{Binding InternalSaveCommand, RelativeSource={RelativeSource AncestorType=local:DataTreeView}}">
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="💾" FontSize="11" Margin="0,0,2,0" VerticalAlignment="Center"/>
                    <TextBlock Text="保存" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
