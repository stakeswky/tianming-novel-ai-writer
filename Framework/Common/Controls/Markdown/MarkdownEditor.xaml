<UserControl x:Class="TM.Framework.Common.Controls.Markdown.MarkdownEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../UI/Windows/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource UnifiedBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Height="36">
            <StackPanel Orientation="Horizontal" Margin="10,5">
                <Button x:Name="SaveButton"
                        Click="OnSave"
                        Height="24"
                        Padding="8,4"
                        Margin="0,0,5,0"
                        Style="{StaticResource TopBarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="💾" FontSize="12" Margin="0,0,3,0"/>
                        <TextBlock Text="保存" FontSize="12"/>
                    </StackPanel>
                </Button>

                <Button x:Name="CopyButton"
                        Click="OnCopy"
                        Height="24"
                        Padding="8,4"
                        Margin="0,0,5,0"
                        Style="{StaticResource TopBarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="📋" FontSize="12" Margin="0,0,3,0"/>
                        <TextBlock Text="复制" FontSize="12"/>
                    </StackPanel>
                </Button>

                <Button x:Name="ExportButton"
                        Click="OnExport"
                        Height="24"
                        Padding="8,4"
                        Margin="0,0,5,0"
                        Style="{StaticResource TopBarButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="📤" FontSize="12" Margin="0,0,3,0"/>
                        <TextBlock Text="导出" FontSize="12"/>
                    </StackPanel>
                </Button>

                <Separator Width="1" Height="20" Margin="5,0" Background="{DynamicResource BorderBrush}"/>

                <TextBlock Text="字数：" 
                          VerticalAlignment="Center"
                          FontSize="12"
                          Foreground="{DynamicResource TextSecondary}"/>
                <TextBlock x:Name="WordCountText"
                          Text="0"
                          VerticalAlignment="Center"
                          FontSize="12"
                          Margin="5,0"
                          FontWeight="SemiBold"
                          Foreground="{DynamicResource TextPrimary}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource ContentBackground}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="EditorTextBox"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="14"
                         Padding="10"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource TextPrimary}"
                         TextChanged="OnTextChanged"
                         VerticalScrollBarVisibility="Disabled"
                         HorizontalScrollBarVisibility="Disabled"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

