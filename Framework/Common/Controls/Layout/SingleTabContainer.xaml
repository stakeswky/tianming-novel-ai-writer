<UserControl x:Class="TM.Framework.Common.Controls.Layout.SingleTabContainer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Padding="{Binding ContentPadding, ElementName=Root}"
            Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ContentPresenter Content="{Binding PageContent, ElementName=Root}"/>
        </ScrollViewer>
    </Border>
</UserControl>

