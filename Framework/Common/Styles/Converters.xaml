<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:TM.Framework.Common.Converters"
                    xmlns:visibility="clr-namespace:TM.Framework.Common.Converters.Visibility"
                    xmlns:value="clr-namespace:TM.Framework.Common.Converters.Value">

    <visibility:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <visibility:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    <visibility:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
    <visibility:InverseCountToVisibilityConverter x:Key="InverseCountToVisibilityConverter"/>
    <visibility:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    <visibility:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter"/>

    <value:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
    <value:InverseBoolConverter x:Key="InverseBoolConverter"/>
    <value:ResourceKeyToDynamicResourceConverter x:Key="ResourceKeyToDynamicResourceConverter"/>
    <value:BoolToTextConverter x:Key="BoolToTextConverter" TrueText="是" FalseText="否"/>
    <value:PercentageToWidthConverter x:Key="PercentageToWidthConverter"/>
    <value:BoolToColorConverter x:Key="BoolToColorConverter"/>
    <value:BoolToExpandTextConverter x:Key="BoolToExpandTextConverter"/>

    <converters:LevelToMarginConverter x:Key="LevelToMarginConverter" IndentPerLevel="20"/>

</ResourceDictionary>

