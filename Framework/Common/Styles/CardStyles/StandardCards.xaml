<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource MediumRadius}"/>
        <Setter Property="Padding" Value="{StaticResource LargePadding}"/>
        <Setter Property="Margin" Value="{StaticResource MediumMargin}"/>
    </Style>

    <Style x:Key="CompactCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Padding" Value="{StaticResource MediumPadding}"/>
    </Style>

    <Style x:Key="SpacedCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Padding" Value="{StaticResource ExtraLargePadding}"/>
    </Style>

    <Style x:Key="ElevatedCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="Black" 
                                Opacity="0.08" 
                                BlurRadius="12" 
                                ShadowDepth="3" 
                                Direction="270"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InteractiveCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                <Setter Property="BorderThickness" Value="2"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SelectableCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="InfoCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="#E7F3FF"/>
        <Setter Property="BorderBrush" Value="#90CAF9"/>
        <Setter Property="BorderThickness" Value="{StaticResource ThickBorder}"/>
    </Style>

    <Style x:Key="SuccessCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="#E8F5E9"/>
        <Setter Property="BorderBrush" Value="#81C784"/>
        <Setter Property="BorderThickness" Value="{StaticResource ThickBorder}"/>
    </Style>

    <Style x:Key="WarningCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="#FFF3CD"/>
        <Setter Property="BorderBrush" Value="#FFE69C"/>
        <Setter Property="BorderThickness" Value="{StaticResource ThickBorder}"/>
    </Style>

    <Style x:Key="DangerCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="#FFEBEE"/>
        <Setter Property="BorderBrush" Value="#EF9A9A"/>
        <Setter Property="BorderThickness" Value="{StaticResource ThickBorder}"/>
    </Style>

    <Style x:Key="CardTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <Style x:Key="CardSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="CardDescriptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="LineHeight" Value="18"/>
    </Style>

    <Style x:Key="StandardGroupBoxStyle" TargetType="GroupBox">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI Symbol, Microsoft YaHei UI"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style x:Key="CardHeaderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="0,0,0,12"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style x:Key="ThemeCardStyle" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource ThemeCardWidth}"/>
        <Setter Property="Height" Value="{StaticResource ThemeCardHeight}"/>
        <Setter Property="Margin" Value="6"/>
        <Setter Property="Background" Value="{DynamicResource Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="{StaticResource ThickBorder}"/>
        <Setter Property="CornerRadius" Value="{StaticResource MediumRadius}"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="Black" 
                                        Opacity="0.1" 
                                        BlurRadius="10" 
                                        ShadowDepth="2" 
                                        Direction="270"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SelectedThemeCardStyle" TargetType="Border" BasedOn="{StaticResource ThemeCardStyle}">
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
        <Setter Property="BorderThickness" Value="{StaticResource ExtraThickBorder}"/>
    </Style>

    <Style x:Key="CurrentThemeCardStyle" TargetType="Border" BasedOn="{StaticResource ThemeCardStyle}">
        <Setter Property="BorderBrush" Value="#28a745"/>
        <Setter Property="BorderThickness" Value="{StaticResource ExtraThickBorder}"/>
    </Style>

</ResourceDictionary>

