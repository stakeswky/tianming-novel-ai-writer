<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:tree="clr-namespace:TM.Framework.Common.Controls"
                    xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
                    xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <Style x:Key="TreeComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Padding" Value="12,8,36,8"/>
        <Setter Property="FontFamily" Value="{DynamicResource GlobalFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSizeNormal}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource ContentBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="helpers:ComboBoxHelper.AutoDetectTreeMode" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="toggleButton"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                    Focusable="False"
                                    ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="templateRoot"
                                           Background="{TemplateBinding Background}"
                                           BorderBrush="{TemplateBinding BorderBrush}"
                                           BorderThickness="{TemplateBinding BorderThickness}"
                                           CornerRadius="6"
                                           SnapsToDevicePixels="True">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="36"/>
                                            </Grid.ColumnDefinitions>
                                            <Path x:Name="arrow"
                                                 Grid.Column="1"
                                                 Data="M 0 0 L 4 4 L 8 0 Z"
                                                 Fill="{DynamicResource TextSecondary}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,8,0"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="templateRoot" Property="BorderBrush" Value="{DynamicResource PrimaryHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="templateRoot" Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                                            <Setter TargetName="arrow" Property="Data" Value="M 0 4 L 4 0 L 8 4 Z"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <StackPanel x:Name="contentDisplay"
                                   Orientation="Horizontal"
                                   HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                   VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                   Margin="{TemplateBinding Padding}"
                                   IsHitTestVisible="False">
                            <emoji:TextBlock x:Name="displayIcon"
                                            FontSize="14"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center">
                                <emoji:TextBlock.Style>
                                    <Style TargetType="emoji:TextBlock">
                                        <Setter Property="Text" Value="{Binding Path=(helpers:ComboBoxHelper.DisplayIcon), RelativeSource={RelativeSource TemplatedParent}}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=(helpers:ComboBoxHelper.DisplayText), RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                <Setter Property="Text" Value="🏠"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Path=(helpers:ComboBoxHelper.DisplayText), RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                <Setter Property="Text" Value="🏠"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </emoji:TextBlock.Style>
                            </emoji:TextBlock>

                            <TextBlock x:Name="displayText"
                                      Foreground="{TemplateBinding Foreground}"
                                      VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Path=(helpers:ComboBoxHelper.DisplayText), RelativeSource={RelativeSource TemplatedParent}}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=(helpers:ComboBoxHelper.DisplayText), RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                <Setter Property="Text" Value="选择分类..."/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Path=(helpers:ComboBoxHelper.DisplayText), RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                <Setter Property="Text" Value="选择分类..."/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Popup x:Name="PART_Popup"
                              AllowsTransparency="True"
                              Placement="Bottom"
                              IsOpen="{TemplateBinding IsDropDownOpen}"
                              Focusable="False"
                              PopupAnimation="Slide">
                            <Border Background="{DynamicResource ContentBackground}"
                                   BorderBrush="{DynamicResource BorderBrush}"
                                   BorderThickness="1"
                                   CornerRadius="8"
                                   MaxHeight="400"
                                   Padding="6"
                                   Margin="10"
                                   SnapsToDevicePixels="True"
                                   Width="{TemplateBinding ActualWidth}">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0"
                                                     BlurRadius="12"
                                                     Opacity="0.2"
                                                     Color="#000000"
                                                     RenderingBias="Quality"/>
                                </Border.Effect>
                                <tree:DataTreeView ItemsSource="{TemplateBinding ItemsSource}"
                                                  MaxLevel="{Binding (helpers:ComboBoxHelper.MaxLevel), RelativeSource={RelativeSource TemplatedParent}}"
                                                  ParentClickMode="Toggle"
                                                  Level1HorizontalAlignment="Left"
                                                  NodeDoubleClickCommand="{Binding (helpers:ComboBoxHelper.NodeDoubleClickCommand), RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

