<UserControl x:Class="TM.Framework.Common.Search.SearchTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI">

    <Grid>
        <TextBox x:Name="SearchBox"
                 Text="{Binding SearchKeyword, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource StandardTextBoxStyle}"
                 helpers:TextInputContextMenuHelper.EnableStandardEditMenu="True"
                 Height="36"/>

        <StackPanel Orientation="Horizontal" 
                    IsHitTestVisible="False"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SearchKeyword, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SearchKeyword, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <emoji:TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBlock Text="{Binding PlaceholderText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="{DynamicResource TextTertiary}"
                       FontSize="14"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>

</UserControl>

