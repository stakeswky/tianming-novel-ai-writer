<UserControl x:Class="TM.Framework.Appearance.Animation.LoadingAnimation.LoadingAnimationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:local="clr-namespace:TM.Framework.Appearance.Animation.LoadingAnimation"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="🎨" Title="动画类型">
                <StackPanel Margin="10">
                    <TextBlock Text="选择加载时显示的动画样式" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>
                    <ComboBox ItemsSource="{Binding AnimationTypes}" 
                              SelectedItem="{Binding SelectedAnimationType}"
                              Style="{DynamicResource StandardComboBoxStyle}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="⚙️" Title="动画参数">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="动画速度" FontSize="12" Margin="0,0,0,5"/>
                            <TextBlock Grid.Column="1" Text="{Binding AnimationSpeed}" FontSize="12" Foreground="{DynamicResource TextTertiary}"/>
                        </Grid>
                        <Slider Minimum="1" Maximum="200" Value="{Binding AnimationSpeed}"/>
                        <TextBlock Text="提示: 数值越小速度越快" FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="动画大小 (像素)" FontSize="12" Margin="0,0,0,5"/>
                            <TextBlock Grid.Column="1" Text="{Binding Size}" FontSize="12" Foreground="{DynamicResource TextTertiary}"/>
                        </Grid>
                        <Slider Minimum="24" Maximum="96" Value="{Binding Size}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,15">
                        <TextBlock Text="动画颜色" FontSize="12" Margin="0,0,0,8"/>
                        <WrapPanel>
                            <Button Content="选择主色" Command="{Binding PickPrimaryColorCommand}" 
                                    Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6" Margin="0,0,10,0"/>
                            <Border Width="32" Height="32" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding PrimaryColor}"/>
                                </Border.Background>
                            </Border>
                            <Button Content="选择副色" Command="{Binding PickSecondaryColorCommand}" 
                                    Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6" Margin="15,0,10,0"/>
                            <Border Width="32" Height="32" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding SecondaryColor}"/>
                                </Border.Background>
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="动画不透明度" FontSize="12" Margin="0,0,0,5"/>
                            <TextBlock Grid.Column="1" Text="{Binding Opacity, StringFormat={}{0:F2}}" FontSize="12" Foreground="{DynamicResource TextTertiary}"/>
                        </Grid>
                        <Slider Minimum="0.1" Maximum="1.0" Value="{Binding Opacity}" TickFrequency="0.1"/>
                    </StackPanel>
                </Grid>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="📝" Title="文本配置">
                <StackPanel Margin="10">
                    <CheckBox Content="显示加载文字" IsChecked="{Binding ShowText}" Margin="0,0,0,10"/>
                    <TextBlock Text="加载提示文字" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding LoadingText}" Style="{DynamicResource StandardTextBoxStyle}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="文字大小" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock Grid.Column="1" Text="{Binding TextSize}" FontSize="12" Foreground="{DynamicResource TextTertiary}"/>
                    </Grid>
                    <Slider Minimum="10" Maximum="24" Value="{Binding TextSize}" Margin="0,0,0,10"/>

                    <Button Content="选择文字颜色" Command="{Binding PickTextColorCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6" 
                            HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <Border Width="60" Height="32" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                            CornerRadius="4" HorizontalAlignment="Left" Margin="0,0,0,10">
                        <Border.Background>
                            <SolidColorBrush Color="{Binding TextColor}"/>
                        </Border.Background>
                    </Border>

                    <CheckBox Content="显示进度百分比 (仅进度条模式)" IsChecked="{Binding ShowPercentage}"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="📍" Title="显示位置">
                <StackPanel Margin="10">
                    <TextBlock Text="选择加载动画在屏幕上的显示位置" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>
                    <ComboBox ItemsSource="{Binding Positions}" 
                              SelectedItem="{Binding SelectedPosition}"
                              Style="{DynamicResource StandardComboBoxStyle}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="🌫️" Title="遮罩配置">
                <StackPanel Margin="10">
                    <TextBlock Text="遮罩模式" FontSize="12" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding OverlayModes}" 
                              SelectedItem="{Binding SelectedOverlayMode}"
                              Style="{DynamicResource StandardComboBoxStyle}" Margin="0,0,0,15">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="遮罩不透明度" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock Grid.Column="1" Text="{Binding OverlayOpacity, StringFormat={}{0:F2}}" FontSize="12" Foreground="{DynamicResource TextTertiary}"/>
                    </Grid>
                    <Slider Minimum="0.0" Maximum="1.0" Value="{Binding OverlayOpacity}" TickFrequency="0.1" Margin="0,0,0,10"/>

                    <Button Content="选择遮罩颜色" Command="{Binding PickOverlayColorCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6" 
                            HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <Border Width="60" Height="32" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                            CornerRadius="4" HorizontalAlignment="Left" Margin="0,0,0,15">
                        <Border.Background>
                            <SolidColorBrush Color="{Binding OverlayColor}"/>
                        </Border.Background>
                    </Border>

                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="模糊半径 (仅模糊模式)" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock Grid.Column="1" Text="{Binding BlurRadius}" FontSize="12" Foreground="{DynamicResource TextTertiary}"/>
                    </Grid>
                    <Slider Minimum="0" Maximum="20" Value="{Binding BlurRadius}" IsEnabled="{Binding IsBlurMode}"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="⏱️" Title="显示控制">
                <StackPanel Margin="10">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="最短显示时间 (毫秒)" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock Grid.Column="1" Text="{Binding MinDisplayTime}" FontSize="12" Foreground="{DynamicResource TextTertiary}"/>
                    </Grid>
                    <Slider Minimum="0" Maximum="2000" Value="{Binding MinDisplayTime}" TickFrequency="100" Margin="0,0,0,5"/>
                    <TextBlock Text="避免加载动画闪烁，设置最短显示时间" FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="延迟显示时间 (毫秒)" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock Grid.Column="1" Text="{Binding DelayTime}" FontSize="12" Foreground="{DynamicResource TextTertiary}"/>
                    </Grid>
                    <Slider Minimum="0" Maximum="1000" Value="{Binding DelayTime}" TickFrequency="50" Margin="0,0,0,5"/>
                    <TextBlock Text="短操作不显示加载，超过此时间才显示" FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,15"/>

                    <CheckBox Content="点击遮罩关闭加载指示器" IsChecked="{Binding CancelOnClick}"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="🔊" Title="音效设置">
                <StackPanel Margin="10">
                    <CheckBox Content="启用加载音效" IsChecked="{Binding EnableSound}" Margin="0,0,0,10"/>
                    <Button Content="选择音效文件" Command="{Binding PickSoundFileCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6" 
                            HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding SoundPath}" FontSize="11" Foreground="{DynamicResource TextTertiary}" TextWrapping="Wrap"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Margin="0,0,0,20" Icon="🎬" Title="预览与操作">
                <WrapPanel Margin="10" HorizontalAlignment="Center">
                    <Button Content="测试效果" Command="{Binding TestLoadingCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="20,8" Margin="5"/>
                    <Button Content="应用设置" Command="{Binding ApplySettingsCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}" Padding="20,8" Margin="5"
                            helpers:ButtonHelper.ConfirmMessage="确定要应用这些加载动画设置吗？"
                            helpers:ButtonHelper.ConfirmTitle="确认应用"/>
                    <Button Content="重置默认" Command="{Binding ResetToDefaultCommand}"
                            Style="{DynamicResource DangerButtonStyle}" Padding="20,8" Margin="5"
                            helpers:ButtonHelper.ConfirmMessage="确定要重置为默认设置吗？当前配置将丢失！"
                            helpers:ButtonHelper.ConfirmTitle="确认重置"/>
                </WrapPanel>
            </common:IconHeaderGroupBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>
