<UserControl x:Class="TM.Framework.Appearance.Animation.UIResolution.UIResolutionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:local="clr-namespace:TM.Framework.Appearance.Animation.UIResolution">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <layout:IconHeaderGroupBox Icon="🖥️" Title="预设分辨率" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="选择常用的窗口分辨率预设" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>
                    <ComboBox ItemsSource="{Binding PresetResolutions}" 
                              SelectedItem="{Binding SelectedPreset}"
                              Style="{DynamicResource StandardComboBoxStyle}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <emoji:TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="📐" Title="自定义尺寸" Margin="0,0,0,15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="窗口宽度 (像素)" FontSize="12" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <Slider Grid.Column="0" 
                                   Minimum="800" 
                                   Maximum="3840" 
                                   Value="{Binding WindowWidth}"
                                   IsEnabled="{Binding IsCustomResolution}"/>

                            <TextBox Grid.Column="2" 
                                    Text="{Binding WindowWidth, UpdateSourceTrigger=PropertyChanged}" 
                                    Style="{DynamicResource StandardTextBoxStyle}"
                                    IsEnabled="{Binding IsCustomResolution}"/>
                        </Grid>
                        <TextBlock Text="范围: 800-3840 像素" 
                                  FontSize="11" 
                                  Foreground="{DynamicResource TextTertiary}" 
                                  Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <TextBlock Text="窗口高度 (像素)" FontSize="12" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <Slider Grid.Column="0" 
                                   Minimum="600" 
                                   Maximum="2160" 
                                   Value="{Binding WindowHeight}"
                                   IsEnabled="{Binding IsCustomResolution}"/>

                            <TextBox Grid.Column="2" 
                                    Text="{Binding WindowHeight, UpdateSourceTrigger=PropertyChanged}" 
                                    Style="{DynamicResource StandardTextBoxStyle}"
                                    IsEnabled="{Binding IsCustomResolution}"/>
                        </Grid>
                        <TextBlock Text="范围: 600-2160 像素" 
                                  FontSize="11" 
                                  Foreground="{DynamicResource TextTertiary}" 
                                  Margin="0,5,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" 
                              FontSize="11" 
                              Foreground="{DynamicResource InfoColor}"
                              TextWrapping="Wrap">
                        <emoji:TextBlock Text="💡" FontSize="11"/>
                        <Run Text=" 提示：选择自定义预设后才能手动调整宽度和高度。"/>
                    </TextBlock>
                </Grid>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="🔍" Title="UI缩放比例" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="调整UI元素的显示大小" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>
                    <ComboBox ItemsSource="{Binding ScaleLevels}" 
                              SelectedItem="{Binding SelectedScale}"
                              Style="{DynamicResource StandardComboBoxStyle}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <emoji:TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="💡 缩放比例会影响所有UI元素的显示大小" 
                              FontSize="11" 
                              Foreground="{DynamicResource InfoColor}" 
                              Margin="0,10,0,0"
                              TextWrapping="Wrap"/>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="ℹ️" Title="当前信息" Margin="0,0,0,15">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="📱" FontSize="14" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" 
                                  Text="{Binding CurrentWindowInfo}" 
                                  FontSize="13" 
                                  VerticalAlignment="Center"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🖥️" FontSize="14" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" 
                                  Text="{Binding ScreenResolutionInfo}" 
                                  FontSize="13" 
                                  VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="⚙️" Title="操作" Margin="0,0,0,15">
                <WrapPanel HorizontalAlignment="Center">
                    <Button Content="预览效果" Command="{Binding PreviewCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" 
                            Padding="20,8" 
                            Margin="5">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <emoji:TextBlock Text="👁️" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="预览效果" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button Content="应用设置" Command="{Binding ApplySettingsCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}" 
                            Padding="20,8" 
                            Margin="5"
                            helpers:ButtonHelper.ConfirmMessage="确定要应用这些分辨率设置吗？窗口大小和UI缩放将立即生效。"
                            helpers:ButtonHelper.ConfirmTitle="确认应用">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <emoji:TextBlock Text="✅" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="应用设置" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button Content="重置默认" Command="{Binding ResetToDefaultCommand}"
                            Style="{DynamicResource DangerButtonStyle}" 
                            Padding="20,8" 
                            Margin="5"
                            helpers:ButtonHelper.ConfirmMessage="确定要重置为默认设置吗？当前配置将丢失！"
                            helpers:ButtonHelper.ConfirmTitle="确认重置">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <emoji:TextBlock Text="🔄" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="重置默认" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </WrapPanel>
            </layout:IconHeaderGroupBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>

