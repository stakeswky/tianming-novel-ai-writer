<UserControl x:Class="TM.Framework.Appearance.Animation.ThemeTransition.ThemeTransitionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <common:IconHeaderGroupBox Icon="🎬" Title="过渡效果组合" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="选择一个或多个效果进行组合（可多选）" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding TransitionEffects}" 
                                 Margin="0,0,0,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                         Margin="0,0,0,8"
                                         Content="{Binding}">
                                    <CheckBox.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <emoji:TextBlock Text="{Binding Icon}" FontSize="14" Margin="5,0,8,0"/>
                                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </CheckBox.ContentTemplate>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock FontSize="11" 
                              Foreground="{DynamicResource InfoColor}"
                              TextWrapping="Wrap">
                        <emoji:TextBlock Text="💡" FontSize="11"/>
                        <Run Text=" 提示：选择多个效果时，它们将同时播放并叠加。不选任何效果将使用快捷配置中的默认效果。"/>
                    </TextBlock>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🎚️" Title="动画参数" Margin="0,0,0,15">
                <StackPanel>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="动画时长" 
                                  Grid.Column="0" 
                                  Grid.Row="0"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextPrimary}"/>

                        <TextBox Grid.Column="2" 
                                Grid.Row="0"
                                Text="{Binding Duration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                Height="36"
                                Style="{DynamicResource StandardTextBoxStyle}"
                                VerticalContentAlignment="Center"
                                HorizontalAlignment="Stretch"/>

                        <TextBlock Text="ms" 
                                  Grid.Column="2" 
                                  Grid.Row="0"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Right"
                                  Margin="0,0,35,0"
                                  Foreground="{DynamicResource TextSecondary}"/>

                        <Slider Grid.Column="0" 
                               Grid.ColumnSpan="3"
                               Grid.Row="2"
                               Minimum="300" 
                               Maximum="3000" 
                               Value="{Binding Duration, Mode=TwoWay}"
                               TickFrequency="100"
                               IsSnapToTickEnabled="True"/>

                        <TextBlock Text="范围: 300-3000 毫秒" 
                                  Grid.Column="0"
                                  Grid.ColumnSpan="3"
                                  Grid.Row="2"
                                  VerticalAlignment="Bottom"
                                  Margin="0,25,0,0"
                                  FontSize="11"
                                  Foreground="{DynamicResource TextTertiary}"/>
                    </Grid>

                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="目标FPS" 
                                  Grid.Column="0" 
                                  Grid.Row="0"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextPrimary}"/>

                        <TextBox Grid.Column="2" 
                                Grid.Row="0"
                                Text="{Binding TargetFPS, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                Height="36"
                                Style="{DynamicResource StandardTextBoxStyle}"
                                VerticalContentAlignment="Center"
                                HorizontalAlignment="Stretch"/>

                        <Slider Grid.Column="0" 
                               Grid.ColumnSpan="3"
                               Grid.Row="2"
                               Minimum="30" 
                               Maximum="{Binding DetectedMonitorFPS, Mode=OneWay}" 
                               Value="{Binding TargetFPS, Mode=TwoWay}"
                               TickFrequency="6"
                               IsSnapToTickEnabled="True"/>

                        <StackPanel Grid.Column="0"
                                   Grid.ColumnSpan="3"
                                   Grid.Row="3"
                                   Orientation="Horizontal"
                                   Margin="0,10,0,0">
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiary}">
                                <Run Text="范围: 30-"/>
                                <Run Text="{Binding DetectedMonitorFPS, Mode=OneWay}"/>
                                <Run Text=" FPS"/>
                            </TextBlock>
                            <TextBlock Text=" | " 
                                      FontSize="11"
                                      Margin="5,0"
                                      Foreground="{DynamicResource TextTertiary}"/>
                            <TextBlock FontSize="11" Foreground="{DynamicResource InfoColor}">
                                <Run Text="检测到显示器刷新率:"/>
                                <Run Text="{Binding DetectedMonitorFPS, Mode=OneWay}"/>
                                <Run Text="Hz"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="缓动函数" 
                              Margin="0,20,0,10"
                              FontSize="13"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource TextPrimary}"/>
                    <ComboBox ItemsSource="{Binding EasingFunctions}" 
                             SelectedItem="{Binding SelectedEasingFunction, Mode=TwoWay}"
                             Height="36"
                             Style="{DynamicResource StandardComboBoxStyle}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <emoji:TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Description}" 
                                              FontSize="11" 
                                              VerticalAlignment="Center"
                                              Foreground="{DynamicResource TextSecondary}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Border Margin="0,10,0,0"
                           Height="100"
                           Background="{DynamicResource Surface}"
                           BorderBrush="{DynamicResource BorderBrush}"
                           BorderThickness="1"
                           CornerRadius="6">
                        <Canvas x:Name="EasingCurveCanvas" 
                               Width="200" 
                               Height="80"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        </Canvas>
                    </Border>
                    <TextBlock Text="▲ 缓动曲线预览" 
                              Margin="0,5,0,0"
                              FontSize="11"
                              HorizontalAlignment="Center"
                              Foreground="{DynamicResource TextTertiary}"/>

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="动画强度" 
                                  Grid.Column="0" 
                                  Grid.Row="0"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextPrimary}"/>

                        <TextBox Grid.Column="2" 
                                Grid.Row="0"
                                Height="36"
                                Style="{DynamicResource StandardTextBoxStyle}"
                                VerticalContentAlignment="Center"
                                HorizontalAlignment="Stretch">
                            <TextBox.Text>
                                <Binding Path="Intensity" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" StringFormat="F1"/>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="×" 
                                  Grid.Column="2" 
                                  Grid.Row="0"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Right"
                                  Margin="0,0,35,0"
                                  Foreground="{DynamicResource TextSecondary}"/>

                        <Slider Grid.Column="0" 
                               Grid.ColumnSpan="3"
                               Grid.Row="2"
                               Minimum="0.5" 
                               Maximum="2.0" 
                               Value="{Binding Intensity, Mode=TwoWay}"
                               TickFrequency="0.1"
                               IsSnapToTickEnabled="True"/>

                        <TextBlock Text="范围: 0.5× - 2.0× (1.0×为标准强度)" 
                                  Grid.Column="0"
                                  Grid.ColumnSpan="3"
                                  Grid.Row="2"
                                  VerticalAlignment="Bottom"
                                  Margin="0,25,0,0"
                                  FontSize="11"
                                  Foreground="{DynamicResource TextTertiary}"/>
                    </Grid>

                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="⚡" Title="快捷配置" Margin="0,0,0,15">
                <WrapPanel Orientation="Horizontal">
                    <Button Command="{Binding ApplyPresetCommand}" 
                           CommandParameter="Fast"
                           Style="{DynamicResource SecondaryButtonStyle}"
                           Margin="0,0,10,10"
                           Padding="15,8">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="⚡" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="快速过渡" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ApplyPresetCommand}" 
                           CommandParameter="Smooth"
                           Style="{DynamicResource SecondaryButtonStyle}"
                           Margin="0,0,10,10"
                           Padding="15,8">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="🌈" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="流畅过渡" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ApplyPresetCommand}" 
                           CommandParameter="Fancy"
                           Style="{DynamicResource SecondaryButtonStyle}"
                           Margin="0,0,10,10"
                           Padding="15,8">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="✨" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="华丽过渡" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ApplyPresetCommand}" 
                           CommandParameter="Simple"
                           Style="{DynamicResource SecondaryButtonStyle}"
                           Margin="0,0,10,10"
                           Padding="15,8">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="🎯" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="简约过渡" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ApplyPresetCommand}" 
                           CommandParameter="Dynamic"
                           Style="{DynamicResource SecondaryButtonStyle}"
                           Margin="0,0,10,10"
                           Padding="15,8">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="🚀" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="动感过渡" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ApplyPresetCommand}" 
                           CommandParameter="Cool"
                           Style="{DynamicResource SecondaryButtonStyle}"
                           Margin="0,0,10,10"
                           Padding="15,8">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="🎪" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="炫酷过渡" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="👁️" Title="动画预览" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="点击下方按钮测试当前配置的动画效果" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <Button Command="{Binding TestTransitionCommand}"
                           Style="{DynamicResource SecondaryButtonStyle}"
                           HorizontalAlignment="Left"
                           Padding="20,8">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="🎬" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="测试动画效果" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <StackPanel Orientation="Horizontal" 
                       HorizontalAlignment="Right" 
                       Margin="0,20,0,0">

                <Button Style="{DynamicResource DangerButtonStyle}"
                       Margin="0,0,10,0"
                       Padding="15,8"
                       helpers:ButtonHelper.ConfirmMessage="确定要重置为默认设置吗？所有自定义配置将被清除。"
                       helpers:ButtonHelper.ConfirmTitle="确认重置"
                       Command="{Binding ResetToDefaultCommand}">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="🔄" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="重置默认" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{DynamicResource PrimaryButtonStyle}"
                       Padding="20,8"
                       helpers:ButtonHelper.ConfirmMessage="确定要应用这些过渡动画设置吗？新设置将在下次切换主题时生效。"
                       helpers:ButtonHelper.ConfirmTitle="确认应用"
                       Command="{Binding ApplySettingsCommand}">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="✅" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="应用设置" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>
