<Window x:Class="TM.Framework.Appearance.AutoTheme.TimeBased.TimeScheduleEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        Title="编辑时间段"
        Height="550" Width="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44"
                      CornerRadius="12"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="0" />
    </WindowChrome.WindowChrome>

    <Border Style="{DynamicResource StandardDialogBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource StandardDialogTitleBarStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <emoji:TextBlock Text="⏰" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="编辑时间段" Style="{DynamicResource StandardDialogTitleTextStyle}"/>
                    </StackPanel>

                    <Button Grid.Column="1" 
                            Click="CancelButton_Click" 
                            Style="{DynamicResource StandardDialogCloseButtonStyle}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="⏰ 开始时间" FontSize="14" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,25,0,10">
                    <TextBox Name="StartHourTextBox" Width="60" Height="36" Margin="0,0,5,0" 
                             Style="{DynamicResource StandardTextBoxStyle}" MaxLength="2" TextAlignment="Center"/>
                    <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="18" FontWeight="Bold"/>
                    <TextBox Name="StartMinuteTextBox" Width="60" Height="36"
                             Style="{DynamicResource StandardTextBoxStyle}" MaxLength="2" TextAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="⏰ 结束时间" FontSize="14" Margin="0,10,0,5" Foreground="{DynamicResource TextPrimary}"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,35,0,10">
                    <TextBox Name="EndHourTextBox" Width="60" Height="36" Margin="0,0,5,0"
                             Style="{DynamicResource StandardTextBoxStyle}" MaxLength="2" TextAlignment="Center"/>
                    <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="18" FontWeight="Bold"/>
                    <TextBox Name="EndMinuteTextBox" Width="60" Height="36"
                             Style="{DynamicResource StandardTextBoxStyle}" MaxLength="2" TextAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Text="🎨 应用主题" FontSize="14" Margin="0,10,0,5" Foreground="{DynamicResource TextPrimary}"/>
                <ComboBox Grid.Row="2" Name="ThemeComboBox" Height="36" Margin="0,35,0,10"
                          Style="{DynamicResource StandardComboBoxStyle}"/>

                <TextBlock Grid.Row="3" Text="⭐ 优先级" FontSize="14" Margin="0,10,0,5" Foreground="{DynamicResource TextPrimary}"/>
                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,35,0,10">
                    <Slider Name="PrioritySlider" Width="300" Minimum="1" Maximum="10" TickFrequency="1" 
                            IsSnapToTickEnabled="True" Value="5" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ElementName=PrioritySlider, Path=Value}" FontSize="16" FontWeight="Bold"
                               Margin="10,0,0,0" VerticalAlignment="Center" MinWidth="30"/>
                </StackPanel>

                <CheckBox Grid.Row="4" Name="UseTransitionCheckBox" Content="🎬 启用过渡动画" 
                          Margin="0,10,0,10" IsChecked="True" FontSize="14"/>

                <TextBlock Grid.Row="5" Text="📅 启用星期" FontSize="14" Margin="0,10,0,5" Foreground="{DynamicResource TextPrimary}"/>
                <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,35,0,10">
                    <CheckBox Name="MondayCheckBox" Content="一" Margin="0,0,10,0" IsChecked="True"/>
                    <CheckBox Name="TuesdayCheckBox" Content="二" Margin="0,0,10,0" IsChecked="True"/>
                    <CheckBox Name="WednesdayCheckBox" Content="三" Margin="0,0,10,0" IsChecked="True"/>
                    <CheckBox Name="ThursdayCheckBox" Content="四" Margin="0,0,10,0" IsChecked="True"/>
                    <CheckBox Name="FridayCheckBox" Content="五" Margin="0,0,10,0" IsChecked="True"/>
                    <CheckBox Name="SaturdayCheckBox" Content="六" Margin="0,0,10,0" IsChecked="False"/>
                    <CheckBox Name="SundayCheckBox" Content="日" Margin="0,0,10,0" IsChecked="False"/>
                </StackPanel>

                <TextBlock Grid.Row="6" Text="📝 描述" FontSize="14" Margin="0,10,0,5" Foreground="{DynamicResource TextPrimary}"/>
                <TextBox Grid.Row="6" Name="DescriptionTextBox" Height="36" Margin="0,35,0,10"
                         Style="{DynamicResource StandardTextBoxStyle}" />

                <StackPanel Grid.Row="8" Style="{DynamicResource StandardDialogFooterStyle}">
                    <Button Content="确定" 
                            Style="{DynamicResource PrimaryButtonStyle}" 
                            Padding="24,8"
                            MinWidth="80"
                            Click="OkButton_Click" 
                            Margin="0,0,10,0"/>
                    <Button Content="取消" 
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="24,8"
                            MinWidth="80"
                            Click="CancelButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>

