<UserControl x:Class="TM.Framework.Appearance.AutoTheme.TimeBased.TimeBasedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:theme="clr-namespace:TM.Framework.Appearance.ThemeManagement"
             xmlns:local="clr-namespace:TM.Framework.Appearance.AutoTheme.TimeBased">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <common:IconHeaderGroupBox Icon="⚙️" Title="基础设置" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <CheckBox Content="启用定时切换" IsChecked="{Binding Enabled}" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="调度模式：" Width="80" VerticalAlignment="Center"/>
                        <ComboBox SelectedIndex="{Binding Mode}" MinWidth="150">
                            <ComboBoxItem Content="简单模式"/>
                            <ComboBoxItem Content="灵活模式"/>
                            <ComboBoxItem Content="日出日落"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="☀️" Title="简单模式配置" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="白天/夜晚两个时间段" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="白天时间：" Width="80" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding DayStartTime, StringFormat=hh\\:mm}" Width="80" Margin="0,0,10,0"/>
                        <TextBlock Text="主题：" Margin="10,0,5,0" VerticalAlignment="Center"/>
                        <ComboBox SelectedItem="{Binding DayTheme}" MinWidth="120">
                            <ComboBox.Items>
                                <theme:ThemeType>Light</theme:ThemeType>
                                <theme:ThemeType>Dark</theme:ThemeType>
                                <theme:ThemeType>Green</theme:ThemeType>
                                <theme:ThemeType>Business</theme:ThemeType>
                            </ComboBox.Items>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="夜晚时间：" Width="80" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding NightStartTime, StringFormat=hh\\:mm}" Width="80" Margin="0,0,10,0"/>
                        <TextBlock Text="主题：" Margin="10,0,5,0" VerticalAlignment="Center"/>
                        <ComboBox SelectedItem="{Binding NightTheme}" MinWidth="120">
                            <ComboBox.Items>
                                <theme:ThemeType>Light</theme:ThemeType>
                                <theme:ThemeType>Dark</theme:ThemeType>
                                <theme:ThemeType>Green</theme:ThemeType>
                                <theme:ThemeType>Business</theme:ThemeType>
                            </ComboBox.Items>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="⏰" Title="灵活模式配置" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="自定义多个时间段" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <ListBox ItemsSource="{Binding Schedules}" Height="150" Margin="0,0,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayText}" VerticalAlignment="Center"/>
                                    <Button Content="✏️" Command="{Binding DataContext.EditScheduleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}"
                                           Style="{DynamicResource SecondaryButtonStyle}" 
                                           Padding="6,3" 
                                           Margin="10,0,5,0"/>
                                    <Button Content="🗑️" Command="{Binding DataContext.RemoveScheduleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}"
                                           Style="{DynamicResource DangerButtonStyle}" 
                                           Padding="6,3"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="➕ 添加时间段" Command="{Binding AddScheduleCommand}" 
                                Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6" Margin="0,0,10,0"/>
                        <Button Content="🔍 检测冲突" Command="{Binding DetectConflictsCommand}" 
                                Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6"/>
                    </StackPanel>

                    <Border BorderBrush="{DynamicResource DangerColor}" BorderThickness="1" CornerRadius="6" Padding="10"
                            Visibility="{Binding HasConflicts, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <emoji:TextBlock Text="⚠️" FontSize="14" Margin="0,0,5,0"/>
                                <TextBlock Text="检测到冲突" FontWeight="Bold" Foreground="{DynamicResource DangerColor}"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding ConflictsList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="•" Margin="0,0,5,0" Foreground="{DynamicResource DangerColor}"/>
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <local:TimelineControl Schedules="{Binding Schedules}"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🌅" Title="日出日落模式" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="根据日出日落时间自动切换" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="纬度：" Width="60" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Latitude}" Width="100" Margin="0,0,15,0"/>
                        <TextBlock Text="经度：" Width="60" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Longitude}" Width="100"/>
                    </StackPanel>

                    <Button Content="🌍 自动获取位置" Command="{Binding GetLocationCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="今日日出：" Width="80"/>
                        <TextBlock Text="{Binding TodaySunrise}" FontWeight="Bold" Margin="0,0,20,0"/>
                        <TextBlock Text="今日日落：" Width="80"/>
                        <TextBlock Text="{Binding TodaySunset}" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="日出主题：" Width="80" VerticalAlignment="Center"/>
                        <ComboBox SelectedItem="{Binding SunriseTheme}" MinWidth="120">
                            <ComboBox.Items>
                                <theme:ThemeType>Light</theme:ThemeType>
                                <theme:ThemeType>Dark</theme:ThemeType>
                                <theme:ThemeType>Green</theme:ThemeType>
                                <theme:ThemeType>Business</theme:ThemeType>
                            </ComboBox.Items>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="日落主题：" Width="80" VerticalAlignment="Center"/>
                        <ComboBox SelectedItem="{Binding SunsetTheme}" MinWidth="120">
                            <ComboBox.Items>
                                <theme:ThemeType>Light</theme:ThemeType>
                                <theme:ThemeType>Dark</theme:ThemeType>
                                <theme:ThemeType>Green</theme:ThemeType>
                                <theme:ThemeType>Business</theme:ThemeType>
                            </ComboBox.Items>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📅" Title="节假日排除" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <CheckBox Content="节假日不自动切换" IsChecked="{Binding ExcludeHolidays}" Margin="0,0,0,10"/>

                    <ListBox ItemsSource="{Binding CustomHolidays}" Height="100" Margin="0,0,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding StringFormat=yyyy-MM-dd}" VerticalAlignment="Center"/>
                                    <Button Content="🗑️" Command="{Binding DataContext.RemoveHolidayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}"
                                           Style="{DynamicResource DangerButtonStyle}" 
                                           Padding="6,3" 
                                           Margin="10,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Content="➕ 添加节假日" Command="{Binding AddHolidayCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="⚔️" Title="冲突管理" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="与跟随系统功能冲突时的优先级设置" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="优先级：" Width="80" VerticalAlignment="Center"/>
                        <Slider Value="{Binding Priority}" Minimum="0" Maximum="10" TickFrequency="1" 
                                IsSnapToTickEnabled="True" Width="200" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding Priority}" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="（数值越大优先级越高）" 
                                  Foreground="{DynamicResource TextSecondary}" 
                                  FontSize="12" 
                                  VerticalAlignment="Center" 
                                  Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="⏸️" Title="临时禁用" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox Content="临时禁用至：" IsChecked="{Binding TemporaryDisabled}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding DisabledUntil, StringFormat=yyyy-MM-dd HH:mm}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="临时禁用1小时" Command="{Binding TemporaryDisableCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6" Margin="0,10,0,0"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📊" Title="切换历史" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <CheckBox Content="记录切换历史" IsChecked="{Binding RecordHistory}" Margin="0,0,0,10"/>

                    <ListBox ItemsSource="{Binding SwitchHistory}" Height="150" Margin="0,0,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding SwitchTime, StringFormat=yyyy-MM-dd HH:mm}"/>
                                    <Run Text=" - "/>
                                    <Run Text="{Binding ScheduleName}"/>
                                    <Run Text=" → "/>
                                    <Run Text="{Binding TargetTheme}"/>
                                    <Run Text="{Binding Success, StringFormat={} ({0})}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Content="🗑️ 清空历史" Command="{Binding ClearHistoryCommand}" 
                            Style="{DynamicResource DangerButtonStyle}" 
                            Padding="12,6"
                            helpers:ButtonHelper.ConfirmMessage="确定要清空所有切换历史吗？"
                            helpers:ButtonHelper.ConfirmTitle="确认清空"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📍" Title="当前状态" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="当前生效：" Width="100"/>
                        <TextBlock Text="{Binding CurrentActiveSchedule}" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="当前主题：" Width="100"/>
                        <TextBlock Text="{Binding CurrentTheme}" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="下次切换：" Width="100"/>
                        <TextBlock Text="{Binding NextSwitchTime}" FontWeight="Bold"/>
                    </StackPanel>
                    <Button Content="🔄 刷新状态" Command="{Binding RefreshStatusCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6" Margin="0,10,0,0"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="💾 应用设置" Command="{Binding ApplySettingsCommand}" 
                        Style="{DynamicResource PrimaryButtonStyle}" 
                        Padding="12,6"
                        helpers:ButtonHelper.ConfirmMessage="确定要保存并应用这些设置吗？"
                        helpers:ButtonHelper.ConfirmTitle="确认应用"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
