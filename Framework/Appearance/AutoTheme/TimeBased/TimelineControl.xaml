<UserControl x:Class="TM.Framework.Appearance.AutoTheme.TimeBased.TimelineControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource Surface}" Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <emoji:TextBlock Text="📊" FontSize="14" Margin="0,0,5,0"/>
                <TextBlock Text="24小时时间轴" FontWeight="Bold" FontSize="14"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Canvas x:Name="TimelineCanvas" Background="{DynamicResource ContentBackground}" Height="60">
                    <Line X1="0" Y1="30" X2="720" Y2="30" Stroke="{DynamicResource BorderBrush}" StrokeThickness="2"/>

                </Canvas>

                <Line x:Name="CurrentTimeIndicator" Y1="0" Y2="60" Stroke="{DynamicResource DangerColor}" StrokeThickness="2">
                    <Line.RenderTransform>
                        <TranslateTransform X="0"/>
                    </Line.RenderTransform>
                </Line>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                <Border Width="20" Height="10" Background="{DynamicResource PrimaryColor}" Margin="0,0,5,0"/>
                <TextBlock Text="时间段" Margin="0,0,15,0" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>

                <Line X1="0" Y1="5" X2="20" Y2="5" Stroke="{DynamicResource DangerColor}" StrokeThickness="2" Margin="0,0,5,0"/>
                <TextBlock Text="当前时间" Margin="0,0,15,0" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>

                <Rectangle Width="20" Height="10" Fill="{DynamicResource DangerColor}" Opacity="0.3" Margin="0,0,5,0">
                    <Rectangle.OpacityMask>
                        <DrawingBrush Viewport="0,0,4,4" ViewportUnits="Absolute" TileMode="Tile">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="Black">
                                    <GeometryDrawing.Geometry>
                                        <PathGeometry>
                                            <PathFigure StartPoint="0,0">
                                                <LineSegment Point="4,4"/>
                                                <LineSegment Point="0,4"/>
                                            </PathFigure>
                                        </PathGeometry>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.OpacityMask>
                </Rectangle>
                <TextBlock Text="冲突区域" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

