<UserControl x:Class="TM.Framework.Appearance.AutoTheme.SystemFollow.SystemFollowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:converters="clr-namespace:TM.Framework.Common.Converters"
             xmlns:value="clr-namespace:TM.Framework.Common.Converters.Value"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:theme="clr-namespace:TM.Framework.Appearance.ThemeManagement">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <common:IconHeaderGroupBox Icon="⚙️" Title="基础设置" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <CheckBox Content="启用跟随系统" IsChecked="{Binding Enabled}" Margin="0,0,0,10"/>
                    <CheckBox Content="应用启动时自动启动监听" IsChecked="{Binding AutoStart}"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🖥️" Title="系统状态" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="10" Height="10" CornerRadius="5" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource TextTertiary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMonitoring}" Value="True">
                                            <Setter Property="Background" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Margin="5,0,0,0" FontSize="12" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="已停止"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMonitoring}" Value="True">
                                            <Setter Property="Text" Value="监控中"/>
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="当前系统主题：" Width="120" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentSystemTheme}" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="高对比度模式：" Width="120" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding IsHighContrast}" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="系统强调色：" Width="120" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AccentColor}" FontWeight="Bold"/>
                    </StackPanel>
                    <Button Content="🔄 刷新状态" Command="{Binding RefreshSystemInfoCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6" Margin="0,10,0,0"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📊" Title="系统状态详情" Margin="0,0,0,20">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="系统DPI" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding SystemDPI, StringFormat={}{0:F0}}" FontSize="14" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="色彩模式" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding ColorMode}" FontSize="14" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Text="窗口主题" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding ThemeName}" FontSize="14" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Text="透明效果" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock FontSize="14" FontWeight="Bold">
                            <TextBlock.Text>
                                <Binding Path="TransparencyEnabled">
                                    <Binding.Converter>
                                        <value:BoolToTextConverter TrueText="已启用" FalseText="已禁用"/>
                                    </Binding.Converter>
                                </Binding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,0,10">
                        <TextBlock Text="窗口动画" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock FontSize="14" FontWeight="Bold">
                            <TextBlock.Text>
                                <Binding Path="WindowAnimationEnabled">
                                    <Binding.Converter>
                                        <value:BoolToTextConverter TrueText="已启用" FalseText="已禁用"/>
                                    </Binding.Converter>
                                </Binding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="2" Margin="0,0,0,10">
                        <TextBlock Text="Aero效果" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock FontSize="14" FontWeight="Bold">
                            <TextBlock.Text>
                                <Binding Path="IsAeroEnabled">
                                    <Binding.Converter>
                                        <value:BoolToTextConverter TrueText="已启用" FalseText="已禁用"/>
                                    </Binding.Converter>
                                </Binding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🖥️" Title="显示器信息" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <ListBox ItemsSource="{Binding Monitors}" 
                             MaxHeight="200"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}" Margin="5"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="🔄 刷新显示器信息" Command="{Binding RefreshMonitorsCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6" Margin="0,10,0,0"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📜" Title="主题变化历史" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <ListBox ItemsSource="{Binding ThemeChangeHistory}" 
                             MaxHeight="250"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}" 
                                          Margin="5"
                                          TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Text="显示最近20条变化记录" 
                              FontSize="11" 
                              Foreground="{DynamicResource TextTertiary}" 
                              Margin="0,10,0,0"
                              HorizontalAlignment="Center"/>
                    <Button Content="🔄 刷新历史记录" Command="{Binding RefreshHistoryCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6" Margin="0,10,0,0"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📊" Title="统计分析" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="切换频率统计" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="今日切换" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Text="{Binding DailySwitchCount}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}"/>
                            <TextBlock Text="次" FontSize="11" Foreground="{DynamicResource TextTertiary}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="本周切换" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Text="{Binding WeeklySwitchCount}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource InfoColor}"/>
                            <TextBlock Text="次" FontSize="11" Foreground="{DynamicResource TextTertiary}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="本月切换" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Text="{Binding MonthlySwitchCount}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource SuccessColor}"/>
                            <TextBlock Text="次" FontSize="11" Foreground="{DynamicResource TextTertiary}"/>
                        </StackPanel>
                    </Grid>

                    <Separator Margin="0,0,0,15" Background="{DynamicResource BorderBrush}"/>

                    <TextBlock Text="性能监控" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="平均耗时：" VerticalAlignment="Center" Margin="0,0,10,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AvgSwitchDuration}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="最近耗时：" VerticalAlignment="Center" Margin="0,0,10,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LastSwitchDuration}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="性能评级：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PerformanceRating}" FontWeight="SemiBold" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PerformanceRating}" Value="优秀">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PerformanceRating}" Value="良好">
                                            <Setter Property="Foreground" Value="{DynamicResource InfoColor}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PerformanceRating}" Value="一般">
                                            <Setter Property="Foreground" Value="{DynamicResource WarningColor}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PerformanceRating}" Value="需优化">
                                            <Setter Property="Foreground" Value="{DynamicResource DangerColor}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Separator Margin="0,0,0,15" Background="{DynamicResource BorderBrush}"/>

                    <TextBlock Text="使用分析" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="最常用主题：" VerticalAlignment="Center" Margin="0,0,10,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MostUsedTheme}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="高峰时段：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PeakSwitchPeriod}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>

                    <Button Content="🔄 刷新统计数据" Command="{Binding RefreshStatisticsCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6" Margin="0,10,0,0"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🎨" Title="主题映射规则" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="设置系统主题与应用主题的对应关系" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="浅色系统 → " Width="100" VerticalAlignment="Center"/>
                        <ComboBox SelectedItem="{Binding LightThemeMapping}" MinWidth="150">
                            <ComboBox.Items>
                                <theme:ThemeType>Light</theme:ThemeType>
                                <theme:ThemeType>Dark</theme:ThemeType>
                                <theme:ThemeType>Green</theme:ThemeType>
                                <theme:ThemeType>Business</theme:ThemeType>
                            </ComboBox.Items>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="深色系统 → " Width="100" VerticalAlignment="Center"/>
                        <ComboBox SelectedItem="{Binding DarkThemeMapping}" MinWidth="150">
                            <ComboBox.Items>
                                <theme:ThemeType>Light</theme:ThemeType>
                                <theme:ThemeType>Dark</theme:ThemeType>
                                <theme:ThemeType>Green</theme:ThemeType>
                                <theme:ThemeType>Business</theme:ThemeType>
                            </ComboBox.Items>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="高对比度 → " Width="100" VerticalAlignment="Center"/>
                        <ComboBox SelectedIndex="{Binding HighContrastMapping}" MinWidth="150">
                            <ComboBoxItem Content="忽略"/>
                            <ComboBoxItem Content="使用浅色"/>
                            <ComboBoxItem Content="使用深色"/>
                            <ComboBoxItem Content="自定义"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="自定义主题 → " Width="100" VerticalAlignment="Center"/>
                        <ComboBox SelectedItem="{Binding HighContrastCustomTheme}" MinWidth="150">
                            <ComboBox.Items>
                                <theme:ThemeType>Light</theme:ThemeType>
                                <theme:ThemeType>Dark</theme:ThemeType>
                                <theme:ThemeType>Green</theme:ThemeType>
                                <theme:ThemeType>Business</theme:ThemeType>
                            </ComboBox.Items>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="⏱️" Title="延迟切换" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="延迟切换可避免系统主题频繁变化时过多切换" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="延迟秒数：" Width="80" VerticalAlignment="Center"/>
                        <Slider Value="{Binding DelaySeconds}" Minimum="0" Maximum="30" Width="200" 
                               TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DelaySeconds}" Width="30" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="秒" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="⏰" Title="排除时间段" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="在指定时间段内不自动切换主题" 
                              Foreground="{DynamicResource TextSecondary}" 
                              FontSize="12" 
                              Margin="0,0,0,10"/>

                    <ListBox ItemsSource="{Binding ExclusionPeriods}" Height="150" Margin="0,0,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayText}" VerticalAlignment="Center"/>
                                    <Button Content="🗑️" Command="{Binding DataContext.RemoveExclusionPeriodCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}"
                                           Style="{DynamicResource DangerButtonStyle}" 
                                           Padding="6,3" 
                                           Margin="10,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Content="➕ 添加时间段" Command="{Binding AddExclusionPeriodCommand}" 
                            Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🔔" Title="通知设置" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <CheckBox Content="显示切换通知" IsChecked="{Binding ShowNotification}"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="🔧" Title="高级选项" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <CheckBox Content="应用系统强调色" IsChecked="{Binding EnableAccentColor}" Margin="0,0,0,10"/>
                    <CheckBox Content="仅在未手动切换时跟随" IsChecked="{Binding OnlyWhenNotManual}" Margin="0,0,0,10"/>
                    <CheckBox Content="启用详细日志" IsChecked="{Binding EnableVerboseLog}"/>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Icon="📊" Title="统计信息" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="上次切换时间：" Width="120"/>
                        <TextBlock Text="{Binding LastSwitchTime}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="总切换次数：" Width="120"/>
                        <TextBlock Text="{Binding TotalSwitchCount}"/>
                    </StackPanel>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="🧪 测试切换" Command="{Binding TestSwitchCommand}" 
                        Style="{DynamicResource SecondaryButtonStyle}" 
                        Padding="12,6" 
                        Margin="0,0,10,0"/>
                <Button Content="💾 应用设置" Command="{Binding ApplySettingsCommand}" 
                        Style="{DynamicResource PrimaryButtonStyle}" 
                        Padding="12,6"
                        helpers:ButtonHelper.ConfirmMessage="确定要保存并应用这些设置吗？"
                        helpers:ButtonHelper.ConfirmTitle="确认应用"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
