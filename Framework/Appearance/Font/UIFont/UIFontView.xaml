<UserControl x:Class="TM.Framework.Appearance.Font.UIFont.UIFontView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:tree="clr-namespace:TM.Framework.Common.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:TM.Framework.Appearance.Font.UIFont"
             xmlns:services="clr-namespace:TM.Framework.Appearance.Font.Services"
             xmlns:converters="clr-namespace:TM.Framework.Appearance.Font.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:UIFontViewModel, IsDesignTimeCreatable=True}"
             Background="{DynamicResource ContentBackground}">

    <UserControl.Resources>
        <ResourceDictionary>

            <converters:FontCategoryToStringConverter x:Key="FontCategoryToStringConverter"/>
            <converters:BoolToStarConverter x:Key="BoolToStarConverter"/>
            <converters:BoolToFavoriteTextConverter x:Key="BoolToFavoriteTextConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="500"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <common:IconHeaderGroupBox Grid.Row="0" Icon="📂" Title="字体分类">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ListBox ItemsSource="{Binding Categories}" 
                             SelectedItem="{Binding SelectedCategory}"
                             BorderThickness="0"
                             Background="Transparent"
                             Margin="10">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ContentHighlight}"
                                        BorderBrush="{DynamicResource PrimaryColor}"
                                        BorderThickness="0"
                                        CornerRadius="6"
                                        Padding="15,8"
                                        Margin="0,0,8,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                    <Setter Property="Background" Value="{DynamicResource PrimaryColor}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Converter={StaticResource FontCategoryToStringConverter}}" 
                                               FontSize="13">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Grid.Row="2" Icon="⚙️" Title="字体配置">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="字体搜索" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource StandardTextBoxStyle}"
                                 Margin="0,0,0,15">
                            <TextBox.Tag>
                                <TextBlock Text="🔍 搜索字体..." Foreground="{DynamicResource TextTertiary}"/>
                            </TextBox.Tag>
                        </TextBox>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="排序方式:" VerticalAlignment="Center" FontSize="12"/>
                            <ComboBox Grid.Column="2" 
                                      ItemsSource="{Binding SortModeOptions}"
                                      SelectedIndex="{Binding CurrentSortMode}"
                                      Style="{DynamicResource StandardComboBoxStyle}"/>
                            <Button Grid.Column="4" 
                                    Content="清除最近使用"
                                    Command="{Binding ClearRecentCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="12,6"
                                    FontSize="12"/>
                        </Grid>

                        <TextBlock Text="选择字体" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <tree:DataTreeView ItemsSource="{Binding FontTree}" 
                                           ParentClickMode="Select" 
                                           ParentNodeClickCommand="{Binding SelectFontCommand}"
                                           MaxHeight="200"
                                           Margin="0,0,0,20"/>

                        <TextBlock Text="字体大小" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" 
                                    Minimum="8" 
                                    Maximum="48" 
                                    Value="{Binding SelectedFontSize}"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"/>
                            <TextBox Grid.Column="2" 
                                     Text="{Binding SelectedFontSize, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource StandardTextBoxStyle}"
                                     HorizontalContentAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="字体粗细" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding FontWeightOptions}"
                                  SelectedItem="{Binding SelectedFontWeight}"
                                  Style="{DynamicResource StandardComboBoxStyle}"
                                  Margin="0,0,0,20"/>

                        <TextBlock Text="行高" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" 
                                    Minimum="1.0" 
                                    Maximum="3.0" 
                                    Value="{Binding SelectedLineHeight}"
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"/>
                            <TextBox Grid.Column="2" 
                                     Text="{Binding SelectedLineHeight, StringFormat=F1, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource StandardTextBoxStyle}"
                                     HorizontalContentAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="字间距" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" 
                                    Minimum="-2" 
                                    Maximum="5" 
                                    Value="{Binding SelectedLetterSpacing}"
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"/>
                            <TextBox Grid.Column="2" 
                                     Text="{Binding SelectedLetterSpacing, StringFormat=F1, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource StandardTextBoxStyle}"
                                     HorizontalContentAlignment="Center"/>
                        </Grid>

                        <StackPanel>
                            <Button Command="{Binding ApplyCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <emoji:TextBlock Text="✅" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="应用设置" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SaveCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <emoji:TextBlock Text="💾" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="保存配置" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ResetCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <emoji:TextBlock Text="🔄" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="重置默认" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="配置管理" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                            <Button Command="{Binding ExportConfigCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <emoji:TextBlock Text="📤" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="导出配置" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ImportConfigCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <emoji:TextBlock Text="📥" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="导入配置" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ShareConfigCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <emoji:TextBlock Text="📦" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="导出分享包" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </common:IconHeaderGroupBox>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <common:IconHeaderGroupBox Grid.Row="0" Icon="🔄" Title="对比模式">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <CheckBox IsChecked="{Binding IsComparisonMode}" 
                                  Content="启用对比模式"
                                  FontSize="14"
                                  VerticalAlignment="Center"
                                  Margin="0,0,20,0"/>
                        <emoji:TextBlock Text="ℹ️" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="同时预览两种字体配置" 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" 
                                Visibility="{Binding IsComparisonMode, Converter={StaticResource BoolToVisibility}}">
                        <Button Command="{Binding ApplyMainFontCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Margin="0,0,10,0"
                                Width="150">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <emoji:TextBlock Text="🅰️" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="测试主字体" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ApplyComparisonFontCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Width="150">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <emoji:TextBlock Text="🅱️" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="测试对比字体" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <emoji:TextBlock Text="⏱️" FontSize="14" Margin="10,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="5秒后自动恢复" 
                                   FontSize="11" 
                                   Foreground="{DynamicResource WarningColor}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Grid.Row="2" Icon="👁️" Title="实时预览">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsComparisonMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel Margin="5" DataContext="{Binding CurrentSettings}">
                        <TextBlock Text="大标题示例 Heading Example"
                                   FontFamily="{Binding FontFamily}"
                                   FontSize="24"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="中标题示例 Subheading Example"
                                   FontFamily="{Binding FontFamily}"
                                   FontSize="18"
                                   Margin="0,0,0,15"/>

                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,15">
                            <TextBlock.Inlines>
                                <Run FontFamily="{Binding FontFamily}" 
                                     FontSize="{Binding FontSize}"
                                     Text="这是正文内容示例。This is body text example. "/>
                                <Run FontFamily="{Binding FontFamily}" 
                                     FontSize="{Binding FontSize}"
                                     Text="字体预览可以帮助您直观地看到字体效果。Font preview helps you see the effect intuitively. "/>
                                <Run FontFamily="{Binding FontFamily}" 
                                     FontSize="{Binding FontSize}"
                                     Text="数字示例：0123456789"/>
                            </TextBlock.Inlines>
                        </TextBlock>

                        <Border Background="{DynamicResource PrimaryColor}"
                                CornerRadius="6"
                                Padding="20,10"
                                Margin="0,0,0,15"
                                HorizontalAlignment="Left">
                            <TextBlock Text="按钮示例 Button"
                                       FontFamily="{Binding FontFamily}"
                                       FontSize="{Binding FontSize}"
                                       Foreground="White"/>
                        </Border>

                        <TextBlock Text="列表示例：" 
                                   FontFamily="{Binding FontFamily}"
                                   FontSize="{Binding FontSize}"
                                   Margin="0,0,0,8"/>
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="15">
                            <StackPanel>
                                <TextBlock FontFamily="{Binding FontFamily}" FontSize="{Binding FontSize}" Text="• 列表项目 1 - List Item 1" Margin="0,0,0,8"/>
                                <TextBlock FontFamily="{Binding FontFamily}" FontSize="{Binding FontSize}" Text="• 列表项目 2 - List Item 2" Margin="0,0,0,8"/>
                                <TextBlock FontFamily="{Binding FontFamily}" FontSize="{Binding FontSize}" Text="• 列表项目 3 - List Item 3"/>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsComparisonMode, Converter={StaticResource BoolToVisibility}}">
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" DataContext="{Binding CurrentSettings}">
                                <TextBlock Text="🅰️ 主字体" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>

                                <TextBlock Text="大标题示例" FontFamily="{Binding FontFamily}" FontSize="20" Margin="0,0,0,10"/>
                                <TextBlock Text="中标题示例" FontFamily="{Binding FontFamily}" FontSize="16" Margin="0,0,0,10"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                                    <Run FontFamily="{Binding FontFamily}" FontSize="{Binding FontSize}" Text="这是正文内容示例。Font preview helps you see the effect. 数字：0123456789"/>
                                </TextBlock>

                                <Border Background="{DynamicResource PrimaryColor}" CornerRadius="6" Padding="15,8" Margin="0,0,0,10" HorizontalAlignment="Left">
                                    <TextBlock Text="按钮示例" FontFamily="{Binding FontFamily}" FontSize="{Binding FontSize}" Foreground="White"/>
                                </Border>

                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <StackPanel>
                                        <TextBlock FontFamily="{Binding FontFamily}" FontSize="{Binding FontSize}" Text="• 列表项目 1" Margin="0,0,0,5"/>
                                        <TextBlock FontFamily="{Binding FontFamily}" FontSize="{Binding FontSize}" Text="• 列表项目 2" Margin="0,0,0,5"/>
                                        <TextBlock FontFamily="{Binding FontFamily}" FontSize="{Binding FontSize}" Text="• 列表项目 3"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2" DataContext="{Binding ComparisonSettings}">
                                <TextBlock Text="🅱️ 对比字体" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>

                                <TextBlock Text="大标题示例" FontFamily="{Binding FontFamily}" FontSize="20" Margin="0,0,0,10"/>
                                <TextBlock Text="中标题示例" FontFamily="{Binding FontFamily}" FontSize="16" Margin="0,0,0,10"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                                    <Run FontFamily="{Binding FontFamily}" FontSize="{Binding FontSize}" Text="这是正文内容示例。Font preview helps you see the effect. 数字：0123456789"/>
                                </TextBlock>

                                <Border Background="{DynamicResource PrimaryColor}" CornerRadius="6" Padding="15,8" Margin="0,0,0,10" HorizontalAlignment="Left">
                                    <TextBlock Text="按钮示例" FontFamily="{Binding FontFamily}" FontSize="{Binding FontSize}" Foreground="White"/>
                                </Border>

                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <StackPanel>
                                        <TextBlock FontFamily="{Binding FontFamily}" FontSize="{Binding FontSize}" Text="• 列表项目 1" Margin="0,0,0,5"/>
                                        <TextBlock FontFamily="{Binding FontFamily}" FontSize="{Binding FontSize}" Text="• 列表项目 2" Margin="0,0,0,5"/>
                                        <TextBlock FontFamily="{Binding FontFamily}" FontSize="{Binding FontSize}" Text="• 列表项目 3"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Grid.Row="4" Icon="📝" Title="当前配置">
                <Grid Margin="10" DataContext="{Binding CurrentSettings}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="字体：" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding FontFamily}" FontSize="12"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="大小：" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding FontSize, StringFormat={}{0} px}" FontSize="12"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="粗细：" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding FontWeight}" FontSize="12"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="行高：" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding LineHeight, StringFormat=F1}" FontSize="12"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="字间距：" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock Grid.Row="8" Grid.Column="2" Text="{Binding LetterSpacing, StringFormat=F1}" FontSize="12"/>
                </Grid>
            </common:IconHeaderGroupBox>
        </Grid>
    </Grid>
</UserControl>
