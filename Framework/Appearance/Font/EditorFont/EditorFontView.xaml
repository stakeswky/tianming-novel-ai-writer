<UserControl x:Class="TM.Framework.Appearance.Font.EditorFont.EditorFontView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:tree="clr-namespace:TM.Framework.Common.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:TM.Framework.Appearance.Font.EditorFont"
             xmlns:converters="clr-namespace:TM.Framework.Appearance.Font.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:EditorFontViewModel, IsDesignTimeCreatable=True}"
             Background="{DynamicResource ContentBackground}">

    <UserControl.Resources>
        <ResourceDictionary>

            <converters:CodeLanguageToStringConverter x:Key="CodeLanguageToStringConverter"/>
            <converters:UsageSceneToStringConverter x:Key="UsageSceneToStringConverter"/>
            <converters:PerformanceRatingToStringConverter x:Key="PerformanceRatingToStringConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <common:IconHeaderGroupBox Grid.Column="0" Icon="⚙️" Title="编辑器字体配置">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="10">
                    <common:IconHeaderGroupBox Icon="💡" Title="使用场景快速预设" Margin="0,0,0,20">
                        <StackPanel Margin="10">
                            <TextBlock Text="根据不同使用场景选择优化配置" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,10"/>

                            <ItemsControl ItemsSource="{Binding ScenePresets}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="1" 
                                                CornerRadius="6"
                                                Padding="12,8"
                                                Margin="0,0,8,8"
                                                Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource ContentBackground}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" 
                                                              Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.ApplySceneCommand}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>

                                            <StackPanel>
                                                <TextBlock FontSize="24" Margin="0,0,0,5" HorizontalAlignment="Center">
                                                    <Run Text="{Binding Icon}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Name}" 
                                                           FontWeight="SemiBold" 
                                                           FontSize="13"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Description}" 
                                                           FontSize="11" 
                                                           Foreground="{DynamicResource TextTertiary}"
                                                           TextWrapping="Wrap"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,4,0,0"
                                                           MaxWidth="120"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Content="应用选中场景配置"
                                    Command="{Binding ApplySceneCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    Margin="0,10,0,0"/>
                        </StackPanel>
                    </common:IconHeaderGroupBox>

                    <common:IconHeaderGroupBox Icon="🎨" Title="编程字体快速预设" Margin="0,0,0,15">
                        <StackPanel>
                            <ComboBox ItemsSource="{Binding EditorPresets}"
                                      SelectedItem="{Binding SelectedPreset}"
                                      Style="{DynamicResource StandardComboBoxStyle}"
                                      Margin="0,0,0,10">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding Description}" 
                                                           FontSize="11" 
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SuccessColor}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                                <Setter Property="Text" Value="✓ 已安装"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                                                <Setter Property="Text" Value="未安装"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                                </ComboBox>

                            <Button Command="{Binding ApplyPresetCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <emoji:TextBlock Text="✨" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="应用预设" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </common:IconHeaderGroupBox>

                    <TextBlock Text="字体族（推荐等宽字体）" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <CheckBox IsChecked="{Binding ShowMonospaceOnly}"
                              Content="🔲 仅显示等宽字体"
                              FontSize="13"
                              Margin="0,0,0,10"/>

                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource StandardTextBoxStyle}"
                             Margin="0,0,0,5">
                        <TextBox.Tag>
                            <TextBlock Text="🔍 搜索字体..." Foreground="{DynamicResource TextTertiary}"/>
                        </TextBox.Tag>
                    </TextBox>
                    <tree:DataTreeView ItemsSource="{Binding FontTree}" 
                                       ParentClickMode="Select" 
                                       ParentNodeClickCommand="{Binding SelectFontCommand}"
                                       MaxHeight="300"
                                       Margin="0,0,0,20"/>

                    <TextBlock Text="字体大小" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" 
                                Minimum="8" 
                                Maximum="48" 
                                Value="{Binding SelectedFontSize}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" 
                                 Text="{Binding SelectedFontSize, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource StandardTextBoxStyle}"
                                 HorizontalContentAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="字体粗细" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding FontWeightOptions}"
                              SelectedItem="{Binding SelectedFontWeight}"
                              Style="{DynamicResource StandardComboBoxStyle}"
                              Margin="0,0,0,20"/>

                    <TextBlock Text="行高" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" 
                                Minimum="1.0" 
                                Maximum="3.0" 
                                Value="{Binding SelectedLineHeight}"
                                TickFrequency="0.1"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" 
                                 Text="{Binding SelectedLineHeight, StringFormat=F1, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource StandardTextBoxStyle}"
                                 HorizontalContentAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="字间距" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" 
                                Minimum="-2" 
                                Maximum="5" 
                                Value="{Binding SelectedLetterSpacing}"
                                TickFrequency="0.1"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" 
                                 Text="{Binding SelectedLetterSpacing, StringFormat=F1, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource StandardTextBoxStyle}"
                                 HorizontalContentAlignment="Center"/>
                    </Grid>

                    <common:IconHeaderGroupBox Icon="👁️" Title="空白字符可视化" Margin="0,0,0,15">
                        <StackPanel>
                            <CheckBox IsChecked="{Binding CurrentSettings.ShowZeroWidthChars}"
                                      Content="显示零宽字符占位符"
                                      FontSize="13"
                                      Margin="0,0,0,10"/>

                            <CheckBox IsChecked="{Binding CurrentSettings.VisualizeWhitespace}"
                                      Content="可视化空白符"
                                      FontSize="13"
                                      Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                           Text="Tab符号:" 
                                           FontSize="13"
                                           VerticalAlignment="Center"/>

                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding TabSymbolOptions}"
                                          SelectedItem="{Binding CurrentSettings.TabSymbol}"
                                          Style="{DynamicResource StandardComboBoxStyle}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                           Text="空格符号:" 
                                           FontSize="13"
                                           VerticalAlignment="Center"/>

                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding SpaceSymbolOptions}"
                                          SelectedItem="{Binding CurrentSettings.SpaceSymbol}"
                                          Style="{DynamicResource StandardComboBoxStyle}"/>
                            </Grid>
                        </StackPanel>
                    </common:IconHeaderGroupBox>

                    <common:IconHeaderGroupBox Icon="⚡" Title="字体性能测试" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="测试当前字体的渲染性能，评估在不同场景下的表现" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource TextSecondary}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>

                            <Button Command="{Binding RunPerformanceTestCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <emoji:TextBlock Text="▶" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="运行性能测试" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Border Background="{DynamicResource Surface}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12"
                                    Visibility="{Binding PerformanceReport, Converter={StaticResource NullToVisibilityConverter}}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" 
                                                   Text="综合评级:" 
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" 
                                                    Orientation="Horizontal" 
                                                    HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding PerformanceReport.Rating, Converter={StaticResource PerformanceRatingToStringConverter}}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,5,0"/>
                                            <TextBlock FontSize="16" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PerformanceReport.Rating}" Value="Excellent">
                                                                <Setter Property="Text" Value="⚡"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PerformanceReport.Rating}" Value="Good">
                                                                <Setter Property="Text" Value="✓"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource InfoColor}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PerformanceReport.Rating}" Value="Fair">
                                                                <Setter Property="Text" Value="⚠️"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource WarningColor}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PerformanceReport.Rating}" Value="Poor">
                                                                <Setter Property="Text" Value="✗"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource DangerColor}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <Separator Margin="0,0,0,10"/>

                                    <TextBlock Text="{Binding PerformanceReport.Summary}" 
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10"/>

                                    <TextBlock Text="详细测试结果:" 
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,5"/>

                                    <ItemsControl ItemsSource="{Binding PerformanceReport.DetailedTimings}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" 
                                                               Text="{Binding Key}" 
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondary}"/>

                                                    <TextBlock Grid.Column="1" 
                                                               FontSize="11"
                                                               FontWeight="SemiBold">
                                                        <Run Text="{Binding Value, StringFormat=F3}"/>
                                                        <Run Text="ms" Foreground="{DynamicResource TextTertiary}"/>
                                                    </TextBlock>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </common:IconHeaderGroupBox>

                    <common:IconHeaderGroupBox Icon="🔗" Title="编程连字" Margin="0,0,0,15">
                        <StackPanel>
                            <CheckBox IsChecked="{Binding EnableLigatures}"
                                      Content="🔗 启用编程连字"
                                      FontSize="13"
                                      Margin="0,0,0,10"/>

                            <TextBlock Text="支持的连字：" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,5"/>
                            <Border Background="{DynamicResource Surface}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8"
                                    Margin="0,0,0,10"
                                    MaxHeight="80">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding SupportedLigatures}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource ContentHighlight}"
                                                        BorderBrush="{DynamicResource PrimaryColor}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="6,3"
                                                        Margin="0,0,5,5">
                                                    <TextBlock Text="{Binding}" 
                                                               FontSize="11"
                                                               FontFamily="Consolas"
                                                               Foreground="{DynamicResource TextPrimary}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <TextBlock Text="预览效果：" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,5"/>
                            <Border Background="{DynamicResource Surface}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <TextBlock Text="{Binding LigaturePreviewText}"
                                           FontFamily="{Binding CurrentSettings.FontFamily}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </Border>
                        </StackPanel>
                    </common:IconHeaderGroupBox>

                    <common:IconHeaderGroupBox Icon="🆓" Title="OpenType特性" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="当前字体支持的OpenType特性："
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,10"/>

                            <ItemsControl ItemsSource="{Binding OpenTypeFeatures}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10"
                                                Margin="0,0,0,8"
                                                Background="{DynamicResource Surface}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <CheckBox Grid.Row="0" Grid.Column="0"
                                                          IsChecked="{Binding IsEnabled}"
                                                          Command="{Binding DataContext.ToggleFeatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,10,0"/>

                                                <StackPanel Grid.Row="0" Grid.Column="1">
                                                    <TextBlock FontWeight="SemiBold" FontSize="13">
                                                        <Run Text="{Binding Name, Mode=OneWay}"/>
                                                        <Run Text=" (" Foreground="{DynamicResource TextTertiary}"/>
                                                        <Run Text="{Binding Tag, Mode=OneWay}" Foreground="{DynamicResource TextTertiary}"/>
                                                        <Run Text=")" Foreground="{DynamicResource TextTertiary}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <TextBlock Grid.Row="1" Grid.Column="1"
                                                           Text="{Binding Description}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,3,0,3"/>

                                                <Border Grid.Row="2" Grid.Column="1"
                                                        Background="{DynamicResource ContentHighlight}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="6"
                                                        Margin="0,3,0,0">
                                                    <TextBlock Text="{Binding PreviewText}"
                                                               FontFamily="{Binding DataContext.CurrentSettings.FontFamily, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                               FontSize="14"
                                                               Foreground="{DynamicResource TextPrimary}"
                                                               TextAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="未检测到OpenType特性"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextTertiary}"
                                       TextAlignment="Center"
                                       Padding="5">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenTypeFeatures.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </common:IconHeaderGroupBox>

                    <StackPanel>
                        <Button Command="{Binding ApplyCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <emoji:TextBlock Text="✅" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="应用设置" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SaveCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <emoji:TextBlock Text="💾" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="保存配置" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ResetCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <emoji:TextBlock Text="🔄" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="重置默认" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </common:IconHeaderGroupBox>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="4*"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <common:IconHeaderGroupBox Grid.Row="0" Icon="💻" Title="代码语法预览">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,5,5,10">
                        <TextBlock Text="语言:" 
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,0,10,0"/>

                        <ComboBox ItemsSource="{Binding SupportedLanguages}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  Style="{DynamicResource StandardComboBoxStyle}"
                                  Width="120"
                                  Margin="0,0,10,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource CodeLanguageToStringConverter}}" 
                                               FontSize="13"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Button Command="{Binding ResetCodeSampleCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                MinWidth="90">
                            <StackPanel Orientation="Horizontal" Margin="6,3">
                                <emoji:TextBlock Text="🔄" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="重置" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Text="{Binding CurrentCode, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{Binding CurrentSettings.FontFamily}"
                             FontSize="{Binding CurrentSettings.FontSize}"
                             Foreground="{DynamicResource TextPrimary}"
                             Background="{DynamicResource Surface}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalAlignment="Stretch"
                             HorizontalAlignment="Stretch"
                             Padding="10"
                             Margin="5"
                             MinHeight="500"/>
                </Grid>
            </common:IconHeaderGroupBox>

            <Button Grid.Row="1"
                    Command="{Binding RunWidthAnalysisCommand}"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Margin="5">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <emoji:TextBlock Text="📊" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="字符宽度分析" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <common:IconHeaderGroupBox Grid.Row="2" Icon="📝" Title="当前配置">
                <Grid Margin="10" DataContext="{Binding CurrentSettings}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="字体：" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding FontFamily}" FontSize="12"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="大小：" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding FontSize, StringFormat={}{0} px}" FontSize="12"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="粗细：" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding FontWeight}" FontSize="12"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="行高：" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding LineHeight, StringFormat=F1}" FontSize="12"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="字间距：" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock Grid.Row="8" Grid.Column="2" Text="{Binding LetterSpacing, StringFormat=F1}" FontSize="12"/>
                </Grid>
            </common:IconHeaderGroupBox>
        </Grid>
    </Grid>
</UserControl>
