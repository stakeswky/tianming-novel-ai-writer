<UserControl x:Class="TM.Framework.Appearance.ThemeManagement.ThemeImportExport.ThemeImportExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:local="clr-namespace:TM.Framework.Appearance.ThemeManagement.ThemeImportExport">

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  Background="{DynamicResource ContentBackground}">
    <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="📤" Title="导出主题">
                <StackPanel>
                    <TextBlock Text="将主题配置导出为 XAML 文件，可分享给其他用户或备份使用" 
                              FontSize="13" 
                              Foreground="{DynamicResource TextSecondary}"
                              TextWrapping="Wrap"
                              Margin="0,0,0,15"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding ExportCurrentCommand}"
                               Style="{StaticResource PrimaryButtonStyle}"
                               helpers:ButtonHelper.ConfirmMessage="确定要导出当前使用的主题吗？&#x0a;主题将保存为 XAML 文件到导出目录。"
                               helpers:ButtonHelper.ConfirmTitle="确认导出"
                               Padding="20,10" Margin="0,0,10,0" MinWidth="140">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="📤" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="导出当前主题" VerticalAlignment="Center"
                                          FontFamily="{DynamicResource GlobalFontFamily}"
                                          FontSize="{DynamicResource FontSizeSmall}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ExportAllCommand}"
                               Style="{StaticResource SecondaryButtonStyle}"
                               helpers:ButtonHelper.ConfirmMessage="确定要导出所有主题吗？&#x0a;将导出系统内所有可用主题到导出目录。"
                               helpers:ButtonHelper.ConfirmTitle="确认导出"
                               Padding="20,10" MinWidth="140">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="📦" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="导出所有主题" VerticalAlignment="Center"
                                          FontFamily="{DynamicResource GlobalFontFamily}"
                                          FontSize="{DynamicResource FontSizeSmall}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="📥" Title="导入主题">
                <StackPanel>
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="从文件导入主题配置，支持标准的 XAML 主题文件" 
                                  FontSize="13" 
                                  Foreground="{DynamicResource TextSecondary}"
                                  TextWrapping="Wrap"
                                  Margin="0,0,0,8"/>
                        <TextBlock FontSize="12" 
                                  Foreground="{DynamicResource TextSecondary}"
                                  TextWrapping="Wrap">
                            <Run Text="支持的文件格式："/>
                            <Run Text=".xaml" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryColor}"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding ImportThemeCommand}"
                               Style="{StaticResource PrimaryButtonStyle}"
                               helpers:ButtonHelper.ConfirmMessage="确定要导入主题文件吗？&#x0a;导入的主题将添加到主题库，可在「主题选择」中使用。"
                               helpers:ButtonHelper.ConfirmTitle="确认导入"
                               Padding="20,10" MinWidth="140">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="📥" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="选择文件导入" VerticalAlignment="Center"
                                          FontFamily="{DynamicResource GlobalFontFamily}"
                                          FontSize="{DynamicResource FontSizeSmall}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="4" Icon="📁" Title="导出位置">
                <StackPanel>
                    <TextBlock FontSize="13" 
                              Foreground="{DynamicResource TextSecondary}"
                              TextWrapping="Wrap"
                              Margin="0,0,0,15">
                        <Run Text="导出的主题文件保存在："/>
                        <LineBreak/>
                        <Run Text="我的文档\天命\导出的主题" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryColor}"/>
                    </TextBlock>

                    <Button Command="{Binding OpenExportFolderCommand}"
                           Style="{StaticResource SecondaryButtonStyle}"
                           HorizontalAlignment="Right"
                           Padding="20,10" MinWidth="160">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="📁" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="打开导出文件夹" VerticalAlignment="Center"
                                      FontFamily="{DynamicResource GlobalFontFamily}"
                                      FontSize="{DynamicResource FontSizeSmall}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="6" Icon="📋" Title="导出记录（最近20条）">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
                           Content="清空列表"
                           Command="{Binding ClearExportListCommand}"
                           Style="{StaticResource SecondaryButtonStyle}"
                           helpers:ButtonHelper.ConfirmMessage="确定要清空导出记录吗？&#x0a;清空后将无法查看历史导出记录。"
                           helpers:ButtonHelper.ConfirmTitle="确认清空"
                           HorizontalAlignment="Right"
                           Padding="12,6"
                           FontSize="12"/>

                    <Border Grid.Row="2" 
                            BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="1" 
                            CornerRadius="6"
                            Background="{DynamicResource Surface}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ExportedListControl" ItemsSource="{Binding ExportedThemes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrush}" 
                                               BorderThickness="0,0,0,1" 
                                               Padding="15,12"
                                               Background="Transparent">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding FileName}" 
                                                              FontSize="13" 
                                                              FontWeight="Medium"
                                                              Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text="{Binding DisplayTime}" 
                                                              FontSize="11" 
                                                              Foreground="{DynamicResource TextSecondary}"
                                                              Margin="0,4,0,0"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="1" 
                                                          Text="{Binding FileSize}" 
                                                          FontSize="12" 
                                                          Foreground="{DynamicResource TextSecondary}"
                                                          VerticalAlignment="Center"
                                                          Margin="15,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>

                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ExportedThemes.Count}" Value="0">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate>
                                                            <Border Padding="40" Background="Transparent">
                                                                <StackPanel HorizontalAlignment="Center">
                                                                    <emoji:TextBlock Text="📭" FontSize="48" 
                                                                                    HorizontalAlignment="Center" 
                                                                                    Opacity="0.3"
                                                                                    Margin="0,0,0,15"/>
                                                                    <TextBlock Text="暂无导出记录" 
                                                                              FontSize="14" 
                                                                              Foreground="{DynamicResource TextSecondary}"
                                                                              HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="4" 
                            Background="{DynamicResource Surface}" 
                            CornerRadius="6" 
                            Padding="12,8">
                        <TextBlock Text="{Binding StatusMessage}" 
                                  FontSize="12" 
                                  Foreground="{DynamicResource TextSecondary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                            <Setter Property="Text" Value="准备就绪"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>
            </layout:IconHeaderGroupBox>
        </Grid>
    </ScrollViewer>
</UserControl>
