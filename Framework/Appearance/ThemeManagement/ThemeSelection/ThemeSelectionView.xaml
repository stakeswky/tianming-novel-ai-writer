<UserControl x:Class="TM.Framework.Appearance.ThemeManagement.ThemeSelection.ThemeSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <common:IconHeaderGroupBox Grid.Row="0" Icon="✅" Title="当前使用">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="正在使用:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock x:Name="CurrentThemeLabel" 
                                       Text="加载中..." 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryColor}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Column="1" 
                                x:Name="FavoritesFilterButton"
                                Click="OnToggleFavoritesFilter"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="12,6"
                                Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="⭐" FontSize="14" Margin="0,0,5,0"/>
                                <TextBlock x:Name="FavoritesText" Text="我的收藏"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" 
                               BorderBrush="{DynamicResource BorderBrush}" 
                               BorderThickness="1" 
                               CornerRadius="6" 
                               Background="{DynamicResource Surface}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <emoji:TextBlock Grid.Column="0" Text="🔍" FontSize="14" 
                                                Margin="10,0,5,0" VerticalAlignment="Center"/>

                                <TextBox x:Name="SearchBox" 
                                        Grid.Column="1"
                                        TextChanged="OnSearchTextChanged"
                                        BorderThickness="0" 
                                        Background="Transparent"
                                        Padding="5,8"
                                        VerticalContentAlignment="Center"
                                        FontSize="13"
                                        Text="">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <TextBlock Grid.Column="1" 
                                          Text="搜索主题名称..." 
                                          Foreground="{DynamicResource TextSecondary}"
                                          FontSize="13"
                                          Padding="5,8"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Button Grid.Column="2" 
                                       x:Name="ClearSearchButton"
                                       Click="OnClearSearch"
                                       Padding="8,4"
                                       Margin="5,0"
                                       Background="Transparent"
                                       BorderThickness="0"
                                       Visibility="Collapsed">
                                    <emoji:TextBlock Text="✖" FontSize="12"/>
                                </Button>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="SearchResultText" 
                                  Grid.Column="1"
                                  Text="找到 0 个匹配的主题"
                                  FontSize="12"
                                  Foreground="{DynamicResource TextSecondary}"
                                  VerticalAlignment="Center"
                                  Margin="15,0,0,0"
                                  Visibility="Collapsed"/>
                    </Grid>
                </Grid>
        </common:IconHeaderGroupBox>

        <common:IconHeaderGroupBox Grid.Row="1" Icon="🎨" Title="可用主题">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource InfoCardStyle}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="💡" FontSize="12" Margin="0,0,5,0"/>
                            <TextBlock Text="提示：点击卡片选中主题，然后点击「应用主题」按钮进行切换" 
                                       Style="{StaticResource CardDescriptionStyle}"
                                       Foreground="{DynamicResource InfoColor}"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ThemesItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="ThemeCard"
                                            Style="{StaticResource ThemeCardStyle}"
                                            MouseDown="OnThemeCardClick"
                                            Tag="{Binding ThemeId}">

                                        <Grid>
                                            <Button HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Width="36"
                                                    Height="36"
                                                    Padding="4"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Click="OnToggleFavorite"
                                                    Margin="0,-5,-5,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            CornerRadius="18">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                         VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <emoji:TextBlock Text="{Binding FavoriteIcon}" FontSize="18"/>
                                            </Button>

                                            <StackPanel>
                                                <TextBlock Text="{Binding ThemeName}" 
                                                           FontWeight="Bold"
                                                           FontSize="11"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,0,8"
                                                           Foreground="{DynamicResource TextPrimary}"/>

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,2,3">
                                                    <Border Height="20" 
                                                            Background="{Binding PrimaryColor}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="{StaticResource StandardBorder}"
                                                            CornerRadius="{StaticResource SmallRadius}"/>
                                                    <TextBlock Text="主色" 
                                                               FontSize="7" 
                                                               TextAlignment="Center"
                                                               Foreground="{DynamicResource TextSecondary}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="2,0,0,3">
                                                    <Border Height="20" 
                                                            Background="{Binding SecondaryColor}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="{StaticResource StandardBorder}"
                                                            CornerRadius="{StaticResource SmallRadius}"/>
                                                    <TextBlock Text="次色" 
                                                               FontSize="7" 
                                                               TextAlignment="Center"
                                                               Foreground="{DynamicResource TextSecondary}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,2,0">
                                                    <Border Height="20" 
                                                            Background="{Binding BackgroundColor}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="{StaticResource StandardBorder}"
                                                            CornerRadius="{StaticResource SmallRadius}"/>
                                                    <TextBlock Text="背景" 
                                                               FontSize="7" 
                                                               TextAlignment="Center"
                                                               Foreground="{DynamicResource TextSecondary}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="2,0,0,0">
                                                    <Border Height="20" 
                                                            Background="{Binding TextColor}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="{StaticResource StandardBorder}"
                                                            CornerRadius="{StaticResource SmallRadius}"/>
                                                    <TextBlock Text="文字" 
                                                               FontSize="7" 
                                                               TextAlignment="Center"
                                                               Foreground="{DynamicResource TextSecondary}"/>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock x:Name="StatusLabel"
                                                       Text="{Binding StatusText}"
                                                       FontSize="9"
                                                       TextAlignment="Center"
                                                       Margin="0,8,0,0"
                                                       Foreground="{Binding StatusColor}"/>

                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                            <Setter TargetName="ThemeCard" Property="BorderBrush" Value="{DynamicResource SuccessColor}"/>
                                            <Setter TargetName="ThemeCard" Property="BorderThickness" Value="{StaticResource ExtraThickBorder}"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="ThemeCard" Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                                            <Setter TargetName="ThemeCard" Property="BorderThickness" Value="{StaticResource ExtraThickBorder}"/>
                                        </DataTrigger>

                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsCurrent}" Value="False"/>
                                                <Condition Binding="{Binding IsSelected}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="ThemeCard" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                            <Setter TargetName="ThemeCard" Property="BorderThickness" Value="{StaticResource ThickBorder}"/>
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </Grid>
        </common:IconHeaderGroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">

                <Button Width="{StaticResource MediumButtonWidth}"
                        Click="OnDeleteThemeClick"
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="🗑️" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="删除主题"/>
                    </StackPanel>
                </Button>

                <Button Width="{StaticResource SmallButtonWidth}"
                        Click="OnRefreshClick"
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="🔄" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="刷新"/>
                    </StackPanel>
                </Button>

                <Button Width="{StaticResource MediumButtonWidth}"
                        Click="OnApplyThemeClick">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="✅" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="应用主题"/>
                    </StackPanel>
                </Button>

        </StackPanel>

    </Grid>

</UserControl>

