<UserControl x:Class="TM.Framework.Appearance.ThemeManagement.ThemeDesign.ThemeDesignView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:local="clr-namespace:TM.Framework.Appearance.ThemeManagement.ThemeDesign">

    <DockPanel Margin="5">

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Command="{Binding ResetThemeCommand}"
                   Style="{StaticResource SecondaryButtonStyle}"
                   helpers:ButtonHelper.ConfirmMessage="确定要重置为默认配色吗？&#x0a;当前所有配色将被重置，未保存的修改将丢失。"
                   helpers:ButtonHelper.ConfirmTitle="确认重置"
                   Margin="0,0,10,0" MinWidth="100">
                <StackPanel Orientation="Horizontal" Margin="12,6">
                    <emoji:TextBlock Text="🔄" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="重置默认" VerticalAlignment="Center"
                              FontFamily="{DynamicResource GlobalFontFamily}"
                              FontSize="{DynamicResource FontSizeSmall}"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding ApplyThemeCommand}"
                   Style="{StaticResource PrimaryButtonStyle}"
                   helpers:ButtonHelper.ConfirmMessage="确定要应用当前设计的主题吗？&#x0a;主题将立即应用到整个程序界面。"
                   helpers:ButtonHelper.ConfirmTitle="确认应用"
                   Margin="0,0,10,0" MinWidth="100">
                <StackPanel Orientation="Horizontal" Margin="12,6">
                    <emoji:TextBlock Text="✅" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="应用主题" VerticalAlignment="Center"
                              FontFamily="{DynamicResource GlobalFontFamily}"
                              FontSize="{DynamicResource FontSizeSmall}"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding SaveThemeCommand}"
                   Style="{StaticResource PrimaryButtonStyle}"
                   helpers:ButtonHelper.ConfirmMessage="确定要保存当前主题配色吗？&#x0a;主题将保存到主题库，可在「主题选择」中查看。"
                   helpers:ButtonHelper.ConfirmTitle="确认保存"
                   MinWidth="100">
                <StackPanel Orientation="Horizontal" Margin="12,6">
                    <emoji:TextBlock Text="💾" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="保存主题" VerticalAlignment="Center"
                              FontFamily="{DynamicResource GlobalFontFamily}"
                              FontSize="{DynamicResource FontSizeSmall}"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <emoji:TextBlock Text="📝" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="主题名称:" VerticalAlignment="Center" FontSize="14" Margin="0,0,10,0"/>
                <TextBox Text="{Binding ThemeName, UpdateSourceTrigger=PropertyChanged}" 
                        Width="200" Height="32" VerticalContentAlignment="Center" Padding="8,0"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock Text="{Binding HistoryInfo}" VerticalAlignment="Center" 
                          FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,15,0"/>
                <Button Command="{Binding UndoCommand}" 
                       Style="{StaticResource SecondaryButtonStyle}"
                       Padding="10,6" Margin="0,0,10,0" MinWidth="80">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="↶" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="撤销" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding RedoCommand}" 
                       Style="{StaticResource SecondaryButtonStyle}"
                       Padding="10,6" MinWidth="80">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="↷" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="重做" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                <StackPanel>
                    <Border Background="{DynamicResource CardBackground}" 
                           BorderBrush="{DynamicResource BorderBrush}" 
                           BorderThickness="1" CornerRadius="8" Padding="5" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <emoji:TextBlock Text="📍" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="顶栏配色" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <local:ColorPickerControl Label="背景颜色" SelectedBrush="{Binding TopBarBackground, Mode=TwoWay}" Margin="0,0,0,10"/>
                            <local:ColorPickerControl Label="字体颜色" SelectedBrush="{Binding TopBarText, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBackground}" 
                           BorderBrush="{DynamicResource BorderBrush}" 
                           BorderThickness="1" CornerRadius="8" Padding="5" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <emoji:TextBlock Text="📐" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="左导航栏配色" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <local:ColorPickerControl Label="背景颜色" SelectedBrush="{Binding LeftBarBackground, Mode=TwoWay}" Margin="0,0,0,10"/>
                            <local:ColorPickerControl Label="图标颜色" SelectedBrush="{Binding LeftBarIconColor, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBackground}" 
                           BorderBrush="{DynamicResource BorderBrush}" 
                           BorderThickness="1" CornerRadius="8" Padding="5" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <emoji:TextBlock Text="📋" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="左工作区配色" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <local:ColorPickerControl Label="背景颜色" SelectedBrush="{Binding LeftWorkspaceBackground, Mode=TwoWay}" Margin="0,0,0,10"/>
                            <local:ColorPickerControl Label="字体颜色" SelectedBrush="{Binding LeftWorkspaceText, Mode=TwoWay}" Margin="0,0,0,10"/>
                            <local:ColorPickerControl Label="边框颜色" SelectedBrush="{Binding LeftWorkspaceBorder, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBackground}" 
                           BorderBrush="{DynamicResource BorderBrush}" 
                           BorderThickness="1" CornerRadius="8" Padding="5" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <emoji:TextBlock Text="🎯" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="中心工作区配色" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <local:ColorPickerControl Label="背景颜色" SelectedBrush="{Binding CenterWorkspaceBackground, Mode=TwoWay}" Margin="0,0,0,10"/>
                            <local:ColorPickerControl Label="字体颜色" SelectedBrush="{Binding CenterWorkspaceText, Mode=TwoWay}" Margin="0,0,0,10"/>
                            <local:ColorPickerControl Label="边框颜色" SelectedBrush="{Binding CenterWorkspaceBorder, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBackground}" 
                           BorderBrush="{DynamicResource BorderBrush}" 
                           BorderThickness="1" CornerRadius="8" Padding="5" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <emoji:TextBlock Text="📄" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="右工作区配色" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <local:ColorPickerControl Label="背景颜色" SelectedBrush="{Binding RightWorkspaceBackground, Mode=TwoWay}" Margin="0,0,0,10"/>
                            <local:ColorPickerControl Label="字体颜色" SelectedBrush="{Binding RightWorkspaceText, Mode=TwoWay}" Margin="0,0,0,10"/>
                            <local:ColorPickerControl Label="边框颜色" SelectedBrush="{Binding RightWorkspaceBorder, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBackground}" 
                           BorderBrush="{DynamicResource BorderBrush}" 
                           BorderThickness="1" CornerRadius="8" Padding="5" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <emoji:TextBlock Text="📊" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="底栏配色" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <local:ColorPickerControl Label="背景颜色" SelectedBrush="{Binding BottomBarBackground, Mode=TwoWay}" Margin="0,0,0,10"/>
                            <local:ColorPickerControl Label="字体颜色" SelectedBrush="{Binding BottomBarText, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBackground}" 
                           BorderBrush="{DynamicResource BorderBrush}" 
                           BorderThickness="1" CornerRadius="8" Padding="5">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <emoji:TextBlock Text="🔘" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="按钮配色" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="主要按钮" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{DynamicResource TextSecondary}"/>
                            <local:ColorPickerControl Label="按钮颜色" SelectedBrush="{Binding PrimaryButtonColor, Mode=TwoWay}" Margin="0,0,0,10"/>
                            <local:ColorPickerControl Label="悬停颜色" SelectedBrush="{Binding PrimaryButtonHover, Mode=TwoWay}" Margin="0,0,0,15"/>

                            <TextBlock Text="危险按钮" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{DynamicResource TextSecondary}"/>
                            <local:ColorPickerControl Label="按钮颜色" SelectedBrush="{Binding DangerButtonColor, Mode=TwoWay}" Margin="0,0,0,10"/>
                            <local:ColorPickerControl Label="悬停颜色" SelectedBrush="{Binding DangerButtonHover, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2" Background="{DynamicResource CardBackground}" 
                   BorderBrush="{DynamicResource BorderBrush}" 
                   BorderThickness="1" CornerRadius="8" Padding="5">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <emoji:TextBlock Text="👁️" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="实时预览" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                            <Border BorderBrush="{Binding CenterWorkspaceBorder}" BorderThickness="2"
                                   CornerRadius="8" Height="420" Margin="0,0,0,15">
                                <Grid Background="{Binding TopBarBackground}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="42"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="30"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Background="{Binding TopBarBackground}" CornerRadius="6,6,0,0">
                                        <DockPanel Margin="15,0">
                                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                                <emoji:TextBlock Text="⚡" FontSize="16" Foreground="{Binding TopBarText}" VerticalAlignment="Center"/>
                                                <TextBlock Text="天命" FontSize="13" FontWeight="SemiBold" Foreground="{Binding TopBarText}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="工作台" FontSize="11" Foreground="{Binding TopBarText}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="功能" FontSize="11" Foreground="{Binding TopBarText}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="对话" FontSize="11" Foreground="{Binding TopBarText}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="— □ ✕" FontSize="11" Foreground="{Binding TopBarText}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>

                                    <ProgressBar Grid.Row="1"
                                                 Height="3"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="65"
                                                 Foreground="{Binding PrimaryButtonColor}"
                                                 Background="Transparent"
                                                 BorderThickness="0"/>

                                    <Grid Grid.Row="2" Background="{Binding TopBarBackground}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="1"
                                                Background="{Binding CenterWorkspaceBackground}"
                                                BorderBrush="{Binding CenterWorkspaceBorder}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Margin="1,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="230"/>
                                                    <ColumnDefinition Width="5"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="5"/>
                                                    <ColumnDefinition Width="1*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" Background="{Binding LeftWorkspaceBackground}"
                                                        BorderBrush="{Binding LeftWorkspaceBorder}" BorderThickness="1"
                                                        CornerRadius="6" Margin="6">
                                                    <TextBlock Text="左工作区" Foreground="{Binding LeftWorkspaceText}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Rectangle Grid.Column="1" Fill="{Binding CenterWorkspaceBorder}"/>
                                                <Border Grid.Column="2" Background="{Binding CenterWorkspaceBackground}"
                                                        BorderBrush="{Binding CenterWorkspaceBorder}" BorderThickness="1"
                                                        CornerRadius="6" Margin="6">
                                                    <TextBlock Text="中心工作区" Foreground="{Binding CenterWorkspaceText}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Rectangle Grid.Column="3" Fill="{Binding CenterWorkspaceBorder}"/>
                                                <Border Grid.Column="4" Background="{Binding RightWorkspaceBackground}"
                                                        BorderBrush="{Binding RightWorkspaceBorder}" BorderThickness="1"
                                                        CornerRadius="6" Margin="6">
                                                    <TextBlock Text="右工作区" Foreground="{Binding RightWorkspaceText}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Border Grid.Row="3" Background="{Binding BottomBarBackground}" CornerRadius="0,0,6,6">
                                        <Grid Margin="15,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="就绪" Foreground="{Binding BottomBarText}" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="内存: 128MB" Foreground="{Binding BottomBarText}" FontSize="11" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="2025-12-17 12:00:00" Foreground="{Binding BottomBarText}" FontSize="11" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                           CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="按钮预览" FontSize="13" FontWeight="SemiBold" 
                                      Margin="0,0,0,10" Foreground="{DynamicResource TextSecondary}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                                <Border Background="{Binding PrimaryButtonColor}" CornerRadius="6" 
                                       Padding="15,8" Margin="0,0,10,0" MinWidth="90">
                                    <TextBlock Text="主要按钮" FontSize="13" Foreground="White" HorizontalAlignment="Center"/>
                                </Border>
                                <Border Background="{Binding DangerButtonColor}" CornerRadius="6" 
                                       Padding="15,8" MinWidth="90">
                                    <TextBlock Text="危险按钮" FontSize="13" Foreground="White" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                           CornerRadius="8" Padding="15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <emoji:TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="对比度检查 (WCAG AA)" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="{Binding ContrastSummary}" FontSize="13" 
                                      FontWeight="SemiBold" Margin="0,0,0,10"/>

                            <ItemsControl ItemsSource="{Binding ContrastWarnings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource Surface}" 
                                               BorderBrush="{DynamicResource WarningColor}" 
                                               BorderThickness="1" CornerRadius="4" 
                                               Padding="10,8" Margin="0,0,0,5">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                    <emoji:TextBlock Text="{Binding Icon}" FontSize="12" Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding Area}" FontWeight="SemiBold" FontSize="12"/>
                                                    <TextBlock Text=" - " FontSize="12" Margin="5,0"/>
                                                    <TextBlock Text="{Binding DisplayRatio}" FontSize="12" Foreground="{DynamicResource DangerColor}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Recommendation}" FontSize="11" 
                                                          Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
    </DockPanel>
</UserControl>
