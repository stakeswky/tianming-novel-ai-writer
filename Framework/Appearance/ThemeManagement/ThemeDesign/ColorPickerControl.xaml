<UserControl x:Class="TM.Framework.Appearance.ThemeManagement.ThemeDesign.ColorPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                  VerticalAlignment="Center" Margin="0,0,15,0" MinWidth="80"/>

        <Border Grid.Column="1" Background="{Binding SelectedBrush, RelativeSource={RelativeSource AncestorType=UserControl}}" 
               BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
               CornerRadius="4" Height="32" Margin="0,0,10,0"/>

        <Button Grid.Column="2" Content="选择颜色" Click="SelectColor_Click"
               Padding="15,8" MinWidth="90"/>
    </Grid>
</UserControl>

