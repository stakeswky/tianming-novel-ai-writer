<UserControl x:Class="TM.Framework.Appearance.IntelligentGeneration.GenerationHistory.GenerationHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:converters="clr-namespace:TM.Framework.Common.Converters"
             xmlns:visibility="clr-namespace:TM.Framework.Common.Converters.Visibility"
             xmlns:local="clr-namespace:TM.Framework.Appearance.IntelligentGeneration.GenerationHistory">

    <UserControl.Resources>
        <ResourceDictionary>

            <visibility:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
               Background="{DynamicResource ContentBackground}"
               BorderBrush="{DynamicResource BorderBrush}"
               BorderThickness="0,0,0,1"
               Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <emoji:TextBlock Text="📜" FontSize="20" Margin="0,0,10,0"/>
                    <TextBlock Text="生成历史" 
                              FontSize="18" 
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource TextPrimary}"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                            Width="250"
                            Height="36"
                            Style="{DynamicResource StandardTextBoxStyle}"
                            Margin="0,0,15,0"/>
                    <TextBlock Text="筛选：" 
                              FontSize="14"
                              Foreground="{DynamicResource TextSecondary}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding FilterOptions}"
                             SelectedItem="{Binding SelectedFilter}"
                             Width="120"
                             Style="{DynamicResource StandardComboBoxStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Command="{Binding RefreshCommand}"
                           Style="{DynamicResource SecondaryButtonStyle}"
                           Padding="12,8"
                           Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="🔄" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="刷新" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ClearAllCommand}"
                           Style="{DynamicResource DangerButtonStyle}"
                           helpers:ButtonHelper.ConfirmMessage="确定要清空所有历史记录吗？&#x0a;此操作无法撤销！"
                           helpers:ButtonHelper.ConfirmTitle="确认清空"
                           Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="🗑️" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="清空历史" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding HistoryRecords}"
                         Padding="5"
                         HorizontalAlignment="Center"
                         MaxWidth="1500">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource ContentBackground}"
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="12"
                               Padding="15"
                               Margin="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <emoji:TextBlock Text="{Binding TypeIcon}" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Name}" 
                                                  FontSize="14" 
                                                  FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextPrimary}"
                                                  VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Command="{Binding FavoriteCommand}"
                                               CommandParameter="{Binding}"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Padding="5"
                                               Margin="0,0,5,0"
                                               Cursor="Hand">
                                            <emoji:TextBlock Text="{Binding FavoriteIcon}" FontSize="16"/>
                                        </Button>
                                        <TextBlock Text="{Binding FormattedTime}" 
                                                  FontSize="11" 
                                                  Foreground="{DynamicResource TextSecondary}"
                                                  VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Background="{DynamicResource HoverBackground}"
                                           CornerRadius="4"
                                           Padding="8,4"
                                           Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Type}" 
                                                  FontSize="11" 
                                                  Foreground="{DynamicResource TextPrimary}"/>
                                    </Border>
                                    <Border Background="{DynamicResource HoverBackground}"
                                           CornerRadius="4"
                                           Padding="8,4">
                                        <TextBlock Text="{Binding Harmony}" 
                                                  FontSize="11" 
                                                  Foreground="{DynamicResource TextPrimary}"/>
                                    </Border>
                                </StackPanel>

                                <Grid Grid.Row="2" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="{Binding PrimaryBrush}" Height="50" CornerRadius="6,0,0,6"/>
                                    <Border Grid.Column="1" Background="{Binding SecondaryBrush}" Height="50"/>
                                    <Border Grid.Column="2" Background="{Binding AccentBrush}" Height="50" CornerRadius="0,6,6,0"/>
                                </Grid>

                                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Command="{Binding ApplyCommand}"
                                           CommandParameter="{Binding}"
                                           Style="{DynamicResource PrimaryButtonStyle}"
                                           helpers:ButtonHelper.ConfirmMessage="确定要应用此配色方案吗？&#x0a;当前主题将被临时替换。"
                                           helpers:ButtonHelper.ConfirmTitle="确认应用"
                                           Padding="10,6"
                                           Margin="0,0,8,0">
                                        <StackPanel Orientation="Horizontal">
                                            <emoji:TextBlock Text="✨" FontSize="12" Margin="0,0,4,0"/>
                                            <TextBlock Text="应用" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ExportCommand}"
                                           CommandParameter="{Binding}"
                                           Style="{DynamicResource SecondaryButtonStyle}"
                                           helpers:ButtonHelper.ConfirmMessage="确定要将此配色方案导出为主题吗？&#x0a;主题将保存到主题库。"
                                           helpers:ButtonHelper.ConfirmTitle="确认导出"
                                           Padding="10,6"
                                           Margin="0,0,8,0">
                                        <StackPanel Orientation="Horizontal">
                                            <emoji:TextBlock Text="💾" FontSize="12" Margin="0,0,4,0"/>
                                            <TextBlock Text="导出" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding DeleteCommand}"
                                           CommandParameter="{Binding}"
                                           Style="{DynamicResource DangerButtonStyle}"
                                           helpers:ButtonHelper.ConfirmMessage="确定要删除此历史记录吗？&#x0a;删除后无法恢复！"
                                           helpers:ButtonHelper.ConfirmTitle="确认删除"
                                           Padding="10,6">
                                        <StackPanel Orientation="Horizontal">
                                            <emoji:TextBlock Text="🗑️" FontSize="12" Margin="0,0,4,0"/>
                                            <TextBlock Text="删除" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="1" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"
                   Visibility="{Binding HistoryRecords.Count, Converter={StaticResource InverseCountToVisibilityConverter}}">
            <emoji:TextBlock Text="📭" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            <TextBlock Text="暂无生成历史" 
                      FontSize="18" 
                      FontWeight="SemiBold"
                      Foreground="{DynamicResource TextPrimary}"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,8"/>
            <TextBlock Text="使用图片取色或AI配色生成主题后会在这里显示" 
                      FontSize="14" 
                      Foreground="{DynamicResource TextSecondary}"
                      HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
