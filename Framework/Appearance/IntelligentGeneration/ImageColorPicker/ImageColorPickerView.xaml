<UserControl x:Class="TM.Framework.Appearance.IntelligentGeneration.ImageColorPicker.ImageColorPickerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:local="clr-namespace:TM.Framework.Appearance.IntelligentGeneration.ImageColorPicker"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <Grid Background="{DynamicResource ContentBackground}" Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <common:IconHeaderGroupBox Grid.Column="0" Icon="📷" Title="上传图片" MaxHeight="330">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="180" 
                            Height="180"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="2"
                            CornerRadius="8"
                            Background="{DynamicResource Surface}"
                            Margin="0,0,15,0">
                        <Grid>
                            <StackPanel VerticalAlignment="Center"
                                       HorizontalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <emoji:TextBlock Text="📁" FontSize="40" 
                                               HorizontalAlignment="Center" 
                                               Margin="0,0,0,8"/>
                                <TextBlock Text="点击下方按钮"
                                          FontSize="11"
                                          HorizontalAlignment="Center"
                                          Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="上传图片"
                                          FontSize="11"
                                          HorizontalAlignment="Center"
                                          Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>

                            <Image Source="{Binding CurrentImage}"
                                   Stretch="Uniform">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="1">
                            <TextBlock Text="上传图片后，系统会自动提取图片中的主要颜色，并生成协调的主题配色方案"
                                       Foreground="{DynamicResource TextTertiary}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,15"/>

                            <TextBlock Text="{Binding ImageInfo}"
                                       Foreground="{DynamicResource TextTertiary}"
                                       FontSize="10"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,0,15"/>

                            <Button Content="📁 选择图片"
                                    Command="{Binding UploadImageCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    Width="150"
                                    HorizontalAlignment="Left"
                                    Margin="20,0,0,0"
                                    Padding="20,10"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </common:IconHeaderGroupBox>

            <common:IconHeaderGroupBox Grid.Column="2" Icon="📊" Title="图片分析" MaxHeight="330">
                <Border Background="{DynamicResource Surface}"
                       Padding="5"
                       CornerRadius="8"
                       MinHeight="270">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TextBlock Text="{Binding AnalysisText}"
                                  Foreground="{DynamicResource TextSecondary}"
                                  TextWrapping="Wrap"
                                  LineHeight="28"
                                  FontSize="13"/>
                    </ScrollViewer>
                </Border>
            </common:IconHeaderGroupBox>
        </Grid>

        <common:IconHeaderGroupBox Grid.Row="1" Icon="🎨" Title="提取的颜色" Margin="0,0,0,20" Height="380">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="从图片中提取的主要颜色，点击颜色可生成对应的主题"
                               Foreground="{DynamicResource TextTertiary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,15"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding ExtractedColors}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ContentBackground}"
                                       BorderBrush="{DynamicResource BorderBrush}"
                                       BorderThickness="1"
                                       CornerRadius="8"
                                       Padding="18"
                                       Margin="12"
                                       Width="160">
                                    <StackPanel>
                                        <Border Width="100" Height="100"
                                               Background="{Binding ColorBrush}"
                                               BorderBrush="{DynamicResource BorderBrush}"
                                               BorderThickness="2"
                                               CornerRadius="8"
                                               Margin="0,0,0,12"/>

                                        <TextBlock Text="{Binding HexColor}"
                                                  FontFamily="Consolas"
                                                  FontWeight="Bold"
                                                  FontSize="11"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,0,0,6"/>

                                        <TextBlock Text="{Binding RgbColor}"
                                                  FontFamily="Consolas"
                                                  FontSize="10"
                                                  Foreground="{DynamicResource TextTertiary}"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,0,0,12"/>

                                        <Button Command="{Binding GenerateCommand}"
                                               Height="40"
                                               FontWeight="Bold"
                                               Cursor="Hand"
                                               Background="{Binding ButtonBackground}"
                                               Foreground="{Binding ButtonForeground}"
                                               BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                           BorderBrush="{TemplateBinding BorderBrush}"
                                                           BorderThickness="{TemplateBinding BorderThickness}"
                                                           CornerRadius="6"
                                                           Padding="10,8">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.9"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <emoji:TextBlock Text="✨" FontSize="14" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Index, StringFormat='生成主题 {0}'}" FontSize="13"/>
                                            </StackPanel>
                                        </Button>
        </StackPanel>
    </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Grid.Row="1"
                               Text="上传图片后，这里会显示提取的颜色"
                               Foreground="{DynamicResource TextTertiary}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Padding="30">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ExtractedColors.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </common:IconHeaderGroupBox>

        <StackPanel Grid.Row="2" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Right" 
                   Margin="0,20,0,0">
                <Button Command="{Binding ClearRecordsCommand}"
                       Style="{DynamicResource SecondaryButtonStyle}"
                       helpers:ButtonHelper.ConfirmMessage="确定要清除所有记录吗？&#x0a;清除后将无法恢复提取的颜色和分析信息。"
                       helpers:ButtonHelper.ConfirmTitle="确认清除"
                       Padding="20,10"
                       Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="🗑️" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="清除记录"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding GenerateThemeCommand}"
                       Style="{DynamicResource PrimaryButtonStyle}"
                       Padding="20,10"
                       Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="✨" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="生成主题"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding AddThemeCommand}"
                       Style="{DynamicResource PrimaryButtonStyle}"
                       helpers:ButtonHelper.ConfirmMessage="确定要将生成的主题加入主题库吗？&#x0a;主题将保存到主题目录，可在「主题选择」中查看。"
                       helpers:ButtonHelper.ConfirmTitle="确认加入"
                       Padding="20,10">
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="📥" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="加入主题"/>
                    </StackPanel>
                </Button>
            </StackPanel>
    </Grid>
</UserControl>
