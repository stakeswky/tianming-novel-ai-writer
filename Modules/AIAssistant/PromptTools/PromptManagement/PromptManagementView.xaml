<UserControl x:Class="TM.Modules.AIAssistant.PromptTools.PromptManagement.PromptManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dm="clr-namespace:TM.Framework.Common.Controls.DataManagement"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout">

    <dm:TwoColumnEditorLayout
        LeftIcon="📚"
        LeftTitle="提示词管理"
        ItemsSource="{Binding TreeData}"
        ShowSearch="True"
        SearchKeyword="{Binding SearchKeyword, Mode=TwoWay}"
        NodeDoubleClickCommand="{Binding SelectNodeCommand}"
        AddCommand="{Binding AddCommand}"
        SaveCommand="{Binding SaveCommand}"
        DeleteCommand="{Binding DeleteCommand}"
        DeleteAllCommand="{Binding DeleteAllCommand}"
        TreeAfterActionCommand="{Binding TreeAfterActionCommand}"
        AIGenerateCommand="{Binding AIGenerateCommand}"
        IsAIGenerateEnabled="{Binding IsAIGenerateEnabled}"
        UseStandardScheme2Layout="True">

        <dm:TwoColumnEditorLayout.EditAdditionalContent>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <layout:IconHeaderGroupBox Grid.Row="0" Icon="✨" Title="Prompt正文" Margin="0,0,0,10">
                    <TextBox Text="{Binding FormSystemPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             Height="Auto" VerticalAlignment="Stretch"
                             BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Grid.Row="1" Icon="📝" Title="说明" Margin="0" MinHeight="100">
                    <TextBox Text="{Binding FormDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Height="Auto" VerticalAlignment="Stretch"
                             BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>

            </Grid>
        </dm:TwoColumnEditorLayout.EditAdditionalContent>

        <dm:TwoColumnEditorLayout.DetailsContent>
            <Border Background="{DynamicResource ContentBackground}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="⚙️"
                             FontSize="48"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,15"/>
                    <TextBlock Text="高级功能"
                             FontSize="16"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimary}"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,8"/>
                    <TextBlock Text="占位中，待构建"
                             FontSize="12"
                             Foreground="{DynamicResource TextSecondary}"
                             HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </dm:TwoColumnEditorLayout.DetailsContent>

    </dm:TwoColumnEditorLayout>

</UserControl>
