<UserControl x:Class="TM.Modules.AIAssistant.PromptTools.VersionTesting.VersionTestingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:dm="clr-namespace:TM.Framework.Common.Controls.DataManagement"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:forms="clr-namespace:TM.Framework.Common.Controls.Forms"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:local="clr-namespace:TM.Modules.AIAssistant.PromptTools.VersionTesting"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200">

    <dm:TwoColumnEditorLayout x:Name="EditorLayout"
        LeftIcon="🧪"
        LeftTitle="测试版本"
        RightIcon="📊"
        RightTitle="测试"
        ShowSearch="True"
        SearchKeyword="{Binding SearchKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
        SearchPlaceholder="搜索测试版本..."
        ItemsSource="{Binding TreeData}"
        ParentClickMode="Toggle"
        MaxLevel="5"
        ShowActionButtons="False"
        EnableContentActions="False"
        ShowAIGenerateButton="False"
        NodeDoubleClickCommand="{Binding TreeNodeSelectedCommand}"
        UseStandardScheme2Layout="False"
        SelectedHeaderTabIndex="1">

        <dm:TwoColumnEditorLayout.DetailsContent>
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="5*"/>
                </Grid.RowDefinitions>

                <layout:IconHeaderGroupBox Grid.Row="0" Icon="⚙️" Title="测试配置">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <emoji:TextBlock Text="💡" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="快捷模板"
                                               Style="{DynamicResource StandardTextStyle}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding QuickTemplateOptions}"
                                          SelectedItem="{Binding SelectedQuickTemplate, Mode=TwoWay}"
                                          Style="{DynamicResource StandardComboBoxStyle}"
                                          Height="32"
                                          Margin="20,0,0,0"
                                          HorizontalAlignment="Left"
                                          MinWidth="220"
                                          VerticalAlignment="Center"/>
                            </Grid>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,5">
                                <emoji:TextBlock Text="🧾" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="测试输入要求"
                                           Style="{DynamicResource StandardTextStyle}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                            <TextBox Grid.Row="3"
                                     Text="{Binding TestInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource StandardTextBoxStyle}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     MinHeight="70"
                                     Margin="0,0,0,4"/>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Button Grid.Row="0" Content="▶ 执行测试"
                                    Command="{Binding ExecuteTestCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    Height="40"
                                    Margin="0,0,0,8"
                                    HorizontalAlignment="Stretch"/>

                            <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8"
                                    Background="{DynamicResource Surface}"
                                    VerticalAlignment="Stretch">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                        <emoji:TextBlock Text="📊" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="动态评分"
                                                   Style="{DynamicResource StandardTextStyle}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <Grid Grid.Row="1" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="45"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="创意性" Style="{DynamicResource StandardTextStyle}" FontSize="12"/>
                                        <ProgressBar Grid.Column="1" Value="{Binding CreativityScore}" Maximum="100" Height="6" Margin="5,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding CreativityScore, StringFormat={}{0}%}" Style="{DynamicResource StandardTextStyle}" FontSize="12" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid Grid.Row="2" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="45"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="连贯性" Style="{DynamicResource StandardTextStyle}" FontSize="12"/>
                                        <ProgressBar Grid.Column="1" Value="{Binding CoherenceScore}" Maximum="100" Height="6" Margin="5,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding CoherenceScore, StringFormat={}{0}%}" Style="{DynamicResource StandardTextStyle}" FontSize="12" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid Grid.Row="3" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="45"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="逻辑性" Style="{DynamicResource StandardTextStyle}" FontSize="12"/>
                                        <ProgressBar Grid.Column="1" Value="{Binding LogicScore}" Maximum="100" Height="6" Margin="5,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding LogicScore, StringFormat={}{0}%}" Style="{DynamicResource StandardTextStyle}" FontSize="12" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid Grid.Row="4" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="45"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="情感度" Style="{DynamicResource StandardTextStyle}" FontSize="12"/>
                                        <ProgressBar Grid.Column="1" Value="{Binding EmotionScore}" Maximum="100" Height="6" Margin="5,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding EmotionScore, StringFormat={}{0}%}" Style="{DynamicResource StandardTextStyle}" FontSize="12" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid Grid.Row="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="综合得分: " Style="{DynamicResource StandardTextStyle}" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalScore, StringFormat={}{0:F2}分}" Style="{DynamicResource StandardTextStyle}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryColor}" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Grid.Row="2" Icon="🔄" Title="版本对比">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <emoji:TextBlock Text="📂" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="分类A" Style="{DynamicResource StandardTextStyle}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="{DynamicResource Surface}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding SelectedPromptA.Name, TargetNullValue=未选择提示词}"
                                               Style="{DynamicResource StandardTextStyle}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                            </Grid>
                            <ComboBox Grid.Row="1" 
                                      ItemsSource="{Binding CategoryATree}"
                                      Style="{StaticResource TreeComboBoxStyle}"
                                      Height="36"
                                      Margin="0,0,0,8"
                                      HorizontalAlignment="Stretch"
                                      IsDropDownOpen="{Binding IsCategoryADropdownOpen, Mode=TwoWay}"
                                      helpers:ComboBoxHelper.SelectedPath="{Binding SelectedCategoryAPath, Mode=TwoWay}"
                                      helpers:ComboBoxHelper.DisplayIcon="{Binding SelectedCategoryAIcon, Mode=TwoWay}"
                                      helpers:ComboBoxHelper.MaxLevel="5"
                                      helpers:ComboBoxHelper.NodeDoubleClickCommand="{Binding CategoryASelectCommand}"/>

                            <Grid Grid.Row="3">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <emoji:TextBlock Text="📄" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="实际输出内容" Style="{DynamicResource StandardTextStyle}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                                            <emoji:TextBlock Text="📊" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="字数:" Style="{DynamicResource StandardTextStyle}" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding OutputAWordCount, Mode=OneWay}" Style="{DynamicResource StandardTextStyle}" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="3,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <emoji:TextBlock Text="⏱️" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="耗时:" Style="{DynamicResource StandardTextStyle}" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding OutputADuration, Mode=OneWay}" Style="{DynamicResource StandardTextStyle}" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="3,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <TextBox Grid.Row="1"
                                         Text="{Binding OutputAContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource StandardTextBoxStyle}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         MinHeight="340"/>
                            </Grid>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <emoji:TextBlock Text="🗂️" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="分类B" Style="{DynamicResource StandardTextStyle}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="{DynamicResource Surface}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding SelectedPromptB.Name}"
                                               Style="{DynamicResource StandardTextStyle}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                            </Grid>
                            <ComboBox Grid.Row="1"
                                      ItemsSource="{Binding CategoryBTree}"
                                      Style="{StaticResource TreeComboBoxStyle}"
                                      Height="36"
                                      Margin="0,0,0,8"
                                      HorizontalAlignment="Stretch"
                                      IsDropDownOpen="{Binding IsCategoryBDropdownOpen, Mode=TwoWay}"
                                      helpers:ComboBoxHelper.SelectedPath="{Binding SelectedCategoryBPath, Mode=TwoWay}"
                                      helpers:ComboBoxHelper.DisplayIcon="{Binding SelectedCategoryBIcon, Mode=TwoWay}"
                                      helpers:ComboBoxHelper.MaxLevel="5"
                                      helpers:ComboBoxHelper.NodeDoubleClickCommand="{Binding CategoryBSelectCommand}"/>

                            <Grid Grid.Row="3">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <emoji:TextBlock Text="📄" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="实际输出内容" Style="{DynamicResource StandardTextStyle}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                                            <emoji:TextBlock Text="📊" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="字数:" Style="{DynamicResource StandardTextStyle}" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding OutputBWordCount, Mode=OneWay}" Style="{DynamicResource StandardTextStyle}" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="3,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <emoji:TextBlock Text="⏱️" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="耗时:" Style="{DynamicResource StandardTextStyle}" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding OutputBDuration, Mode=OneWay}" Style="{DynamicResource StandardTextStyle}" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="3,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <TextBox Grid.Row="1"
                                         Text="{Binding OutputBContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource StandardTextBoxStyle}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         MinHeight="340"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </layout:IconHeaderGroupBox>
            </Grid>
        </dm:TwoColumnEditorLayout.DetailsContent>
    </dm:TwoColumnEditorLayout>
</UserControl>
