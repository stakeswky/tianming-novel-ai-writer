<UserControl x:Class="TM.Modules.AIAssistant.ModelIntegration.ModelManagement.ModelManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dm="clr-namespace:TM.Framework.Common.Controls.DataManagement"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:helpers="clr-namespace:TM.Framework.Common.Helpers.UI"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <dm:TwoColumnEditorLayout
        x:Name="RootLayout"
        LeftTitle="模型管理"
        IsEditAreaEnabled="{Binding IsTab1Enabled}"
        ItemsSource="{Binding TreeData}"
        ShowSearch="True"
        SearchKeyword="{Binding SearchKeyword, Mode=TwoWay}"
        NodeDoubleClickCommand="{Binding SelectNodeCommand}"
        AddCommand="{Binding AddCommand}"
        SaveCommand="{Binding SaveCommand}"
        DeleteCommand="{Binding DeleteCommand}"
        DeleteAllCommand="{Binding DeleteAllCommand}"
        TreeAfterActionCommand="{Binding TreeAfterActionCommand}"
        AIGenerateCommand="{Binding AIGenerateCommand}"
        IsAIGenerateEnabled="False"
        ShowAIGenerateButton="True"
        UseStandardScheme2Layout="True"
        Tab3Header="全局配置">

        <dm:TwoColumnEditorLayout.EditAdditionalContent>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <layout:IconHeaderGroupBox Grid.Row="0" Icon="🔌" Title="API配置" Margin="0,0,0,10"
                                          IsEnabled="{Binding IsApiConfigEditable}">
                    <StackPanel>
                        <TextBlock Text="API端点" Margin="0,0,0,3"
                                  Foreground="{DynamicResource TextPrimary}"/>
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="4"
                               Background="{DynamicResource Surface}"
                               Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                        Text="{Binding FormApiEndpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        BorderThickness="0"
                                        Padding="8,0"/>
                                <Border Grid.Column="1" 
                                        Width="32"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding ShowEndpointVerificationStatus, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ToolTip="{Binding EndpointVerificationTooltip}">
                                    <emoji:TextBlock Text="{Binding EndpointVerificationIcon}" FontSize="14" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Margin="0,0,0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="API密钥"
                                      Foreground="{DynamicResource TextPrimary}"
                                      VerticalAlignment="Center"/>
                            <Button Grid.Column="2"
                                   Command="{Binding OpenApiKeyManagerCommand}"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   Padding="4,2"
                                   Cursor="Hand"
                                   ToolTip="管理 API 密钥">
                                <StackPanel Orientation="Horizontal">
                                    <emoji:TextBlock Text="⚙️" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text=" 增加轮询key" FontSize="12"
                                              Foreground="{DynamicResource TextTertiary}"
                                              VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="4"
                               Background="{DynamicResource Surface}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <PasswordBox Grid.Column="0"
                                            Loaded="ApiKeyBox_Loaded"
                                            PasswordChanged="ApiKeyBox_PasswordChanged"
                                            BorderThickness="0"
                                            Padding="8,0"
                                            Visibility="{Binding IsApiKeyVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                                <TextBox Grid.Column="0"
                                        Text="{Binding FormApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        BorderThickness="0"
                                        Padding="8,0"
                                        Visibility="{Binding IsApiKeyVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <Button Grid.Column="1"
                                       Command="{Binding ToggleApiKeyVisibilityCommand}"
                                       Width="32"
                                       Height="32"
                                       Margin="0,0,2,0"
                                       Background="Transparent"
                                       BorderThickness="0"
                                       Cursor="Hand"
                                       ToolTip="显示/隐藏密钥">
                                    <emoji:TextBlock Text="{Binding ApiKeyVisibilityIcon}" FontSize="14"/>
                                </Button>
                            </Grid>
                        </Border>
                    </StackPanel>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Grid.Row="1" Icon="📦" Title="模型获取方式" Margin="0,0,0,10"
                                          IsEnabled="{Binding IsApiConfigEditable}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="1" 
                                    Command="{Binding TestApiConnectionCommand}"
                                    Height="36"
                                    Padding="12,0"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <emoji:TextBlock Text="🔗" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="测试API连接" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <RadioButton IsChecked="{Binding IsAutoFetchMode}" Margin="0,0,0,8">
                                    <TextBlock Text="自动获取端点内所有模型" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                </RadioButton>
                                <Button Command="{Binding FetchModelsCommand}" HorizontalAlignment="Stretch" Height="36">
                                    <StackPanel Orientation="Horizontal">
                                        <emoji:TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="获取可用模型列表" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <RadioButton IsChecked="{Binding IsManualInputMode}" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="手动获取输入指定模型" FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextPrimary}"/>
                                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                                            <emoji:TextBlock Text="💡" FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                            <TextBlock Text="例如: gpt-4o" FontSize="11"
                                                      Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                            Text="{Binding ManualModelName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Margin="0,0,10,0" VerticalContentAlignment="Center" Height="36"
                                            IsEnabled="{Binding IsManualInputMode}"/>
                                    <Button Grid.Column="1"
                                           Command="{Binding FetchManualModelCommand}" Height="36"
                                           Padding="12,6" MinWidth="88" HorizontalContentAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <emoji:TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="获取" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <emoji:TextBlock Text="ℹ️" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="若 Chat 端点测试失败，可在下方选择已获取的模型或手动输入模型名称进行重试" FontSize="12"
                                      Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <RadioButton IsChecked="{Binding IsAutoRetryMode}" Margin="0,0,0,8">
                                    <TextBlock Text="获取模型重试" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                </RadioButton>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                             ItemsSource="{Binding ChatRetryModels}"
                                             SelectedItem="{Binding SelectedChatRetryModel, Mode=TwoWay}"
                                             DisplayMemberPath="Id"
                                             IsEnabled="{Binding IsAutoRetryDropdownEnabled}"
                                             Margin="0,0,10,0" VerticalContentAlignment="Center" Height="36"/>
                                    <Button Grid.Column="1"
                                           Command="{Binding RetryWithDropdownCommand}" Height="36"
                                           Padding="12,6" MinWidth="88" HorizontalContentAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <emoji:TextBlock Text="🔄" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="重试" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <RadioButton IsChecked="{Binding IsManualRetryMode}" Margin="0,0,0,8">
                                    <TextBlock Text="指定模型重试" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                </RadioButton>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                            Text="{Binding RetryManualModelName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Margin="0,0,10,0" VerticalContentAlignment="Center" Height="36"
                                            IsEnabled="{Binding IsManualRetryInputEnabled}"/>
                                    <Button Grid.Column="1"
                                           Command="{Binding RetryWithManualCommand}" Height="36"
                                           Padding="12,6" MinWidth="88" HorizontalContentAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <emoji:TextBlock Text="🔄" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="重试" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Grid.Row="2" Icon="📝" Title="描述" Margin="0">
                    <TextBox Text="{Binding FormDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"
                            Height="Auto" VerticalAlignment="Stretch"
                            BorderThickness="0" Background="Transparent"/>
                </layout:IconHeaderGroupBox>

            </Grid>
        </dm:TwoColumnEditorLayout.EditAdditionalContent>

        <dm:TwoColumnEditorLayout.DetailsContent>
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          IsEnabled="{Binding IsTab2Enabled}">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel Margin="0">
                    <layout:IconHeaderGroupBox Icon="🎚️" Title="参数调整" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Temperature（随机性）" Margin="0,0,0,5"
                                      Foreground="{DynamicResource TextPrimary}"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0"
                                       Value="{Binding FormTemperature}"
                                       Minimum="0" Maximum="2"
                                       TickFrequency="0.1"
                                       IsSnapToTickEnabled="True"
                                       VerticalAlignment="Center"
                                       Margin="0,0,15,0"/>
                                <TextBox Grid.Column="1"
                                        Text="{Binding FormTemperature, Mode=TwoWay, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="Top P（核采样）" Margin="0,0,0,5"
                                      Foreground="{DynamicResource TextPrimary}"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0"
                                       Value="{Binding FormTopP}"
                                       Minimum="0" Maximum="1"
                                       TickFrequency="0.05"
                                       IsSnapToTickEnabled="True"
                                       VerticalAlignment="Center"
                                       Margin="0,0,15,0"/>
                                <TextBox Grid.Column="1"
                                        Text="{Binding FormTopP, Mode=TwoWay, StringFormat={}{0:F2}, UpdateSourceTrigger=PropertyChanged}"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="频率惩罚（Frequency Penalty）" Margin="0,0,0,5"
                                      Foreground="{DynamicResource TextPrimary}"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0"
                                       Value="{Binding FormFrequencyPenalty}"
                                       Minimum="-2" Maximum="2"
                                       TickFrequency="0.1"
                                       IsSnapToTickEnabled="True"
                                       VerticalAlignment="Center"
                                       Margin="0,0,15,0"/>
                                <TextBox Grid.Column="1"
                                        Text="{Binding FormFrequencyPenalty, Mode=TwoWay, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="存在惩罚（Presence Penalty）" Margin="0,0,0,5"
                                      Foreground="{DynamicResource TextPrimary}"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0"
                                       Value="{Binding FormPresencePenalty}"
                                       Minimum="-2" Maximum="2"
                                       TickFrequency="0.1"
                                       IsSnapToTickEnabled="True"
                                       VerticalAlignment="Center"
                                       Margin="0,0,15,0"/>
                                <TextBox Grid.Column="1"
                                        Text="{Binding FormPresencePenalty, Mode=TwoWay, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Center"/>
                            </Grid>

                            <UniformGrid Columns="4" HorizontalAlignment="Stretch" Margin="0,0,0,0">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="随机种子" Margin="0,0,0,5"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox Text="{Binding FormSeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="停止序列" Margin="0,0,0,5"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox Text="{Binding FormStopSequences, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="重试次数" Margin="0,0,0,5"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox Text="{Binding FormRetryCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel>
                                    <TextBlock Text="超时时间（秒）" Margin="0,0,0,5"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox Text="{Binding FormTimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </layout:IconHeaderGroupBox>

                    <layout:IconHeaderGroupBox Icon="⚡" Title="速率限制" Margin="0,0,0,5">
                        <StackPanel>
                            <UniformGrid Columns="4" HorizontalAlignment="Stretch" Margin="0">
                                <StackPanel Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <emoji:TextBlock Text="📊" FontSize="12" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <TextBlock Text="最大Token数" FontSize="12"
                                                  Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBox Text="{Binding FormMaxTokens, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <emoji:TextBlock Text="🕐" FontSize="12" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <TextBlock Text="每分钟请求数上限" FontSize="12"
                                                  Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBox Text="{Binding FormRateLimitRPM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <emoji:TextBlock Text="📅" FontSize="12" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <TextBlock Text="每分钟令牌数上限" FontSize="12"
                                                  Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBox Text="{Binding FormRateLimitTPM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <emoji:TextBlock Text="🔀" FontSize="12" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                        <TextBlock Text="最大并发请求数" FontSize="12"
                                                  Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBox Text="{Binding FormMaxConcurrency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </UniformGrid>

                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="💡" FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                <TextBlock Text="设置为 0 表示无限制，速率限制依据厂商政策建议不要过高" FontSize="11"
                                          Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </layout:IconHeaderGroupBox>

                    <CheckBox Content="启用流式输出" 
                             IsChecked="{Binding FormEnableStreaming}"
                             Margin="0,10,0,0"/>

                </StackPanel>
            </ScrollViewer>
        </dm:TwoColumnEditorLayout.DetailsContent>

        <dm:TwoColumnEditorLayout.Tab3Content>
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          IsEnabled="{Binding IsGlobalParametersAvailable}">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel Margin="0">
                    <layout:IconHeaderGroupBox Icon="⚙️" Title="全局参数模板" Margin="0,0,0,10">
                        <UniformGrid Columns="2" HorizontalAlignment="Stretch">
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="当前供应商" Margin="0,0,0,5" FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextPrimary}"/>
                                <TextBox Text="{Binding CurrentProviderName, Mode=OneWay}"
                                         IsReadOnly="True"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="默认参数模板" Margin="0,0,0,5" FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextPrimary}"/>
                                <ComboBox ItemsSource="{Binding ParameterProfiles}"
                                          SelectedValue="{Binding SelectedProfileId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          IsEnabled="{Binding HasCurrentProvider}"/>
                            </StackPanel>
                        </UniformGrid>
                    </layout:IconHeaderGroupBox>

                    <layout:IconHeaderGroupBox Icon="📚" Title="模板参数配置" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="模板名称" Margin="0,0,0,5" FontWeight="SemiBold"
                                      Foreground="{DynamicResource TextPrimary}"/>
                            <TextBox Text="{Binding SelectedProfile.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding HasSelectedProfile}"
                                     Margin="0,0,0,10"/>

                            <UniformGrid Columns="4" HorizontalAlignment="Stretch" Margin="0,0,0,10"
                                         IsEnabled="{Binding HasSelectedProfile}">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="随机性" Margin="0,0,0,5"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox Text="{Binding SelectedProfile.Temperature, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="采样比例" Margin="0,0,0,5"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox Text="{Binding SelectedProfile.TopP, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="最大Token数" Margin="0,0,0,5"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox Text="{Binding SelectedProfile.MaxTokens, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel>
                                    <TextBlock Text="最大并发请求数" Margin="0,0,0,5"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox Text="{Binding SelectedProfile.MaxConcurrency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel Margin="0,10,10,0">
                                    <TextBlock Text="每分钟请求数上限" Margin="0,0,0,5"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox Text="{Binding SelectedProfile.RateLimitRPM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel Margin="0,10,10,0">
                                    <TextBlock Text="每分钟令牌数上限" Margin="0,0,0,5"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox Text="{Binding SelectedProfile.RateLimitTPM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel Margin="0,10,10,0">
                                    <TextBlock Text="重试次数" Margin="0,0,0,5"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox Text="{Binding SelectedProfile.RetryCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="超时时间（秒）" Margin="0,0,0,5"
                                              Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBox Text="{Binding SelectedProfile.TimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </UniformGrid>

                            <CheckBox Content="启用流式输出" 
                                      IsChecked="{Binding SelectedProfile.EnableStreaming, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding HasSelectedProfile}"
                                      Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Command="{Binding SaveProfilesCommand}" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <emoji:TextBlock Text="💾" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="保存模板更改" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding ApplyProfileToAllModelsCommand}"
                                        IsEnabled="{Binding HasCurrentProvider}">
                                    <StackPanel Orientation="Horizontal">
                                        <emoji:TextBlock Text="🌐" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="将模板应用到当前供应商全部模型" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </layout:IconHeaderGroupBox>

                    <layout:IconHeaderGroupBox Icon="📄" Title="当前模型参数（实际生效）" Margin="0">
                        <UniformGrid Columns="4" HorizontalAlignment="Stretch" Margin="0">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="随机性" Margin="0,0,0,3"
                                              Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Text="{Binding FormTemperature}"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="采样比例" Margin="0,0,0,3"
                                              Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Text="{Binding FormTopP}"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="最大Token数" Margin="0,0,0,3"
                                              Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Text="{Binding FormMaxTokens}"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>

                                <StackPanel>
                                    <TextBlock Text="最大并发请求数" Margin="0,0,0,3"
                                              Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Text="{Binding FormMaxConcurrency}"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>

                                <StackPanel Margin="0,10,10,0">
                                    <TextBlock Text="每分钟请求数上限" Margin="0,0,0,3"
                                              Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Text="{Binding FormRateLimitRPM}"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>

                                <StackPanel Margin="0,10,10,0">
                                    <TextBlock Text="每分钟令牌数上限" Margin="0,0,0,3"
                                              Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Text="{Binding FormRateLimitTPM}"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>

                                <StackPanel Margin="0,10,10,0">
                                    <TextBlock Text="重试次数" Margin="0,0,0,3"
                                              Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Text="{Binding FormRetryCount}"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>

                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="超时时间（秒）" Margin="0,0,0,3"
                                              Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Text="{Binding FormTimeoutSeconds}"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>
                        </UniformGrid>
                    </layout:IconHeaderGroupBox>

                </StackPanel>
            </ScrollViewer>
        </dm:TwoColumnEditorLayout.Tab3Content>

    </dm:TwoColumnEditorLayout>

</UserControl>
