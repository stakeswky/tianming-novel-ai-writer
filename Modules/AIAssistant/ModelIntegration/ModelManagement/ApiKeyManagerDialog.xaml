<Window x:Class="TM.Modules.AIAssistant.ModelIntegration.ModelManagement.ApiKeyManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Width="500"
        SizeToContent="Height"
        MaxHeight="660">

    <Border Background="{DynamicResource ContentBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    MinHeight="42"
                    Padding="16,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <emoji:TextBlock Text="🔑" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TitleText"
                                   Text="API 密钥管理"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryColor}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Click="ToggleShowAll_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="8,6"
                                Cursor="Hand"
                                ToolTip="一键显示/隐藏全部密钥明文">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <emoji:TextBlock x:Name="ToggleAllIcon" Text="🔒" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ToggleAllText"
                                           Text=" 一键显示"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondary}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Background="Transparent"
                                BorderThickness="0"
                                Padding="8,6"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Click="CloseButton_Click">
                            <TextBlock Text="✕" FontSize="13" Foreground="{DynamicResource TextSecondary}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="KeyListBorder" Grid.Row="1" Margin="16,12,16,0" MaxHeight="240">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="KeyList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,8"
                                        Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,0"
                                                  ToolTip="启用/禁用"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayKey}"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       FontFamily="Consolas"
                                                       FontSize="13"/>
                                            <TextBlock Text="{Binding Remark}"
                                                       Foreground="{DynamicResource TextTertiary}"
                                                       FontSize="11"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="8,0">
                                            <emoji:TextBlock Text="{Binding StatusIcon}" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding StatusText}" FontSize="11" Margin="3,0,0,0"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HealthStatus}" Value="RateLimited">
                                                                <Setter Property="Foreground" Value="{DynamicResource WarningColor}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="Foreground" Value="{DynamicResource DangerColor}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <Button Grid.Column="3"
                                                Tag="{Binding Id}"
                                                Click="DeleteKey_Click"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="4,2"
                                                Cursor="Hand"
                                                ToolTip="删除">
                                            <emoji:TextBlock Text="🗑️" FontSize="12"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2" Margin="16,8,16,0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="{DynamicResource Surface}">
                <Grid MinHeight="36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NewKeyInput"
                             Grid.Column="0"
                             BorderThickness="0"
                             Padding="10,8"
                             VerticalContentAlignment="Center"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimary}"
                             FontFamily="Consolas"
                             FontSize="13"
                             KeyDown="NewKeyInput_KeyDown"/>
                    <TextBlock Grid.Column="0"
                               Text="输入单条密钥，回车或点击添加"
                               Foreground="{DynamicResource TextTertiary}"
                               FontSize="12"
                               Padding="11,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=NewKeyInput}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Grid.Column="1"
                            Click="AddKey_Click"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Content="添加"
                            Padding="16,6"
                            Margin="4"
                            VerticalAlignment="Center"
                            FontSize="13"/>
                </Grid>
            </Border>

            <Border x:Name="BatchImportArea"
                    Grid.Row="3"
                    Margin="16,6,16,0"
                    BorderBrush="{DynamicResource PrimaryColor}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="{DynamicResource Surface}"
                    Height="108"
                    Visibility="Collapsed">
                <TextBox x:Name="BatchInput"
                         BorderThickness="0"
                         Padding="10,8"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Background="Transparent"
                         Foreground="{DynamicResource TextPrimary}"
                         FontFamily="Consolas"
                         FontSize="12"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="BatchInput_TextChanged">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Top">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="粘贴多条密钥，每行一个（支持行尾逗号）&#x0a;例：&#x0a;sk-XXXXXX，&#x0a;sk-cccccc，"
                                                               Foreground="{DynamicResource TextTertiary}"
                                                               FontSize="12"
                                                               Padding="10,8"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Border>

            <Grid Grid.Row="4" Margin="16,8,16,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatsText"
                           Grid.Column="0"
                           Foreground="{DynamicResource TextTertiary}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <Button x:Name="BatchImportBtn"
                        Grid.Column="1"
                        Click="BatchImportBtn_Click"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="14,6"
                        Margin="0,0,8,0"
                        FontSize="13">
                    <TextBlock x:Name="BatchImportBtnText" Text="一键导入"/>
                </Button>
                <Button Grid.Column="2"
                        Click="CloseButton_Click"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Content="确定"
                        Padding="20,6"
                        FontSize="13"/>
            </Grid>
        </Grid>
    </Border>
</Window>
