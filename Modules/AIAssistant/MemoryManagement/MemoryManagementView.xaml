<UserControl x:Class="TM.Modules.AIAssistant.MemoryManagement.MemoryManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:visibility="clr-namespace:TM.Framework.Common.Converters.Visibility"
             xmlns:local="clr-namespace:TM.Modules.AIAssistant.MemoryManagement">

    <UserControl.Resources>
        <visibility:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <visibility:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Surface}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <emoji:TextBlock Text="🧠" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text=" AI 结构化记忆"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>

                <Border Visibility="{Binding HasMemory, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                        Background="{DynamicResource ContentBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="24"
                        Margin="0,16">
                    <StackPanel HorizontalAlignment="Center">
                        <emoji:TextBlock Text="💭" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="当前会话暂无结构化记忆"
                                   FontSize="13" Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="与 AI 对话后，天命会自动从内容中提取角色、剧情等结构化信息"
                                   FontSize="11" Foreground="{DynamicResource TextTertiary}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <StackPanel Visibility="{Binding HasMemory, Converter={StaticResource BoolToVisibilityConverter}}">

                    <Border Background="{DynamicResource ContentBackground}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <emoji:TextBlock Text="👤" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text=" 角色状态" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding Characters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource Surface}"
                                                CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           VerticalAlignment="Top"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap">
                                                        <Run Text="位置: "/><Run Text="{Binding Location, FallbackValue='—'}"/>
                                                        <Run Text="  情绪: "/><Run Text="{Binding Emotion, FallbackValue='—'}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondary}"
                                                               Text="{Binding Goal, StringFormat='目标: {0}'}"
                                                               Visibility="{Binding Goal, Converter={StaticResource NullToVisibilityConverter}}"
                                                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="暂无角色信息"
                                       FontSize="11" Foreground="{DynamicResource TextTertiary}"
                                       Visibility="{Binding Characters.Count, Converter={StaticResource InverseCountToVisibilityConverter}}"
                                       Margin="0,4"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource ContentBackground}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12"
                            Visibility="{Binding PlotMilestones.Count, Converter={StaticResource CountToVisibilityConverter}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <emoji:TextBlock Text="📖" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text=" 剧情里程碑" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding PlotMilestones}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   TextWrapping="Wrap" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource ContentBackground}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12"
                            Visibility="{Binding ForeshadowingPending.Count, Converter={StaticResource CountToVisibilityConverter}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <emoji:TextBlock Text="🪝" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text=" 待回收伏笔" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding ForeshadowingPending}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   Foreground="{DynamicResource WarningColor}"
                                                   TextWrapping="Wrap" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource ContentBackground}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12"
                            Visibility="{Binding WorldRules.Count, Converter={StaticResource CountToVisibilityConverter}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <emoji:TextBlock Text="🌐" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text=" 世界规则" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding WorldRules}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   TextWrapping="Wrap" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource ContentBackground}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12"
                            Visibility="{Binding CurrentTask, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <emoji:TextBlock Text="✅" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text=" 当前任务" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding CurrentTask}" FontSize="11"
                                       Foreground="{DynamicResource InfoColor}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{DynamicResource Surface}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="刷新"
                        Command="{Binding RefreshCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="12,6" Margin="0,0,8,0"/>

                <Button Content="清空记忆"
                        Command="{Binding ClearMemoryCommand}"
                        Style="{DynamicResource DangerButtonStyle}"
                        Padding="12,6" Margin="0,0,8,0"/>

                <Button Padding="12,6">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Setter Property="Content" Value="AI 深度提取"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExtracting}" Value="True">
                                    <Setter Property="Content" Value="提取中…"/>
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Command>
                        <Binding Path="ExtractWithLLMCommand"/>
                    </Button.Command>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
