<Window x:Class="TM.Modules.Validate.ValidationSummary.ValidationResult.ChapterRepairDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        xmlns:feedback="clr-namespace:TM.Framework.Common.Controls.Feedback"
        xmlns:visConverters="clr-namespace:TM.Framework.Common.Converters.Visibility"
        xmlns:diffViewer="clr-namespace:TM.Framework.UI.Workspace.CenterPanel.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Width="800"
        Height="600">

    <Window.Resources>
        <visConverters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <visConverters:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" IsInverted="True"/>
    </Window.Resources>

    <Border Background="{DynamicResource ContentBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    Padding="16,7"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="🔧" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="章节修复 · " FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ChapterTitle}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="20" Height="20" Padding="0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource TextSecondary}"
                            FontSize="14" Content="✕"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1">

                <Grid Visibility="{Binding IsComparing, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource Surface}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,8" MaxHeight="90">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Problems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <emoji:TextBlock Text="⚠️" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock FontSize="12" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource WarningColor}"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding ModuleName, Mode=OneWay}" FontWeight="SemiBold"/>
                                                <Run Text="："/>
                                                <Run Text="{Binding Summary, Mode=OneWay}" Foreground="{DynamicResource TextPrimary}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="1">
                        <Border Padding="4">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding ChapterContent}"
                                           FontSize="13" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextPrimary}"
                                           Padding="8" LineHeight="22"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Visibility="{Binding IsComparing, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource Surface}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,6"
                            Visibility="{Binding HasConsistencyHint, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="ℹ️" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding ConsistencyHint}" FontSize="12"
                                       Foreground="{DynamicResource InfoColor}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <diffViewer:DiffViewer Grid.Row="1"
                                           DataContext="{Binding DiffViewModel}"/>
                </Grid>

            </Grid>

            <feedback:BusyOverlay Grid.Row="1" Grid.RowSpan="2"
                                  IsBusy="{Binding IsGenerating}"
                                  OverlayBackground="#66000000"
                                  OverlayCornerRadius="0,0,12,12"
                                  Panel.ZIndex="999">
                <feedback:BusyOverlay.OverlayContent>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <feedback:LoadingIndicator Width="56" Height="56"/>
                        <TextBlock Text="正在修复..."
                                   Margin="0,12,0,0"
                                   Foreground="White"
                                   FontSize="14"
                                   TextAlignment="Center"/>
                        <TextBlock Text="{Binding ProgressText}"
                                   Margin="0,6,0,0"
                                   Foreground="#DDDDDD"
                                   FontSize="12"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="400"/>
                        <Button Content="取消修复"
                                Margin="0,14,0,0"
                                Padding="18,8"
                                Command="{Binding CancelRepairCommand}"
                                Style="{DynamicResource DangerButtonStyle}"/>
                    </StackPanel>
                </feedback:BusyOverlay.OverlayContent>
            </feedback:BusyOverlay>

            <Border Grid.Row="2"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="16,8">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                Visibility="{Binding IsReading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button Content="Agent修复"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="16,6"
                                Command="{Binding RepairCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="关闭"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="12,6"
                                Click="CloseButton_Click"/>
                    </StackPanel>

                    <Grid Visibility="{Binding IsComparing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding DiffViewModel.DiffSummary}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="确认接受，保存"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    Padding="16,6"
                                    Command="{Binding ConfirmCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Content="放弃"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="12,6"
                                    Click="CloseButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
