<UserControl x:Class="TM.Modules.Validate.ValidationSummary.ValidationResult.ValidationResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dm="clr-namespace:TM.Framework.Common.Controls.DataManagement"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:visConverters="clr-namespace:TM.Framework.Common.Converters.Visibility">
    <UserControl.Resources>
        <visConverters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <dm:TwoColumnEditorLayout
        LeftIcon="📋"
        LeftTitle="校验汇总"
        RightIcon="📊"
        RightTitle="校验详情"
        ItemsSource="{Binding TreeData}"
        ShowSearch="True"
        SearchKeyword="{Binding SearchKeyword, Mode=TwoWay}"
        NodeDoubleClickCommand="{Binding SelectNodeCommand}"
        AddCommand="{Binding AddCommand}"
        SaveCommand="{Binding SaveCommand}"
        DeleteCommand="{Binding DeleteCommand}"
        DeleteAllCommand="{Binding DeleteAllCommand}"
        TreeAfterActionCommand="{Binding TreeAfterActionCommand}"
        ShowAIGenerateButton="True"
        AIGenerateCommand="{Binding AIGenerateCommand}"
        IsAIGenerateEnabled="{Binding IsAIGenerateEnabled}"
        UseStandardScheme2Layout="True">

        <dm:TwoColumnEditorLayout.EditAdditionalContent>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <layout:IconHeaderGroupBox Grid.Row="0" Icon="📋" Title="卷信息" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="卷号：" 
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,8,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" 
                                   Text="{Binding SelectedData.TargetVolumeNumber}" 
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,20,8"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="抽样章节：" 
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,8,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" 
                                   Text="{Binding SelectedData.SampledChapterCount}" 
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="最后校验：" 
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,8,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                   Text="{Binding SelectedData.LastValidatedTime, StringFormat=yyyy-MM-dd HH:mm}" 
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </Grid>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Grid.Row="1" Icon="📊" Title="校验统计" Margin="0,0,0,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="总体状态：" Foreground="{DynamicResource TextSecondary}" 
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <emoji:TextBlock Text="{Binding OverallResultIcon}" FontSize="18" 
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding SelectedData.OverallResult}" 
                                       FontWeight="SemiBold" FontSize="16"
                                       Foreground="{DynamicResource TextPrimary}" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="✅" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="通过：" Foreground="{DynamicResource TextSecondary}" 
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding PassedCount}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SuccessColor}" 
                                       VerticalAlignment="Center" Margin="0,0,20,0"/>

                            <emoji:TextBlock Text="⚠️" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="警告：" Foreground="{DynamicResource TextSecondary}" 
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding WarningCount}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource WarningColor}" 
                                       VerticalAlignment="Center" Margin="0,0,20,0"/>

                            <emoji:TextBlock Text="❌" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="失败：" Foreground="{DynamicResource TextSecondary}" 
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding FailedCount}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ErrorColor}" 
                                       VerticalAlignment="Center" Margin="0,0,20,0"/>

                            <emoji:TextBlock Text="⏳" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="未校验：" Foreground="{DynamicResource TextSecondary}" 
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding NotValidatedCount}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextTertiary}" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Grid.Row="2" Icon="📝" Title="规则明细" VerticalContentAlignment="Stretch">
                    <ListBox ItemsSource="{Binding SelectedData.ModuleResults}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}" 
                                        BorderThickness="0,0,0,1" Padding="8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <emoji:TextBlock Grid.Column="0" 
                                                         Text="{Binding ResultIcon}" 
                                                         FontSize="16" 
                                                         VerticalAlignment="Center" 
                                                         Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding DisplayName}" 
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding Result}" 
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </layout:IconHeaderGroupBox>
            </Grid>
        </dm:TwoColumnEditorLayout.EditAdditionalContent>

        <dm:TwoColumnEditorLayout.DetailsContent>
            <layout:IconHeaderGroupBox Icon="⚠️" Title="问题清单" VerticalContentAlignment="Stretch">
                <ListBox ItemsSource="{Binding ProblemItems}"
                         BorderThickness="0" Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderBrush}" 
                                    BorderThickness="0,0,0,1" Padding="8,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center">
                                        <Run Text="{Binding ModuleName, Mode=OneWay}" FontWeight="SemiBold"/>
                                        <Run Text="：" Foreground="{DynamicResource TextSecondary}"/>
                                        <Run Text="{Binding Summary, Mode=OneWay}"/>
                                        <Run Text="；" Foreground="{DynamicResource TextTertiary}"/>
                                        <Run Text="{Binding Reason, Mode=OneWay}" Foreground="{DynamicResource TextSecondary}"/>
                                    </TextBlock>
                                    <Button Grid.Column="1"
                                            Content="定位章节"
                                            Margin="8,0,0,0"
                                            Padding="8,4"
                                            FontSize="12"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Visibility="{Binding HasChapterLocation, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Command="{Binding DataContext.LocateChapterCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </layout:IconHeaderGroupBox>
        </dm:TwoColumnEditorLayout.DetailsContent>

    </dm:TwoColumnEditorLayout>
</UserControl>
