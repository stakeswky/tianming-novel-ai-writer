<UserControl x:Class="TM.Modules.Validate.ValidationIntro.WorldviewIntro.WorldviewIntroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <emoji:TextBlock Text="🌍" FontSize="32" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="世界观校验介绍" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="世界观校验用于确保小说中的世界设定保持一致性和合理性。包含以下三个校验项：" 
                       Foreground="{DynamicResource TextSecondary}" 
                       TextWrapping="Wrap" Margin="0,0,0,20" FontSize="14"/>

            <layout:IconHeaderGroupBox Icon="🔮" Title="世界观一致性" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="校验目的" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12">
                        检查小说中的世界观设定是否前后一致，包括物理法则、魔法体系、科技水平等核心设定是否存在矛盾。
                    </TextBlock>

                    <TextBlock Text="校验内容" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="• 物理法则：重力、时间流速、空间规则等基础设定" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="• 能力体系：魔法、异能、武功等能力系统的规则一致性" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="• 社会规则：政治制度、经济体系、文化习俗的合理性" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="⏰" Title="时空背景校验" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="校验目的" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12">
                        验证故事发生的时间线和空间背景是否合理，确保时代特征和地理环境描述的准确性。
                    </TextBlock>

                    <TextBlock Text="校验内容" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="• 时间线描述：历史事件、年代背景、季节变化的准确性" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="• 空间描述：地理位置、建筑风格、自然环境的合理性" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="• 时代特征：科技水平、社会风貌、生活方式的时代匹配度" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="👤" Title="实体资格审查" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="校验目的" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12">
                        审查故事中出现的实体（人物、物品、组织等）是否符合世界观设定，是否具备在该世界存在的资格。
                    </TextBlock>

                    <TextBlock Text="校验内容" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="• 时代准入检查：实体是否符合所处时代的科技/文化水平" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="• 能力兼容性：角色能力是否符合世界观的能力体系" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="• 设定一致性：实体属性是否与已建立的设定相符" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <Border Background="{DynamicResource InfoBackground}" 
                    BorderBrush="{DynamicResource InfoBorder}" 
                    BorderThickness="1" CornerRadius="6" Padding="15">
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="💡" FontSize="16" VerticalAlignment="Top" Margin="0,2,10,0"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}">
                        世界观校验结果可在「校验汇总 / 校验结果」页面查看。每次卷校验会自动执行所有校验项并生成汇总报告。
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
