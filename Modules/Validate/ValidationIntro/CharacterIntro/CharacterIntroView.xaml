<UserControl x:Class="TM.Modules.Validate.ValidationIntro.CharacterIntro.CharacterIntroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <emoji:TextBlock Text="👤" FontSize="32" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="角色校验介绍" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="角色校验用于确保小说中的角色设定保持一致性和合理性。包含以下校验项：" 
                       Foreground="{DynamicResource TextSecondary}" 
                       TextWrapping="Wrap" Margin="0,0,0,20" FontSize="14"/>

            <layout:IconHeaderGroupBox Icon="🎭" Title="角色一致性校验" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="校验目的" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12">
                        检查角色的性格、行为、语言风格是否前后一致，确保角色塑造的连贯性。
                    </TextBlock>

                    <TextBlock Text="校验内容" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="• 性格一致性：角色性格特征是否保持稳定" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="• 行为逻辑：角色行为是否符合其性格和动机" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="• 语言风格：对话是否符合角色身份和背景" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="📈" Title="角色弧光校验" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="校验目的" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12">
                        验证角色成长轨迹是否合理，确保角色变化有充分的铺垫和动机支撑。
                    </TextBlock>

                    <TextBlock Text="校验内容" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="• 成长合理性：角色变化是否有足够的事件驱动" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="• 目标达成：Want和Need的实现是否合理" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="• 缺陷克服：致命缺点的克服是否有说服力" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Icon="🔗" Title="角色关系校验" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="校验目的" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12">
                        审查角色之间的关系网络是否合理，互动是否符合既定关系。
                    </TextBlock>

                    <TextBlock Text="校验内容" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="• 关系一致性：角色关系是否前后一致" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="• 互动合理性：角色互动是否符合关系设定" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="• 情感变化：关系发展是否有合理的铺垫" 
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </layout:IconHeaderGroupBox>

            <Border Background="{DynamicResource InfoBackground}" 
                    BorderBrush="{DynamicResource InfoBorder}" 
                    BorderThickness="1" CornerRadius="6" Padding="15">
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="💡" FontSize="16" VerticalAlignment="Top" Margin="0,2,10,0"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}">
                        角色校验结果可在「校验汇总 / 校验结果」页面查看。
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
