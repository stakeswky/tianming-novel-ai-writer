<UserControl
    x:Class="TM.Modules.Generate.Elements.Blueprint.BlueprintView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dm="clr-namespace:TM.Framework.Common.Controls.DataManagement"
    xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
    xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">
<dm:TwoColumnEditorLayout
    LeftIcon="🎬"
    LeftTitle="蓝图列表"
    RightIcon="🎬"
    RightTitle="蓝图编辑"
    ItemsSource="{Binding TreeData}"
    ShowSearch="True"
    SearchKeyword="{Binding SearchKeyword, Mode=TwoWay}"
    NodeDoubleClickCommand="{Binding SelectNodeCommand}"
    AddCommand="{Binding AddCommand}"
    SaveCommand="{Binding SaveCommand}"
    DeleteCommand="{Binding DeleteCommand}"
    DeleteAllCommand="{Binding DeleteAllCommand}"
    TreeAfterActionCommand="{Binding TreeAfterActionCommand}"
    UseStandardScheme2Layout="True"
    Tab1Header="蓝图概览"
    Tab2Header="场景列表"
    Tab3Header="要素清单">

    <dm:TwoColumnEditorLayout.EditAdditionalContent>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="🔗" Title="关联章节ID" Margin="0,0,0,10">
                <ComboBox ItemsSource="{Binding AvailableChapterIds}"
                          Text="{Binding FormChapterId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Style="{DynamicResource StandardComboBoxStyle}" Height="36"
                          IsEditable="True"
                          ToolTip="选择章节ID（格式：vol{卷号}_ch{章号}）"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="📝" Title="本章结构一句话" Margin="0,0,0,10">
                <TextBox Text="{Binding FormOneLineStructure, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="📈" Title="节奏/强度曲线" Margin="0">
                <TextBox Text="{Binding FormPacingCurve, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.EditAdditionalContent>

    <dm:TwoColumnEditorLayout.DetailsContent>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="🎬" Title="场景基本信息" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="场景序号" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBox Text="{Binding FormSceneNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource StandardTextBoxStyle}" Height="36"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="场景标题" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBox Text="{Binding FormSceneTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource StandardTextBoxStyle}" Height="36"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="视角角色" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                        <ComboBox ItemsSource="{Binding AvailablePovCharacters}"
                                  SelectedItem="{Binding FormPovCharacter, Mode=TwoWay}"
                                  Style="{DynamicResource StandardComboBoxStyle}" Height="36"
                                  IsEditable="True"
                                  ToolTip="选择视角角色"/>
                    </StackPanel>
                </Grid>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="🎬" Title="起（开场）" Margin="0,0,0,10">
                <TextBox Text="{Binding FormOpening, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="📈" Title="承（发展）" Margin="0,0,0,10">
                <TextBox Text="{Binding FormDevelopment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="3" Icon="🔄" Title="转（转折）" Margin="0,0,0,10">
                <TextBox Text="{Binding FormTurning, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="4" Icon="🎯" Title="合（结尾）" Margin="0">
                <TextBox Text="{Binding FormEnding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.DetailsContent>

    <dm:TwoColumnEditorLayout.Tab3Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="👥" Title="出场角色" Margin="0,0,0,5">
                <TextBox Text="{Binding FormCast, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="📍" Title="涉及地点" Margin="0,0,0,5">
                <TextBox Text="{Binding FormLocations, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="🏛️" Title="涉及势力" Margin="0,0,0,5">
                <TextBox Text="{Binding FormFactions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="3" Icon="📝" Title="场景信息投放" Margin="0,0,0,5">
                <TextBox Text="{Binding FormInfoDrop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="4" Icon="🔑" Title="关键道具/线索" Margin="0">
                <TextBox Text="{Binding FormItemsClues, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.Tab3Content>

</dm:TwoColumnEditorLayout>
</UserControl>
