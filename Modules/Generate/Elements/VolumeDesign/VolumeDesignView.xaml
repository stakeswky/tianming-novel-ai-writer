<UserControl
    x:Class="TM.Modules.Generate.Elements.VolumeDesign.VolumeDesignView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dm="clr-namespace:TM.Framework.Common.Controls.DataManagement"
    xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
    xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">
<dm:TwoColumnEditorLayout
    LeftIcon="📚"
    LeftTitle="分卷列表"
    RightIcon="📚"
    RightTitle="分卷编辑"
    ItemsSource="{Binding TreeData}"
    ShowSearch="True"
    SearchKeyword="{Binding SearchKeyword, Mode=TwoWay}"
    NodeDoubleClickCommand="{Binding SelectNodeCommand}"
    AddCommand="{Binding AddCommand}"
    SaveCommand="{Binding SaveCommand}"
    DeleteCommand="{Binding DeleteCommand}"
    DeleteAllCommand="{Binding DeleteAllCommand}"
    TreeAfterActionCommand="{Binding TreeAfterActionCommand}"
    UseStandardScheme2Layout="True"
    Tab1Header="卷定位"
    Tab2Header="关键节点"
    Tab3Header="章节分配"
    Tab4Header="出场实体">

    <dm:TwoColumnEditorLayout.EditAdditionalContent>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="📌" Title="卷基本信息" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="7*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="卷序号" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBox Text="{Binding FormVolumeNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource StandardTextBoxStyle}" Height="36"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="卷标题" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBox Text="{Binding FormVolumeTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource StandardTextBoxStyle}" Height="36"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="起始章节" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBox Text="{Binding FormStartChapter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource StandardTextBoxStyle}" Height="36"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="结束章节" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBox Text="{Binding FormEndChapter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource StandardTextBoxStyle}" Height="36"/>
                    </StackPanel>
                </Grid>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="🎭" Title="卷主题" Margin="0,0,0,10">
                <TextBox Text="{Binding FormVolumeTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="🎯" Title="卷阶段目标" Margin="0,0,0,10">
                <TextBox Text="{Binding FormStageGoal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="3" Icon="🧮" Title="预计字数" Margin="0">
                <TextBox Text="{Binding FormEstimatedWordCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.EditAdditionalContent>

    <dm:TwoColumnEditorLayout.DetailsContent>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="⚔️" Title="卷主冲突" Margin="0,0,0,10">
                <TextBox Text="{Binding FormMainConflict, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="🚫" Title="对抗源/压力来源" Margin="0,0,0,10">
                <TextBox Text="{Binding FormPressureSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="🔄" Title="关键转折/大事件" Margin="0,0,0,10">
                <TextBox Text="{Binding FormKeyEvents, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="3" Icon="🌅" Title="卷开篇状态" Margin="0,0,0,10">
                <TextBox Text="{Binding FormOpeningState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="4" Icon="🏁" Title="卷收束状态" Margin="0">
                <TextBox Text="{Binding FormEndingState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.DetailsContent>

    <dm:TwoColumnEditorLayout.Tab3Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="📊" Title="章节分配总览" Margin="0,0,0,10">
                <TextBox Text="{Binding FormChapterAllocationOverview, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="🧩" Title="剧情分配（结构化）" Margin="0,0,0,10">
                <TextBox Text="{Binding FormPlotAllocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="💡" Title="章节生成提示" Margin="0">
                <TextBox Text="{Binding FormChapterGenerationHints, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.Tab3Content>

    <dm:TwoColumnEditorLayout.Tab4Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="👤" Title="出场角色" Margin="0,0,0,10">
                <TextBox Text="{Binding FormReferencedCharacterNames, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="🏛️" Title="涉及势力" Margin="0,0,0,10">
                <TextBox Text="{Binding FormReferencedFactionNames, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="📍" Title="涉及地点" Margin="0">
                <TextBox Text="{Binding FormReferencedLocationNames, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.Tab4Content>

</dm:TwoColumnEditorLayout>
</UserControl>
