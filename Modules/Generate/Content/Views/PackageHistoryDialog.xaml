<Window x:Class="TM.Modules.Generate.Content.Views.PackageHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        Title="打包历史"
        Width="650"
        Height="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44"
                      CornerRadius="12"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <Border Style="{DynamicResource StandardDialogBorderStyle}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource StandardDialogTitleBarStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <emoji:TextBlock Text="📜" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="打包历史" Style="{DynamicResource StandardDialogTitleTextStyle}"/>
                    </StackPanel>

                    <Button Grid.Column="1" 
                            Click="Close_Click" 
                            Style="{DynamicResource StandardDialogCloseButtonStyle}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" 
                        Background="{DynamicResource Surface}"
                        CornerRadius="8"
                        Padding="16,12"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="历史版本记录"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="保留次数："
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <ComboBox x:Name="RetainCountComboBox"
                                      Width="70"
                                      SelectedIndex="4"
                                      SelectionChanged="RetainCountComboBox_SelectionChanged">
                                <ComboBoxItem Content="1" />
                                <ComboBoxItem Content="2" />
                                <ComboBoxItem Content="3" />
                                <ComboBoxItem Content="4" />
                                <ComboBoxItem Content="5" />
                                <ComboBoxItem Content="6" />
                                <ComboBoxItem Content="7" />
                                <ComboBoxItem Content="8" />
                                <ComboBoxItem Content="9" />
                                <ComboBoxItem Content="10" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{DynamicResource ContentBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <ListBox x:Name="HistoryListBox"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectionChanged="HistoryListBox_SelectionChanged"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.ScrollUnit="Pixel"
                             ScrollViewer.CanContentScroll="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16,12"
                                        Background="Transparent"
                                        CornerRadius="6"
                                        Margin="4,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource HoverBackground}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}">
                                                    <Run Text="版本 " />
                                                    <Run Text="{Binding Version}" />
                                                </TextBlock>
                                                <TextBlock Text="✓当前"
                                                           Foreground="{DynamicResource SuccessColor}"
                                                           FontWeight="Medium"
                                                           Margin="8,0,0,0"
                                                           Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </StackPanel>

                                            <TextBlock Text="{Binding PublishTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="12"
                                                       Margin="0,4,0,0" />

                                            <TextBlock Text="{Binding EnabledSummary}"
                                                       Foreground="{DynamicResource TextTertiary}"
                                                       FontSize="12"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding IsCurrent, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                            <Button Content="查看差异"
                                                    Style="{DynamicResource SecondaryButtonStyle}"
                                                    Padding="12,6"
                                                    Margin="0,0,8,0"
                                                    Tag="{Binding Version}"
                                                    Click="ViewDiff_Click" />
                                            <Button Content="恢复此版本"
                                                    Style="{DynamicResource PrimaryButtonStyle}"
                                                    Padding="12,6"
                                                    Tag="{Binding Version}"
                                                    Click="Restore_Click" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <StackPanel Grid.Row="2" Style="{DynamicResource StandardDialogFooterStyle}">
                    <Button Content="关闭"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="24,8"
                            MinWidth="80"
                            Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
