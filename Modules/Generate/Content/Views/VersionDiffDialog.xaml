<Window x:Class="TM.Modules.Generate.Content.Views.VersionDiffDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        Title="版本差异对比"
        Width="550"
        Height="450"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44"
                      CornerRadius="12"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <Border Style="{DynamicResource StandardDialogBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource StandardDialogTitleBarStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <emoji:TextBlock Text="📊" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="版本差异对比" Style="{DynamicResource StandardDialogTitleTextStyle}"/>
                    </StackPanel>

                    <Button Grid.Column="1" 
                            Click="Close_Click" 
                            Style="{DynamicResource StandardDialogCloseButtonStyle}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="VersionCompareText"
                           Grid.Row="0"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"
                           Margin="0,0,0,12" />

                <Border Grid.Row="1"
                        Background="{DynamicResource ContentBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="DiffItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}">
                                                    <Run Text="{Binding DisplayName}" />
                                                </TextBlock>
                                                <Border Margin="8,0,0,0"
                                                        Padding="6,2"
                                                        CornerRadius="4"
                                                        Background="{DynamicResource WarningColor}">
                                                    <TextBlock Text="状态变更"
                                                               FontSize="11"
                                                               Foreground="White" />
                                                </Border>
                                            </StackPanel>

                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="当前版本"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextTertiary}" />
                                                    <TextBlock Text="{Binding CurrentState}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource SuccessColor}"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="1"
                                                           Text="←"
                                                           FontSize="16"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0" />

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="历史版本"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextTertiary}" />
                                                    <TextBlock Text="{Binding HistoryState}"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <StackPanel Grid.Row="2" Style="{DynamicResource StandardDialogFooterStyle}">
                    <Button Content="关闭"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="24,8"
                            MinWidth="80"
                            Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
