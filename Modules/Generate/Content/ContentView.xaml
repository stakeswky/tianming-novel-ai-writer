<UserControl x:Class="TM.Modules.Generate.Content.ContentView"
             x:Name="RootControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TM.Modules.Generate.Content"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:common="clr-namespace:TM.Framework.Common.Controls.Layout">

    <UserControl.Resources>
        <DataTemplate x:Key="ModuleCardTemplate">
            <Border BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="6"
                    Cursor="Hand"
                    ClipToBounds="True">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource Surface}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                <Setter Property="Background" Value="#F5F5F5" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" 
                                  Command="{Binding DataContext.NavigateToModuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding ModulePath}" />
                </Border.InputBindings>

                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="🔄 刷新状态"
                                  Command="{Binding DataContext.RefreshModuleCommand, Source={x:Reference Name=RootControl}}"
                                  CommandParameter="{Binding}" />
                        <MenuItem Header="📂 跳转到模块"
                                  Command="{Binding DataContext.NavigateToModuleCommand, Source={x:Reference Name=RootControl}}"
                                  CommandParameter="{Binding ModulePath}" />
                    </ContextMenu>
                </Border.ContextMenu>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="8,0,0,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2196F3" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ModuleType}" Value="Generate">
                                        <Setter Property="Background" Value="#FF9800" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <Grid Grid.Column="1" Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <emoji:TextBlock Text="{Binding Icon}"
                                             FontSize="18"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0" />
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center" />
                            <Border CornerRadius="4" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E3F2FD" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ModuleType}" Value="Generate">
                                                <Setter Property="Background" Value="#FFF3E0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="设计" />
                                            <Setter Property="Foreground" Value="#1976D2" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ModuleType}" Value="Generate">
                                                    <Setter Property="Text" Value="生成" />
                                                    <Setter Property="Foreground" Value="#F57C00" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding ItemCountText}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="13"
                                   Margin="0,6,0,0" />

                        <TextBlock Grid.Row="2"
                                   Text="{Binding StatusText}"
                                   FontSize="13"
                                   Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessColor}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasChanges}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource WarningColor}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="状态"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />

                            <Border CornerRadius="4"
                                    Padding="12,6"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="OnStatusLabelClick"
                                    Tag="{Binding}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E8F5E9" />
                                        <Setter Property="BorderBrush" Value="#4CAF50" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                <Setter Property="Background" Value="#FFEBEE" />
                                                <Setter Property="BorderBrush" Value="#EF5350" />
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderThickness" Value="2" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="14" FontWeight="Medium" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="● 已启用" />
                                            <Setter Property="Foreground" Value="#2E7D32" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="Text" Value="● 已禁用" />
                                                    <Setter Property="Foreground" Value="#C62828" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                        <Setter Property="IsEnabled" Value="False" />
                        <Setter Property="Opacity" Value="0.6" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding ModuleGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <common:IconHeaderGroupBox Icon="{Binding Icon}"
                                                       Title="{Binding DisplayName}"
                                                       ShowCount="True"
                                                       Count="{Binding EnabledCount}"
                                                       Margin="0,0,0,16">
                                <ItemsControl ItemsSource="{Binding Cards}"
                                              ItemTemplate="{StaticResource ModuleCardTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </common:IconHeaderGroupBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <common:IconHeaderGroupBox Icon="📊" Title="状态汇总" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{Binding StatusSummary}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,0,0,4" />

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Foreground="{DynamicResource TextSecondary}">
                                <Run Text="变更项：" />
                                <Run Text="{Binding ChangedCount, Mode=OneWay}" />
                                <Run Text="项" />
                            </TextBlock>
                            <TextBlock Text="，建议重新打包"
                                       Foreground="{DynamicResource WarningColor}"
                                       Visibility="{Binding ChangedCount, Converter={StaticResource CountToVisibilityConverter}}" />
                        </StackPanel>

                        <TextBlock Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0">
                            <Run Text="上次打包：" />
                            <Run Text="{Binding LastPublishTime, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </common:IconHeaderGroupBox>

                <StackPanel HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                        <Button Command="{Binding ClearPackageCommand}"
                                Style="{DynamicResource DangerButtonStyle}"
                                Padding="16,8"
                                Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="🗑" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="清除打包" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding PublishCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="🔄" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="重新打包" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                        <Button Command="{Binding ShowHistoryCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="16,8"
                                Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="📜" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="打包历史" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding RefreshCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="🔃" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="刷新状态" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                        <Button Command="{Binding GlobalCleanupCommand}"
                                Style="{DynamicResource DangerButtonStyle}"
                                Padding="16,8"
                                ToolTip="清理AI生成会话的上下文缓存，解决对话卡顿问题">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="🧹" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="全局清理（上下文+缓存）" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding BusinessCleanupCommand}"
                                Style="{DynamicResource DangerButtonStyle}"
                                Padding="16,8"
                                ToolTip="清理设计和创作模块所有已生成的业务数据">
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="🔥" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="业务清理（设计+创作）" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
