<UserControl x:Class="TM.Modules.Generate.Content.ChapterPreview.ChapterPreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
             xmlns:search="clr-namespace:TM.Framework.Common.Search"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <UserControl.Resources>
        <HierarchicalDataTemplate x:Key="VolumeTemplate" ItemsSource="{Binding Chapters}">
            <StackPanel Orientation="Horizontal">
                <emoji:TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Chapters.Count, StringFormat=' ({0}章)'}" 
                           Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
            </StackPanel>
            <HierarchicalDataTemplate.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <emoji:TextBlock Text="{Binding Icon}" FontSize="12" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding DisplayName}"/>
                    </StackPanel>
                </DataTemplate>
            </HierarchicalDataTemplate.ItemTemplate>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200" MaxWidth="400"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" MinWidth="500"/>
        </Grid.ColumnDefinitions>

        <layout:IconHeaderGroupBox Grid.Column="0" Icon="📖" Title="章节预览">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <search:SearchTextBox Grid.Row="0" 
                                      Margin="0,0,0,10"
                                      SearchKeyword="{Binding SearchKeyword, Mode=TwoWay}"
                                      PlaceholderText="搜索章节..."/>

                <TreeView Grid.Row="1" 
                          ItemsSource="{Binding VolumeTree}"
                          ItemTemplate="{StaticResource VolumeTemplate}"
                          BorderThickness="0"
                          Background="Transparent"
                          SelectedItemChanged="TreeView_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="Padding" Value="3"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>

                <Grid Grid.Row="2" Margin="0,6,0,2">
                    <Border Background="{DynamicResource Surface}" 
                            CornerRadius="6" 
                            Padding="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <emoji:TextBlock Text="📊" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Foreground="{DynamicResource TextSecondary}" TextAlignment="Center">
                                <Run Text="统计：共"/>
                                <Run Text="{Binding TotalVolumes, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text="卷，"/>
                                <Run Text="{Binding TotalChapters, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text="章"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </layout:IconHeaderGroupBox>

        <GridSplitter Grid.Column="1" 
                      Width="5" 
                      HorizontalAlignment="Center" 
                      Background="Transparent" 
                      Cursor="SizeWE"/>

        <layout:IconHeaderGroupBox Grid.Column="2" Icon="📄" Title="章节详情">
            <Grid Margin="5" DataContext="{Binding SelectedChapterDetail}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <layout:IconHeaderGroupBox Grid.Row="0" Icon="📖" Title="当前章节" Margin="0,0,0,10">
                    <Grid>
                        <TextBlock Text="请选择章节" FontSize="16" Foreground="{DynamicResource TextTertiary}" Margin="5,2"
                                   Visibility="{Binding DataContext.HasSelectedChapter, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Margin="5,2"
                                   Visibility="{Binding DataContext.HasSelectedChapter, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Run Text="第"/>
                            <Run Text="{Binding ChapterNumber}"/>
                            <Run Text="章 "/>
                            <Run Text="{Binding Title}"/>
                        </TextBlock>
                    </Grid>
                </layout:IconHeaderGroupBox>

                <Grid Grid.Row="1" Height="180" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <layout:IconHeaderGroupBox Grid.Column="0" Icon="👤" Title="涉及角色" Margin="0,0,5,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <TextBlock Text="暂无" Foreground="{DynamicResource TextTertiary}" Margin="5,2"
                                           Visibility="{Binding DataContext.CharacterNames.Count, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseCountToVisibilityConverter}}"/>
                                <ItemsControl ItemsSource="{Binding DataContext.CharacterNames, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Visibility="{Binding DataContext.CharacterNames.Count, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource CountToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat=• {0}}" Margin="5,2,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </ScrollViewer>
                    </layout:IconHeaderGroupBox>

                    <layout:IconHeaderGroupBox Grid.Column="1" Icon="📍" Title="涉及地点" Margin="5,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <TextBlock Text="暂无" Foreground="{DynamicResource TextTertiary}" Margin="5,2"
                                           Visibility="{Binding DataContext.LocationNames.Count, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseCountToVisibilityConverter}}"/>
                                <ItemsControl ItemsSource="{Binding DataContext.LocationNames, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Visibility="{Binding DataContext.LocationNames.Count, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource CountToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat=• {0}}" Margin="5,2,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </ScrollViewer>
                    </layout:IconHeaderGroupBox>

                    <layout:IconHeaderGroupBox Grid.Column="2" Icon="🏛️" Title="涉及势力" Margin="5,0,5,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <TextBlock Text="暂无" Foreground="{DynamicResource TextTertiary}" Margin="5,2"
                                           Visibility="{Binding DataContext.FactionNames.Count, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseCountToVisibilityConverter}}"/>
                                <ItemsControl ItemsSource="{Binding DataContext.FactionNames, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Visibility="{Binding DataContext.FactionNames.Count, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource CountToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat=• {0}}" Margin="5,2,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </ScrollViewer>
                    </layout:IconHeaderGroupBox>

                    <layout:IconHeaderGroupBox Grid.Column="3" Icon="📜" Title="涉及剧情" Margin="5,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <TextBlock Text="暂无" Foreground="{DynamicResource TextTertiary}" Margin="5,2"
                                           Visibility="{Binding DataContext.PlotRuleNames.Count, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseCountToVisibilityConverter}}"/>
                                <ItemsControl ItemsSource="{Binding DataContext.PlotRuleNames, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Visibility="{Binding DataContext.PlotRuleNames.Count, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource CountToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat=• {0}}" Margin="5,2,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </ScrollViewer>
                    </layout:IconHeaderGroupBox>
                </Grid>
                <layout:IconHeaderGroupBox Grid.Row="2" Icon="📋" Title="章节信息" Margin="0,0,0,10" VerticalAlignment="Stretch">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="章节主题：" Foreground="{DynamicResource TextSecondary}" Margin="5,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ChapterTheme, FallbackValue='—', TargetNullValue='—'}" TextWrapping="Wrap" Margin="5,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="主要目标：" Foreground="{DynamicResource TextSecondary}" Margin="5,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MainGoal, FallbackValue='—', TargetNullValue='—'}" TextWrapping="Wrap" Margin="5,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="关键转折：" Foreground="{DynamicResource TextSecondary}" Margin="5,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding KeyTurn, FallbackValue='—', TargetNullValue='—'}" TextWrapping="Wrap" Margin="5,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="钩子：" Foreground="{DynamicResource TextSecondary}" Margin="5,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Hook, FallbackValue='—', TargetNullValue='—'}" TextWrapping="Wrap" Margin="5,2"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="世界信息：" Foreground="{DynamicResource TextSecondary}" Margin="5,2"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding WorldInfoDrop, FallbackValue='—', TargetNullValue='—'}" TextWrapping="Wrap" Margin="5,2"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="角色弧进展：" Foreground="{DynamicResource TextSecondary}" Margin="5,2"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding CharacterArcProgress, FallbackValue='—', TargetNullValue='—'}" TextWrapping="Wrap" Margin="5,2"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="伏笔：" Foreground="{DynamicResource TextSecondary}" Margin="5,2"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Foreshadowing, FallbackValue='—', TargetNullValue='—'}" TextWrapping="Wrap" Margin="5,2"/>
                        </Grid>
                    </ScrollViewer>
                </layout:IconHeaderGroupBox>

                <layout:IconHeaderGroupBox Grid.Row="3" Icon="🎬" Title="场景" Margin="0,0,0,0" VerticalAlignment="Stretch">
                    <Grid>
                        <TextBlock Text="暂无场景" Foreground="{DynamicResource TextTertiary}" Margin="5,2"
                                   Visibility="{Binding Scenes.Count, Converter={StaticResource InverseCountToVisibilityConverter}}"/>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding Scenes.Count, Converter={StaticResource CountToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding Scenes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource Surface}" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,5" FontWeight="SemiBold">
                                                    <Run Text="场景"/>
                                                    <Run Text="{Binding SceneNumber}"/>
                                                    <Run Text=" - "/>
                                                    <Run Text="{Binding Title, FallbackValue='—'}"/>
                                                    <Run Text="          "/>
                                                    <Run Text="[视角：" Foreground="{DynamicResource TextSecondary}" FontWeight="Normal"/>
                                                    <Run Text="{Binding PovCharacter, FallbackValue='—'}" Foreground="{DynamicResource TextSecondary}" FontWeight="Normal"/>
                                                    <Run Text="]" Foreground="{DynamicResource TextSecondary}" FontWeight="Normal"/>
                                                </TextBlock>

                                                <Grid Margin="0,5,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="目的：" Foreground="{DynamicResource TextTertiary}" FontSize="12" Margin="0,2"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Purpose, FallbackValue='—'}" FontSize="12" TextWrapping="Wrap" Margin="0,2"/>

                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="起：" Foreground="{DynamicResource TextTertiary}" FontSize="12" Margin="0,2"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Opening, FallbackValue='—'}" FontSize="12" TextWrapping="Wrap" Margin="0,2"/>

                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="承：" Foreground="{DynamicResource TextTertiary}" FontSize="12" Margin="0,2"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Development, FallbackValue='—'}" FontSize="12" TextWrapping="Wrap" Margin="0,2"/>

                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="转：" Foreground="{DynamicResource TextTertiary}" FontSize="12" Margin="0,2"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Turning, FallbackValue='—'}" FontSize="12" TextWrapping="Wrap" Margin="0,2"/>

                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="合：" Foreground="{DynamicResource TextTertiary}" FontSize="12" Margin="0,2"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Ending, FallbackValue='—'}" FontSize="12" TextWrapping="Wrap" Margin="0,2"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </layout:IconHeaderGroupBox>
            </Grid>
        </layout:IconHeaderGroupBox>
    </Grid>
</UserControl>
