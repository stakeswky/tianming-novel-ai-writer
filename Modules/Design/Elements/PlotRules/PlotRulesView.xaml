<UserControl
    x:Class="TM.Modules.Design.Elements.PlotRules.PlotRulesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dm="clr-namespace:TM.Framework.Common.Controls.DataManagement"
    xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
    xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">
<dm:TwoColumnEditorLayout
    LeftIcon="📖"
    LeftTitle="剧情规则"
    RightIcon="📖"
    RightTitle="规则编辑"
    ItemsSource="{Binding TreeData}"
    ShowSearch="True"
    SearchKeyword="{Binding SearchKeyword, Mode=TwoWay}"
    NodeDoubleClickCommand="{Binding SelectNodeCommand}"
    AddCommand="{Binding AddCommand}"
    SaveCommand="{Binding SaveCommand}"
    DeleteCommand="{Binding DeleteCommand}"
    DeleteAllCommand="{Binding DeleteAllCommand}"
    TreeAfterActionCommand="{Binding TreeAfterActionCommand}"
    UseStandardScheme2Layout="True"
    Tab1Header="事件概览"
    Tab2Header="参与方"
    Tab3Header="情节流程"
    Tab4Header="事件影响">

    <dm:TwoColumnEditorLayout.EditAdditionalContent>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="🏷️" Title="事件分类" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="总卷数（必填）" Margin="0,0,0,5" Foreground="{DynamicResource DangerColor}"/>
                        <Grid>
                            <TextBox Text="{Binding FormTargetVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource StandardTextBoxStyle}" Height="36"
                                     ToolTip="必须为数字。后续大纲/分卷设计将按此卷数构建"/>
                            <TextBlock Text="必须手动填写卷数" IsHitTestVisible="False"
                                       Margin="12,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource DangerColor}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FormTargetVolume}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="所属卷" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                        <ComboBox ItemsSource="{Binding AssignedVolumeOptions}"
                                  SelectedItem="{Binding FormAssignedVolume, Mode=TwoWay}"
                                  IsEditable="True"
                                  Text="{Binding FormAssignedVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{DynamicResource StandardComboBoxStyle}" Height="36"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="事件类型" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                        <ComboBox ItemsSource="{Binding EventTypeOptions}"
                                  SelectedItem="{Binding FormEventType, Mode=TwoWay}"
                                  IsEditable="True"
                                  Text="{Binding FormEventType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{DynamicResource StandardComboBoxStyle}" Height="36"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="所属阶段" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBox Text="{Binding FormStoryPhase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource StandardTextBoxStyle}" Height="36"/>
                    </StackPanel>
                </Grid>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="📝" Title="一句话简介" Margin="0,0,0,10">
                <TextBox Text="{Binding FormOneLineSummary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="🔗" Title="前置条件/触发方式" Margin="0">
                <TextBox Text="{Binding FormPrerequisitesTrigger, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.EditAdditionalContent>

    <dm:TwoColumnEditorLayout.DetailsContent>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="👤" Title="主要角色/视点角色" Margin="0,0,0,10">
                <TextBox Text="{Binding FormMainCharacters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="👥" Title="关键NPC" Margin="0,0,0,10">
                <TextBox Text="{Binding FormKeyNpcs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="📍" Title="地点" Margin="0,0,0,10">
                <TextBox Text="{Binding FormLocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="3" Icon="⏰" Title="时间/持续时长" Margin="0">
                <TextBox Text="{Binding FormTimeDuration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.DetailsContent>

    <dm:TwoColumnEditorLayout.Tab3Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="📋" Title="步骤标题" Margin="0,0,0,10">
                <TextBox Text="{Binding FormStepTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="0" Background="Transparent" Height="36"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="🎯" Title="目标" Margin="0,0,0,10">
                <TextBox Text="{Binding FormGoal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="⚔️" Title="冲突" Margin="0,0,0,10">
                <TextBox Text="{Binding FormConflict, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="3" Icon="✅" Title="结果" Margin="0,0,0,10">
                <TextBox Text="{Binding FormResult, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="4" Icon="🎭" Title="情绪曲线" Margin="0">
                <TextBox Text="{Binding FormEmotionCurve, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.Tab3Content>

    <dm:TwoColumnEditorLayout.Tab4Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="📈" Title="对主线故事的推动" Margin="0,0,0,10">
                <TextBox Text="{Binding FormMainPlotPush, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="👤" Title="对角色成长的影响" Margin="0,0,0,10">
                <TextBox Text="{Binding FormCharacterGrowth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="🌍" Title="对世界观信息的揭示" Margin="0,0,0,10">
                <TextBox Text="{Binding FormWorldReveal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="3" Icon="🎁" Title="获得的物品/奖励/新线索" Margin="0">
                <TextBox Text="{Binding FormRewardsClues, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.Tab4Content>

</dm:TwoColumnEditorLayout>
</UserControl>
