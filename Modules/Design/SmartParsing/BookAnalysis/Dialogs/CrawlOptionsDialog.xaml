<Window x:Class="TM.Modules.Design.SmartParsing.BookAnalysis.Dialogs.CrawlOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        Title="抓取选项"
        Width="450" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="{DynamicResource ContentBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="12"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.3"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <emoji:TextBlock Text="📚" FontSize="24" VerticalAlignment="Center"/>
                    <TextBlock Text="抓取选项" FontSize="20" FontWeight="SemiBold" 
                               Margin="10,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TextSecondary}"
                        FontSize="16" Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>

            <Border Grid.Row="1" Background="{DynamicResource Surface}" 
                    CornerRadius="8" Padding="16" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="已识别章节" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="ChapterSummaryText" 
                               Text="共 0 章，约 0 万字"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <TextBlock Text="选择抓取范围" FontWeight="SemiBold" 
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>

                <RadioButton x:Name="AllRadio" Content="全部抓取" 
                             IsChecked="True" Margin="0,5" GroupName="CrawlMode"
                             Foreground="{DynamicResource TextPrimary}"/>

                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <RadioButton x:Name="FirstNRadio" Content="只抓前" 
                                 GroupName="CrawlMode"
                                 Foreground="{DynamicResource TextPrimary}"/>
                    <TextBox x:Name="FirstNCountBox" Text="50" Width="60" 
                             Margin="8,0" VerticalContentAlignment="Center"
                             IsEnabled="{Binding IsChecked, ElementName=FirstNRadio}"/>
                    <TextBlock Text="章" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <RadioButton x:Name="RangeRadio" Content="指定范围" 
                                 GroupName="CrawlMode"
                                 Foreground="{DynamicResource TextPrimary}"/>
                    <TextBox x:Name="RangeStartBox" Text="1" Width="50" 
                             Margin="8,0" VerticalContentAlignment="Center"
                             IsEnabled="{Binding IsChecked, ElementName=RangeRadio}"/>
                    <TextBlock Text="-" VerticalAlignment="Center" Margin="5,0"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBox x:Name="RangeEndBox" Text="100" Width="50" 
                             VerticalContentAlignment="Center"
                             IsEnabled="{Binding IsChecked, ElementName=RangeRadio}"/>
                    <TextBlock Text="章" VerticalAlignment="Center" Margin="8,0,0,0"
                               Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </StackPanel>

            <CheckBox x:Name="SkipVipCheckBox" Grid.Row="3"
                      Content="跳过 VIP 章节（VIP章节通常无法抓取）" 
                      IsChecked="True" Margin="0,0,0,20"
                      Foreground="{DynamicResource TextPrimary}"/>

            <StackPanel Grid.Row="4" Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <Button Content="取消" Click="CancelButton_Click"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="24,10" Margin="0,0,10,0"/>
                <Button Content="开始抓取" Click="StartButton_Click"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="24,10"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
