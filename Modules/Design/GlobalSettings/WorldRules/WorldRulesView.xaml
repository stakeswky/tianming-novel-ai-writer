<UserControl
    x:Class="TM.Modules.Design.GlobalSettings.WorldRules.WorldRulesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dm="clr-namespace:TM.Framework.Common.Controls.DataManagement"
    xmlns:layout="clr-namespace:TM.Framework.Common.Controls.Layout"
    xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">
<dm:TwoColumnEditorLayout
    LeftIcon="🌍"
    LeftTitle="世界观规则"
    RightIcon="🌍"
    RightTitle="规则编辑"
    ItemsSource="{Binding TreeData}"
    ShowSearch="True"
    SearchKeyword="{Binding SearchKeyword, Mode=TwoWay}"
    NodeDoubleClickCommand="{Binding SelectNodeCommand}"
    AddCommand="{Binding AddCommand}"
    SaveCommand="{Binding SaveCommand}"
    DeleteCommand="{Binding DeleteCommand}"
    DeleteAllCommand="{Binding DeleteAllCommand}"
    TreeAfterActionCommand="{Binding TreeAfterActionCommand}"
    UseStandardScheme2Layout="True"
    Tab1Header="核心设定"
    Tab2Header="规则约束"
    Tab3Header="历史/时间线">

    <dm:TwoColumnEditorLayout.EditAdditionalContent>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="📝" Title="一句话简介" Margin="0,0,0,10">
                <TextBox Text="{Binding FormOneLineSummary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="⚡" Title="力量体系" Margin="0,0,0,10">
                <TextBox Text="{Binding FormPowerSystem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="🌌" Title="宇宙观" Margin="0,0,0,10">
                <TextBox Text="{Binding FormCosmology, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="3" Icon="✨" Title="特殊法则/现象" Margin="0,0,0,10">
                <TextBox Text="{Binding FormSpecialLaws, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.EditAdditionalContent>

    <dm:TwoColumnEditorLayout.DetailsContent>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="🚫" Title="硬规则（不可违反）" Margin="0,0,0,10">
                <TextBox Text="{Binding FormHardRules, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="⚠️" Title="软规则（可打破但需解释）" Margin="0">
                <TextBox Text="{Binding FormSoftRules, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.DetailsContent>

    <dm:TwoColumnEditorLayout.Tab3Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <layout:IconHeaderGroupBox Grid.Row="0" Icon="🌅" Title="创世/古代纪元" Margin="0,0,0,10">
                <TextBox Text="{Binding FormAncientEra, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="1" Icon="📜" Title="关键历史事件" Margin="0,0,0,10">
                <TextBox Text="{Binding FormKeyEvents, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="2" Icon="🎬" Title="近代史" Margin="0,0,0,10">
                <TextBox Text="{Binding FormModernHistory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>

            <layout:IconHeaderGroupBox Grid.Row="3" Icon="📍" Title="故事开始前的现状" Margin="0">
                <TextBox Text="{Binding FormStatusQuo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="Auto" VerticalAlignment="Stretch"
                         BorderThickness="0" Background="Transparent"/>
            </layout:IconHeaderGroupBox>
        </Grid>
    </dm:TwoColumnEditorLayout.Tab3Content>

</dm:TwoColumnEditorLayout>
</UserControl>
